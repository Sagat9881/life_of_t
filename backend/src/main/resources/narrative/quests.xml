<?xml version="1.0" encoding="UTF-8"?>
<quests xmlns="https://lifeoft.sagat.dev/narrative/quests">
  
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- QUEST DEFINITIONS: 3 основных квеста -->
  <!-- Все автоматически активируются в начале игры -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  
  <quest id="quest_career_growth" type="CAREER_GROWTH" auto-start="true">
    <label>Карьерный рост</label>
    <description>Добиться признания на работе</description>
    
    <steps>
      <step id="work_5_days" type="counter">
        <label>Отработать 5 дней</label>
        <target>work_days</target>
        <threshold>5</threshold>
      </step>
      
      <step id="satisfaction_70" type="threshold">
        <label>Удовлетворённость работой >= 70</label>
        <target>job_satisfaction</target>
        <threshold>70</threshold>
      </step>
      
      <step id="satisfaction_80" type="threshold">
        <label>Удовлетворённость работой >= 80</label>
        <target>job_satisfaction</target>
        <threshold>80</threshold>
      </step>
    </steps>
    
    <rewards>
      <stat-effect field="self_esteem" delta="10"/>
      <achievement id="CAREER_SUCCESS"/>
    </rewards>
  </quest>
  
  <quest id="quest_self_care" type="SELF_CARE_ARC" auto-start="true">
    <label>Забота о себе</label>
    <description>Научиться заботиться о себе</description>
    
    <steps>
      <step id="self_care_3_times" type="counter">
        <label>Позаботиться о себе 3 раза</label>
        <target>self_care_count</target>
        <threshold>3</threshold>
      </step>
      
      <step id="self_esteem_75" type="threshold">
        <label>Самооценка >= 75</label>
        <target>self_esteem</target>
        <threshold>75</threshold>
      </step>
      
      <step id="mood_and_esteem_80" type="compound">
        <label>Настроение >= 80 и самооценка >= 80</label>
        <conditions>
          <condition type="stat" field="mood" operator="gte" value="80"/>
          <condition type="stat" field="self_esteem" operator="gte" value="80"/>
        </conditions>
      </step>
    </steps>
    
    <rewards>
      <stat-effect field="mood" delta="15"/>
      <achievement id="SELF_LOVE"/>
    </rewards>
  </quest>
  
  <quest id="quest_family_harmony" type="FAMILY_HARMONY" auto-start="true">
    <label>Семейная гармония</label>
    <description>Укрепить семейные отношения</description>
    
    <steps>
      <step id="date_3_times" type="counter">
        <label>Сходить на свидание 3 раза</label>
        <target>date_count</target>
        <threshold>3</threshold>
      </step>
      
      <step id="visit_father_3_times" type="counter">
        <label>Навестить отца 3 раза</label>
        <target>visit_count</target>
        <threshold>3</threshold>
      </step>
      
      <step id="family_closeness" type="compound">
        <label>Близость с мужем >= 80, романтика >= 70</label>
        <conditions>
          <condition type="relationship" target="HUSBAND" field="closeness" operator="gte" value="80"/>
          <condition type="relationship" target="HUSBAND" field="romance" operator="gte" value="70"/>
        </conditions>
      </step>
    </steps>
    
    <rewards>
      <relationship-effect target="HUSBAND" field="closeness" delta="10"/>
      <relationship-effect target="FATHER" field="trust" delta="10"/>
      <achievement id="FAMILY_HERO"/>
    </rewards>
  </quest>
  
</quests>