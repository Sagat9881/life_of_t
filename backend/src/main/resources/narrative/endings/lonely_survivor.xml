<?xml version="1.0" encoding="UTF-8"?>
<ending id="LONELY_SURVIVOR" category="STORY" priority="40">
  <meta>
    <title>Одиночество</title>
    <summary>Все отношения разрушены</summary>
    <epilogue>Татьяна осталась одна. Остались только кошки...</epilogue>
  </meta>
  <conditions mode="AND">
    <condition type="relationship-sum" field="closeness" operator="lt" value="50"/>
    <condition type="relationship" target="HUSBAND" field="broken" operator="eq" value="true"/>
    <condition type="action-count" action="date_husband" operator="lt" count="3"/>
    <condition type="action-count" action="visit_father" operator="lt" count="3"/>
    <condition type="pet" id="garfield" field="alive" operator="eq" value="true"/>
    <condition type="stat" field="self_esteem" operator="lt" value="40"/>
    <min-score>4</min-score>
  </conditions>
</ending>
