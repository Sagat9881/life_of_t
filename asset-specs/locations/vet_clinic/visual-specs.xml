<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>location</entity-type>
        <entity-name>vet_clinic</entity-name>
        <version>1.0.0</version>
        <description>
            Ветеринарная клиника — для квестов save_lada, duke_arrives.
            Чистая, стерильная обстановка.
            Три слоя: background (стены/шкафы), midground (vet_table/оборудование), foreground (плакаты/аптечка).
        </description>
    </meta>

    <atmosphere>
        <mood>тревожный, стерильный, но с надеждой</mood>
        <lighting>яркий белый хирургический свет</lighting>
        <colors>
            <dominant>#F5F5FF</dominant>
            <accent>#00BCD4</accent>
            <accent>#FF9800</accent>
            <neutral>#E0E0E0</neutral>
        </colors>
    </atmosphere>

    <layers>
        <layer type="background" description="Стены, шкафы с лекарствами">
            <elements>
                <element>Белые стены с бирюзовой полосой</element>
                <element>Стеклянный шкаф с медикаментами</element>
                <element>Рентгеновский снимок на стене</element>
                <element>Плакат "Анатомия кошки"</element>
            </elements>
        </layer>

        <layer type="midground" description="Оборудование">
            <elements>
                <element>Ветеринарный стол осмотра (vet_table)</element>
                <element>Стул врача</element>
                <element>Весы для животных</element>
                <element>Раковина</element>
            </elements>
        </layer>

        <layer type="foreground" description="Ближние предметы">
            <elements>
                <element>Переноска для кошки</element>
                <element>Аптечка на стене</element>
                <element>Бахилы в контейнере</element>
            </elements>
        </layer>
    </layers>

    <animated-details>
        <detail id="drip">
            <name>Капельница</name>
            <atlas>assets/locations/vet_clinic/animations/drip-atlas.png</atlas>
            <frames>8</frames>
            <animation-type>Капли падают по трубке</animation-type>
        </detail>
        <detail id="heart-monitor">
            <name>Монитор пульса</name>
            <atlas>assets/locations/vet_clinic/animations/heart-monitor-atlas.png</atlas>
            <frames>12</frames>
            <animation-type>Бегущая линия пульса</animation-type>
        </detail>
    </animated-details>

    <time-of-day-variations>
        <variation time="day">
            <lighting>Стандартный приём — яркий свет</lighting>
            <mood>Профессиональный</mood>
        </variation>
        <variation time="night">
            <lighting>Экстренный ночной визит — приглушённый</lighting>
            <mood>Тревога, экстренность</mood>
        </variation>
    </time-of-day-variations>

    <naming>
        <output-dir>locations/vet_clinic</output-dir>
    </naming>
</asset-spec>