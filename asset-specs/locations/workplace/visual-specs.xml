<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>location</entity-type>
        <entity-name>workplace</entity-name>
        <version>1.0.0</version>
        <description>
            Офис Тани — open-space с рабочими местами.
            Используется для карьерных квестов (work_deadline) и действия "Работать".
            Три слоя: background (стены/окна), midground (столы/стулья), foreground (растения/кулер).
        </description>
    </meta>

    <atmosphere>
        <mood>деловой, нейтральный, слегка стрессовый</mood>
        <lighting>флуоресцентный белый свет сверху</lighting>
        <colors>
            <dominant>#F0F0F0</dominant>
            <accent>#4A90D9</accent>
            <accent>#C8A882</accent>
            <neutral>#B0B0B0</neutral>
        </colors>
    </atmosphere>

    <layers>
        <layer type="background" description="Стены, панорамные окна с видом на город">
            <elements>
                <element>Светло-серая стена</element>
                <element>Два больших окна с жалюзи</element>
                <element>Городской пейзаж за окном (силуэты зданий)</element>
                <element>Часы на стене</element>
                <element>Доска с задачами (kanban board)</element>
            </elements>
        </layer>

        <layer type="midground" description="Рабочие столы, стулья, техника">
            <elements>
                <element>Стол Тани с монитором и клавиатурой (office_desk)</element>
                <element>Офисный стул на колёсах</element>
                <element>Соседний стол (фон, не интерактивный)</element>
                <element>Принтер</element>
            </elements>
        </layer>

        <layer type="foreground" description="Ближние объекты, декор">
            <elements>
                <element>Кулер с водой</element>
                <element>Кофемашина</element>
                <element>Горшок с фикусом</element>
                <element>Стопка бумаг на краю стола</element>
            </elements>
        </layer>
    </layers>

    <animated-details>
        <detail id="wall-clock">
            <name>Настенные часы</name>
            <atlas>assets/locations/workplace/animations/wall-clock-atlas.png</atlas>
            <frames>24</frames>
            <animation-type>Секундная стрелка тикает</animation-type>
        </detail>
        <detail id="window-blinds">
            <name>Жалюзи</name>
            <atlas>assets/locations/workplace/animations/window-blinds-atlas.png</atlas>
            <frames>8</frames>
            <animation-type>Лёгкое покачивание от вентиляции</animation-type>
        </detail>
        <detail id="screen-glow">
            <name>Свечение экранов</name>
            <atlas>assets/locations/workplace/animations/screen-glow-atlas.png</atlas>
            <frames>4</frames>
            <animation-type>Мерцание мониторов соседних столов</animation-type>
        </detail>
    </animated-details>

    <time-of-day-variations>
        <variation time="morning">
            <lighting>Утренний свет из окон, тёплый</lighting>
            <mood>Спокойное начало дня</mood>
        </variation>
        <variation time="day">
            <lighting>Яркий дневной свет + флуоресцент</lighting>
            <mood>Рабочая суета</mood>
        </variation>
        <variation time="evening">
            <lighting>Только настольные лампы, окна тёмные</lighting>
            <mood>Переработка, усталость</mood>
        </variation>
    </time-of-day-variations>

    <naming>
        <output-dir>locations/workplace</output-dir>
    </naming>
</asset-spec>