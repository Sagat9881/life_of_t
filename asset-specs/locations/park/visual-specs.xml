<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>location</entity-type>
        <entity-name>park</entity-name>
        <version>1.0.0</version>
        <description>
            Городской парк — для прогулок с Sam, медитации, отдыха.
            Снижает стресс, повышает настроение.
            Три слоя: background (небо/деревья), midground (дорожки/скамейки), foreground (кусты/цветы).
        </description>
    </meta>

    <atmosphere>
        <mood>расслабленный, свежий, природный</mood>
        <lighting>естественный солнечный свет через кроны</lighting>
        <colors>
            <dominant>#90C695</dominant>
            <accent>#FFD93D</accent>
            <accent>#87CEEB</accent>
            <neutral>#8B7355</neutral>
        </colors>
    </atmosphere>

    <layers>
        <layer type="background" description="Небо, дальние деревья">
            <elements>
                <element>Голубое небо с облаками</element>
                <element>Ряд деревьев (дальний план)</element>
                <element>Верхушки многоэтажек вдали</element>
            </elements>
        </layer>

        <layer type="midground" description="Дорожки, скамейки">
            <elements>
                <element>Гравийная дорожка</element>
                <element>Парковая скамейка (место для "Медитация")</element>
                <element>Фонарный столб</element>
                <element>Урна</element>
                <element>Голуби (декоративные, 2-3 штуки)</element>
            </elements>
        </layer>

        <layer type="foreground" description="Ближняя растительность">
            <elements>
                <element>Куст сирени</element>
                <element>Клумба с цветами</element>
                <element>Одуванчики на газоне</element>
            </elements>
        </layer>
    </layers>

    <animated-details>
        <detail id="leaves">
            <name>Листья</name>
            <atlas>assets/locations/park/animations/leaves-atlas.png</atlas>
            <frames>12</frames>
            <animation-type>Листья качаются на ветру</animation-type>
        </detail>
        <detail id="pigeons">
            <name>Голуби</name>
            <atlas>assets/locations/park/animations/pigeons-atlas.png</atlas>
            <frames>6</frames>
            <animation-type>Голуби клюют и ходят</animation-type>
        </detail>
        <detail id="fountain">
            <name>Фонтанчик</name>
            <atlas>assets/locations/park/animations/fountain-atlas.png</atlas>
            <frames>8</frames>
            <animation-type>Струя воды плещется</animation-type>
        </detail>
    </animated-details>

    <time-of-day-variations>
        <variation time="morning">
            <lighting>Тёплый утренний свет, роса</lighting>
            <mood>Свежесть, утренняя пробежка с Sam</mood>
        </variation>
        <variation time="day">
            <lighting>Яркое солнце, тени от деревьев</lighting>
            <mood>Активность, гуляющие люди</mood>
        </variation>
        <variation time="evening">
            <lighting>Золотой закат, фонари зажигаются</lighting>
            <mood>Романтика, спокойствие</mood>
        </variation>
        <variation time="night">
            <lighting>Фонари, лунный свет</lighting>
            <mood>Тишина, ночная прогулка</mood>
        </variation>
    </time-of-day-variations>

    <naming>
        <output-dir>locations/park</output-dir>
    </naming>
</asset-spec>