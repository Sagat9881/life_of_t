<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>location</entity-type>
        <entity-name>city_street</entity-name>
        <version>1.0.0</version>
        <description>
            Городская улица — транзитная локация-хаб.
            Из неё переходы в gym, workplace, vet_clinic, park.
            Три слоя: background (здания), midground (тротуар/остановка), foreground (машины/столбы).
        </description>
    </meta>

    <atmosphere>
        <mood>городской, динамичный, повседневный</mood>
        <lighting>зависит от времени суток</lighting>
        <colors>
            <dominant>#A0A0A0</dominant>
            <accent>#FF6B9D</accent>
            <accent>#FFE66D</accent>
            <neutral>#707070</neutral>
        </colors>
    </atmosphere>

    <layers>
        <layer type="background" description="Фасады зданий, небо">
            <elements>
                <element>Многоэтажка (фасад с окнами)</element>
                <element>Магазинчик "Продукты"</element>
                <element>Вывеска "Ветклиника" (визуальная подсказка)</element>
                <element>Небо</element>
            </elements>
        </layer>

        <layer type="midground" description="Тротуар, остановка">
            <elements>
                <element>Асфальтовый тротуар</element>
                <element>Автобусная остановка</element>
                <element>Пешеходный переход</element>
                <element>Лужа (при вечере/ночи)</element>
            </elements>
        </layer>

        <layer type="foreground" description="Ближний план">
            <elements>
                <element>Припаркованная машина</element>
                <element>Фонарный столб</element>
                <element>Мусорный бак</element>
                <element>Рекламная тумба</element>
            </elements>
        </layer>
    </layers>

    <animated-details>
        <detail id="traffic-light">
            <name>Светофор</name>
            <atlas>assets/locations/city_street/animations/traffic-light-atlas.png</atlas>
            <frames>6</frames>
            <animation-type>Переключение красный-жёлтый-зелёный</animation-type>
        </detail>
        <detail id="passing-car">
            <name>Проезжающая машина</name>
            <atlas>assets/locations/city_street/animations/passing-car-atlas.png</atlas>
            <frames>8</frames>
            <animation-type>Машина проезжает слева направо</animation-type>
        </detail>
        <detail id="shop-sign">
            <name>Неоновая вывеска</name>
            <atlas>assets/locations/city_street/animations/shop-sign-atlas.png</atlas>
            <frames>4</frames>
            <animation-type>Вывеска мигает</animation-type>
        </detail>
    </animated-details>

    <time-of-day-variations>
        <variation time="morning">
            <lighting>Мягкий утренний свет, длинные тени</lighting>
            <mood>Город просыпается</mood>
        </variation>
        <variation time="day">
            <lighting>Полуденное солнце</lighting>
            <mood>Шумный, людный</mood>
        </variation>
        <variation time="evening">
            <lighting>Закат, зажигаются фонари и вывески</lighting>
            <mood>Вечерний город, огни</mood>
        </variation>
        <variation time="night">
            <lighting>Фонари, неон, окна светятся</lighting>
            <mood>Ночной город, тише</mood>
        </variation>
    </time-of-day-variations>

    <naming>
        <output-dir>locations/city_street</output-dir>
    </naming>
</asset-spec>