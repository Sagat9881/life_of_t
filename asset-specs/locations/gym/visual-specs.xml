<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>locations</entity-type>
        <entity-name>gym</entity-name>
        <version>1.0.0</version>
    </meta>
    <!-- Small gym / fitness room. Canvas: 320x180.
         Mirrored wall, rubber floor, equipment. -->
    <layers>
        <layer id="back_wall" type="base" z-order="0" width="320" height="180">
            <pixel-data>
                <rect x="0" y="0" w="320" h="90" color="#E8E0D0"/>
                <rect x="0" y="88" w="320" h="4" color="#C8B898"/>
            </pixel-data>
        </layer>
        <layer id="mirror_wall" type="base" z-order="1" width="320" height="180">
            <pixel-data>
                <rect x="30" y="10" w="120" h="70" color="#C8D8E8"/>
                <rect x="30" y="10" w="120" h="2" color="#A0A0A0"/>
                <rect x="30" y="10" w="2" h="70" color="#A0A0A0"/>
                <rect x="148" y="10" w="2" h="70" color="#A0A0A0"/>
                <rect x="30" y="78" w="120" h="2" color="#A0A0A0"/>
            </pixel-data>
        </layer>
        <layer id="floor" type="base" z-order="2" width="320" height="180">
            <pixel-data>
                <rect x="0" y="90" w="320" h="90" color="#404850"/>
                <!-- rubber mat pattern -->
                <rect x="10" y="100" w="140" h="70" color="#384048"/>
                <rect x="160" y="100" w="140" h="70" color="#384048"/>
            </pixel-data>
        </layer>
        <layer id="dumbbell_rack" type="base" z-order="3" width="320" height="180">
            <pixel-data>
                <rect x="200" y="40" w="80" h="45" color="#606060"/>
                <rect x="200" y="40" w="80" h="2" color="#505050"/>
                <!-- dumbbells -->
                <rect x="210" y="50" w="16" h="6" color="#333333"/>
                <rect x="230" y="50" w="16" h="6" color="#333333"/>
                <rect x="250" y="50" w="16" h="6" color="#333333"/>
                <rect x="210" y="62" w="20" h="6" color="#444444"/>
                <rect x="240" y="62" w="20" h="6" color="#444444"/>
                <rect x="210" y="74" w="24" h="6" color="#555555"/>
            </pixel-data>
        </layer>
        <layer id="yoga_mat" type="overlay" z-order="4" width="320" height="180">
            <pixel-data>
                <rect x="40" y="120" w="80" h="40" color="#7B68EE"/>
                <rect x="40" y="120" w="80" h="2" color="#6A5ACD"/>
            </pixel-data>
        </layer>
    </layers>
    <animations>
        <animation name="idle" frames="1" fps="1" loop="false" frame-width="320" frame-height="180">
            <frame index="0" layer-offsets=""/>
        </animation>
    </animations>
    <naming>
        <output-dir>locations/gym</output-dir>
    </naming>
</asset-spec>