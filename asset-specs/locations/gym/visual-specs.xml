<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>location</entity-type>
        <entity-name>gym</entity-name>
        <version>1.0.0</version>
        <description>
            Спортзал — небольшой фитнес-клуб.
            Действие "Тренировка" — повышает здоровье, снижает стресс, тратит энергию.
            Три слоя: background (стены/зеркала), midground (тренажёры), foreground (бутылка/полотенце).
        </description>
    </meta>

    <atmosphere>
        <mood>энергичный, мотивирующий</mood>
        <lighting>яркий верхний свет, зеркала отражают</lighting>
        <colors>
            <dominant>#E8E8E8</dominant>
            <accent>#FF6B6B</accent>
            <accent>#4ECDC4</accent>
            <neutral>#606060</neutral>
        </colors>
    </atmosphere>

    <layers>
        <layer type="background" description="Стены, зеркала, мотивационные постеры">
            <elements>
                <element>Серые стены с красными акцентами</element>
                <element>Большое зеркало в полный рост</element>
                <element>Мотивационный постер "NO PAIN NO GAIN"</element>
                <element>Вентиляционная решётка</element>
            </elements>
        </layer>

        <layer type="midground" description="Тренажёры">
            <elements>
                <element>Беговая дорожка (gym_equipment) — основной интерактив</element>
                <element>Стойка с гантелями (декоративная)</element>
                <element>Скамья для жима (декоративная)</element>
            </elements>
        </layer>

        <layer type="foreground" description="Ближние предметы">
            <elements>
                <element>Бутылка воды</element>
                <element>Полотенце на крючке</element>
                <element>Сумка Тани</element>
            </elements>
        </layer>
    </layers>

    <animated-details>
        <detail id="fan">
            <name>Вентилятор</name>
            <atlas>assets/locations/gym/animations/fan-atlas.png</atlas>
            <frames>4</frames>
            <animation-type>Лопасти крутятся</animation-type>
        </detail>
        <detail id="mirror-reflection">
            <name>Отражение в зеркале</name>
            <atlas>assets/locations/gym/animations/mirror-atlas.png</atlas>
            <frames>6</frames>
            <animation-type>Лёгкое мерцание отражения</animation-type>
        </detail>
    </animated-details>

    <time-of-day-variations>
        <variation time="morning">
            <lighting>Свежий утренний свет</lighting>
            <mood>Бодрость, пустой зал</mood>
        </variation>
        <variation time="day">
            <lighting>Полный яркий свет</lighting>
            <mood>Активность</mood>
        </variation>
        <variation time="evening">
            <lighting>Приглушённый, уставший свет</lighting>
            <mood>Вечерняя тренировка после работы</mood>
        </variation>
    </time-of-day-variations>

    <naming>
        <output-dir>locations/gym</output-dir>
    </naming>
</asset-spec>