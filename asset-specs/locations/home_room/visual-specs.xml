<?xml version="1.0" encoding="UTF-8"?>
<!--
    Home Room — Tanya & Alexander's main living room.
    Canvas: 640×480. This spec defines ONLY the room shell.
    All furniture (bed, computer, phone, mirror, cat_tree) is rendered
    separately via SpriteAnimator from locations.ts config.

    Layers:
      z0: floor        — warm oak wood planks
      z1: wall         — cream walls with wainscoting
      z2: ceiling_trim — crown molding + ceiling
      z3: window       — large window with sky, curtains
      z4: window_glow  — animated light from window (time-of-day)
      z5: ambient_light — soft warm ambient overlay
      z6: shadow_overlay — corner/edge shadows for depth
-->
<asset-spec extends="abstract/environments/indoor_room@1.0" version="3.0.0">
    <meta>
        <entity-type>location</entity-type>
        <entity-name>home_room</entity-name>
        <version>3.0.0</version>
        <canvas width="640" height="480" displayScale="1.0"/>
        <description>
            Clean room shell. Warm cozy apartment.
            Three logical layers: background (wall+ceiling), midground (floor+window), foreground (light+shadow).
            Furniture is NOT part of this spec — it comes from SpriteAnimator entities.
        </description>
    </meta>

    <color-palette>
        <!-- Floor -->
        <color name="$floor_main" value="#C8A882"/>
        <color name="$floor_plank1" value="#C4A47E"/>
        <color name="$floor_plank2" value="#CCAC86"/>
        <color name="$floor_line" value="#B89872"/>
        <color name="$floor_grain" value="#BEA07A"/>
        <color name="$floor_joint" value="#A8885E"/>
        <color name="$floor_highlight" value="#D8C4A0"/>
        <color name="$floor_shadow" value="#B09068"/>
        <!-- Wall -->
        <color name="$wall_upper" value="#FFF4E0"/>
        <color name="$wall_line" value="#FFF0D8"/>
        <color name="$wall_lower" value="#FFF0D4"/>
        <color name="$wall_dado" value="#EDD8B0"/>
        <color name="$wall_dado_shadow" value="#E0CAA0"/>
        <color name="$wall_panel" value="#FFF6E8"/>
        <color name="$wall_panel_border" value="#E8D8C0"/>
        <color name="$wall_crack" value="#EDE0C8"/>
        <!-- Ceiling -->
        <color name="$ceiling" value="#FFFBF4"/>
        <color name="$crown_main" value="#F0E4D0"/>
        <color name="$crown_shadow" value="#E0D0B8"/>
        <color name="$crown_highlight" value="#FFF8EC"/>
        <!-- Window -->
        <color name="$sky_top" value="#88C0E8"/>
        <color name="$sky_mid" value="#A8D4F0"/>
        <color name="$sky_bottom" value="#C8E4F8"/>
        <color name="$cloud" value="#FFFFFF"/>
        <color name="$cloud_shadow" value="#E8F0F8"/>
        <color name="$frame_main" value="#E8DCC8"/>
        <color name="$frame_shadow" value="#D4C8B0"/>
        <color name="$frame_highlight" value="#F4ECE0"/>
        <color name="$sill" value="#E0D4C0"/>
        <color name="$curtain_main" value="#FFB6C1"/>
        <color name="$curtain_fold" value="#FF9BAE"/>
        <color name="$curtain_highlight" value="#FFC8D0"/>
        <color name="$curtain_rod" value="#C0A078"/>
        <color name="$curtain_ring" value="#D4B090"/>
        <!-- Baseboard -->
        <color name="$baseboard" value="#E8DCC8"/>
        <color name="$baseboard_top" value="#F0E8D8"/>
        <color name="$baseboard_shadow" value="#D4C8B0"/>
        <!-- Light -->
        <color name="$light_warm" value="#FFF8E020"/>
        <color name="$light_soft" value="#FFF0D010"/>
        <color name="$light_floor" value="#FFE8C010"/>
        <color name="$shadow_dark" value="#00000018"/>
        <color name="$shadow_light" value="#0000000C"/>
    </color-palette>

    <layer-overrides>
        <!-- Override floor from abstract indoor_room -->
        <layer id="floor" replace="true" type="background" z-order="0" width="640" height="480">
            <pixel-data>
                <!-- Main floor area -->
                <rect x="0" y="316" w="640" h="164" color="$floor_main"/>
                <!-- Alternating plank colors for realism -->
                <rect x="0" y="316" w="80" h="164" color="$floor_plank1"/>
                <rect x="80" y="316" w="100" h="164" color="$floor_plank2"/>
                <rect x="180" y="316" w="110" h="164" color="$floor_plank1"/>
                <rect x="290" y="316" w="110" h="164" color="$floor_plank2"/>
                <rect x="400" y="316" w="110" h="164" color="$floor_plank1"/>
                <rect x="510" y="316" w="130" h="164" color="$floor_plank2"/>
                <!-- Plank separation lines -->
                <hline x="0" y="338" len="640" color="$floor_line"/>
                <hline x="0" y="360" len="640" color="$floor_line"/>
                <hline x="0" y="382" len="640" color="$floor_line"/>
                <hline x="0" y="404" len="640" color="$floor_line"/>
                <hline x="0" y="426" len="640" color="$floor_line"/>
                <hline x="0" y="448" len="640" color="$floor_line"/>
                <hline x="0" y="470" len="640" color="$floor_line"/>
                <!-- Board joints (vertical) -->
                <rect x="80" y="316" w="2" h="164" color="$floor_joint"/>
                <rect x="180" y="316" w="2" h="164" color="$floor_joint"/>
                <rect x="290" y="316" w="2" h="164" color="$floor_joint"/>
                <rect x="400" y="316" w="2" h="164" color="$floor_joint"/>
                <rect x="510" y="316" w="2" h="164" color="$floor_joint"/>
                <!-- Staggered joints (offset per row) -->
                <rect x="130" y="338" w="2" h="22" color="$floor_joint"/>
                <rect x="340" y="338" w="2" h="22" color="$floor_joint"/>
                <rect x="560" y="338" w="2" h="22" color="$floor_joint"/>
                <rect x="50" y="360" w="2" h="22" color="$floor_joint"/>
                <rect x="240" y="360" w="2" h="22" color="$floor_joint"/>
                <rect x="450" y="360" w="2" h="22" color="$floor_joint"/>
                <rect x="130" y="382" w="2" h="22" color="$floor_joint"/>
                <rect x="340" y="382" w="2" h="22" color="$floor_joint"/>
                <rect x="560" y="382" w="2" h="22" color="$floor_joint"/>
                <!-- Wood grain details -->
                <hline x="20" y="326" len="50" color="$floor_grain"/>
                <hline x="200" y="348" len="70" color="$floor_grain"/>
                <hline x="100" y="370" len="60" color="$floor_grain"/>
                <hline x="420" y="392" len="70" color="$floor_grain"/>
                <hline x="300" y="414" len="50" color="$floor_grain"/>
                <hline x="530" y="436" len="60" color="$floor_grain"/>
                <hline x="40" y="458" len="80" color="$floor_grain"/>
                <!-- Window light patch on floor -->
                <rect x="380" y="340" w="180" h="80" color="$floor_highlight"/>
                <rect x="400" y="350" w="140" h="60" color="#D4C098"/>
                <!-- Floor shadow near wall -->
                <rect x="0" y="316" w="640" h="6" color="$floor_shadow"/>
            </pixel-data>
        </layer>

        <!-- Override wall from abstract indoor_room -->
        <layer id="wall" replace="true" type="background" z-order="1" width="640" height="480">
            <pixel-data>
                <!-- Upper wall -->
                <rect x="0" y="30" w="640" h="200" color="$wall_upper"/>
                <!-- Subtle wallpaper lines -->
                <hline x="0" y="60" len="640" color="$wall_line"/>
                <hline x="0" y="90" len="640" color="$wall_line"/>
                <hline x="0" y="120" len="640" color="$wall_line"/>
                <hline x="0" y="150" len="640" color="$wall_line"/>
                <hline x="0" y="180" len="640" color="$wall_line"/>
                <hline x="0" y="210" len="640" color="$wall_line"/>
                <!-- Dado rail -->
                <rect x="0" y="224" w="640" h="4" color="$wall_dado"/>
                <hline x="0" y="224" len="640" color="$wall_dado_shadow"/>
                <hline x="0" y="228" len="640" color="$crown_highlight"/>
                <!-- Lower wall (wainscoting area) -->
                <rect x="0" y="228" w="640" h="80" color="$wall_lower"/>
                <!-- Wainscoting panels -->
                <rect x="16" y="236" w="90" h="60" color="$wall_panel"/>
                <rect x="16" y="236" w="90" h="2" color="$wall_panel_border"/>
                <rect x="16" y="294" w="90" h="2" color="$wall_panel_border"/>
                <rect x="16" y="236" w="2" h="60" color="$wall_panel_border"/>
                <rect x="104" y="236" w="2" h="60" color="$wall_panel_border"/>
                <rect x="120" y="236" w="90" h="60" color="$wall_panel"/>
                <rect x="120" y="236" w="90" h="2" color="$wall_panel_border"/>
                <rect x="120" y="294" w="90" h="2" color="$wall_panel_border"/>
                <rect x="120" y="236" w="2" h="60" color="$wall_panel_border"/>
                <rect x="208" y="236" w="2" h="60" color="$wall_panel_border"/>
                <rect x="224" y="236" w="90" h="60" color="$wall_panel"/>
                <rect x="224" y="236" w="90" h="2" color="$wall_panel_border"/>
                <rect x="224" y="294" w="90" h="2" color="$wall_panel_border"/>
                <rect x="224" y="236" w="2" h="60" color="$wall_panel_border"/>
                <rect x="312" y="236" w="2" h="60" color="$wall_panel_border"/>
                <rect x="328" y="236" w="90" h="60" color="$wall_panel"/>
                <rect x="328" y="236" w="90" h="2" color="$wall_panel_border"/>
                <rect x="328" y="294" w="90" h="2" color="$wall_panel_border"/>
                <rect x="328" y="236" w="2" h="60" color="$wall_panel_border"/>
                <rect x="416" y="236" w="2" h="60" color="$wall_panel_border"/>
                <rect x="432" y="236" w="90" h="60" color="$wall_panel"/>
                <rect x="432" y="236" w="90" h="2" color="$wall_panel_border"/>
                <rect x="432" y="294" w="90" h="2" color="$wall_panel_border"/>
                <rect x="432" y="236" w="2" h="60" color="$wall_panel_border"/>
                <rect x="520" y="236" w="2" h="60" color="$wall_panel_border"/>
                <rect x="536" y="236" w="90" h="60" color="$wall_panel"/>
                <rect x="536" y="236" w="90" h="2" color="$wall_panel_border"/>
                <rect x="536" y="294" w="90" h="2" color="$wall_panel_border"/>
                <rect x="536" y="236" w="2" h="60" color="$wall_panel_border"/>
                <rect x="624" y="236" w="2" h="60" color="$wall_panel_border"/>
                <!-- Baseboard -->
                <rect x="0" y="306" w="640" h="12" color="$baseboard"/>
                <hline x="0" y="306" len="640" color="$baseboard_top"/>
                <hline x="0" y="316" len="640" color="$baseboard_shadow"/>
                <!-- Subtle wall imperfections -->
                <pixel x="120" y="80" color="$wall_crack"/>
                <pixel x="121" y="81" color="$wall_crack"/>
                <pixel x="450" y="150" color="$wall_crack"/>
                <pixel x="451" y="151" color="$wall_crack"/>
                <pixel x="280" y="100" color="$wall_crack"/>
            </pixel-data>
        </layer>

        <!-- Override baseboard from abstract -->
        <layer id="baseboard" replace="true" type="background" z-order="1" width="640" height="480">
            <pixel-data>
                <!-- Merged into wall layer above, this override empties the abstract baseboard -->
            </pixel-data>
        </layer>

        <!-- Override ceiling from abstract -->
        <layer id="ceiling" replace="true" type="background" z-order="2" width="640" height="480">
            <pixel-data>
                <!-- Ceiling -->
                <rect x="0" y="0" w="640" h="30" color="$ceiling"/>
                <!-- Crown molding -->
                <rect x="0" y="26" w="640" h="8" color="$crown_main"/>
                <hline x="0" y="26" len="640" color="$crown_highlight"/>
                <hline x="0" y="28" len="640" color="$crown_shadow"/>
                <hline x="0" y="33" len="640" color="$crown_shadow"/>
            </pixel-data>
        </layer>

        <!-- Override ambient_light -->
        <layer id="ambient_light" replace="true" type="overlay" z-order="6" width="640" height="480">
            <pixel-data>
                <!-- Window light cone -->
                <rect x="350" y="30" w="290" h="200" color="$light_warm"/>
                <rect x="380" y="60" w="240" h="160" color="$light_soft"/>
                <!-- Floor light from window -->
                <rect x="380" y="320" w="200" h="100" color="$light_floor"/>
                <!-- Soft warm ambient across room -->
                <rect x="0" y="0" w="300" h="320" color="$light_soft"/>
            </pixel-data>
            <conditions>
                <condition id="time_morning"><override layer-ref="ambient_light" tint="#E8F4FF" opacity="0.12"/></condition>
                <condition id="time_day"><override layer-ref="ambient_light" tint="#FFF8E8" opacity="0.06"/></condition>
                <condition id="time_evening"><override layer-ref="ambient_light" tint="#FFB060" opacity="0.20"/></condition>
                <condition id="time_night"><override layer-ref="ambient_light" tint="#1A1830" opacity="0.55"/></condition>
            </conditions>
        </layer>

        <!-- Override shadow_overlay -->
        <layer id="shadow_overlay" replace="true" type="overlay" z-order="7" width="640" height="480">
            <pixel-data>
                <!-- Corner shadows for depth -->
                <rect x="0" y="0" w="40" h="320" color="$shadow_light"/>
                <rect x="600" y="0" w="40" h="320" color="$shadow_dark"/>
                <!-- Floor-wall junction shadow -->
                <rect x="0" y="316" w="640" h="8" color="$shadow_light"/>
                <!-- Bottom edge shadow -->
                <rect x="0" y="460" w="640" h="20" color="$shadow_light"/>
                <!-- Ceiling corners -->
                <rect x="0" y="0" w="80" h="30" color="$shadow_light"/>
                <rect x="560" y="0" w="80" h="30" color="$shadow_light"/>
            </pixel-data>
        </layer>
    </layer-overrides>

    <layers>
        <!-- z3: Window with sky, clouds, curtains -->
        <layer id="window" type="midground" z-order="3" width="640" height="480">
            <pixel-data>
                <!-- Sky gradient -->
                <rect x="408" y="48" w="152" h="60" color="$sky_top"/>
                <rect x="408" y="108" w="152" h="50" color="$sky_mid"/>
                <rect x="408" y="158" w="152" h="60" color="$sky_bottom"/>
                <!-- Clouds -->
                <rect x="420" y="60" w="40" h="10" color="$cloud_shadow"/>
                <rect x="424" y="58" w="32" h="10" color="$cloud"/>
                <rect x="416" y="64" w="48" h="8" color="$cloud"/>
                <rect x="480" y="84" w="32" h="8" color="$cloud_shadow"/>
                <rect x="484" y="82" w="24" h="8" color="$cloud"/>
                <rect x="476" y="88" w="40" h="6" color="$cloud"/>
                <rect x="440" y="120" w="28" h="6" color="$cloud_shadow"/>
                <rect x="444" y="118" w="20" h="6" color="$cloud"/>
                <!-- Distant buildings silhouette -->
                <rect x="410" y="180" w="20" h="38" color="#A0B8C8"/>
                <rect x="432" y="190" w="16" h="28" color="#98B0C0"/>
                <rect x="452" y="170" w="24" h="48" color="#A8BCC8"/>
                <rect x="480" y="185" w="18" h="33" color="#9CB4C4"/>
                <rect x="502" y="175" w="14" h="43" color="#A4B8C8"/>
                <rect x="520" y="192" w="20" h="26" color="#98B0C0"/>
                <rect x="544" y="188" w="12" h="30" color="#A0B8C8"/>
                <!-- Window frame -->
                <rect x="404" y="44" w="160" h="6" color="$frame_main"/>
                <rect x="404" y="216" w="160" h="6" color="$frame_main"/>
                <rect x="404" y="44" w="6" h="178" color="$frame_main"/>
                <rect x="558" y="44" w="6" h="178" color="$frame_main"/>
                <!-- Frame highlights/shadows -->
                <hline x="404" y="44" len="160" color="$frame_highlight"/>
                <hline x="404" y="221" len="160" color="$frame_shadow"/>
                <vline x="404" y="44" len="178" color="$frame_highlight"/>
                <vline x="563" y="44" len="178" color="$frame_shadow"/>
                <!-- Center dividers -->
                <rect x="404" y="130" w="160" h="4" color="$frame_main"/>
                <rect x="480" y="44" w="4" h="178" color="$frame_main"/>
                <!-- Glass reflection -->
                <rect x="412" y="52" w="4" h="72" color="#FFFFFF20"/>
                <rect x="488" y="52" w="4" h="72" color="#FFFFFF18"/>
                <!-- Windowsill -->
                <rect x="398" y="222" w="172" h="12" color="$sill"/>
                <hline x="398" y="222" len="172" color="$frame_highlight"/>
                <hline x="398" y="233" len="172" color="$frame_shadow"/>
                <!-- Curtain rod -->
                <rect x="378" y="32" w="216" h="4" color="$curtain_rod"/>
                <hline x="378" y="32" len="216" color="$curtain_ring"/>
                <!-- Rod finials -->
                <rect x="374" y="30" w="8" h="8" color="$curtain_ring"/>
                <rect x="590" y="30" w="8" h="8" color="$curtain_ring"/>
                <!-- Left curtain -->
                <rect x="380" y="36" w="30" h="210" color="$curtain_main"/>
                <vline x="382" y="36" len="210" color="$curtain_highlight"/>
                <vline x="390" y="36" len="210" color="$curtain_fold"/>
                <vline x="398" y="36" len="210" color="$curtain_fold"/>
                <vline x="406" y="36" len="210" color="$curtain_highlight"/>
                <!-- Curtain fold shadows -->
                <hline x="380" y="60" len="30" color="$curtain_fold"/>
                <hline x="380" y="90" len="30" color="$curtain_fold"/>
                <hline x="380" y="120" len="30" color="$curtain_fold"/>
                <hline x="380" y="150" len="30" color="$curtain_fold"/>
                <hline x="380" y="180" len="30" color="$curtain_fold"/>
                <hline x="380" y="210" len="30" color="$curtain_fold"/>
                <!-- Right curtain -->
                <rect x="558" y="36" w="30" h="210" color="$curtain_main"/>
                <vline x="560" y="36" len="210" color="$curtain_highlight"/>
                <vline x="568" y="36" len="210" color="$curtain_fold"/>
                <vline x="576" y="36" len="210" color="$curtain_fold"/>
                <vline x="584" y="36" len="210" color="$curtain_highlight"/>
                <hline x="558" y="60" len="30" color="$curtain_fold"/>
                <hline x="558" y="90" len="30" color="$curtain_fold"/>
                <hline x="558" y="120" len="30" color="$curtain_fold"/>
                <hline x="558" y="150" len="30" color="$curtain_fold"/>
                <hline x="558" y="180" len="30" color="$curtain_fold"/>
                <hline x="558" y="210" len="30" color="$curtain_fold"/>
                <!-- Curtain tiebacks -->
                <rect x="384" y="170" w="24" h="4" color="$curtain_fold"/>
                <rect x="560" y="170" w="24" h="4" color="$curtain_fold"/>
            </pixel-data>
        </layer>

        <!-- z4: Window light glow (animated — reacts to time of day) -->
        <layer id="window_glow" type="overlay" z-order="4" width="640" height="480">
            <pixel-data>
                <!-- Light rays from window onto floor -->
                <rect x="400" y="300" w="160" h="120" color="#FFF8E018"/>
                <rect x="420" y="320" w="120" h="80" color="#FFF0D010"/>
                <!-- Light on nearby wall -->
                <rect x="370" y="60" w="30" h="200" color="#FFF8E010"/>
            </pixel-data>
            <conditions>
                <condition id="time_morning"><override layer-ref="window_glow" tint="#FFE8B0" opacity="0.20"/></condition>
                <condition id="time_day"><override layer-ref="window_glow" tint="#FFFFF0" opacity="0.10"/></condition>
                <condition id="time_evening"><override layer-ref="window_glow" tint="#FF8040" opacity="0.25"/></condition>
                <condition id="time_night"><override layer-ref="window_glow" tint="#2040A0" opacity="0.08"/></condition>
            </conditions>
        </layer>

        <!-- z5: String lights on wall (cozy detail) -->
        <layer id="string_lights" type="foreground" z-order="5" width="640" height="480">
            <pixel-data>
                <!-- Wire -->
                <hline x="120" y="38" len="240" color="#C0A868"/>
                <!-- Bulbs -->
                <pixel x="130" y="40" color="#FFE880"/>
                <pixel x="150" y="42" color="#FFE880"/>
                <pixel x="170" y="40" color="#FFE880"/>
                <pixel x="190" y="42" color="#FFE880"/>
                <pixel x="210" y="40" color="#FFE880"/>
                <pixel x="230" y="42" color="#FFE880"/>
                <pixel x="250" y="40" color="#FFE880"/>
                <pixel x="270" y="42" color="#FFE880"/>
                <pixel x="290" y="40" color="#FFE880"/>
                <pixel x="310" y="42" color="#FFE880"/>
                <pixel x="330" y="40" color="#FFE880"/>
                <pixel x="350" y="42" color="#FFE880"/>
                <!-- Glow around bulbs -->
                <pixel x="131" y="39" color="#FFF0C040"/>
                <pixel x="171" y="39" color="#FFF0C040"/>
                <pixel x="211" y="39" color="#FFF0C040"/>
                <pixel x="251" y="39" color="#FFF0C040"/>
                <pixel x="291" y="39" color="#FFF0C040"/>
                <pixel x="331" y="39" color="#FFF0C040"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <!-- Ambient light flicker + subtle window glow shift -->
        <animation name="idle" frames="12" fps="2" loop="true"
                   frame-width="640" frame-height="480">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="ambient_light:2,0; window_glow:0,2"/>
            <frame index="2" layer-offsets="ambient_light:4,2; window_glow:2,4"/>
            <frame index="3" layer-offsets="ambient_light:2,4; window_glow:4,2"/>
            <frame index="4" layer-offsets="ambient_light:0,2; window_glow:2,0"/>
            <frame index="5" layer-offsets="ambient_light:-2,0; window_glow:0,-2"/>
            <frame index="6" layer-offsets=""/>
            <frame index="7" layer-offsets="ambient_light:-2,2; window_glow:-2,2"/>
            <frame index="8" layer-offsets="ambient_light:-4,0; window_glow:-4,4"/>
            <frame index="9" layer-offsets="ambient_light:-2,-2; window_glow:-2,2"/>
            <frame index="10" layer-offsets="ambient_light:0,-2; window_glow:0,-2"/>
            <frame index="11" layer-offsets="ambient_light:2,0; window_glow:2,0"/>
        </animation>
    </animations>

    <naming><output-dir>locations/home_room</output-dir></naming>
</asset-spec>
