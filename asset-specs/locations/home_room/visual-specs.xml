<?xml version="1.0" encoding="UTF-8"?>
<asset-spec extends="abstract/environments/indoor_room@1.0" version="2.0.0">
    <meta>
        <entity-type>location</entity-type>
        <entity-name>home_room</entity-name>
        <version>2.0.0</version>
        <canvas width="640" height="480" displayScale="1.0"/>
        <description>
            Tanya and Alexander's main living room. Warm, cozy.
            Canvas ×2: 320×240 → 640×480. All coords ×2.
        </description>
    </meta>

    <color-palette>
        <color name="$floor_main" value="#C8A882"/>
        <color name="$floor_line" value="#B89872"/>
        <color name="$floor_line2" value="#BA9A74"/>
        <color name="$floor_joint" value="#A8885E"/>
        <color name="$floor_border" value="#D4B896"/>
        <color name="$wall_main" value="#FFF4E0"/>
        <color name="$wall_line" value="#FFF0D8"/>
        <color name="$wall_dado" value="#EDD8B0"/>
        <color name="$wall_lower" value="#FFF0D4"/>
        <color name="$window_sky" value="#B0D8F0"/>
        <color name="$window_frame" value="#D4B896"/>
        <color name="$curtain" value="#FFB6C1"/>
        <color name="$curtain_fold" value="#FF9BAE"/>
        <color name="$bed_frame" value="#A08060"/>
        <color name="$bed_inner" value="#B89878"/>
        <color name="$sheet" value="#F5E6D3"/>
        <color name="$pillow" value="#FFFFFF"/>
        <color name="$blanket" value="#B5EAD7"/>
        <color name="$blanket_fold" value="#A0D8C4"/>
        <color name="$desk_top" value="#B89878"/>
        <color name="$desk_frame" value="#A08868"/>
        <color name="$bookshelf" value="#C8A070"/>
        <color name="$shelf_inner" value="#D4B080"/>
        <color name="$shelf_edge" value="#A08060"/>
    </color-palette>

    <layer-overrides>
        <!-- Override floor from abstract indoor_room -->
        <layer id="floor" replace="true" type="background" z-order="0" width="640" height="480">
            <pixel-data>
                <rect x="0" y="320" w="640" h="160" color="$floor_main"/>
                <hline x="0" y="340" len="640" color="$floor_line"/>
                <hline x="0" y="362" len="640" color="$floor_line2"/>
                <hline x="0" y="384" len="640" color="$floor_line"/>
                <hline x="0" y="406" len="640" color="$floor_line2"/>
                <hline x="0" y="428" len="640" color="$floor_line"/>
                <hline x="0" y="450" len="640" color="$floor_line2"/>
                <!-- Board joints -->
                <rect x="80"  y="320" w="2" h="160" color="$floor_joint"/>
                <rect x="180" y="320" w="2" h="160" color="$floor_joint"/>
                <rect x="290" y="320" w="2" h="160" color="$floor_joint"/>
                <rect x="400" y="320" w="2" h="160" color="$floor_joint"/>
                <rect x="510" y="320" w="2" h="160" color="$floor_joint"/>
                <rect x="600" y="320" w="2" h="160" color="$floor_joint"/>
                <!-- Baseboard -->
                <rect x="0" y="316" w="640" h="8" color="$floor_border"/>
                <!-- Wood grain detail -->
                <hline x="20" y="350" len="50" color="#C0A07A"/>
                <hline x="200" y="370" len="80" color="#C0A07A"/>
                <hline x="420" y="390" len="60" color="#C0A07A"/>
                <hline x="100" y="440" len="70" color="#C0A07A"/>
                <!-- Floor shadow near wall -->
                <rect x="0" y="320" w="640" h="4" color="#B89872"/>
            </pixel-data>
        </layer>

        <layer id="wall" replace="true" type="background" z-order="1" width="640" height="480">
            <pixel-data>
                <rect x="0" y="0" w="640" h="324" color="$wall_main"/>
                <hline x="0" y="60" len="640" color="$wall_line"/>
                <hline x="0" y="120" len="640" color="$wall_line"/>
                <hline x="0" y="180" len="640" color="$wall_line"/>
                <hline x="0" y="240" len="640" color="$wall_line"/>
                <hline x="0" y="300" len="640" color="$wall_line"/>
                <!-- Dado rail -->
                <rect x="0" y="224" w="640" h="6" color="$wall_dado"/>
                <rect x="0" y="230" w="640" h="90" color="$wall_lower"/>
                <!-- Wall texture cracks -->
                <pixel x="120" y="80" color="#EDE0C8"/>
                <pixel x="121" y="81" color="#EDE0C8"/>
                <pixel x="122" y="82" color="#EDE0C8"/>
                <pixel x="450" y="150" color="#EDE0C8"/>
                <pixel x="451" y="151" color="#EDE0C8"/>
                <!-- Subtle wall stain -->
                <rect x="340" y="100" w="4" h="4" color="#F8ECD0"/>
            </pixel-data>
        </layer>
    </layer-overrides>

    <layers>
        <!-- z=2: Window -->
        <layer id="window" type="midground" z-order="2" width="640" height="480">
            <pixel-data>
                <rect x="408" y="48" w="152" h="172" color="$window_sky"/>
                <!-- Cloud reflections -->
                <rect x="420" y="60" w="36" h="12" color="#E8F4FF"/>
                <rect x="416" y="66" w="44" h="8" color="#FFFFFF"/>
                <rect x="476" y="84" w="28" h="10" color="#E8F4FF"/>
                <rect x="472" y="88" w="36" h="8" color="#FFFFFF"/>
                <!-- Sill -->
                <rect x="408" y="160" w="152" h="16" color="#88AABB"/>
                <rect x="408" y="176" w="152" h="8" color="#A0C0C8"/>
                <!-- Frame -->
                <rect x="404" y="44" w="160" h="6" color="$window_frame"/>
                <rect x="404" y="218" w="160" h="6" color="$window_frame"/>
                <rect x="404" y="44" w="6" h="180" color="$window_frame"/>
                <rect x="558" y="44" w="6" h="180" color="$window_frame"/>
                <rect x="404" y="132" w="160" h="4" color="$window_frame"/>
                <rect x="480" y="44" w="4" h="180" color="$window_frame"/>
                <!-- Windowsill -->
                <rect x="400" y="224" w="168" h="10" color="#E8D4B0"/>
                <!-- Left curtain -->
                <rect x="384" y="28" w="28" h="220" color="$curtain"/>
                <hline x="386" y="40" len="24" color="$curtain_fold"/>
                <hline x="386" y="70" len="24" color="$curtain_fold"/>
                <hline x="386" y="100" len="24" color="$curtain_fold"/>
                <hline x="386" y="130" len="24" color="$curtain_fold"/>
                <hline x="386" y="160" len="24" color="$curtain_fold"/>
                <hline x="386" y="190" len="24" color="$curtain_fold"/>
                <!-- Right curtain -->
                <rect x="556" y="28" w="28" h="220" color="$curtain"/>
                <hline x="558" y="40" len="24" color="$curtain_fold"/>
                <hline x="558" y="70" len="24" color="$curtain_fold"/>
                <hline x="558" y="100" len="24" color="$curtain_fold"/>
                <hline x="558" y="130" len="24" color="$curtain_fold"/>
                <hline x="558" y="160" len="24" color="$curtain_fold"/>
                <hline x="558" y="190" len="24" color="$curtain_fold"/>
                <!-- Curtain rod -->
                <hline x="380" y="28" len="208" color="#C0A078"/>
                <pixel x="380" y="26" color="#D4B090"/>
                <pixel x="586" y="26" color="#D4B090"/>
            </pixel-data>
        </layer>

        <!-- z=3: Bed -->
        <layer id="bed" type="foreground" z-order="3" width="640" height="480">
            <pixel-data>
                <!-- Headboard -->
                <rect x="20" y="236" w="280" h="40" color="$bed_frame"/>
                <rect x="24" y="240" w="272" h="32" color="$bed_inner"/>
                <!-- Frame -->
                <rect x="20" y="272" w="280" h="100" color="$bed_frame"/>
                <!-- Mattress -->
                <rect x="26" y="276" w="268" h="68" color="$sheet"/>
                <!-- Pillows -->
                <rect x="32" y="280" w="72" h="40" color="$pillow"/>
                <rect x="36" y="284" w="64" h="32" color="#F8F8F8"/>
                <hline x="34" y="296" len="68" color="#E8E8E8"/>
                <rect x="116" y="280" w="72" h="40" color="#F0F0EE"/>
                <rect x="120" y="284" w="64" h="32" color="#EBEBEA"/>
                <hline x="118" y="296" len="68" color="#E0E0DE"/>
                <!-- Blanket -->
                <rect x="26" y="320" w="268" h="28" color="$blanket"/>
                <hline x="26" y="322" len="268" color="$blanket_fold"/>
                <hline x="26" y="330" len="268" color="#9ECFBB"/>
                <!-- Blanket folds -->
                <rect x="26" y="324" w="4" h="20" color="#A8DDCC"/>
                <rect x="80" y="324" w="4" h="20" color="#A8DDCC"/>
                <rect x="140" y="324" w="4" h="20" color="#A8DDCC"/>
                <rect x="200" y="324" w="4" h="20" color="#A8DDCC"/>
                <rect x="260" y="324" w="4" h="20" color="#A8DDCC"/>
                <!-- Legs -->
                <rect x="24" y="368" w="10" h="16" color="#8A6A4A"/>
                <rect x="286" y="368" w="10" h="16" color="#8A6A4A"/>
                <!-- Shadow under bed -->
                <rect x="20" y="380" w="280" h="4" color="#A89070"/>
            </pixel-data>
        </layer>

        <!-- z=4: Desk -->
        <layer id="desk" type="foreground" z-order="4" width="640" height="480">
            <pixel-data>
                <!-- Desktop -->
                <rect x="336" y="264" w="200" h="72" color="$desk_top"/>
                <rect x="336" y="264" w="200" h="6" color="$desk_frame"/>
                <!-- Legs -->
                <rect x="340" y="336" w="8" h="36" color="$bed_frame"/>
                <rect x="524" y="336" w="8" h="36" color="$bed_frame"/>
                <!-- Laptop -->
                <rect x="356" y="252" w="80" h="16" color="#404040"/>
                <rect x="358" y="254" w="76" h="12" color="#484848"/>
                <rect x="356" y="216" w="80" h="36" color="#303030"/>
                <rect x="360" y="220" w="72" h="28" color="#5090C8"/>
                <!-- Screen content -->
                <rect x="362" y="222" w="20" h="6" color="#7AAAD8"/>
                <rect x="386" y="222" w="12" h="6" color="#FF8A80"/>
                <rect x="362" y="232" w="68" h="4" color="#6080A0"/>
                <rect x="362" y="240" w="40" h="4" color="#6080A0"/>
                <!-- Mug -->
                <rect x="444" y="290" w="16" h="24" color="#505050"/>
                <rect x="446" y="292" w="12" h="10" color="#606060"/>
                <!-- Photo frame -->
                <rect x="488" y="256" w="20" h="24" color="#E8C090"/>
                <rect x="490" y="258" w="16" h="20" color="#D4A870"/>
                <pixel x="508" y="266" color="#C09060"/>
                <!-- Pencil holder -->
                <rect x="516" y="250" w="16" h="20" color="#C8A878"/>
                <rect x="518" y="236" w="4" h="14" color="#404040"/>
                <rect x="524" y="232" w="4" h="18" color="#2060A0"/>
                <rect x="530" y="238" w="4" h="12" color="#E05050"/>
            </pixel-data>
        </layer>

        <!-- z=5: Bookshelf -->
        <layer id="bookshelf" type="foreground" z-order="5" width="640" height="480">
            <pixel-data>
                <rect x="60" y="48" w="160" h="180" color="$bookshelf"/>
                <rect x="62" y="50" w="156" h="176" color="$shelf_inner"/>
                <!-- Shelf edges -->
                <hline x="60" y="48" len="160" color="$shelf_edge"/>
                <hline x="60" y="96" len="160" color="$shelf_edge"/>
                <hline x="60" y="140" len="160" color="$shelf_edge"/>
                <hline x="60" y="184" len="160" color="$shelf_edge"/>
                <hline x="60" y="226" len="160" color="$shelf_edge"/>
                <!-- Row 1 books -->
                <rect x="64" y="54" w="10" h="38" color="#E05050"/>
                <rect x="76" y="58" w="10" h="34" color="#4080C0"/>
                <rect x="88" y="54" w="8" h="38" color="#50A850"/>
                <rect x="98" y="60" w="10" h="32" color="#E0C040"/>
                <rect x="110" y="54" w="8" h="38" color="#9050C0"/>
                <rect x="120" y="58" w="10" h="34" color="#E08040"/>
                <rect x="132" y="54" w="10" h="38" color="#4090BB"/>
                <rect x="144" y="60" w="8" h="32" color="#D06080"/>
                <rect x="154" y="54" w="10" h="38" color="#60A080"/>
                <rect x="166" y="58" w="8" h="34" color="#A08040"/>
                <rect x="176" y="54" w="10" h="38" color="#C05858"/>
                <rect x="188" y="58" w="8" h="34" color="#5870C0"/>
                <!-- Row 2 books -->
                <rect x="64" y="102" w="12" h="34" color="#8060A0"/>
                <rect x="78" y="106" w="10" h="30" color="#E09040"/>
                <rect x="90" y="102" w="10" h="34" color="#4488BB"/>
                <rect x="102" y="108" w="8" h="28" color="#D06080"/>
                <rect x="112" y="102" w="12" h="34" color="#60A080"/>
                <rect x="126" y="106" w="10" h="30" color="#A08040"/>
                <rect x="138" y="102" w="10" h="34" color="#E05050"/>
                <rect x="150" y="108" w="8" h="28" color="#4080C0"/>
                <rect x="160" y="102" w="10" h="34" color="#50A850"/>
                <rect x="172" y="106" w="10" h="30" color="#E0C040"/>
                <rect x="184" y="102" w="10" h="34" color="#9050C0"/>
                <!-- Row 3 books -->
                <rect x="64" y="146" w="10" h="34" color="#C08030"/>
                <rect x="76" y="150" w="10" h="30" color="#3070B0"/>
                <rect x="88" y="146" w="8" h="34" color="#E84040"/>
                <rect x="98" y="150" w="10" h="30" color="#60C080"/>
                <rect x="110" y="146" w="10" h="34" color="#B040A0"/>
                <rect x="122" y="150" w="8" h="30" color="#F0A020"/>
                <rect x="132" y="146" w="10" h="34" color="#4090C0"/>
                <rect x="144" y="150" w="10" h="30" color="#D06040"/>
                <rect x="156" y="146" w="8" h="34" color="#40A060"/>
                <rect x="166" y="150" w="10" h="30" color="#C0A040"/>
                <rect x="178" y="146" w="10" h="34" color="#8040C0"/>
                <rect x="190" y="150" w="10" h="30" color="#D08050"/>
                <!-- Plant on top -->
                <rect x="72" y="34" w="24" h="14" color="#80C080"/>
                <rect x="74" y="30" w="20" h="6" color="#60A060"/>
            </pixel-data>
        </layer>

        <!-- z=6: Decorations -->
        <layer id="decorations" type="foreground" z-order="6" width="640" height="480">
            <pixel-data>
                <!-- Photo frames on wall -->
                <rect x="260" y="36" w="72" h="56" color="#C0A070"/>
                <rect x="264" y="40" w="64" h="48" color="#E8D8C0"/>
                <rect x="268" y="44" w="24" h="24" color="#F0C898"/>
                <rect x="300" y="44" w="24" h="24" color="#D4A878"/>
                <rect x="268" y="68" w="56" h="16" color="#A08050"/>
                <!-- Cat photos -->
                <rect x="260" y="108" w="56" h="44" color="#B08860"/>
                <rect x="264" y="112" w="48" h="36" color="#E8DDD0"/>
                <rect x="266" y="114" w="12" h="12" color="#E08848"/>
                <rect x="282" y="114" w="12" h="12" color="#888888"/>
                <rect x="298" y="114" w="12" h="12" color="#202020"/>
                <!-- Potted plant -->
                <rect x="328" y="220" w="28" h="24" color="#8B6040"/>
                <rect x="332" y="208" w="20" h="16" color="#50A050"/>
                <rect x="330" y="200" w="8" h="12" color="#40C040"/>
                <rect x="340" y="196" w="8" h="16" color="#38B838"/>
                <rect x="350" y="204" w="6" h="8" color="#44AA44"/>
                <!-- String lights -->
                <hline x="236" y="20" len="120" color="#D4B040"/>
                <pixel x="240" y="22" color="#FFE080"/>
                <pixel x="256" y="24" color="#FFE080"/>
                <pixel x="272" y="22" color="#FFE080"/>
                <pixel x="288" y="24" color="#FFE080"/>
                <pixel x="304" y="22" color="#FFE080"/>
                <pixel x="320" y="24" color="#FFE080"/>
                <pixel x="336" y="22" color="#FFE080"/>
            </pixel-data>
        </layer>

        <!-- z=7: Ambient light -->
        <layer id="ambient_light" type="overlay" z-order="7" width="640" height="480">
            <pixel-data>
                <rect x="372" y="0" w="268" h="120" color="#FFF8E820"/>
                <rect x="300" y="0" w="340" h="60" color="#FFF0D010"/>
                <rect x="0" y="380" w="640" h="100" color="#FFE8C010"/>
                <rect x="420" y="200" w="120" h="100" color="#FFD88010"/>
            </pixel-data>
            <conditions>
                <condition id="time_morning"><override layer-ref="ambient_light" tint="#E8F4FF" opacity="0.12"/></condition>
                <condition id="time_day"><override layer-ref="ambient_light" tint="#FFF8E8" opacity="0.08"/></condition>
                <condition id="time_evening"><override layer-ref="ambient_light" tint="#FFB060" opacity="0.18"/></condition>
                <condition id="time_night"><override layer-ref="ambient_light" tint="#1A1830" opacity="0.55"/></condition>
            </conditions>
        </layer>
    </layers>

    <animations>
        <animation name="idle" frames="8" fps="1" loop="true"
                   frame-width="640" frame-height="480">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="ambient_light:0,0"/>
            <frame index="2" layer-offsets=""/>
            <frame index="3" layer-offsets="ambient_light:0,0"/>
            <frame index="4" layer-offsets=""/>
            <frame index="5" layer-offsets="ambient_light:0,1"/>
            <frame index="6" layer-offsets=""/>
            <frame index="7" layer-offsets="ambient_light:0,0"/>
        </animation>
    </animations>

    <naming><output-dir>locations/home_room</output-dir></naming>
</asset-spec>