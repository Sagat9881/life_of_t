<?xml version="1.0" encoding="UTF-8"?>
<asset-spec abstract="true" version="1.0">
    <meta>
        <entity-type>entities</entity-type>
        <entity-name>human</entity-name>
        <version>1.0</version>
        <canvas width="128" height="192" displayScale="1.5"/>
        <description>
            Abstract human template (22 layers, 5 animations).
            Canvas: 128×192px (64×96 body in 50×50 grid, ×2 upscale).
            All concrete human specs extend this.
        </description>
    </meta>

    <layers>
        <!-- Z=0-2: Lower body -->
        <layer id="foot_right" type="base" z-order="0" width="128" height="192"/>
        <layer id="shin_right" type="base" z-order="1" width="128" height="192"/>
        <layer id="thigh_right" type="base" z-order="2" width="128" height="192"/>

        <!-- Z=3: Pelvis/hip core -->
        <layer id="pelvis" type="base" z-order="3" width="128" height="192"/>

        <!-- Z=4-6: Left leg in front of pelvis -->
        <layer id="thigh_left" type="base" z-order="4" width="128" height="192"/>
        <layer id="shin_left" type="base" z-order="5" width="128" height="192"/>
        <layer id="foot_left" type="base" z-order="6" width="128" height="192"/>

        <!-- Z=7: Torso -->
        <layer id="torso" type="base" z-order="7" width="128" height="192"/>

        <!-- Z=8-9: Right arm behind torso -->
        <layer id="upper_arm_right" type="base" z-order="8" width="128" height="192"/>
        <layer id="forearm_right" type="base" z-order="9" width="128" height="192"/>
        <layer id="hand_right" type="base" z-order="10" width="128" height="192"/>

        <!-- Z=11-13: Left arm in front -->
        <layer id="upper_arm_left" type="base" z-order="11" width="128" height="192"/>
        <layer id="forearm_left" type="base" z-order="12" width="128" height="192"/>
        <layer id="hand_left" type="base" z-order="13" width="128" height="192"/>

        <!-- Z=14-16: Head stack -->
        <layer id="neck" type="base" z-order="14" width="128" height="192"/>
        <layer id="head" type="base" z-order="15" width="128" height="192"/>
        <layer id="face" type="base" z-order="16" width="128" height="192"/>

        <!-- Z=17-19: Hair & accessories -->
        <layer id="hair_back" type="overlay" z-order="17" width="128" height="192"/>
        <layer id="hair_front" type="overlay" z-order="18" width="128" height="192"/>
        <layer id="accessory" type="overlay" z-order="19" width="128" height="192"/>

        <!-- Z=20-21: Effects -->
        <layer id="shadow" type="effect" z-order="20" width="128" height="192"/>
        <layer id="highlight" type="effect" z-order="21" width="128" height="192"/>

        <!-- Layer 'accessory' in concrete specs SHOULD use follows="neck" for necklaces/collars -->
        <!-- Layer 'accessory' SHOULD use follows="head" for headbands/hats -->
        <!-- Layer 'shoe_detail_*' SHOULD use follows="foot_left" / follows="foot_right" -->
        <!-- Layer 'bracelet_*' SHOULD use follows="hand_left" / follows="hand_right" -->
    </layers>

    <color-palette>
        <primary>
            <color hex="#FFE0BD"/>
            <color hex="#FFA07A"/>
            <color hex="#8B4513"/>
            <color hex="#2F4F4F"/>
            <color hex="#FFFFFF"/>
        </primary>
        <secondary>
            <color hex="#FFD700"/>
            <color hex="#FF6347"/>
            <color hex="#4682B4"/>
            <color hex="#32CD32"/>
            <color hex="#DDA0DD"/>
        </secondary>
    </color-palette>

    <animations>
        <!-- IDLE: 24 frames @ 12fps = 2s loop, breathing + subtle blink -->
        <animation name="idle" frames="24" fps="12" loop="true"
                   frame-width="128" frame-height="192">
            <!-- Breathing cycle: frames 0-11 inhale, 12-23 exhale -->
            <!-- Blink: frames 8, 16, 20 (face shifts down 1px) -->
            <!-- Pelvis/torso move together to prevent separation -->
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="pelvis:0,-1; torso:0,-1; neck:0,-1; head:0,-1; upper_arm_right:0,-1; upper_arm_left:0,-1"/>
            <frame index="2" layer-offsets=""/>
            <frame index="3" layer-offsets="pelvis:0,-1; torso:0,-1; neck:0,-1; head:0,-1; upper_arm_right:0,-1; upper_arm_left:0,-1"/>
            <frame index="4" layer-offsets=""/>
            <frame index="5" layer-offsets="pelvis:0,-1; torso:0,-1; neck:0,-1; head:0,-1; upper_arm_right:0,-1; upper_arm_left:0,-1"/>
            <frame index="6" layer-offsets=""/>
            <frame index="7" layer-offsets="pelvis:0,-1; torso:0,-1"/>
            <frame index="8" layer-offsets="pelvis:0,-1; torso:0,-1; face:0,1"/>
            <frame index="9" layer-offsets="pelvis:0,-1; torso:0,-1; neck:0,-1; head:0,-1; upper_arm_right:0,-1; upper_arm_left:0,-1"/>
            <frame index="10" layer-offsets="pelvis:0,-1; torso:0,-1"/>
            <frame index="11" layer-offsets=""/>
            <frame index="12" layer-offsets=""/>
            <frame index="13" layer-offsets="pelvis:0,1; torso:0,1; neck:0,1; upper_arm_right:0,1; upper_arm_left:0,1"/>
            <frame index="14" layer-offsets=""/>
            <frame index="15" layer-offsets="pelvis:0,1; torso:0,1"/>
            <frame index="16" layer-offsets="pelvis:0,1; torso:0,1; face:0,1"/>
            <frame index="17" layer-offsets="pelvis:0,1; torso:0,1; neck:0,1; upper_arm_right:0,1; upper_arm_left:0,1"/>
            <frame index="18" layer-offsets=""/>
            <frame index="19" layer-offsets="pelvis:0,1; torso:0,1"/>
            <frame index="20" layer-offsets="pelvis:0,1; torso:0,1; face:0,1"/>
            <frame index="21" layer-offsets="pelvis:0,1; torso:0,1; neck:0,1; head:0,1; upper_arm_right:0,1; upper_arm_left:0,1"/>
            <frame index="22" layer-offsets=""/>
            <frame index="23" layer-offsets=""/>
        </animation>

        <!-- WALK: 8 frames @ 8fps = 1s loop -->
        <animation name="walk" frames="8" fps="8" loop="true"
                   frame-width="128" frame-height="192">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="foot_right:0,-4; shin_right:0,-2; thigh_right:0,-1; pelvis:0,-1; torso:0,-1; neck:0,-1"/>
            <frame index="2" layer-offsets="foot_right:0,-2; shin_right:0,-1"/>
            <frame index="3" layer-offsets="foot_left:0,-2; shin_left:0,-1; neck:0,-1"/>
            <frame index="4" layer-offsets=""/>
            <frame index="5" layer-offsets="foot_left:0,-4; shin_left:0,-2; thigh_left:0,-1; pelvis:0,-1; torso:0,-1; neck:0,-1"/>
            <frame index="6" layer-offsets="foot_left:0,-2; shin_left:0,-1"/>
            <frame index="7" layer-offsets="foot_right:0,-2; shin_right:0,-1; neck:0,-1"/>
        </animation>

        <!-- SLEEP: 16 frames @ 4fps = 4s loop (slow breathing) -->
        <animation name="sleep" frames="16" fps="4" loop="true"
                   frame-width="128" frame-height="192">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="torso:0,-1; pelvis:0,-1"/>
            <frame index="2" layer-offsets="torso:0,-1; pelvis:0,-1"/>
            <frame index="3" layer-offsets="torso:0,-2; pelvis:0,-1"/>
            <frame index="4" layer-offsets="torso:0,-2; pelvis:0,-1"/>
            <frame index="5" layer-offsets="torso:0,-2; pelvis:0,-1"/>
            <frame index="6" layer-offsets="torso:0,-2; pelvis:0,-1"/>
            <frame index="7" layer-offsets="torso:0,-1; pelvis:0,-1"/>
            <frame index="8" layer-offsets=""/>
            <frame index="9" layer-offsets=""/>
            <frame index="10" layer-offsets="torso:0,1; pelvis:0,1"/>
            <frame index="11" layer-offsets="torso:0,1; pelvis:0,1"/>
            <frame index="12" layer-offsets=""/>
            <frame index="13" layer-offsets=""/>
            <frame index="14" layer-offsets=""/>
            <frame index="15" layer-offsets=""/>
        </animation>

        <!-- WORK: 12 frames @ 6fps = 2s loop (typing motion) -->
        <animation name="work" frames="12" fps="6" loop="true"
                   frame-width="128" frame-height="192">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="forearm_left:0,-1; hand_left:0,-2"/>
            <frame index="2" layer-offsets="forearm_right:0,-1; hand_right:0,-2"/>
            <frame index="3" layer-offsets=""/>
            <frame index="4" layer-offsets="forearm_left:0,-1; hand_left:0,-2"/>
            <frame index="5" layer-offsets=""/>
            <frame index="6" layer-offsets="forearm_right:0,-1; hand_right:0,-2"/>
            <frame index="7" layer-offsets=""/>
            <frame index="8" layer-offsets="forearm_left:0,-1; hand_left:0,-2"/>
            <frame index="9" layer-offsets="forearm_right:0,-1; hand_right:0,-2"/>
            <frame index="10" layer-offsets=""/>
            <frame index="11" layer-offsets="neck:0,-1"/>
        </animation>

        <!-- EXERCISE: 8 frames @ 10fps = 0.8s loop (jumping jacks) -->
        <animation name="exercise" frames="8" fps="10" loop="true"
                   frame-width="128" frame-height="192">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="upper_arm_left:0,-2; upper_arm_right:0,-2; thigh_left:-2,0; thigh_right:2,0; pelvis:0,-2; torso:0,-2"/>
            <frame index="2" layer-offsets="upper_arm_left:0,-4; upper_arm_right:0,-4; thigh_left:-4,0; thigh_right:4,0; pelvis:0,-4; torso:0,-4"/>
            <frame index="3" layer-offsets="upper_arm_left:0,-4; upper_arm_right:0,-4; thigh_left:-4,0; thigh_right:4,0; pelvis:0,-4; torso:0,-4"/>
            <frame index="4" layer-offsets="upper_arm_left:0,-2; upper_arm_right:0,-2; thigh_left:-2,0; thigh_right:2,0; pelvis:0,-2; torso:0,-2"/>
            <frame index="5" layer-offsets=""/>
            <frame index="6" layer-offsets=""/>
            <frame index="7" layer-offsets=""/>
        </animation>
    </animations>

    <naming><output-dir>abstract/entities/human</output-dir></naming>
</asset-spec>