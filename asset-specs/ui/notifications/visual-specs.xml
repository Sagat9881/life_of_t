<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>ui</entity-type>
        <entity-name>notifications</entity-name>
        <version>1.0.0</version>
        <description>
            UI-уведомления: тосты, всплывающие подсказки,
            статусные индикаторы. Появляются поверх игрового
            экрана при изменении статов, событиях, конфликтах.
        </description>
    </meta>

    <layers>
        <!-- === TOAST — базовый контейнер === -->
        <layer id="toast-bg" type="base" z-order="2000" width="160" height="32">
            <pixel-data>
                <!-- Фон тоста -->
                <rect x="2" y="2" w="156" h="28" color="#FFFFFF"/>
                <!-- Тень -->
                <hline x="4" y="30" len="154" color="#E0E0E0"/>
                <vline x="158" y="4" len="26" color="#E0E0E0"/>
                <!-- Скругления (имитация) -->
                <pixel x="2" y="2" color="#F8F8F8"/>
                <pixel x="157" y="2" color="#F8F8F8"/>
                <pixel x="2" y="29" color="#F8F8F8"/>
                <pixel x="157" y="29" color="#F8F8F8"/>
            </pixel-data>
        </layer>

        <!-- Акцентная полоска слева (цвет зависит от типа) -->
        <layer id="toast-accent-success" type="overlay" z-order="2001" width="160" height="32"
               condition="type:success">
            <pixel-data>
                <rect x="2" y="3" w="3" h="26" color="#4CAF50"/>
            </pixel-data>
        </layer>

        <layer id="toast-accent-warning" type="overlay" z-order="2001" width="160" height="32"
               condition="type:warning">
            <pixel-data>
                <rect x="2" y="3" w="3" h="26" color="#FFA726"/>
            </pixel-data>
        </layer>

        <layer id="toast-accent-danger" type="overlay" z-order="2001" width="160" height="32"
               condition="type:danger">
            <pixel-data>
                <rect x="2" y="3" w="3" h="26" color="#E74C3C"/>
            </pixel-data>
        </layer>

        <layer id="toast-accent-info" type="overlay" z-order="2001" width="160" height="32"
               condition="type:info">
            <pixel-data>
                <rect x="2" y="3" w="3" h="26" color="#4FC3F7"/>
            </pixel-data>
        </layer>

        <layer id="toast-accent-love" type="overlay" z-order="2001" width="160" height="32"
               condition="type:love">
            <pixel-data>
                <rect x="2" y="3" w="3" h="26" color="#FF6B9D"/>
            </pixel-data>
        </layer>

        <!-- === STAT CHANGE BUBBLE — маленький пузырёк +/-N === -->
        <layer id="stat-bubble" type="animated-overlay" z-order="2000" width="24" height="12">
            <pixel-data>
                <rect x="2" y="1" w="20" h="10" color="#FFFFFF"/>
                <hline x="4" y="11" len="16" color="#E0E0E0"/>
                <pixel x="2" y="1" color="#F0F0F0"/>
                <pixel x="21" y="1" color="#F0F0F0"/>
            </pixel-data>
        </layer>

        <!-- === EVENT ALERT — иконка восклицательного знака === -->
        <layer id="event-alert" type="animated-overlay" z-order="2000" width="12" height="12">
            <pixel-data>
                <!-- Круг -->
                <rect x="2" y="1" w="8" h="10" color="#FF6B9D"/>
                <pixel x="1" y="3" color="#FF6B9D"/>
                <pixel x="1" y="8" color="#FF6B9D"/>
                <pixel x="10" y="3" color="#FF6B9D"/>
                <pixel x="10" y="8" color="#FF6B9D"/>
                <!-- ! -->
                <rect x="5" y="3" w="2" h="4" color="#FFFFFF"/>
                <rect x="5" y="8" w="2" h="1" color="#FFFFFF"/>
            </pixel-data>
        </layer>

        <!-- === CONFLICT ALERT — молния === -->
        <layer id="conflict-alert" type="animated-overlay" z-order="2000" width="12" height="14">
            <pixel-data>
                <pixel x="7" y="1" color="#FFA726"/>
                <pixel x="6" y="2" color="#FFA726"/>
                <pixel x="5" y="3" color="#FFD740"/>
                <rect x="4" y="4" w="4" h="1" color="#FFA726"/>
                <pixel x="7" y="5" color="#FFA726"/>
                <pixel x="6" y="6" color="#FFD740"/>
                <pixel x="5" y="7" color="#FFA726"/>
                <pixel x="4" y="8" color="#FFA726"/>
                <pixel x="3" y="9" color="#FFD740"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <!-- Toast: выезжает сверху, задерживается, уезжает -->
        <animation name="toast-show" frames="8" fps="6" loop="false"
                   frame-width="160" frame-height="32">
            <description>
                Тост появляется сверху экрана: слайд вниз (3 кадра),
                пауза на месте (3 кадра), слайд вверх и исчезновение (2 кадра).
                Easing: ease-out при появлении, ease-in при исчезновении.
            </description>
            <frame index="0" layer-offsets="toast-bg:0,-32" alpha="0.5"/>
            <frame index="1" layer-offsets="toast-bg:0,-16" alpha="0.8"/>
            <frame index="2" layer-offsets="toast-bg:0,0" alpha="1.0"/>
            <frame index="3" layer-offsets="toast-bg:0,0" alpha="1.0"/>
            <frame index="4" layer-offsets="toast-bg:0,0" alpha="1.0"/>
            <frame index="5" layer-offsets="toast-bg:0,0" alpha="1.0"/>
            <frame index="6" layer-offsets="toast-bg:0,-16" alpha="0.6"/>
            <frame index="7" layer-offsets="toast-bg:0,-32" alpha="0.0"/>
        </animation>

        <!-- Stat bubble: всплывает вверх от персонажа -->
        <animation name="stat-change" frames="6" fps="4" loop="false"
                   frame-width="24" frame-height="12"
                   spawn="above-stat-bar">
            <description>
                Пузырёк с +5 или -3 поднимается вверх
                от полоски стата и растворяется.
            </description>
            <frame index="0" layer-offsets="stat-bubble:0,0" alpha="0.8"/>
            <frame index="1" layer-offsets="stat-bubble:0,-3" alpha="1.0"/>
            <frame index="2" layer-offsets="stat-bubble:0,-6" alpha="1.0"/>
            <frame index="3" layer-offsets="stat-bubble:0,-9" alpha="0.8"/>
            <frame index="4" layer-offsets="stat-bubble:0,-12" alpha="0.5"/>
            <frame index="5" layer-offsets="stat-bubble:0,-14" alpha="0.0"/>
        </animation>

        <!-- Event alert: пульсирующий восклицательный знак -->
        <animation name="event-pulse" frames="4" fps="3" loop="true"
                   frame-width="12" frame-height="12">
            <description>
                Иконка пульсирует — масштабирование через
                layer-offsets (сдвиг на ±1px имитирует «дыхание»).
            </description>
            <frame index="0" layer-offsets="event-alert:0,0" alpha="1.0"/>
            <frame index="1" layer-offsets="event-alert:0,-1" alpha="1.0"/>
            <frame index="2" layer-offsets="event-alert:0,0" alpha="0.9"/>
            <frame index="3" layer-offsets="event-alert:0,0" alpha="1.0"/>
        </animation>

        <!-- Conflict alert: молния мерцает -->
        <animation name="conflict-flash" frames="4" fps="4" loop="true"
                   frame-width="12" frame-height="14">
            <description>
                Молния мерцает — чередование яркости
                и лёгкий сдвиг, имитация грозового разряда.
            </description>
            <frame index="0" layer-offsets="conflict-alert:0,0" alpha="1.0"/>
            <frame index="1" layer-offsets="conflict-alert:1,0" alpha="0.7"/>
            <frame index="2" layer-offsets="conflict-alert:0,0" alpha="1.0"/>
            <frame index="3" layer-offsets="conflict-alert:-1,0" alpha="0.5"/>
        </animation>
    </animations>

    <naming>
        <output-dir>ui/notifications</output-dir>
    </naming>
</asset-spec>
