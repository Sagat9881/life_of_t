<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>thelma</entity-name>
        <version>1.0.0</version>
    </meta>
    <!-- Thelma: black and white cat, more black than Lada, thinner build.
         Canvas: 20x16. Coat: #0A0A0A (very dark, more pure black), white #EEEEEE
         only on face blaze and one white paw. Two modes: lazy winter / energetic summer.
         The last foster cat; lost her kittens. -->
    <layers>
        <!-- z=0: paws — mostly black, one distinctive white front-right paw -->
        <layer id="paws" type="base" z-order="0" width="20" height="16">
            <pixel-data>
                <!-- front left: black -->
                <rect x="3" y="13" w="2" h="2" color="#0A0A0A"/>
                <hline x="3" y="14" len="2" color="#1A1A1A"/>
                <!-- front right: WHITE (distinguishing mark) -->
                <rect x="7" y="13" w="2" h="2" color="#EEEEEE"/>
                <hline x="7" y="14" len="2" color="#CCCCCC"/>
                <!-- rear left: black -->
                <rect x="11" y="13" w="2" h="2" color="#0A0A0A"/>
                <hline x="11" y="14" len="2" color="#1A1A1A"/>
                <!-- rear right: black -->
                <rect x="15" y="13" w="2" h="2" color="#0A0A0A"/>
                <hline x="15" y="14" len="2" color="#1A1A1A"/>
                <!-- paw pads -->
                <pixel x="4" y="14" color="#221122"/>
                <pixel x="8" y="14" color="#FFBBDD"/>
                <pixel x="12" y="14" color="#221122"/>
                <pixel x="16" y="14" color="#221122"/>
            </pixel-data>
        </layer>
        <!-- z=1: legs — all black, slender -->
        <layer id="legs" type="base" z-order="1" width="20" height="16">
            <pixel-data>
                <rect x="3" y="9" w="2" h="4" color="#0A0A0A"/>
                <!-- white paw leg transition -->
                <rect x="7" y="9" w="2" h="4" color="#0A0A0A"/>
                <hline x="7" y="12" len="2" color="#CCCCCC"/>
                <rect x="11" y="9" w="2" h="4" color="#0A0A0A"/>
                <rect x="15" y="9" w="2" h="4" color="#0A0A0A"/>
            </pixel-data>
        </layer>
        <!-- z=2: body/torso — thinner than Lada, very dark, sleek -->
        <layer id="body" type="base" z-order="2" width="20" height="16">
            <pixel-data>
                <rect x="3" y="6" w="12" h="5" color="#0A0A0A"/>
                <!-- very subtle sheen -->
                <hline x="4" y="6" len="10" color="#1A1A2A"/>
                <hline x="5" y="7" len="8" color="#111122"/>
                <!-- underside barely lighter -->
                <hline x="4" y="10" len="10" color="#080808"/>
                <!-- slim silhouette: one pixel narrower sides -->
                <pixel x="3" y="10" color="#0A0A0A"/>
                <pixel x="14" y="10" color="#0A0A0A"/>
            </pixel-data>
        </layer>
        <!-- z=3: belly_pattern — minimal white blaze on chest, narrow stripe -->
        <layer id="belly_pattern" type="overlay" z-order="3" width="20" height="16">
            <pixel-data>
                <!-- very thin chest stripe (less white than Lada) -->
                <hline x="8" y="8" len="2" color="#EEEEEE"/>
                <hline x="8" y="9" len="2" color="#EEEEEE"/>
                <!-- white chin (narrow) -->
                <hline x="5" y="7" len="2" color="#E0E0E0"/>
            </pixel-data>
        </layer>
        <!-- z=4: tail — long thin black tail with white tip -->
        <layer id="tail" type="base" z-order="4" width="20" height="16">
            <pixel-data>
                <pixel x="15" y="9" color="#0A0A0A"/>
                <pixel x="16" y="8" color="#0A0A0A"/>
                <pixel x="17" y="7" color="#0A0A0A"/>
                <pixel x="18" y="6" color="#0A0A0A"/>
                <pixel x="18" y="5" color="#0A0A0A"/>
                <pixel x="17" y="4" color="#111122"/>
                <!-- white tip (like a paint brush) -->
                <pixel x="18" y="4" color="#EEEEEE"/>
                <pixel x="19" y="4" color="#EEEEEE"/>
                <pixel x="19" y="5" color="#CCCCCC"/>
            </pixel-data>
        </layer>
        <!-- z=5: head — slim black head with white blaze from nose to forehead -->
        <layer id="head" type="base" z-order="5" width="20" height="16">
            <pixel-data>
                <!-- main head: deep black -->
                <rect x="2" y="2" w="8" h="6" color="#0A0A0A"/>
                <!-- forehead subtle sheen -->
                <hline x="3" y="2" len="6" color="#1A1A2A"/>
                <!-- white blaze stripe down the middle of face -->
                <hline x="5" y="2" len="2" color="#EEEEEE"/>
                <hline x="5" y="3" len="2" color="#EEEEEE"/>
                <hline x="5" y="4" len="2" color="#E0E0E0"/>
                <pixel x="5" y="5" color="#DDDDDD"/>
                <pixel x="6" y="5" color="#DDDDDD"/>
                <!-- chin white -->
                <hline x="4" y="7" len="4" color="#E0E0E0"/>
            </pixel-data>
        </layer>
        <!-- z=6: ears — slim black ears, very pointed, elegant -->
        <layer id="ears" type="base" z-order="6" width="20" height="16">
            <pixel-data>
                <!-- left ear: sharp -->
                <pixel x="2" y="1" color="#0A0A0A"/>
                <pixel x="3" y="0" color="#0A0A0A"/>
                <pixel x="3" y="1" color="#0A0A0A"/>
                <pixel x="3" y="1" color="#220011"/>
                <!-- right ear -->
                <pixel x="8" y="1" color="#0A0A0A"/>
                <pixel x="7" y="0" color="#0A0A0A"/>
                <pixel x="7" y="1" color="#0A0A0A"/>
                <pixel x="7" y="1" color="#220011"/>
            </pixel-data>
        </layer>
        <!-- z=7: face_details — vivid blue eyes (beautiful contrast with black), whiskers -->
        <layer id="face_details" type="overlay" z-order="7" width="20" height="16">
            <pixel-data>
                <!-- left eye: piercing blue on blaze side -->
                <pixel x="4" y="4" color="#0066CC"/>
                <pixel x="5" y="3" color="#2299EE"/>
                <pixel x="5" y="4" color="#2299EE"/>
                <pixel x="4" y="3" color="#0066CC"/>
                <pixel x="5" y="4" color="#111111"/>
                <!-- right eye: same vivid blue -->
                <pixel x="7" y="4" color="#0066CC"/>
                <pixel x="8" y="3" color="#2299EE"/>
                <pixel x="8" y="4" color="#2299EE"/>
                <pixel x="7" y="3" color="#0066CC"/>
                <pixel x="8" y="4" color="#111111"/>
                <!-- eye shine -->
                <pixel x="4" y="3" color="#FFFFFF"/>
                <pixel x="7" y="3" color="#FFFFFF"/>
                <!-- nose: in white blaze, pink -->
                <pixel x="5" y="5" color="#FF8899"/>
                <pixel x="6" y="5" color="#FF8899"/>
                <pixel x="6" y="6" color="#CC6677"/>
                <!-- mouth small -->
                <pixel x="5" y="7" color="#220011"/>
                <pixel x="7" y="7" color="#220011"/>
                <!-- whiskers prominent on black/white face -->
                <hline x="0" y="5" len="3" color="#FFFFFF"/>
                <hline x="0" y="6" len="2" color="#EEEEEE"/>
                <hline x="9" y="5" len="3" color="#FFFFFF"/>
                <hline x="9" y="6" len="2" color="#EEEEEE"/>
            </pixel-data>
        </layer>
    </layers>
    <animations>
        <!-- idle_morning: winter mode — barely waking, slow and sluggish -->
        <animation name="idle_morning" frames="4" fps="2" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="morning"/>
            <condition type="season" value="winter"/>
            <!-- barely moves: one slow blink and a slight head shift -->
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="head:0,0; face_details:0,1"/>
            <frame index="2" layer-offsets=""/>
            <frame index="3" layer-offsets="head:0,1; face_details:0,1"/>
        </animation>
        <!-- idle_day: summer mode — alert, ready to play -->
        <animation name="idle_day" frames="4" fps="5" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="day"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="head:-1,-1; ears:-1,-1; face_details:-1,-1"/>
            <frame index="2" layer-offsets="tail:0,-2"/>
            <frame index="3" layer-offsets="head:1,0; ears:1,0; face_details:1,0; tail:0,-1"/>
        </animation>
        <!-- idle_evening: curled, relaxed but alert -->
        <animation name="idle_evening" frames="4" fps="3" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="evening"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="tail:0,1"/>
            <frame index="2" layer-offsets="head:0,1; face_details:0,1; body:0,1; belly_pattern:0,1"/>
            <frame index="3" layer-offsets="tail:-1,1"/>
        </animation>
        <!-- idle_night: deeply sleeping, winter-mode fully flat -->
        <animation name="idle_night" frames="4" fps="2" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="night"/>
            <frame index="0" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-2,1"/>
            <frame index="1" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-2,1"/>
            <frame index="2" layer-offsets="head:0,2; ears:0,2; face_details:0,2; body:0,1; belly_pattern:0,1; tail:-2,1"/>
            <frame index="3" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-2,1"/>
        </animation>
        <!-- walk: brisk energetic walk (summer mode) -->
        <animation name="walk" frames="6" fps="9" loop="true" frame-width="20" frame-height="16">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="paws:-1,-1; legs:-1,0"/>
            <frame index="2" layer-offsets="body:-1,0; belly_pattern:-1,0"/>
            <frame index="3" layer-offsets="paws:1,-1; legs:1,0"/>
            <frame index="4" layer-offsets="tail:0,-2; body:1,0; belly_pattern:1,0"/>
            <frame index="5" layer-offsets="tail:0,-1"/>
        </animation>
        <!-- run: unique — fast summer sprint, legs blurring, tail streaming behind -->
        <animation name="run" frames="6" fps="12" loop="true" frame-width="20" frame-height="16">
            <condition type="trigger" value="summer_mode"/>
            <!-- frame 0: full extension leap -->
            <frame index="0" layer-offsets="paws:-3,-2; legs:-2,-1; body:-2,-1"/>
            <!-- frame 1: mid-air -->
            <frame index="1" layer-offsets="paws:-3,-3; legs:-2,-2; body:-2,-2; tail:2,-1"/>
            <!-- frame 2: land front paws -->
            <frame index="2" layer-offsets="paws:-1,-1; legs:-1,0; body:-1,0"/>
            <!-- frame 3: rear paws tuck through -->
            <frame index="3" layer-offsets="paws:2,-1; legs:2,0"/>
            <!-- frame 4: full extension other side -->
            <frame index="4" layer-offsets="paws:3,-2; legs:2,-1; body:1,-1; tail:-1,-1"/>
            <!-- frame 5: gather for next stride -->
            <frame index="5" layer-offsets=""/>
        </animation>
    </animations>
    <naming>
        <output-dir>characters/thelma</output-dir>
    </naming>
</asset-spec>