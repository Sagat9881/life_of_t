<?xml version="1.0" encoding="UTF-8"?>
<!--
    Life of T — Tanya Visual Spec v3.0.0
    Extends: abstract/entities/human@1.0
    Canvas: 128×192 | displayScale: 1.5
    Character: Tanya — 28yo, web designer, dark-auburn hair, green eyes,
               mint top, beige cardigan, white pants, grey slippers, gold necklace.
               Anxious, loving, smart. Partner of Alexander.
-->
<asset-spec extends="abstract/entities/human@1.0" version="3.0.0">
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>tanya</entity-name>
        <version>3.0.0</version>
        <display-scale>1.5</display-scale>
    </meta>

    <color-palette>
        <color name="$skin_base" value="#F0C098"/>
        <color name="$skin_shadow" value="#D8A078"/>
        <color name="$skin_highlight" value="#F8D0B0"/>
        <color name="$hair_base" value="#801828"/>
        <color name="$hair_shadow" value="#601020"/>
        <color name="$hair_highlight" value="#A02030"/>
        <color name="$clothing_primary" value="#90D8C0"/><!-- mint top -->
        <color name="$clothing_primary_shadow" value="#70C0A8"/>
        <color name="$clothing_primary_highlight" value="#A8E8D0"/>
        <color name="$clothing_secondary" value="#D8C8A0"/><!-- beige cardigan -->
        <color name="$clothing_secondary_shadow" value="#B8A880"/>
        <color name="$clothing_secondary_highlight" value="#E8D8B0"/>
        <color name="$pants_base" value="#F0F0E8"/>
        <color name="$pants_shadow" value="#D8D8D0"/>
        <color name="$pants_highlight" value="#FAFAF5"/>
        <color name="$shoe_base" value="#C8C8C8"/><!-- grey slippers -->
        <color name="$shoe_shadow" value="#A8A8A8"/>
        <color name="$shoe_highlight" value="#E0E0E0"/>
        <color name="$eye_color" value="#228B22"/><!-- forest green -->
        <color name="$eye_highlight" value="#40B050"/>
        <color name="$lip_color" value="#D08878"/>
        <color name="$brow_color" value="#601020"/><!-- matches dark auburn -->
        <color name="$accessory_gold" value="#F0C030"/>
        <color name="$accessory_gold_shadow" value="#D4A017"/>
        <color name="$accessory_gold_highlight" value="#FFF0A0"/>
    </color-palette>

    <layer-overrides>
        <!-- === FACE — Tanya's unique features === -->
        <layer id="face" replace="true">
            <pixel-data>
                <!-- LEFT EYE -->
                <rect x="42" y="30" w="16" h="10" color="#FFFFFF"/><!-- sclera -->
                <rect x="44" y="28" w="12" h="13" color="$eye_color"/><!-- iris outer -->
                <rect x="46" y="30" w="9" h="9" color="#30A040"/><!-- iris inner -->
                <rect x="47" y="31" w="6" h="6" color="$eye_highlight"/><!-- iris bright -->
                <rect x="49" y="32" w="3" h="4" color="#101010"/><!-- pupil -->
                <rect x="45" y="28" w="3" h="3" color="#FFFFFF"/><!-- shine -->
                <hline x="42" y="27" len="16" color="$skin_shadow"/><!-- upper lid -->
                <hline x="42" y="39" len="16" color="$skin_shadow"/><!-- lower lash -->
                <!-- RIGHT EYE -->
                <rect x="70" y="30" w="16" h="10" color="#FFFFFF"/>
                <rect x="72" y="28" w="12" h="13" color="$eye_color"/>
                <rect x="74" y="30" w="9" h="9" color="#30A040"/>
                <rect x="75" y="31" w="6" h="6" color="$eye_highlight"/>
                <rect x="77" y="32" w="3" h="4" color="#101010"/>
                <rect x="73" y="28" w="3" h="3" color="#FFFFFF"/>
                <hline x="70" y="27" len="16" color="$skin_shadow"/>
                <hline x="70" y="39" len="16" color="$skin_shadow"/>
                <!-- EYEBROWS — slightly arched, dark auburn -->
                <hline x="42" y="24" len="14" color="$brow_color"/>
                <hline x="44" y="23" len="8" color="#801828"/>
                <hline x="72" y="24" len="14" color="$brow_color"/>
                <hline x="74" y="23" len="8" color="#801828"/>
                <!-- NOSE -->
                <rect x="59" y="38" w="4" h="4" color="$skin_shadow"/><!-- bridge -->
                <hline x="56" y="44" len="10" color="#E0A078"/><!-- tip -->
                <rect x="55" y="45" w="3" h="2" color="#B87050"/><!-- nostril L -->
                <rect x="64" y="45" w="3" h="2" color="#B87050"/><!-- nostril R -->
                <!-- LIPS -->
                <hline x="52" y="48" len="20" color="#C07868"/><!-- upper lip -->
                <rect x="55" y="48" w="14" h="2" color="$lip_color"/><!-- lip body -->
                <hline x="52" y="50" len="20" color="#E0A090"/><!-- lower lip -->
                <rect x="58" y="49" w="6" h="2" color="#F0C0B0"/><!-- lip highlight -->
                <!-- CHEEK BLUSH -->
                <rect x="36" y="38" w="10" h="6" color="#F4B090"/><!-- left -->
                <rect x="82" y="38" w="10" h="6" color="#F4B090"/><!-- right -->
            </pixel-data>
        </layer>

        <!-- === HAIR BACK — dark auburn, mid-length, wavy === -->
        <layer id="hair_back" replace="true">
            <pixel-data>
                <!-- Hair mass behind head -->
                <rect x="30" y="55" w="12" h="20" color="$hair_shadow"/>
                <rect x="86" y="55" w="12" h="20" color="$hair_shadow"/>
                <!-- Lower hair tips with wave -->
                <rect x="28" y="70" w="8" h="6" color="$hair_base"/>
                <rect x="92" y="70" w="8" h="6" color="$hair_base"/>
                <rect x="30" y="74" w="4" h="3" color="$hair_highlight"/>
                <rect x="94" y="74" w="4" h="3" color="$hair_highlight"/>
            </pixel-data>
        </layer>

        <!-- === HAIR FRONT — frames face, dark auburn === -->
        <layer id="hair_front" replace="true">
            <pixel-data>
                <!-- Top hair mass -->
                <rect x="34" y="8" w="60" h="16" color="$hair_base"/>
                <hline x="38" y="8" len="52" color="$hair_highlight"/><!-- crown highlight -->
                <hline x="42" y="9" len="40" color="#902028"/><!-- secondary highlight -->
                <!-- Part line -->
                <hline x="46" y="8" len="16" color="$hair_shadow"/>
                <!-- Left side hair fall -->
                <rect x="30" y="18" w="10" h="28" color="$hair_base"/>
                <rect x="28" y="24" w="6" h="22" color="$hair_base"/>
                <rect x="30" y="22" w="5" h="26" color="$hair_shadow"/><!-- depth -->
                <rect x="36" y="18" w="3" h="24" color="$hair_highlight"/><!-- strand -->
                <!-- Right side hair fall -->
                <rect x="88" y="18" w="10" h="28" color="$hair_base"/>
                <rect x="94" y="24" w="6" h="22" color="$hair_base"/>
                <rect x="93" y="22" w="5" h="26" color="$hair_shadow"/>
                <rect x="89" y="18" w="3" h="24" color="$hair_highlight"/>
                <!-- Strand texture -->
                <hline x="34" y="12" len="20" color="#701020"/>
                <hline x="72" y="12" len="22" color="#701020"/>
                <hline x="30" y="32" len="8" color="#701020"/>
                <hline x="90" y="32" len="8" color="#701020"/>
            </pixel-data>
        </layer>

        <!-- === ACCESSORY — gold necklace + stud earrings + watch === -->
        <layer id="accessory" follows="neck" replace="true">
            <pixel-data>
                <!-- Gold necklace chain across collarbone -->
                <rect x="44" y="62" w="2" h="2" color="$accessory_gold_shadow"/>
                <rect x="47" y="61" w="2" h="2" color="$accessory_gold"/>
                <rect x="50" y="60" w="2" h="2" color="$accessory_gold"/>
                <rect x="53" y="59" w="2" h="2" color="$accessory_gold_highlight"/>
                <rect x="56" y="58" w="4" h="2" color="$accessory_gold_highlight"/>
                <rect x="60" y="58" w="4" h="2" color="$accessory_gold_highlight"/>
                <rect x="64" y="58" w="4" h="2" color="$accessory_gold_highlight"/>
                <rect x="68" y="59" w="2" h="2" color="$accessory_gold"/>
                <rect x="71" y="60" w="2" h="2" color="$accessory_gold"/>
                <rect x="74" y="61" w="2" h="2" color="$accessory_gold"/>
                <rect x="77" y="62" w="2" h="2" color="$accessory_gold_shadow"/>
                <!-- Pendant -->
                <rect x="60" y="64" w="3" h="3" color="$accessory_gold"/>
                <rect x="61" y="67" w="2" h="2" color="$accessory_gold_shadow"/>
                <!-- Left earring -->
                <rect x="32" y="34" w="3" h="3" color="$accessory_gold"/>
                <rect x="33" y="33" w="2" h="2" color="$accessory_gold_highlight"/>
                <!-- Right earring -->
                <rect x="93" y="34" w="3" h="3" color="$accessory_gold"/>
                <rect x="94" y="33" w="2" h="2" color="$accessory_gold_highlight"/>
                <!-- Watch on left wrist -->
                <rect x="18" y="118" w="8" h="4" color="#C0A060"/>
                <rect x="20" y="119" w="4" h="2" color="#E8D0A0"/>
            </pixel-data>
        </layer>

        <!-- === TORSO override — mint top + beige cardigan === -->
        <layer id="torso" replace="true">
            <pixel-data>
                <!-- Cardigan body -->
                <rect x="26" y="64" w="76" h="40" color="$clothing_secondary"/>
                <!-- Cardigan side panels -->
                <rect x="26" y="64" w="16" h="40" color="$clothing_secondary_shadow"/>
                <rect x="86" y="64" w="16" h="40" color="$clothing_secondary_shadow"/>
                <!-- Mint top center -->
                <rect x="42" y="64" w="44" h="40" color="$clothing_primary"/>
                <rect x="52" y="64" w="24" h="40" color="$clothing_primary_highlight"/>
                <rect x="42" y="64" w="6" h="40" color="$clothing_primary_shadow"/>
                <rect x="80" y="64" w="6" h="40" color="$clothing_primary_shadow"/>
                <!-- Cardigan opening lines -->
                <rect x="42" y="64" w="2" h="40" color="$clothing_secondary_shadow"/>
                <rect x="84" y="64" w="2" h="40" color="$clothing_secondary_shadow"/>
                <!-- Collar fold -->
                <hline x="30" y="64" len="68" color="$clothing_secondary_highlight"/>
                <!-- Bottom hem -->
                <hline x="28" y="103" len="72" color="#C0B088"/>
                <!-- Buttons -->
                <rect x="34" y="72" w="2" h="2" color="#A89070"/>
                <rect x="34" y="82" w="2" h="2" color="#A89070"/>
                <rect x="34" y="92" w="2" h="2" color="#A89070"/>
                <!-- Rib texture left -->
                <hline x="26" y="72" len="14" color="#C0B088"/>
                <hline x="26" y="80" len="14" color="#C0B088"/>
                <hline x="26" y="88" len="14" color="#C0B088"/>
                <hline x="26" y="96" len="14" color="#C0B088"/>
                <!-- Rib texture right -->
                <hline x="88" y="72" len="14" color="#C0B088"/>
                <hline x="88" y="80" len="14" color="#C0B088"/>
                <hline x="88" y="88" len="14" color="#C0B088"/>
                <hline x="88" y="96" len="14" color="#C0B088"/>
            </pixel-data>
        </layer>

        <!-- === PELVIS/HIPS override — white pants === -->
        <layer id="pelvis" replace="true">
            <pixel-data>
                <rect x="28" y="104" w="72" h="8" color="$pants_base"/>
                <hline x="28" y="104" len="72" color="$pants_shadow"/><!-- waistband -->
                <rect x="48" y="105" w="32" h="6" color="$pants_highlight"/><!-- center highlight -->
                <rect x="28" y="105" w="8" h="6" color="$pants_shadow"/><!-- L hip shadow -->
                <rect x="92" y="105" w="8" h="6" color="$pants_shadow"/><!-- R hip shadow -->
                <hline x="34" y="105" len="60" color="#E8E8E0"/><!-- seam -->
            </pixel-data>
        </layer>

        <!-- === FOOT overrides — grey slippers === -->
        <layer id="foot_left" replace="true">
            <pixel-data>
                <rect x="34" y="176" w="24" h="12" color="$shoe_base"/>
                <rect x="30" y="178" w="6" h="6" color="$shoe_base"/><!-- rounded toe -->
                <hline x="34" y="176" len="24" color="$shoe_highlight"/><!-- top edge -->
                <hline x="30" y="187" len="30" color="$shoe_shadow"/><!-- sole shadow -->
                <rect x="36" y="180" w="20" h="4" color="#B8B8B8"/><!-- inner shadow -->
            </pixel-data>
        </layer>

        <layer id="foot_right" replace="true">
            <pixel-data>
                <rect x="70" y="176" w="24" h="12" color="$shoe_base"/>
                <rect x="92" y="178" w="6" h="6" color="$shoe_base"/><!-- rounded toe -->
                <hline x="70" y="176" len="24" color="$shoe_highlight"/>
                <hline x="68" y="187" len="30" color="$shoe_shadow"/>
                <rect x="72" y="180" w="20" h="4" color="#B8B8B8"/>
            </pixel-data>
        </layer>
    </layer-overrides>

    <!-- Tanya-specific extra animation -->
    <animations-extra>
        <animation name="anxiety_attack" frames="12" fps="5" loop="false" frame-width="128" frame-height="192">
            <frame index="0" layer-offsets="hand_left:2,0; hand_right:-2,0"/>
            <frame index="1" layer-offsets="hand_left:4,-4; hand_right:-4,-4; head:0,-1"/>
            <frame index="2" layer-offsets="hand_left:6,-10; hand_right:-6,-10; head:0,-2; hair_front:0,-1"/>
            <frame index="3" layer-offsets="hand_left:8,-16; hand_right:-8,-16; forearm_left:4,-8; forearm_right:-4,-8; head:0,-2; hair_front:0,-2"/>
            <frame index="4" layer-offsets="hand_left:10,-20; hand_right:-10,-20; forearm_left:6,-12; forearm_right:-6,-12; upper_arm_left:2,-4; upper_arm_right:-2,-4; head:0,-3; hair_front:1,-2"/>
            <frame index="5" layer-offsets="hand_left:10,-20; hand_right:-10,-20; forearm_left:6,-12; forearm_right:-6,-12; upper_arm_left:2,-4; upper_arm_right:-2,-4; head:1,-3; hair_front:1,-2"/>
            <frame index="6" layer-offsets="hand_left:10,-20; hand_right:-10,-20; forearm_left:6,-12; forearm_right:-6,-12; upper_arm_left:2,-4; upper_arm_right:-2,-4; head:-1,-3; hair_front:-1,-2"/>
            <frame index="7" layer-offsets="hand_left:10,-20; hand_right:-10,-20; forearm_left:6,-12; forearm_right:-6,-12; upper_arm_left:2,-4; upper_arm_right:-2,-4; head:1,-2; torso:0,-1"/>
            <frame index="8" layer-offsets="hand_left:8,-16; hand_right:-8,-16; forearm_left:4,-8; forearm_right:-4,-8; head:0,-2"/>
            <frame index="9" layer-offsets="hand_left:6,-10; hand_right:-6,-10; head:0,-1"/>
            <frame index="10" layer-offsets="hand_left:3,-4; hand_right:-3,-4"/>
            <frame index="11" layer-offsets=""/>
        </animation>
    </animations-extra>

    <naming>
        <output-dir>characters/tanya</output-dir>
    </naming>
</asset-spec>