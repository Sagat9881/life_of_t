<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>tanya</entity-name>
        <version>1.2.0</version>
    </meta>

    <layers>
        <!-- Slippers (z=0, bottom) -->
        <layer id="slippers" type="base" z-order="0" width="32" height="48">
            <pixel-data>
                <rect x="8" y="46" w="5" h="2" color="#808080"/>
                <pixel x="8" y="47" color="#606060"/>
                <rect x="19" y="46" w="5" h="2" color="#808080"/>
                <pixel x="23" y="47" color="#606060"/>
            </pixel-data>
        </layer>

        <!-- Legs / white pants (z=1) -->
        <layer id="legs" type="base" z-order="1" width="32" height="48">
            <pixel-data>
                <rect x="9" y="33" w="5" h="13" color="#F0F0E8"/>
                <rect x="9" y="33" w="1" h="13" color="#D0D0C8"/>
                <rect x="18" y="33" w="5" h="13" color="#F0F0E8"/>
                <rect x="22" y="33" w="1" h="13" color="#D0D0C8"/>
                <hline x="9" y="33" len="14" color="#D0D0C8"/>
            </pixel-data>
        </layer>

        <!-- Torso: mint top + beige cardigan (z=2) -->
        <layer id="torso" type="base" z-order="2" width="32" height="48">
            <pixel-data>
                <!-- Mint tank top -->
                <rect x="11" y="20" w="10" h="13" color="#90D8C0"/>
                <rect x="11" y="20" w="1" h="13" color="#70C0A8"/>
                <rect x="20" y="20" w="1" h="13" color="#70C0A8"/>
                <!-- Cardigan left -->
                <rect x="6" y="21" w="6" h="12" color="#D8C8A0"/>
                <rect x="6" y="21" w="1" h="12" color="#C0B088"/>
                <!-- Cardigan right -->
                <rect x="20" y="21" w="6" h="12" color="#D8C8A0"/>
                <rect x="25" y="21" w="1" h="12" color="#C0B088"/>
                <!-- Cardigan shoulders -->
                <rect x="6" y="20" w="4" h="2" color="#D8C8A0"/>
                <rect x="22" y="20" w="4" h="2" color="#D8C8A0"/>
                <!-- Cardigan collar -->
                <rect x="11" y="20" w="1" h="3" color="#D8C8A0"/>
                <rect x="20" y="20" w="1" h="3" color="#D8C8A0"/>
                <!-- Arms/wrists (skin) -->
                <rect x="6" y="30" w="3" h="4" color="#F0C098"/>
                <hline x="6" y="33" len="3" color="#D8A078"/>
                <rect x="23" y="30" w="3" h="4" color="#F0C098"/>
                <hline x="23" y="33" len="3" color="#D8A078"/>
            </pixel-data>
        </layer>

        <!-- Necklace (z=3) -->
        <layer id="necklace" type="overlay" z-order="3" width="32" height="48">
            <pixel-data>
                <pixel x="14" y="18" color="#E0C040"/>
                <pixel x="15" y="19" color="#E0C040"/>
                <pixel x="16" y="20" color="#E0C040"/>
                <pixel x="17" y="19" color="#E0C040"/>
                <pixel x="18" y="18" color="#E0C040"/>
                <pixel x="16" y="21" color="#E0C040"/>
            </pixel-data>
        </layer>

        <!-- Head (z=4) -->
        <layer id="head" type="base" z-order="4" width="32" height="48">
            <pixel-data>
                <!-- Face -->
                <rect x="12" y="8" w="8" h="9" color="#F0C098"/>
                <rect x="12" y="12" w="1" h="3" color="#D8A078"/>
                <!-- Rosy cheeks -->
                <pixel x="13" y="13" color="#E89888"/>
                <pixel x="19" y="13" color="#E89888"/>
                <!-- Left eye -->
                <pixel x="14" y="11" color="#30A040"/>
                <pixel x="14" y="12" color="#30A040"/>
                <pixel x="13" y="11" color="#202020"/>
                <!-- Right eye -->
                <pixel x="18" y="11" color="#30A040"/>
                <pixel x="18" y="12" color="#30A040"/>
                <pixel x="19" y="11" color="#202020"/>
                <!-- Eyebrows -->
                <hline x="13" y="10" len="2" color="#801828"/>
                <hline x="18" y="10" len="2" color="#801828"/>
                <!-- Mouth -->
                <hline x="15" y="15" len="2" color="#D07070"/>
                <!-- Neck -->
                <rect x="14" y="17" w="4" h="2" color="#F0C098"/>
            </pixel-data>
        </layer>

        <!-- Hair (z=5, on top) -->
        <layer id="hair" type="overlay" z-order="5" width="32" height="48">
            <pixel-data>
                <!-- Top volume -->
                <rect x="11" y="5" w="10" h="4" color="#801828"/>
                <rect x="14" y="5" w="4" h="1" color="#A02838"/>
                <rect x="13" y="6" w="6" h="1" color="#A02838"/>
                <!-- Left side -->
                <rect x="10" y="7" w="2" h="10" color="#801828"/>
                <pixel x="9" y="9" color="#801828"/>
                <pixel x="9" y="11" color="#A02838"/>
                <pixel x="10" y="16" color="#A02838"/>
                <pixel x="9" y="14" color="#801828"/>
                <!-- Right side -->
                <rect x="20" y="7" w="2" h="10" color="#801828"/>
                <pixel x="22" y="9" color="#801828"/>
                <pixel x="22" y="11" color="#A02838"/>
                <pixel x="21" y="16" color="#A02838"/>
                <pixel x="22" y="14" color="#801828"/>
                <!-- Fringe -->
                <pixel x="12" y="8" color="#801828"/>
                <pixel x="13" y="7" color="#801828"/>
                <pixel x="19" y="8" color="#801828"/>
                <pixel x="20" y="7" color="#801828"/>
            </pixel-data>
        </layer>

        <!-- Phone in hand overlay (z=6, только при phone-talk) -->
        <layer id="phone-in-hand" type="overlay" z-order="6" width="32" height="48"
               condition="animation:phone-talk OR animation:browse-social">
            <pixel-data>
                <!-- Телефон у уха / перед лицом -->
                <rect x="24" y="12" w="3" h="5" color="#2A2A2A"/>
                <rect x="25" y="13" w="1" h="3" color="#4080C0"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <!-- === БАЗОВЫЕ === -->

        <animation name="idle" frames="6" fps="8" loop="true"
                   frame-width="32" frame-height="48">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets=""/>
            <frame index="2" layer-offsets="head:0,-1; hair:0,-1; necklace:0,-1; torso:0,-1"/>
            <frame index="3" layer-offsets="head:0,-1; hair:0,-1; necklace:0,-1; torso:0,-1"/>
            <frame index="4" layer-offsets=""/>
            <frame index="5" layer-offsets=""/>
        </animation>

        <animation name="walk" frames="8" fps="10" loop="true"
                   frame-width="32" frame-height="48">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="legs:0,0; slippers:1,0"/>
            <frame index="2" layer-offsets="torso:0,-1; head:0,-1; hair:0,-1; necklace:0,-1; legs:2,0; slippers:2,0"/>
            <frame index="3" layer-offsets="torso:0,-1; head:0,-1; hair:0,-1; necklace:0,-1; legs:1,0; slippers:1,0"/>
            <frame index="4" layer-offsets=""/>
            <frame index="5" layer-offsets="legs:0,0; slippers:-1,0"/>
            <frame index="6" layer-offsets="torso:0,-1; head:0,-1; hair:0,-1; necklace:0,-1; legs:-2,0; slippers:-2,0"/>
            <frame index="7" layer-offsets="torso:0,-1; head:0,-1; hair:0,-1; necklace:0,-1; legs:-1,0; slippers:-1,0"/>
        </animation>

        <!-- === РАБОТА ЗА КОМПЬЮТЕРОМ === -->

        <animation name="sit-work" frames="8" fps="4" loop="true"
                   frame-width="32" frame-height="48"
                   interact-with="furniture/computer">
            <description>
                Таня сидит за столом, работает на Tilda.
                Ноги согнуты (сидячая поза — ноги сдвинуты вверх и ближе друг к другу).
                Руки вытянуты к клавиатуре (торс немного наклонён вперёд).
                Голова покачивается — лёгкий наклон к экрану и обратно.
                Каждые 4 кадра — «дыхание» (торс +1px вверх).
            </description>
            <frame index="0" layer-offsets="legs:0,-6; slippers:3,-6; torso:0,-1; head:0,-1; hair:0,-1; necklace:0,-1"/>
            <frame index="1" layer-offsets="legs:0,-6; slippers:3,-6; torso:0,-1; head:1,-1; hair:1,-1; necklace:0,-1"/>
            <frame index="2" layer-offsets="legs:0,-6; slippers:3,-6; torso:0,-2; head:1,-2; hair:1,-2; necklace:0,-2"/>
            <frame index="3" layer-offsets="legs:0,-6; slippers:3,-6; torso:0,-2; head:0,-2; hair:0,-2; necklace:0,-2"/>
            <frame index="4" layer-offsets="legs:0,-6; slippers:3,-6; torso:0,-1; head:0,-1; hair:0,-1; necklace:0,-1"/>
            <frame index="5" layer-offsets="legs:0,-6; slippers:3,-6; torso:0,-1; head:-1,-1; hair:-1,-1; necklace:0,-1"/>
            <frame index="6" layer-offsets="legs:0,-6; slippers:3,-6; torso:0,-2; head:-1,-2; hair:-1,-2; necklace:0,-2"/>
            <frame index="7" layer-offsets="legs:0,-6; slippers:3,-6; torso:0,-1; head:0,-1; hair:0,-1; necklace:0,-1"/>
        </animation>

        <!-- === СОН === -->

        <animation name="sleep" frames="6" fps="2" loop="true"
                   frame-width="32" frame-height="48"
                   interact-with="furniture/bed">
            <description>
                Таня лежит в кровати. Спрайт повёрнут/трансформирован:
                персонаж горизонтально, ноги вправо, голова влево.
                Используется rotate="90" на уровне рендера.
                Анимация — лёгкое «дыхание»: торс и голова
                поднимаются на 1px каждые 3 кадра.
                Глаза закрыты (оверрайд head: рот и глаза
                заменяются на закрытые — линии вместо точек).
            </description>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="torso:0,-1; head:0,-1; hair:0,-1; necklace:0,-1"/>
            <frame index="2" layer-offsets="torso:0,-1; head:0,-1; hair:0,-1; necklace:0,-1"/>
            <frame index="3" layer-offsets=""/>
            <frame index="4" layer-offsets=""/>
            <frame index="5" layer-offsets="torso:0,-1; head:0,-1; hair:0,-1; necklace:0,-1"/>
            <head-override>
                <!-- Закрытые глаза: горизонтальные линии вместо точек -->
                <remove>
                    <pixel x="14" y="11"/><pixel x="14" y="12"/><pixel x="13" y="11"/>
                    <pixel x="18" y="11"/><pixel x="18" y="12"/><pixel x="19" y="11"/>
                </remove>
                <add>
                    <hline x="13" y="12" len="2" color="#202020"/>
                    <hline x="18" y="12" len="2" color="#202020"/>
                </add>
                <!-- Рот — спокойная линия -->
                <remove>
                    <hline x="15" y="15" len="2"/>
                </remove>
                <add>
                    <pixel x="15" y="15" color="#C08080"/>
                    <pixel x="16" y="15" color="#C08080"/>
                </add>
            </head-override>
            <render-transform rotate="90" anchor="center"/>
        </animation>

        <!-- === ТЕЛЕФОН: РАЗГОВОР === -->

        <animation name="phone-talk" frames="6" fps="4" loop="true"
                   frame-width="32" frame-height="48"
                   interact-with="furniture/phone">
            <description>
                Таня стоит/сидит с телефоном у уха (правая рука).
                Правая рука поднята к голове — overlay phone-in-hand активен.
                Голова слегка наклонена к телефону (+1px вправо).
                Лёгкое покачивание — имитация разговора.
                Рот анимирован (открыт/закрыт каждые 2 кадра).
            </description>
            <frame index="0" layer-offsets="head:1,0; hair:1,0; phone-in-hand:0,0"/>
            <frame index="1" layer-offsets="head:1,0; hair:1,0; phone-in-hand:0,0"/>
            <frame index="2" layer-offsets="head:1,-1; hair:1,-1; phone-in-hand:0,-1; torso:0,-1; necklace:0,-1"/>
            <frame index="3" layer-offsets="head:1,-1; hair:1,-1; phone-in-hand:0,-1; torso:0,-1; necklace:0,-1"/>
            <frame index="4" layer-offsets="head:1,0; hair:1,0; phone-in-hand:0,0"/>
            <frame index="5" layer-offsets="head:1,0; hair:1,0; phone-in-hand:0,0"/>
            <mouth-override>
                <!-- Кадры 0,2,4: рот открыт (разговор) -->
                <frame-set indices="0,2,4">
                    <remove><hline x="15" y="15" len="2"/></remove>
                    <add>
                        <rect x="15" y="15" w="2" h="2" color="#D07070"/>
                        <pixel x="15" y="16" color="#A05050"/>
                        <pixel x="16" y="16" color="#A05050"/>
                    </add>
                </frame-set>
                <!-- Кадры 1,3,5: рот закрыт (стандарт) -->
            </mouth-override>
        </animation>

        <!-- === ТЕЛЕФОН: ЛИСТАТЬ СОЦСЕТИ === -->

        <animation name="browse-social" frames="6" fps="3" loop="true"
                   frame-width="32" frame-height="48"
                   interact-with="furniture/phone">
            <description>
                Таня стоит/сидит, телефон перед лицом (обе руки).
                Overlay phone-in-hand активен, но позиция ниже (перед грудью).
                Голова слегка наклонена вниз к экрану.
                Большой палец «скроллит» — лёгкий сдвиг phone-in-hand
                по Y на 1px каждые 2 кадра.
                Периодически — лёгкая улыбка (каждые 3 кадра).
            </description>
            <frame index="0" layer-offsets="head:0,1; hair:0,1; phone-in-hand:0,6"/>
            <frame index="1" layer-offsets="head:0,1; hair:0,1; phone-in-hand:0,5"/>
            <frame index="2" layer-offsets="head:0,1; hair:0,1; phone-in-hand:0,6"/>
            <frame index="3" layer-offsets="head:0,1; hair:0,1; phone-in-hand:0,5"/>
            <frame index="4" layer-offsets="head:0,0; hair:0,0; phone-in-hand:0,6"/>
            <frame index="5" layer-offsets="head:0,1; hair:0,1; phone-in-hand:0,6"/>
        </animation>
    </animations>

    <naming>
        <output-dir>characters/tanya</output-dir>
    </naming>
</asset-spec>
