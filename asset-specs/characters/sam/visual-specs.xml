<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>sam</entity-name>
        <version>1.0.0</version>
    </meta>

    <layers>
        <!-- Shoes (z=0) -->
        <layer id="shoes" type="base" z-order="0" width="32" height="48">
            <pixel-data>
                <rect x="9" y="46" w="5" h="2" color="#2C2C2C"/>
                <rect x="18" y="46" w="5" h="2" color="#2C2C2C"/>
                <pixel x="9" y="47" color="#1A1A1A"/>
                <pixel x="22" y="47" color="#1A1A1A"/>
            </pixel-data>
        </layer>

        <!-- Legs / dark jeans (z=1) -->
        <layer id="legs" type="base" z-order="1" width="32" height="48">
            <pixel-data>
                <rect x="10" y="32" w="4" h="14" color="#3A4A5C"/>
                <rect x="10" y="32" w="1" h="14" color="#2E3E4E"/>
                <rect x="18" y="32" w="4" h="14" color="#3A4A5C"/>
                <rect x="21" y="32" w="1" h="14" color="#2E3E4E"/>
                <hline x="10" y="32" len="12" color="#2E3E4E"/>
            </pixel-data>
        </layer>

        <!-- Torso: dark gray T-shirt (z=2) -->
        <layer id="torso" type="base" z-order="2" width="32" height="48">
            <pixel-data>
                <rect x="9" y="20" w="14" h="12" color="#4A5859"/>
                <rect x="9" y="20" w="1" h="12" color="#3A4849"/>
                <rect x="22" y="20" w="1" h="12" color="#3A4849"/>
                <!-- Shoulders -->
                <rect x="6" y="20" w="4" h="3" color="#4A5859"/>
                <rect x="22" y="20" w="4" h="3" color="#4A5859"/>
                <!-- Arms -->
                <rect x="6" y="23" w="3" h="8" color="#E8C090"/>
                <hline x="6" y="30" len="3" color="#D0A870"/>
                <rect x="23" y="23" w="3" h="8" color="#E8C090"/>
                <hline x="23" y="30" len="3" color="#D0A870"/>
            </pixel-data>
        </layer>

        <!-- Head (z=3) -->
        <layer id="head" type="base" z-order="3" width="32" height="48">
            <pixel-data>
                <rect x="12" y="8" w="8" h="9" color="#E8C090"/>
                <rect x="12" y="12" w="1" h="3" color="#D0A870"/>
                <!-- Eyes (brown) -->
                <pixel x="14" y="11" color="#6B4423"/>
                <pixel x="14" y="12" color="#6B4423"/>
                <pixel x="13" y="11" color="#202020"/>
                <pixel x="18" y="11" color="#6B4423"/>
                <pixel x="18" y="12" color="#6B4423"/>
                <pixel x="19" y="11" color="#202020"/>
                <!-- Eyebrows -->
                <hline x="13" y="10" len="2" color="#3A2A1A"/>
                <hline x="18" y="10" len="2" color="#3A2A1A"/>
                <!-- Mouth -->
                <hline x="15" y="15" len="2" color="#C08070"/>
                <!-- Neck -->
                <rect x="14" y="17" w="4" h="2" color="#E8C090"/>
            </pixel-data>
        </layer>

        <!-- Hair: short dark brown (z=4) -->
        <layer id="hair" type="overlay" z-order="4" width="32" height="48">
            <pixel-data>
                <rect x="11" y="5" w="10" h="4" color="#3A2A1A"/>
                <rect x="14" y="5" w="4" h="1" color="#4A3A2A"/>
                <rect x="11" y="7" w="1" h="3" color="#3A2A1A"/>
                <rect x="20" y="7" w="1" h="3" color="#3A2A1A"/>
                <pixel x="12" y="8" color="#3A2A1A"/>
                <pixel x="19" y="8" color="#3A2A1A"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <animation name="idle" frames="4" fps="6" loop="true"
                   frame-width="32" frame-height="48">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="head:0,-1; hair:0,-1; torso:0,-1"/>
            <frame index="2" layer-offsets=""/>
            <frame index="3" layer-offsets="head:0,-1; hair:0,-1; torso:0,-1"/>
        </animation>
    </animations>

    <naming>
        <output-dir>characters/sam</output-dir>
    </naming>
</asset-spec>
