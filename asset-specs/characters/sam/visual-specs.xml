<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>sam</entity-name>
        <version>2.1.0</version>
    </meta>
    <!-- Sam: Miniature Pinscher (Zwergpinscher), ~1 year old.
         Canvas: 24x20. Black body (#0A0A0A), tan markings (#CC6633).
         Tiny but proud; scared of Alexander; devoted to Tanya. -->
    <layers>
        <!-- z=0: paws -->
        <layer id="paws" type="base" z-order="0" width="24" height="20">
            <pixel-data>
                <rect x="3" y="16" w="2" h="2" color="#0A0A0A"/>
                <hline x="3" y="17" len="2" color="#CC6633"/>
                <rect x="8" y="16" w="2" h="2" color="#0A0A0A"/>
                <hline x="8" y="17" len="2" color="#CC6633"/>
                <rect x="14" y="16" w="2" h="2" color="#0A0A0A"/>
                <hline x="14" y="17" len="2" color="#CC6633"/>
                <rect x="19" y="16" w="2" h="2" color="#0A0A0A"/>
                <hline x="19" y="17" len="2" color="#CC6633"/>
                <pixel x="4" y="17" color="#553322"/>
                <pixel x="9" y="17" color="#553322"/>
                <pixel x="15" y="17" color="#553322"/>
                <pixel x="20" y="17" color="#553322"/>
            </pixel-data>
        </layer>
        <!-- z=1: legs -->
        <layer id="legs" type="base" z-order="1" width="24" height="20">
            <pixel-data>
                <rect x="3" y="10" w="2" h="6" color="#0A0A0A"/>
                <rect x="8" y="10" w="2" h="6" color="#0A0A0A"/>
                <rect x="14" y="10" w="2" h="6" color="#0A0A0A"/>
                <rect x="19" y="10" w="2" h="6" color="#0A0A0A"/>
                <hline x="3" y="10" len="2" color="#1A1A1A"/>
                <hline x="8" y="10" len="2" color="#1A1A1A"/>
                <hline x="14" y="10" len="2" color="#1A1A1A"/>
                <hline x="19" y="10" len="2" color="#1A1A1A"/>
            </pixel-data>
        </layer>
        <!-- z=2: body -->
        <layer id="body" type="base" z-order="2" width="24" height="20">
            <pixel-data>
                <rect x="3" y="7" w="15" h="5" color="#0A0A0A"/>
                <hline x="4" y="7" len="13" color="#1A1A1A"/>
                <hline x="5" y="8" len="11" color="#111111"/>
                <hline x="5" y="11" len="11" color="#080808"/>
                <pixel x="3" y="8" color="#151515"/>
                <pixel x="17" y="8" color="#151515"/>
            </pixel-data>
        </layer>
        <!-- z=3: chest_markings -->
        <layer id="chest_markings" type="overlay" z-order="3" width="24" height="20">
            <pixel-data>
                <rect x="4" y="9" w="5" h="3" color="#CC6633"/>
                <hline x="5" y="9" len="3" color="#DD8844"/>
                <pixel x="14" y="10" color="#CC6633"/>
                <pixel x="15" y="10" color="#CC6633"/>
                <pixel x="14" y="11" color="#CC6633"/>
            </pixel-data>
        </layer>
        <!-- z=4: tail -->
        <layer id="tail" type="base" z-order="4" width="24" height="20">
            <pixel-data>
                <pixel x="18" y="9" color="#0A0A0A"/>
                <pixel x="19" y="8" color="#0A0A0A"/>
                <pixel x="20" y="7" color="#0A0A0A"/>
                <pixel x="20" y="6" color="#1A1A1A"/>
                <pixel x="21" y="6" color="#1A1A1A"/>
                <pixel x="21" y="5" color="#0A0A0A"/>
                <pixel x="19" y="9" color="#1A1A1A"/>
            </pixel-data>
        </layer>
        <!-- z=5: head -->
        <layer id="head" type="base" z-order="5" width="24" height="20">
            <pixel-data>
                <rect x="1" y="2" w="9" h="7" color="#0A0A0A"/>
                <rect x="1" y="5" w="5" h="4" color="#0A0A0A"/>
                <hline x="2" y="2" len="7" color="#1A1A1A"/>
                <rect x="1" y="6" w="5" h="3" color="#CC6633"/>
                <pixel x="1" y="4" color="#0A0A0A"/>
                <pixel x="9" y="4" color="#0A0A0A"/>
            </pixel-data>
        </layer>
        <!-- z=6: ears -->
        <layer id="ears" type="base" z-order="6" width="24" height="20">
            <pixel-data>
                <pixel x="1" y="1" color="#0A0A0A"/>
                <pixel x="2" y="0" color="#0A0A0A"/>
                <pixel x="3" y="1" color="#0A0A0A"/>
                <pixel x="2" y="1" color="#CC6633"/>
                <pixel x="7" y="1" color="#0A0A0A"/>
                <pixel x="8" y="0" color="#0A0A0A"/>
                <pixel x="9" y="1" color="#0A0A0A"/>
                <pixel x="8" y="1" color="#CC6633"/>
            </pixel-data>
        </layer>
        <!-- z=7: face_details -->
        <layer id="face_details" type="overlay" z-order="7" width="24" height="20">
            <pixel-data>
                <pixel x="3" y="3" color="#553311"/>
                <pixel x="4" y="2" color="#7A4422"/>
                <pixel x="5" y="2" color="#7A4422"/>
                <pixel x="4" y="3" color="#7A4422"/>
                <pixel x="5" y="3" color="#111111"/>
                <pixel x="6" y="3" color="#553311"/>
                <pixel x="7" y="2" color="#7A4422"/>
                <pixel x="8" y="2" color="#7A4422"/>
                <pixel x="7" y="3" color="#7A4422"/>
                <pixel x="8" y="3" color="#111111"/>
                <pixel x="4" y="2" color="#FFFFFF"/>
                <pixel x="7" y="2" color="#FFFFFF"/>
                <pixel x="4" y="1" color="#CC6633"/>
                <pixel x="7" y="1" color="#CC6633"/>
                <pixel x="2" y="5" color="#111111"/>
                <pixel x="3" y="5" color="#111111"/>
                <pixel x="3" y="6" color="#0A0A0A"/>
                <hline x="2" y="8" len="3" color="#884422"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <!-- === БАЗОВЫЕ === -->

        <animation name="idle_morning" frames="4" fps="4" loop="true" frame-width="24" frame-height="20">
            <condition type="time_of_day" value="morning"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="head:-1,0; ears:-1,0; face_details:-1,0"/>
            <frame index="2" layer-offsets="head:1,0; ears:1,0; face_details:1,0"/>
            <frame index="3" layer-offsets="tail:0,-1"/>
        </animation>

        <animation name="idle_day" frames="4" fps="4" loop="true" frame-width="24" frame-height="20">
            <condition type="time_of_day" value="day"/>
            <frame index="0" layer-offsets="tail:0,-1"/>
            <frame index="1" layer-offsets="head:0,-1; ears:0,-1; face_details:0,-1; tail:0,-2"/>
            <frame index="2" layer-offsets="tail:-1,-1"/>
            <frame index="3" layer-offsets="tail:1,-1"/>
        </animation>

        <animation name="idle_evening" frames="4" fps="3" loop="true" frame-width="24" frame-height="20">
            <condition type="time_of_day" value="evening"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="tail:0,1"/>
            <frame index="2" layer-offsets="head:0,1; face_details:0,1"/>
            <frame index="3" layer-offsets="tail:1,0"/>
        </animation>

        <animation name="idle_night" frames="4" fps="2" loop="true" frame-width="24" frame-height="20">
            <condition type="time_of_day" value="night"/>
            <frame index="0" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-1,2"/>
            <frame index="1" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-1,2"/>
            <frame index="2" layer-offsets="head:0,2; ears:0,2; face_details:0,2; body:0,1; chest_markings:0,1; tail:-1,2"/>
            <frame index="3" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-1,2"/>
        </animation>

        <animation name="walk" frames="6" fps="8" loop="true" frame-width="24" frame-height="20">
            <frame index="0" layer-offsets="tail:0,-1"/>
            <frame index="1" layer-offsets="paws:-2,-2; legs:-1,-1; tail:0,-1"/>
            <frame index="2" layer-offsets="body:-1,0; chest_markings:-1,0; tail:0,-1"/>
            <frame index="3" layer-offsets="paws:2,-2; legs:1,-1; tail:0,-1"/>
            <frame index="4" layer-offsets="body:1,0; chest_markings:1,0; tail:0,-1"/>
            <frame index="5" layer-offsets="tail:0,-1"/>
        </animation>

        <animation name="tremble" frames="6" fps="10" loop="true" frame-width="24" frame-height="20">
            <condition type="trigger" value="alexander_nearby"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="head:1,0; ears:1,0; face_details:1,0; body:1,0; chest_markings:1,0; legs:1,0; paws:1,0"/>
            <frame index="2" layer-offsets="head:-1,0; ears:-1,0; face_details:-1,0; body:-1,0; chest_markings:-1,0; legs:-1,0; paws:-1,0"/>
            <frame index="3" layer-offsets="head:1,0; ears:1,0; face_details:1,0; body:1,0; chest_markings:1,0; legs:1,0; paws:1,0"/>
            <frame index="4" layer-offsets="head:-1,0; ears:-1,0; face_details:-1,0; body:-1,0; chest_markings:-1,0; legs:-1,0; paws:-1,0"/>
            <frame index="5" layer-offsets="head:-3,0; ears:-3,0; face_details:-3,0"/>
        </animation>

        <!-- === ЕДА ИЗ МИСКИ === -->

        <animation name="eat" frames="8" fps="6" loop="true"
                   frame-width="24" frame-height="20"
                   interact-with="furniture/pet_bowl">
            <description>
                Сэм энергично ест из миски — быстрее Гарфилда (6 FPS).
                Голова ныряет вниз к миске, хвост бешено виляет
                (±2px по X каждый кадр). Весь корпус слегка
                покачивается от энтузиазма.
            </description>
            <frame index="0" layer-offsets="head:0,3; ears:0,3; face_details:0,3; tail:2,-1"/>
            <frame index="1" layer-offsets="head:-1,4; ears:-1,4; face_details:-1,4; tail:-2,-1; body:0,0"/>
            <frame index="2" layer-offsets="head:1,4; ears:1,4; face_details:1,4; tail:2,-2; body:1,0; chest_markings:1,0"/>
            <frame index="3" layer-offsets="head:0,3; ears:0,3; face_details:0,3; tail:-2,-1; body:-1,0; chest_markings:-1,0"/>
            <frame index="4" layer-offsets="head:-1,4; ears:-1,4; face_details:-1,4; tail:2,-2"/>
            <frame index="5" layer-offsets="head:1,4; ears:1,4; face_details:1,4; tail:-2,-1; body:1,0; chest_markings:1,0"/>
            <frame index="6" layer-offsets="head:0,3; ears:0,3; face_details:0,3; tail:2,-1; body:0,0"/>
            <frame index="7" layer-offsets="head:0,3; ears:0,3; face_details:0,3; tail:-1,-1"/>
        </animation>

        <!-- === ПРИЖАТЬСЯ К ТАНЕ === -->

        <animation name="cuddle-tanya" frames="6" fps="3" loop="true"
                   frame-width="24" frame-height="20">
            <description>
                Сэм прижимается к ногам Тани.
                Голова поднята вверх (смотрит на Таню),
                хвост виляет медленно, тело
                слегка покачивается. Спокойный и счастливый.
            </description>
            <frame index="0" layer-offsets="head:0,-1; ears:0,-1; face_details:0,-1; tail:1,-1"/>
            <frame index="1" layer-offsets="head:0,-2; ears:0,-2; face_details:0,-2; tail:-1,-1"/>
            <frame index="2" layer-offsets="head:0,-1; ears:0,-1; face_details:0,-1; tail:1,-2"/>
            <frame index="3" layer-offsets="head:0,-2; ears:0,-2; face_details:0,-2; tail:-1,-2"/>
            <frame index="4" layer-offsets="head:0,-1; ears:0,-1; face_details:0,-1; tail:1,-1"/>
            <frame index="5" layer-offsets="head:0,-1; ears:0,-1; face_details:0,-1; tail:0,-1"/>
        </animation>

        <!-- === СЛЕДОВАТЬ ЗА ТАНЕЙ (hackney gait, быстрее walk) === -->

        <animation name="follow-tanya" frames="6" fps="12" loop="true"
                   frame-width="24" frame-height="20">
            <description>
                Сэм семенит за Таней — ускоренный hackney gait (12 FPS).
                Хвост поднят максимально высоко.
                Уши напряжены вперёд. Энергичная побежка.
            </description>
            <frame index="0" layer-offsets="tail:0,-2; ears:0,-1"/>
            <frame index="1" layer-offsets="paws:-2,-3; legs:-1,-2; tail:1,-2; ears:0,-1"/>
            <frame index="2" layer-offsets="body:-1,-1; chest_markings:-1,-1; tail:0,-2; ears:0,-1"/>
            <frame index="3" layer-offsets="paws:2,-3; legs:1,-2; tail:-1,-2; ears:0,-1"/>
            <frame index="4" layer-offsets="body:1,-1; chest_markings:1,-1; tail:0,-2; ears:0,-1"/>
            <frame index="5" layer-offsets="tail:0,-2; ears:0,-1"/>
        </animation>
    </animations>

    <naming>
        <output-dir>characters/sam</output-dir>
    </naming>
</asset-spec>
