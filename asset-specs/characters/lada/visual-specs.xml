<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>lada</entity-name>
        <version>1.0.0</version>
    </meta>
    <!-- Lada: black and white cat, mostly black like Batman. ~2 years old.
         Canvas: 20x16. Color: body #111111 (near-black), white patches #F0F0F0
         on chest and paws only. Rescued twice; formerly timid, now chubby friend of Klop. -->
    <layers>
        <!-- z=0: paws — white front paws (gloves), black rear paws -->
        <layer id="paws" type="base" z-order="0" width="20" height="16">
            <pixel-data>
                <!-- front left paw: white (Batman gloves) -->
                <rect x="3" y="13" w="2" h="2" color="#F0F0F0"/>
                <hline x="3" y="14" len="2" color="#CCCCCC"/>
                <!-- front right paw: white -->
                <rect x="7" y="13" w="2" h="2" color="#F0F0F0"/>
                <hline x="7" y="14" len="2" color="#CCCCCC"/>
                <!-- rear left paw: black -->
                <rect x="11" y="13" w="2" h="2" color="#111111"/>
                <hline x="11" y="14" len="2" color="#222222"/>
                <!-- rear right paw: black -->
                <rect x="15" y="13" w="2" h="2" color="#111111"/>
                <hline x="15" y="14" len="2" color="#222222"/>
                <!-- paw pads -->
                <pixel x="4" y="14" color="#DDBBDD"/>
                <pixel x="8" y="14" color="#DDBBDD"/>
                <pixel x="12" y="14" color="#443344"/>
                <pixel x="16" y="14" color="#443344"/>
            </pixel-data>
        </layer>
        <!-- z=1: legs — front legs black, slight white trim at bottom -->
        <layer id="legs" type="base" z-order="1" width="20" height="16">
            <pixel-data>
                <!-- front left -->
                <rect x="3" y="9" w="2" h="4" color="#111111"/>
                <hline x="3" y="12" len="2" color="#F0F0F0"/>
                <!-- front right -->
                <rect x="7" y="9" w="2" h="4" color="#111111"/>
                <hline x="7" y="12" len="2" color="#F0F0F0"/>
                <!-- rear left: all black -->
                <rect x="11" y="9" w="2" h="4" color="#111111"/>
                <!-- rear right: all black -->
                <rect x="15" y="9" w="2" h="4" color="#111111"/>
            </pixel-data>
        </layer>
        <!-- z=2: body/torso — predominantly black, plump (Klop influence) -->
        <layer id="body" type="base" z-order="2" width="20" height="16">
            <pixel-data>
                <rect x="3" y="6" w="12" h="5" color="#111111"/>
                <!-- subtle sheen on black coat (not fully flat black) -->
                <hline x="4" y="6" len="10" color="#222222"/>
                <hline x="5" y="7" len="8" color="#1A1A2E"/>
                <!-- underside matte -->
                <hline x="4" y="10" len="10" color="#0D0D0D"/>
            </pixel-data>
        </layer>
        <!-- z=3: belly_pattern — white chest bib, small white chin patch -->
        <layer id="belly_pattern" type="overlay" z-order="3" width="20" height="16">
            <pixel-data>
                <!-- white chest bib: narrow, like Batman's chest symbol -->
                <rect x="7" y="8" w="4" h="3" color="#F0F0F0"/>
                <!-- bib top narrower -->
                <hline x="8" y="8" len="2" color="#FFFFFF"/>
                <!-- chin white patch (small) -->
                <hline x="5" y="7" len="3" color="#EEEEEE"/>
            </pixel-data>
        </layer>
        <!-- z=4: tail — all black, long tail -->
        <layer id="tail" type="base" z-order="4" width="20" height="16">
            <pixel-data>
                <pixel x="15" y="9" color="#111111"/>
                <pixel x="16" y="8" color="#111111"/>
                <pixel x="17" y="7" color="#111111"/>
                <pixel x="18" y="6" color="#111111"/>
                <pixel x="18" y="5" color="#111111"/>
                <pixel x="17" y="4" color="#1A1A2E"/>
                <pixel x="18" y="4" color="#1A1A2E"/>
                <pixel x="19" y="5" color="#111111"/>
                <!-- tail tip white dot (tiny) -->
                <pixel x="19" y="4" color="#AAAAAA"/>
            </pixel-data>
        </layer>
        <!-- z=5: head — mostly black head, white chin triangle -->
        <layer id="head" type="base" z-order="5" width="20" height="16">
            <pixel-data>
                <!-- main head: black -->
                <rect x="2" y="2" w="8" h="6" color="#111111"/>
                <!-- subtle head sheen -->
                <hline x="3" y="2" len="6" color="#1A1A2E"/>
                <!-- white chin triangle (like Batman mask) -->
                <rect x="4" y="6" w="4" h="2" color="#F0F0F0"/>
                <!-- cheeks black -->
                <pixel x="2" y="5" color="#0D0D0D"/>
                <pixel x="9" y="5" color="#0D0D0D"/>
            </pixel-data>
        </layer>
        <!-- z=6: ears — pointed black ears, very Batman-like -->
        <layer id="ears" type="base" z-order="6" width="20" height="16">
            <pixel-data>
                <!-- left ear: sharp black point -->
                <pixel x="2" y="1" color="#111111"/>
                <pixel x="3" y="0" color="#111111"/>
                <pixel x="3" y="1" color="#111111"/>
                <!-- left inner dark pink -->
                <pixel x="3" y="1" color="#330022"/>
                <!-- right ear: sharp black point -->
                <pixel x="8" y="1" color="#111111"/>
                <pixel x="7" y="0" color="#111111"/>
                <pixel x="7" y="1" color="#111111"/>
                <!-- right inner -->
                <pixel x="7" y="1" color="#330022"/>
            </pixel-data>
        </layer>
        <!-- z=7: face_details — yellow-green eyes (bright contrast on black), tiny nose -->
        <layer id="face_details" type="overlay" z-order="7" width="20" height="16">
            <pixel-data>
                <!-- left eye: bright yellow-green (striking on black face) -->
                <pixel x="4" y="4" color="#8BC34A"/>
                <pixel x="5" y="3" color="#AEEA00"/>
                <pixel x="5" y="4" color="#AEEA00"/>
                <pixel x="4" y="3" color="#8BC34A"/>
                <pixel x="5" y="4" color="#111111"/>
                <!-- right eye -->
                <pixel x="7" y="4" color="#8BC34A"/>
                <pixel x="8" y="3" color="#AEEA00"/>
                <pixel x="8" y="4" color="#AEEA00"/>
                <pixel x="7" y="3" color="#8BC34A"/>
                <pixel x="8" y="4" color="#111111"/>
                <!-- eye shine -->
                <pixel x="4" y="3" color="#FFFFFF"/>
                <pixel x="7" y="3" color="#FFFFFF"/>
                <!-- nose: tiny pink-red -->
                <pixel x="5" y="5" color="#FF6688"/>
                <pixel x="6" y="5" color="#FF6688"/>
                <pixel x="6" y="6" color="#CC4466"/>
                <!-- mouth cautious, small -->
                <pixel x="5" y="6" color="#330022"/>
                <pixel x="7" y="6" color="#330022"/>
                <!-- whiskers white on black: very visible -->
                <hline x="0" y="5" len="3" color="#FFFFFF"/>
                <hline x="0" y="6" len="2" color="#FFFFFF"/>
                <hline x="9" y="5" len="3" color="#FFFFFF"/>
                <hline x="9" y="6" len="2" color="#FFFFFF"/>
            </pixel-data>
        </layer>
    </layers>
    <animations>
        <!-- idle_morning: cautious waking, checks environment first -->
        <animation name="idle_morning" frames="4" fps="3" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="morning"/>
            <frame index="0" layer-offsets=""/>
            <!-- slow look left -->
            <frame index="1" layer-offsets="head:-1,0; ears:-1,0; face_details:-1,0"/>
            <!-- slow look right -->
            <frame index="2" layer-offsets="head:1,0; ears:1,0; face_details:1,0"/>
            <!-- settle, relaxed now -->
            <frame index="3" layer-offsets=""/>
        </animation>
        <!-- idle_day: alert and curious, more confident now -->
        <animation name="idle_day" frames="4" fps="4" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="day"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="head:0,-1; ears:0,-1; face_details:0,-1"/>
            <frame index="2" layer-offsets=""/>
            <frame index="3" layer-offsets="tail:1,0"/>
        </animation>
        <!-- idle_evening: relaxed snuggling with Klop -->
        <animation name="idle_evening" frames="4" fps="3" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="evening"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="tail:0,1; body:0,1; belly_pattern:0,1"/>
            <frame index="2" layer-offsets="head:0,1; face_details:0,1; body:0,1; belly_pattern:0,1"/>
            <frame index="3" layer-offsets="body:0,1; belly_pattern:0,1"/>
        </animation>
        <!-- idle_night: sleeping flat, all layers settling -->
        <animation name="idle_night" frames="4" fps="2" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="night"/>
            <frame index="0" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-2,1"/>
            <frame index="1" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-2,1"/>
            <frame index="2" layer-offsets="head:0,2; ears:0,2; face_details:0,2; body:0,1; belly_pattern:0,1; tail:-2,1"/>
            <frame index="3" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-2,1"/>
        </animation>
        <!-- walk: careful steps, slightly hunched (trauma residue) -->
        <animation name="walk" frames="6" fps="6" loop="true" frame-width="20" frame-height="16">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="paws:-1,-1; legs:-1,0"/>
            <frame index="2" layer-offsets="body:-1,0; belly_pattern:-1,0"/>
            <frame index="3" layer-offsets="paws:1,-1; legs:1,0"/>
            <frame index="4" layer-offsets="tail:0,-1; body:1,0; belly_pattern:1,0"/>
            <frame index="5" layer-offsets=""/>
        </animation>
        <!-- hide: unique — crouching low, scared pose, shrinking into shadow -->
        <animation name="hide" frames="6" fps="6" loop="false" frame-width="20" frame-height="16">
            <condition type="trigger" value="loud_noise"/>
            <!-- frame 0: hears something, freeze -->
            <frame index="0" layer-offsets="ears:0,-1; face_details:0,-1"/>
            <!-- frame 1: crouching down -->
            <frame index="1" layer-offsets="body:0,2; belly_pattern:0,2; legs:0,1; paws:0,1; head:0,1; ears:0,0; face_details:0,1"/>
            <!-- frame 2: fully crouched, flat to ground -->
            <frame index="2" layer-offsets="body:0,3; belly_pattern:0,3; legs:0,2; paws:0,2; head:0,2; ears:0,1; face_details:0,2; tail:0,2"/>
            <!-- frame 3: hold crouch, wide eyes -->
            <frame index="3" layer-offsets="body:0,3; belly_pattern:0,3; legs:0,2; paws:0,2; head:0,2; ears:0,1; face_details:0,2; tail:0,2"/>
            <!-- frame 4: peek slightly -->
            <frame index="4" layer-offsets="body:0,2; belly_pattern:0,2; legs:0,1; paws:0,1; head:0,1; face_details:0,1; tail:0,1"/>
            <!-- frame 5: cautiously return to normal -->
            <frame index="5" layer-offsets=""/>
        </animation>
    </animations>
    <naming>
        <output-dir>characters/lada</output-dir>
    </naming>
</asset-spec>