            <!-- f8: both paws settle, big exhale -->
            <frame index="8" layer-offsets="body:0,2; belly:0,2; front_legs:0,2; hind_legs:0,2; paws:0,2; head:0,2; neck:0,1; face_details:0,1; ears:0,1; tail:2,1"/>
            <!-- f9: inhale, slight body lift -->
