            <frame index="2" layer-offsets="head:0,3; neck:0,2; ears:0,1; face_details:0,3; body:0,1; belly:0,1; front_legs:0,1; paws:0,1; tail:2,-1"/>
            <!-- f3: head lifts, chewing vigorously -->
