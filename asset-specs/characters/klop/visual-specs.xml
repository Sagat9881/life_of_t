<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>klop</entity-name>
        <version>2.0.0</version>
    </meta>
    <!-- Klop: Russian Blue-type cat, chubby, smoky blue-grey fur.
         Canvas: 32x24. 10 layers. 12 animations.
         Named "Klop" because as a kitten he crawled on Tanya's face like a bug.
         Most peaceful creature in the universe — social worker, integrates Lada.
         Palette:
           #6B7B8D — base blue-grey coat
           #8899AA — lighter coat / top surface
           #4A5B6D — shadow coat / underside
           #3A4A5A — deepest shadow
           #AABBC8 — highlight / silver sheen
           #C8D4DC — bright highlight top
           #556677 — smoky undercoat
           #9BABB8 — belly lighter
           #CCAACC — pink-grey paw pads / ear inner
           #FFBBDD — nose pink
           #44BB44 — green eyes (Russian blue hallmark)
           #228B22 — dark green eye iris
           #FFFFFF — eye shine
           #111111 — pupil
         Character: fat but agile, loves ALL touch, purrs constantly, belly-up by default. -->
    <layers>
        <!-- z=0: paws — four chubby wide paws, pink-grey pads, silver toe tips -->
        <layer id="paws" type="base" z-order="0" width="32" height="24">
            <pixel-data>
                <!-- front-left paw: chubby 3px wide -->
                <rect x="5" y="19" w="3" h="2" color="#6B7B8D"/>
                <hline x="5" y="19" len="3" color="#8899AA"/>
                <hline x="5" y="20" len="3" color="#4A5B6D"/>
                <!-- paw pad center -->
                <pixel x="6" y="20" color="#CCAACC"/>
                <!-- front-right paw -->
                <rect x="11" y="19" w="3" h="2" color="#6B7B8D"/>
                <hline x="11" y="19" len="3" color="#8899AA"/>
                <hline x="11" y="20" len="3" color="#4A5B6D"/>
                <pixel x="12" y="20" color="#CCAACC"/>
                <!-- hind-left paw: slightly larger (chubby hind quarters) -->
                <rect x="19" y="19" w="3" h="2" color="#6B7B8D"/>
                <hline x="19" y="19" len="3" color="#8899AA"/>
                <hline x="19" y="20" len="3" color="#4A5B6D"/>
                <pixel x="20" y="20" color="#CCAACC"/>
                <!-- hind-right paw -->
                <rect x="25" y="19" w="3" h="2" color="#6B7B8D"/>
                <hline x="25" y="19" len="3" color="#8899AA"/>
                <hline x="25" y="20" len="3" color="#4A5B6D"/>
                <pixel x="26" y="20" color="#CCAACC"/>
                <!-- toe detail highlights -->
                <pixel x="5" y="19" color="#AABBC8"/>
                <pixel x="11" y="19" color="#AABBC8"/>
                <pixel x="19" y="19" color="#AABBC8"/>
                <pixel x="25" y="19" color="#AABBC8"/>
            </pixel-data>
        </layer>

        <!-- z=1: hind_legs — short thick rear legs, big thighs, smoky undercoat at joints -->
        <layer id="hind_legs" type="base" z-order="1" width="32" height="24">
            <pixel-data>
                <!-- hind-left thigh: fat 3px wide, short -->
                <rect x="19" y="13" w="3" h="6" color="#6B7B8D"/>
                <hline x="19" y="13" len="3" color="#8899AA"/>
                <!-- smoky shadow at rear haunch -->
                <pixel x="19" y="14" color="#556677"/>
                <pixel x="19" y="15" color="#4A5B6D"/>
                <!-- side fat roll shading -->
                <pixel x="21" y="14" color="#4A5B6D"/>
                <pixel x="21" y="15" color="#4A5B6D"/>
                <!-- hind-right thigh -->
                <rect x="25" y="13" w="3" h="6" color="#6B7B8D"/>
                <hline x="25" y="13" len="3" color="#8899AA"/>
                <pixel x="25" y="14" color="#556677"/>
                <pixel x="25" y="15" color="#4A5B6D"/>
                <pixel x="27" y="14" color="#4A5B6D"/>
                <pixel x="27" y="15" color="#4A5B6D"/>
                <!-- inner leg smoky undercoat band -->
                <hline x="20" y="17" len="2" color="#556677"/>
                <hline x="26" y="17" len="2" color="#556677"/>
            </pixel-data>
        </layer>

        <!-- z=2: front_legs — stubby fat forelegs, silver sheen on top -->
        <layer id="front_legs" type="base" z-order="2" width="32" height="24">
            <pixel-data>
                <!-- front-left leg: 3px wide, short and stout -->
                <rect x="5" y="13" w="3" h="6" color="#6B7B8D"/>
                <hline x="5" y="13" len="3" color="#8899AA"/>
                <!-- silver top sheen on leg -->
                <pixel x="6" y="13" color="#AABBC8"/>
                <!-- shadow inner side -->
                <pixel x="5" y="14" color="#4A5B6D"/>
                <pixel x="5" y="15" color="#556677"/>
                <!-- front-right leg -->
                <rect x="11" y="13" w="3" h="6" color="#6B7B8D"/>
                <hline x="11" y="13" len="3" color="#8899AA"/>
                <pixel x="12" y="13" color="#AABBC8"/>
                <pixel x="13" y="14" color="#4A5B6D"/>
                <pixel x="13" y="15" color="#556677"/>
                <!-- smoky undercoat at leg-body junction -->
                <hline x="6" y="14" len="2" color="#556677"/>
                <hline x="12" y="14" len="2" color="#556677"/>
            </pixel-data>
        </layer>

        <!-- z=3: body — extremely round wide torso, fat roll shading, silver back sheen -->
        <layer id="body" type="base" z-order="3" width="32" height="24">
            <pixel-data>
                <!-- wide chubby torso: 18px wide, 8px tall — very rotund -->
                <rect x="5" y="9" w="18" h="8" color="#6B7B8D"/>
                <!-- back top silver sheen — bright center line -->
                <hline x="6" y="9" len="16" color="#C8D4DC"/>
                <hline x="7" y="10" len="14" color="#AABBC8"/>
                <hline x="8" y="11" len="12" color="#8899AA"/>
                <!-- barrel chest sides — round shadow -->
                <pixel x="5" y="10" color="#4A5B6D"/>
                <pixel x="5" y="11" color="#4A5B6D"/>
                <pixel x="5" y="12" color="#3A4A5A"/>
                <pixel x="5" y="13" color="#3A4A5A"/>
                <pixel x="22" y="10" color="#4A5B6D"/>
                <pixel x="22" y="11" color="#4A5B6D"/>
                <pixel x="22" y="12" color="#3A4A5A"/>
                <pixel x="22" y="13" color="#3A4A5A"/>
                <!-- lower belly underside — smoky rounding -->
                <hline x="6" y="16" len="16" color="#4A5B6D"/>
                <hline x="7" y="17" len="14" color="#556677"/>
                <!-- mid-body smoky undercoat band -->
                <hline x="6" y="14" len="16" color="#556677"/>
                <!-- fat roll crease at waist -->
                <hline x="7" y="13" len="14" color="#5A6B7A"/>
            </pixel-data>
        </layer>

        <!-- z=4: belly — huge round pale belly, silver undercoat visible, center plush -->
        <layer id="belly" type="overlay" z-order="4" width="32" height="24">
            <pixel-data>
                <!-- belly patch: wide pale area, nearly the full underside -->
                <rect x="8" y="12" w="12" h="5" color="#9BABB8"/>
                <!-- belly top highlight — lightest zone -->
                <hline x="9" y="12" len="10" color="#AABBC8"/>
                <!-- belly center soft highlight -->
                <hline x="10" y="13" len="8" color="#C8D4DC"/>
                <!-- belly lower shadow — smoky undercoat -->
                <hline x="9" y="15" len="10" color="#556677"/>
                <hline x="10" y="16" len="8" color="#4A5B6D"/>
                <!-- subtle fur texture rows in belly -->
                <pixel x="9" y="14" color="#8899AA"/>
                <pixel x="11" y="14" color="#8899AA"/>
                <pixel x="13" y="14" color="#8899AA"/>
                <pixel x="15" y="14" color="#8899AA"/>
                <pixel x="17" y="14" color="#8899AA"/>
                <!-- fat belly side rolls -->
                <pixel x="8" y="13" color="#8899AA"/>
                <pixel x="8" y="14" color="#7788A0"/>
                <pixel x="19" y="13" color="#8899AA"/>
                <pixel x="19" y="14" color="#7788A0"/>
            </pixel-data>
        </layer>

        <!-- z=5: tail — thick fluffy tail, curves gently, silver tip -->
        <layer id="tail" type="base" z-order="5" width="32" height="24">
            <pixel-data>
                <!-- tail base at rump: thick 2px -->
                <pixel x="22" y="12" color="#6B7B8D"/>
                <pixel x="23" y="11" color="#6B7B8D"/>
                <pixel x="23" y="10" color="#8899AA"/>
                <!-- tail mid sweep -->
                <pixel x="24" y="9" color="#8899AA"/>
                <pixel x="25" y="8" color="#8899AA"/>
                <pixel x="26" y="8" color="#AABBC8"/>
                <!-- tail curves back (lazy C-shape) -->
                <pixel x="27" y="8" color="#8899AA"/>
                <pixel x="28" y="9" color="#6B7B8D"/>
                <!-- tip curls slightly inward -->
                <pixel x="28" y="10" color="#AABBC8"/>
                <pixel x="27" y="10" color="#8899AA"/>
                <!-- tail underside shadow -->
                <pixel x="23" y="12" color="#4A5B6D"/>
                <pixel x="24" y="10" color="#556677"/>
            </pixel-data>
        </layer>

        <!-- z=6: neck — short thick neck, fat jowls merging into chest -->
        <layer id="neck" type="base" z-order="6" width="32" height="24">
            <pixel-data>
                <!-- short wide neck column: 4px wide -->
                <rect x="7" y="7" w="4" h="3" color="#6B7B8D"/>
                <!-- neck top highlight -->
                <hline x="7" y="7" len="4" color="#8899AA"/>
                <pixel x="8" y="7" color="#AABBC8"/>
                <!-- neck shadow sides -->
                <pixel x="7" y="8" color="#4A5B6D"/>
                <pixel x="7" y="9" color="#4A5B6D"/>
                <pixel x="10" y="8" color="#4A5B6D"/>
                <!-- chin/throat pale smoky area -->
                <hline x="8" y="9" len="2" color="#8899AA"/>
                <!-- smoky undercoat at base of neck -->
                <hline x="7" y="9" len="4" color="#556677"/>
            </pixel-data>
        </layer>

        <!-- z=7: head — large round chubby head, jowly cheeks, broad forehead -->
        <layer id="head" type="base" z-order="7" width="32" height="24">
            <pixel-data>
                <!-- head block: 11px wide, 8px tall — very round -->
                <rect x="2" y="2" w="11" h="8" color="#6B7B8D"/>
                <!-- forehead silver sheen — broad highlight -->
                <hline x="3" y="2" len="9" color="#C8D4DC"/>
                <hline x="4" y="3" len="7" color="#AABBC8"/>
                <!-- chubby cheek puffs — wider than skull -->
                <pixel x="2" y="5" color="#8899AA"/>
                <pixel x="2" y="6" color="#8899AA"/>
                <pixel x="2" y="7" color="#7788A0"/>
                <pixel x="12" y="5" color="#8899AA"/>
                <pixel x="12" y="6" color="#8899AA"/>
                <pixel x="12" y="7" color="#7788A0"/>
                <!-- jaw underside rounded -->
                <hline x="3" y="9" len="8" color="#4A5B6D"/>
                <!-- facial plane shadow sides -->
                <pixel x="2" y="4" color="#4A5B6D"/>
                <pixel x="12" y="4" color="#4A5B6D"/>
                <!-- muzzle area slightly lighter -->
                <rect x="4" y="6" w="6" h="3" color="#7788A0"/>
                <hline x="5" y="6" len="4" color="#8899AA"/>
            </pixel-data>
        </layer>

        <!-- z=8: ears — small rounded ears with pink-grey inner, typical cat ear shape -->
        <layer id="ears" type="base" z-order="8" width="32" height="24">
            <pixel-data>
                <!-- left ear: small rounded triangle -->
                <pixel x="2" y="2" color="#6B7B8D"/>
                <pixel x="3" y="1" color="#8899AA"/>
                <pixel x="4" y="0" color="#AABBC8"/>
                <pixel x="5" y="1" color="#8899AA"/>
                <pixel x="4" y="1" color="#6B7B8D"/>
                <!-- left ear inner: pink-grey -->
                <pixel x="3" y="1" color="#CCAACC"/>
                <pixel x="4" y="1" color="#CCAACC"/>
                <!-- right ear -->
                <pixel x="9" y="2" color="#6B7B8D"/>
                <pixel x="10" y="1" color="#8899AA"/>
                <pixel x="11" y="0" color="#AABBC8"/>
                <pixel x="12" y="1" color="#8899AA"/>
                <pixel x="11" y="1" color="#6B7B8D"/>
                <!-- right ear inner -->
                <pixel x="10" y="1" color="#CCAACC"/>
                <pixel x="11" y="1" color="#CCAACC"/>
            </pixel-data>
        </layer>

        <!-- z=9: face_details — vivid green eyes, pink nose, content smile, whiskers -->
        <layer id="face_details" type="overlay" z-order="9" width="32" height="24">
            <pixel-data>
                <!-- left eye: vivid green — Russian Blue hallmark -->
                <pixel x="4" y="4" color="#228B22"/>
                <pixel x="5" y="3" color="#44BB44"/>
                <pixel x="6" y="3" color="#44BB44"/>
                <pixel x="5" y="4" color="#44BB44"/>
                <pixel x="6" y="4" color="#111111"/>
                <!-- left eye outer ring -->
                <pixel x="4" y="3" color="#228B22"/>
                <!-- left eye shine: bright white -->
                <pixel x="5" y="3" color="#FFFFFF"/>
                <!-- right eye -->
                <pixel x="7" y="4" color="#228B22"/>
                <pixel x="8" y="3" color="#44BB44"/>
                <pixel x="9" y="3" color="#44BB44"/>
                <pixel x="8" y="4" color="#44BB44"/>
                <pixel x="9" y="4" color="#111111"/>
                <pixel x="7" y="3" color="#228B22"/>
                <!-- right eye shine -->
                <pixel x="8" y="3" color="#FFFFFF"/>
                <!-- nose: pink, wider (chubby cat nose) -->
                <pixel x="5" y="6" color="#FFBBDD"/>
                <pixel x="6" y="6" color="#FFBBDD"/>
                <pixel x="7" y="6" color="#FFBBDD"/>
                <pixel x="6" y="7" color="#DD99BB"/>
                <!-- nostril dots -->
                <pixel x="5" y="7" color="#CC88AA"/>
                <pixel x="7" y="7" color="#CC88AA"/>
                <!-- content smile: subtle upturned mouth -->
                <pixel x="5" y="8" color="#557799"/>
                <pixel x="6" y="8" color="#446688"/>
                <pixel x="7" y="8" color="#557799"/>
                <pixel x="4" y="8" color="#4A5B6D"/>
                <pixel x="8" y="8" color="#4A5B6D"/>
                <!-- whiskers: long and relaxed hanging (chubby cat has plentiful whiskers) -->
                <hline x="0" y="6" len="4" color="#FFFFFF"/>
                <hline x="0" y="7" len="3" color="#DDDDDD"/>
                <hline x="10" y="6" len="4" color="#FFFFFF"/>
                <hline x="10" y="7" len="3" color="#DDDDDD"/>
                <!-- forehead spot (character marking) -->
                <pixel x="6" y="2" color="#8899AA"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <!-- ═══════════════════════════════════════════════════════
             IDLE ANIMATIONS — 4 time-of-day variants, 12 frames each
             ═══════════════════════════════════════════════════════ -->

        <!-- idle_morning: slow stretch, rolls around yawning, getting up reluctantly -->
        <animation name="idle_morning" frames="12" fps="4" loop="true" frame-width="32" frame-height="24">
            <condition type="time_of_day" value="morning"/>
            <!-- f0: just woke, still loafed, body flat against ground -->
            <frame index="0" layer-offsets="body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1; tail:1,1"/>
            <!-- f1: slow front stretch — front paws extend far forward, chest dips -->
            <frame index="1" layer-offsets="body:0,1; belly:0,1; front_legs:-2,2; paws:-3,2; hind_legs:0,0; tail:1,1; neck:0,-1; head:0,-1; ears:0,-1; face_details:0,-1"/>
            <!-- f2: deep stretch, spine arched upward (cat stretch) -->
            <frame index="2" layer-offsets="body:0,-1; belly:0,0; front_legs:-2,1; paws:-3,2; hind_legs:1,-1; tail:2,0; neck:0,-1; head:0,-1; ears:0,-1; face_details:0,-1"/>
            <!-- f3: yawn — head tilts back, mouth opens wide, eyes close -->
            <frame index="3" layer-offsets="body:0,-1; belly:0,0; neck:0,-2; head:0,-2; ears:0,-2; face_details:0,-2; tail:1,0"/>
            <!-- f4: after yawn head drops, shake of head side to side -->
            <frame index="4" layer-offsets="head:-1,-1; ears:-1,-1; face_details:-1,-1; neck:-1,-1; body:0,0; belly:0,0; tail:1,0"/>
            <!-- f5: head shake other way -->
            <frame index="5" layer-offsets="head:1,-1; ears:1,-1; face_details:1,-1; neck:1,-1; body:0,0; belly:0,0; tail:1,0"/>
            <!-- f6: standing up — rear legs straighten, body rises -->
            <frame index="6" layer-offsets="body:0,-1; belly:0,-1; neck:0,-1; head:0,-1; ears:0,-1; face_details:0,-1; hind_legs:0,-1; tail:0,0"/>
            <!-- f7: full stand, all four paws down, blinking contentedly -->
            <frame index="7" layer-offsets="face_details:0,-1; tail:0,-1"/>
            <!-- f8: slow weight shift left, deciding what to do -->
            <frame index="8" layer-offsets="body:-1,0; belly:-1,0; front_legs:-1,0; paws:-1,0; tail:-1,0"/>
            <!-- f9: weight shift right -->
            <frame index="9" layer-offsets="body:1,0; belly:1,0; front_legs:1,0; paws:1,0; tail:1,0"/>
            <!-- f10: settles, inhale — body rises -->
            <frame index="10" layer-offsets="body:0,-1; belly:0,-1; neck:0,-1; head:0,-1; ears:0,-1; face_details:0,-1; tail:0,-1"/>
            <!-- f11: exhale — body settles, blissful morning -->
            <frame index="11" layer-offsets="body:0,0; belly:0,0; neck:0,0; head:0,0; face_details:0,0; tail:0,0"/>
        </animation>

        <!-- idle_day: alert and sociable, looking around for interaction, slow tail swish -->
        <animation name="idle_day" frames="12" fps="5" loop="true" frame-width="32" frame-height="24">
            <condition type="time_of_day" value="day"/>
            <!-- f0: standing, tail up, bright-eyed -->
            <frame index="0" layer-offsets="tail:0,-2"/>
            <!-- f1: head turns left, surveying for company -->
            <frame index="1" layer-offsets="head:-1,0; ears:-1,0; face_details:-1,0; neck:-1,0; tail:0,-2"/>
            <!-- f2: further left, ears forward -->
            <frame index="2" layer-offsets="head:-2,0; ears:-2,-1; face_details:-2,0; neck:-1,0; tail:-1,-2"/>
            <!-- f3: head sweeps right, tail swishes left -->
            <frame index="3" layer-offsets="head:1,0; ears:1,0; face_details:1,0; neck:1,0; tail:-2,-1"/>
            <!-- f4: head right, sees something, ears forward -->
            <frame index="4" layer-offsets="head:2,-1; ears:2,-1; face_details:2,-1; neck:1,-1; tail:-1,-2"/>
            <!-- f5: tail swishes right, body weight shifts -->
            <frame index="5" layer-offsets="head:1,0; ears:1,0; face_details:1,0; neck:1,0; tail:2,-1; body:1,0; belly:1,0"/>
            <!-- f6: tail right extreme, chubby bottom wobbles -->
            <frame index="6" layer-offsets="tail:3,-1; hind_legs:1,0; body:1,0; belly:1,0"/>
            <!-- f7: tail comes back center, head center -->
            <frame index="7" layer-offsets="tail:0,-2"/>
            <!-- f8: slow blink — content expression -->
            <frame index="8" layer-offsets="face_details:0,-1; tail:0,-2"/>
            <!-- f9: eyes fully open after blink, very soft expression -->
            <frame index="9" layer-offsets="tail:0,-2"/>
            <!-- f10: slight upward sit — showing belly interest -->
            <frame index="10" layer-offsets="body:0,-1; belly:0,-1; neck:0,-1; head:0,-1; ears:0,-1; face_details:0,-1; tail:0,-2"/>
            <!-- f11: back down, fully content loop -->
            <frame index="11" layer-offsets="tail:0,-2"/>
        </animation>

        <!-- idle_evening: blissfully purring, body vibrates with purr, very relaxed -->
        <animation name="idle_evening" frames="12" fps="4" loop="true" frame-width="32" frame-height="24">
            <condition type="time_of_day" value="evening"/>
            <!-- f0: settled into loaf, eyes half-closed -->
            <frame index="0" layer-offsets="body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1; tail:1,1"/>
            <!-- f1: purr vibration +0,+1 — body resonates -->
            <frame index="1" layer-offsets="body:0,0; belly:0,0; front_legs:0,0; hind_legs:0,0; paws:0,0; tail:1,0; neck:0,0; head:0,0; ears:0,0; face_details:0,0"/>
            <!-- f2: purr settles back -->
            <frame index="2" layer-offsets="body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1; tail:1,1"/>
            <!-- f3: slow inhale — belly swells -->
            <frame index="3" layer-offsets="body:0,1; belly:0,0; front_legs:0,1; hind_legs:0,1; paws:0,1; tail:1,1"/>
            <!-- f4: exhale — belly drops -->
            <frame index="4" layer-offsets="body:0,1; belly:0,2; front_legs:0,1; hind_legs:0,1; paws:0,1; tail:1,1"/>
            <!-- f5: purr vibration again -->
            <frame index="5" layer-offsets="body:0,0; belly:0,1; front_legs:0,0; hind_legs:0,0; paws:0,0; tail:1,0"/>
            <!-- f6: head droops contentedly -->
            <frame index="6" layer-offsets="body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1; tail:1,1; head:0,1; neck:0,1; face_details:0,1; ears:0,1"/>
            <!-- f7: ear twitch, sound registered, doesn't care -->
            <frame index="7" layer-offsets="body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1; tail:1,1; head:0,1; neck:0,1; face_details:0,1; ears:1,1"/>
            <!-- f8: ear settles, back to bliss -->
            <frame index="8" layer-offsets="body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1; tail:1,1; head:0,1; neck:0,1; face_details:0,1; ears:0,1"/>
            <!-- f9: purr vibration peak — whole loaf buzzes -->
            <frame index="9" layer-offsets="body:0,0; belly:0,0; front_legs:0,0; hind_legs:0,0; paws:0,0; neck:0,0; head:0,0; ears:0,0; face_details:0,0; tail:1,0"/>
            <!-- f10: tail tip flick in satisfaction -->
            <frame index="10" layer-offsets="body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1; tail:2,0; head:0,1; neck:0,1; face_details:0,1; ears:0,1"/>
            <!-- f11: full settle, deepest peace -->
            <frame index="11" layer-offsets="body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1; tail:1,1; head:0,1; neck:0,1; face_details:0,1; ears:0,1"/>
        </animation>

        <!-- idle_night: completely flat spread, maximum surface area, belly skyward, deep sleep -->
        <animation name="idle_night" frames="12" fps="2" loop="true" frame-width="32" frame-height="24">
            <condition type="time_of_day" value="night"/>
            <!-- f0: full belly-up sleep position — head tilted back, legs splayed up -->
