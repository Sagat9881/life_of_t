        <!-- play_with_dog: Klop lets the dog sniff and lick him — totally unbothered, chubby rolling -->
        <animation name="play_with_dog" frames="12" fps="7" loop="false" frame-width="32" frame-height="24">
            <condition type="trigger" value="dog_approaches"/>
            <!-- f0: sitting calmly, dog incoming, Klop is completely relaxed -->
            <frame index="0" layer-offsets="tail:1,-1; body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1"/>
            <!-- f1: tilts head curiously at the dog's approach -->
            <frame index="1" layer-offsets="tail:1,-1; body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1; head:1,0; ears:1,0; face_details:1,0; neck:1,0"/>
            <!-- f2: gets licked — head pushed slightly away, but doesn't mind -->
            <frame index="2" layer-offsets="tail:1,-1; body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1; head:-1,0; ears:-1,0; face_details:-1,0; neck:-1,0"/>
            <!-- f3: shakes head from lick, amused -->
            <frame index="3" layer-offsets="tail:2,-1; body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1; head:1,0; ears:1,0; face_details:1,0; neck:1,0"/>
            <!-- f4: raises paw gently — soft boops the dog -->
            <frame index="4" layer-offsets="tail:2,-1; body:0,1; belly:0,1; front_legs:-1,-1; paws:-1,-2; hind_legs:0,1; head:0,0; ears:0,0; face_details:0,0; neck:0,0"/>
            <!-- f5: paw comes back down, rolls slightly onto side to expose belly to dog -->
            <frame index="5" layer-offsets="tail:2,0; body:1,2; belly:1,0; front_legs:2,-1; hind_legs:1,1; paws:2,0; head:1,1; ears:1,1; face_details:1,1; neck:1,1"/>
            <!-- f6: belly exposed, dog investigates — Klop fully relaxed and open -->
            <frame index="6" layer-offsets="tail:3,0; body:1,2; belly:1,-1; front_legs:2,-1; hind_legs:1,0; paws:2,-1; head:1,2; ears:1,2; face_details:1,2; neck:1,2"/>
            <!-- f7: dog nose on belly — Klop's tail flicks with delight -->
            <frame index="7" layer-offsets="tail:4,-1; body:1,2; belly:1,-1; front_legs:2,-1; hind_legs:1,0; paws:2,-1; head:1,2; ears:1,2; face_details:1,2; neck:1,2"/>
            <!-- f8: wriggling a little — playful reaction -->
            <frame index="8" layer-offsets="tail:3,-1; body:0,2; belly:0,-1; front_legs:1,-1; hind_legs:0,0; paws:1,-1; head:0,2; ears:0,2; face_details:0,2; neck:0,2"/>
            <!-- f9: rolls back upright, playful expression -->
            <frame index="9" layer-offsets="tail:2,-1; body:0,1; belly:0,1; front_legs:0,0; hind_legs:0,1; paws:0,1; head:0,1; ears:0,1; face_details:0,1; neck:0,1"/>
            <!-- f10: stands, swipes gently at dog's nose — friendly play -->
            <frame index="10" layer-offsets="tail:2,-1; body:0,0; belly:0,0; front_legs:-1,-2; paws:-2,-2; hind_legs:0,0; head:0,0; ears:0,0; face_details:0,0; neck:0,0"/>
            <!-- f11: fully standing, tail up, play complete, both satisfied -->
            <frame index="11" layer-offsets="tail:1,-2"/>
        </animation>

        <!-- waddle: slow exaggerated side-to-side waddle walk, maximum chub display -->
        <animation name="waddle" frames="12" fps="6" loop="true" frame-width="32" frame-height="24">
            <!-- f0: standing, weight center -->
            <frame index="0" layer-offsets="tail:0,-1"/>
            <!-- f1: weight shifts hard left, left-lean, body tilts -->
            <frame index="1" layer-offsets="body:-2,0; belly:-2,0; neck:-1,0; head:-1,0; ears:-1,0; face_details:-1,0; tail:-1,-1; front_legs:-1,0; paws:-1,0"/>
            <!-- f2: right paws lift, waddling peak left -->
            <frame index="2" layer-offsets="body:-2,-1; belly:-2,0; neck:-1,-1; head:-1,-1; ears:-1,-1; face_details:-1,-1; tail:-1,-1; hind_legs:2,0; paws:0,-1"/>
            <!-- f3: right paws swing forward in air -->
            <frame index="3" layer-offsets="body:-1,0; belly:-1,0; neck:-1,0; head:-1,0; front_legs:0,-1; paws:1,-1; hind_legs:1,0; tail:-1,-1"/>
            <!-- f4: right paws land, weight center briefly -->
            <frame index="4" layer-offsets="body:0,1; belly:0,1; tail:0,-1"/>
            <!-- f5: weight shifts hard right, right-lean -->
            <frame index="5" layer-offsets="body:2,0; belly:2,0; neck:1,0; head:1,0; ears:1,0; face_details:1,0; tail:1,-1; front_legs:1,0; paws:1,0"/>
            <!-- f6: left paws lift, waddling peak right -->
            <frame index="6" layer-offsets="body:2,-1; belly:2,0; neck:1,-1; head:1,-1; ears:1,-1; face_details:1,-1; tail:1,-1; hind_legs:-2,0; paws:0,-1"/>
            <!-- f7: left paws swing forward -->
            <frame index="7" layer-offsets="body:1,0; belly:1,0; neck:1,0; head:1,0; front_legs:0,-1; paws:-1,-1; hind_legs:-1,0; tail:1,-1"/>
            <!-- f8: left paws land, brief center -->
            <frame index="8" layer-offsets="body:0,1; belly:0,1; tail:0,-1"/>
            <!-- f9: weight left again — slow continued waddle -->
            <frame index="9" layer-offsets="body:-1,0; belly:-1,0; neck:-1,0; head:-1,0; tail:-1,-1"/>
            <!-- f10: mid-waddle body at highest point (compression between steps) -->
            <frame index="10" layer-offsets="body:0,-1; belly:0,-1; neck:0,-1; head:0,-1; tail:0,-2"/>
            <!-- f11: body drops back, completing waddle cycle -->
            <frame index="11" layer-offsets="body:0,0; belly:0,1; tail:0,-1"/>
        </animation>
    </animations>

    <naming>
        <output-dir>characters/klop</output-dir>
    </naming>
</asset-spec>
