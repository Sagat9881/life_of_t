            <!-- f7: rock right — full wriggle -->
            <frame index="7" layer-offsets="body:1,2; belly:1,-3; front_legs:1,-4; hind_legs:1,-3; paws:1,-5; tail:4,2; head:3,4; neck:2,3; ears:3,4; face_details:3,4"/>
            <!-- f8: back center — fully blissful belly-up -->
            <frame index="8" layer-offsets="body:0,2; belly:0,-3; front_legs:0,-4; hind_legs:0,-3; paws:0,-5; tail:3,2; head:2,4; neck:1,3; ears:2,4; face_details:2,4"/>
            <!-- f9: still belly-up, paw knead in air -->
