            <!-- f0: lying belly-down, head slightly raised, eyes half closed -->
            <frame index="0" layer-offsets="body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1; head:0,0; neck:0,0; tail:1,0"/>
