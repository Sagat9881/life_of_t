            <!-- f5: slow blink — definitive peace signal -->
            <frame index="5" layer-offsets="tail:0,-2; head:-1,0; neck:-1,0; ears:-1,0; face_details:-1,1"/>
            <!-- f6: turns very slightly sideways (non-confrontational profile) -->
            <frame index="6" layer-offsets="tail:1,-1; head:-1,0; ears:-1,0; face_details:-1,0; neck:-1,0; body:0,0; belly:0,0"/>
            <!-- f7: sits down gently — says "I'm staying here, I'm calm" -->
            <frame index="7" layer-offsets="tail:1,-1; head:-1,0; ears:-1,-1; face_details:-1,-1; neck:-1,0; body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1"/>
            <!-- f8: slow blink while sitting — peak trust signal -->
            <frame index="8" layer-offsets="tail:1,-1; head:-1,0; neck:-1,0; ears:-1,-1; face_details:-1,1; body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1"/>
