            <!-- f6: deep sleep exhale -->
            <frame index="6" layer-offsets="body:0,2; belly:0,-3; front_legs:1,-3; hind_legs:0,-2; paws:0,-4; tail:3,2; head:2,3; neck:1,3; ears:2,3; face_details:2,3"/>
