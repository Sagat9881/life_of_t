            <!-- f1: PASSING A — body rolls left, chubby body sways -->
            <frame index="1" layer-offsets="body:-2,0; belly:-2,0; neck:-1,0; head:-1,0; ears:-1,0; face_details:-1,0; front_legs:-2,0; paws:-2,0; tail:-1,-1"/>
            <!-- f2: LIFT A — FL lifts high, body peaks left-lean, belly wobbles -->
            <frame index="2" layer-offsets="body:-2,-1; belly:-2,0; neck:-1,-1; head:-1,-1; ears:-1,-1; face_details:-1,-1; front_legs:-2,-2; paws:-2,-2; tail:-1,-1"/>
            <!-- f3: SWING A — FL swings forward, chubby leg reaches -->
