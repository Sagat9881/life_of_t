            <frame index="0" layer-offsets="body:1,0; belly:1,0; tail:2,0"/>
            <!-- f1: leaning sideways, front legs begin to buckle -->
            <frame index="1" layer-offsets="body:2,1; belly:2,0; front_legs:2,1; tail:3,0; head:1,0; neck:1,0; ears:1,0; face_details:1,0"/>
            <!-- f2: tipping, back legs sliding out to side -->
            <frame index="2" layer-offsets="body:2,2; belly:2,-1; front_legs:3,0; hind_legs:3,0; paws:4,-1; tail:3,-1; head:2,1; neck:2,1; ears:2,1; face_details:2,1"/>
            <!-- f3: halfway over — laying on side, legs start going up -->
            <frame index="3" layer-offsets="body:1,2; belly:1,-1; front_legs:2,-2; hind_legs:2,-1; paws:3,-2; tail:2,0; head:2,2; neck:2,2; ears:2,2; face_details:2,2"/>
