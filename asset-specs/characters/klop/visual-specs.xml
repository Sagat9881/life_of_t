        <!-- befriend: Klop approaches Lada (or any new animal), gentle head-bob, non-threatening posture -->
        <animation name="befriend" frames="12" fps="6" loop="false" frame-width="32" frame-height="24">
            <condition type="trigger" value="new_animal_nearby"/>
            <!-- f0: standing calmly, noticing new animal, tail up and curved friendly -->
