        </animation>

        <!-- eat: enthusiastic eating, head bobs down with gusto, tail swishes with pleasure -->
        <animation name="eat" frames="12" fps="8" loop="true" frame-width="32" frame-height="24">
            <condition type="trigger" value="feeding_time"/>
            <!-- f0: approaching bowl, head begins to lower -->
