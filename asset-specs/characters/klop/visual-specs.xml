            <!-- f3: paw twitches in dream (front left) -->
            <frame index="3" layer-offsets="head:2,4; ears:2,4; face_details:2,4; neck:1,3; tail:4,2; body:0,2; belly:0,-1; front_legs:2,-2; hind_legs:-1,-2; paws:1,-3"/>
