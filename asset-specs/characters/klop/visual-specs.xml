            <!-- f11: sitting peacefully, purring, tail gently curved — social work complete -->
            <frame index="11" layer-offsets="tail:1,-1; head:-1,0; neck:-1,0; ears:-1,-1; face_details:-1,0; body:0,1; belly:0,1; front_legs:0,1; hind_legs:0,1; paws:0,1"/>
