            <!-- f4: CONTACT B — FR + HL touch, weight transfers right -->
            <frame index="4" layer-offsets="front_legs:0,0; paws:0,0; hind_legs:-1,0; body:1,0; belly:1,0; tail:0,-1"/>
            <!-- f5: PASSING B — body rolls right, chubby sway other way -->
            <frame index="5" layer-offsets="body:2,0; belly:2,0; neck:1,0; head:1,0; ears:1,0; face_details:1,0; front_legs:2,0; paws:2,0; tail:1,-1"/>
            <!-- f6: LIFT B — FR lifts, right-lean, belly sways right -->
            <frame index="6" layer-offsets="body:2,-1; belly:2,0; neck:1,-1; head:1,-1; ears:1,-1; face_details:1,-1; front_legs:3,-2; paws:3,-2; tail:1,-1"/>
            <!-- f7: SWING B — FR swings forward, head bobs -->
