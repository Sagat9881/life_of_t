<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>cirilla</entity-name>
        <version>1.0.0</version>
    </meta>
    <!-- Cirilla: self-sufficient cat, daughter of tricolor Alisa.
         Canvas: 20x16. Tricolor (calico): white base #F5F5F5, orange patches #E07820,
         black patches #1A1A1A. First to befriend Garfield; plays alone with muselet. -->
    <layers>
        <!-- z=0: paws -->
        <layer id="paws" type="base" z-order="0" width="20" height="16">
            <pixel-data>
                <!-- front left paw: white -->
                <rect x="3" y="13" w="2" h="2" color="#F5F5F5"/>
                <hline x="3" y="14" len="2" color="#DDDDDD"/>
                <!-- front right paw: orange patch -->
                <rect x="7" y="13" w="2" h="2" color="#E07820"/>
                <hline x="7" y="14" len="2" color="#C06010"/>
                <!-- rear left paw: white -->
                <rect x="11" y="13" w="2" h="2" color="#F5F5F5"/>
                <hline x="11" y="14" len="2" color="#DDDDDD"/>
                <!-- rear right paw: black patch -->
                <rect x="15" y="13" w="2" h="2" color="#1A1A1A"/>
                <hline x="15" y="14" len="2" color="#111111"/>
                <!-- paw pads -->
                <pixel x="4" y="14" color="#FFAAAA"/>
                <pixel x="8" y="14" color="#CC8800"/>
                <pixel x="12" y="14" color="#FFAAAA"/>
                <pixel x="16" y="14" color="#333333"/>
            </pixel-data>
        </layer>
        <!-- z=1: legs -->
        <layer id="legs" type="base" z-order="1" width="20" height="16">
            <pixel-data>
                <!-- front left leg: white -->
                <rect x="3" y="9" w="2" h="4" color="#F5F5F5"/>
                <!-- front right leg: orange -->
                <rect x="7" y="9" w="2" h="4" color="#E07820"/>
                <!-- rear left leg: white -->
                <rect x="11" y="9" w="2" h="4" color="#F5F5F5"/>
                <!-- rear right leg: black -->
                <rect x="15" y="9" w="2" h="4" color="#1A1A1A"/>
                <!-- leg tops -->
                <hline x="3" y="9" len="2" color="#CCCCCC"/>
                <hline x="7" y="9" len="2" color="#C06010"/>
                <hline x="11" y="9" len="2" color="#CCCCCC"/>
                <hline x="15" y="9" len="2" color="#333333"/>
            </pixel-data>
        </layer>
        <!-- z=2: body/torso — tricolor patchwork body -->
        <layer id="body" type="base" z-order="2" width="20" height="16">
            <pixel-data>
                <!-- main body rectangle -->
                <rect x="3" y="6" w="12" h="5" color="#F5F5F5"/>
                <!-- large orange patch on left side -->
                <rect x="3" y="6" w="5" h="4" color="#E07820"/>
                <!-- black patch on right -->
                <rect x="10" y="7" w="4" h="3" color="#1A1A1A"/>
                <!-- white centre strip remains -->
                <rect x="7" y="6" w="3" h="5" color="#F5F5F5"/>
                <!-- top highlight -->
                <hline x="4" y="6" len="10" color="#F8F8F8"/>
                <!-- belly underside -->
                <hline x="4" y="10" len="10" color="#EEEEEE"/>
            </pixel-data>
        </layer>
        <!-- z=3: belly_pattern — white belly with small orange dots (calico trait) -->
        <layer id="belly_pattern" type="overlay" z-order="3" width="20" height="16">
            <pixel-data>
                <!-- white belly -->
                <rect x="6" y="8" w="6" h="3" color="#FFFFFF"/>
                <!-- small orange calico spot -->
                <pixel x="8" y="9" color="#E07820"/>
                <pixel x="9" y="9" color="#E07820"/>
                <!-- small black calico spot -->
                <pixel x="7" y="9" color="#1A1A1A"/>
            </pixel-data>
        </layer>
        <!-- z=4: tail — tricolor tail, mostly white with orange tip -->
        <layer id="tail" type="base" z-order="4" width="20" height="16">
            <pixel-data>
                <pixel x="15" y="9" color="#F5F5F5"/>
                <pixel x="16" y="8" color="#F5F5F5"/>
                <pixel x="17" y="7" color="#E07820"/>
                <pixel x="18" y="6" color="#E07820"/>
                <pixel x="18" y="5" color="#E07820"/>
                <pixel x="17" y="4" color="#1A1A1A"/>
                <pixel x="18" y="4" color="#1A1A1A"/>
                <pixel x="19" y="5" color="#E07820"/>
                <!-- tail underside -->
                <pixel x="16" y="9" color="#DDDDDD"/>
                <pixel x="17" y="8" color="#C06010"/>
            </pixel-data>
        </layer>
        <!-- z=5: head — tricolor head: white face, orange forehead, black ear patch -->
        <layer id="head" type="base" z-order="5" width="20" height="16">
            <pixel-data>
                <!-- main head: white base -->
                <rect x="2" y="2" w="8" h="6" color="#F5F5F5"/>
                <!-- orange forehead patch -->
                <rect x="3" y="2" w="4" h="3" color="#E07820"/>
                <!-- black patch over right side of head -->
                <rect x="7" y="2" w="3" h="3" color="#1A1A1A"/>
                <!-- cheeks white -->
                <pixel x="2" y="5" color="#FFFFFF"/>
                <pixel x="9" y="5" color="#FFFFFF"/>
                <!-- chin -->
                <hline x="3" y="7" len="5" color="#EEEEEE"/>
            </pixel-data>
        </layer>
        <!-- z=6: ears — left ear orange, right ear black (matches head patches) -->
        <layer id="ears" type="base" z-order="6" width="20" height="16">
            <pixel-data>
                <!-- left ear: orange -->
                <pixel x="2" y="1" color="#E07820"/>
                <pixel x="3" y="0" color="#E07820"/>
                <pixel x="3" y="1" color="#E07820"/>
                <pixel x="3" y="0" color="#FFB347"/>
                <!-- left inner -->
                <pixel x="3" y="1" color="#FFB6C1"/>
                <!-- right ear: black -->
                <pixel x="8" y="1" color="#1A1A1A"/>
                <pixel x="7" y="0" color="#1A1A1A"/>
                <pixel x="7" y="1" color="#1A1A1A"/>
                <!-- right inner pink -->
                <pixel x="7" y="1" color="#AA4455"/>
            </pixel-data>
        </layer>
        <!-- z=7: face_details — bright curious eyes, pink nose, whiskers -->
        <layer id="face_details" type="overlay" z-order="7" width="20" height="16">
            <pixel-data>
                <!-- left eye: amber/gold (bright and curious) -->
                <pixel x="4" y="4" color="#DAA520"/>
                <pixel x="5" y="3" color="#FFD700"/>
                <pixel x="5" y="4" color="#FFD700"/>
                <pixel x="4" y="3" color="#DAA520"/>
                <pixel x="5" y="4" color="#111111"/>
                <!-- right eye -->
                <pixel x="7" y="4" color="#DAA520"/>
                <pixel x="8" y="3" color="#FFD700"/>
                <pixel x="8" y="4" color="#FFD700"/>
                <pixel x="7" y="3" color="#DAA520"/>
                <pixel x="8" y="4" color="#111111"/>
                <!-- eye shine -->
                <pixel x="4" y="3" color="#FFFFFF"/>
                <pixel x="7" y="3" color="#FFFFFF"/>
                <!-- nose: small orange-pink -->
                <pixel x="5" y="5" color="#FF9966"/>
                <pixel x="6" y="5" color="#FF9966"/>
                <pixel x="6" y="6" color="#CC6633"/>
                <!-- mouth -->
                <pixel x="5" y="6" color="#884422"/>
                <pixel x="7" y="6" color="#884422"/>
                <!-- whiskers -->
                <hline x="0" y="5" len="3" color="#FFFFFF"/>
                <hline x="0" y="6" len="2" color="#CCCCCC"/>
                <hline x="9" y="5" len="3" color="#FFFFFF"/>
                <hline x="9" y="6" len="2" color="#CCCCCC"/>
            </pixel-data>
        </layer>
    </layers>
    <animations>
        <!-- idle_morning: yawning and stretching, self-reliant wake-up -->
        <animation name="idle_morning" frames="4" fps="4" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="morning"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="head:0,-1; ears:0,-1; face_details:0,-1; body:0,1"/>
            <frame index="2" layer-offsets="head:0,-1; ears:0,-2; face_details:0,-1"/>
            <frame index="3" layer-offsets=""/>
        </animation>
        <!-- idle_day: active and alert, looking around playfully -->
        <animation name="idle_day" frames="4" fps="5" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="day"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="head:-1,-1; ears:-1,-1; face_details:-1,-1"/>
            <frame index="2" layer-offsets="head:0,-1; ears:0,-1; face_details:0,-1"/>
            <frame index="3" layer-offsets="head:1,0; ears:1,0; face_details:1,0"/>
        </animation>
        <!-- idle_evening: relaxed, content, tail curled -->
        <animation name="idle_evening" frames="4" fps="3" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="evening"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="tail:0,1"/>
            <frame index="2" layer-offsets="head:0,1; face_details:0,1; tail:1,0"/>
            <frame index="3" layer-offsets="tail:0,1"/>
        </animation>
        <!-- idle_night: sleeping curled up -->
        <animation name="idle_night" frames="4" fps="2" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="night"/>
            <frame index="0" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-1,1"/>
            <frame index="1" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-1,1"/>
            <frame index="2" layer-offsets="head:0,2; ears:0,2; face_details:0,2; body:0,1; belly_pattern:0,1; tail:-1,1"/>
            <frame index="3" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-1,1"/>
        </animation>
        <!-- walk: lively quick-stepping walk -->
        <animation name="walk" frames="6" fps="8" loop="true" frame-width="20" frame-height="16">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="paws:-1,-1; legs:-1,0"/>
            <frame index="2" layer-offsets="body:-1,0; belly_pattern:-1,0"/>
            <frame index="3" layer-offsets="paws:1,-1; legs:1,0"/>
            <frame index="4" layer-offsets="tail:0,-1; body:1,0; belly_pattern:1,0"/>
            <frame index="5" layer-offsets=""/>
        </animation>
        <!-- play_muselet: unique animation — batting the champagne wire cage along the floor -->
        <animation name="play_muselet" frames="6" fps="6" loop="false" frame-width="20" frame-height="16">
            <condition type="trigger" value="toy_nearby"/>
            <!-- frame 0: spots the muselet, crouching low -->
            <frame index="0" layer-offsets="body:0,1; belly_pattern:0,1; head:0,1; face_details:0,1"/>
            <!-- frame 1: butt wiggle prep (shift left) -->
            <frame index="1" layer-offsets="body:-1,1; belly_pattern:-1,1; tail:0,-1"/>
            <!-- frame 2: pounce (paws extend forward) -->
            <frame index="2" layer-offsets="paws:-2,-1; legs:-1,0; body:-1,0"/>
            <!-- frame 3: batting with front paw -->
            <frame index="3" layer-offsets="paws:-3,-2; face_details:0,-1"/>
            <!-- frame 4: chases the rolling muselet -->
            <frame index="4" layer-offsets="paws:-1,-1; body:-1,0; belly_pattern:-1,0"/>
            <!-- frame 5: reset, looking pleased -->
            <frame index="5" layer-offsets=""/>
        </animation>
    </animations>
    <naming>
        <output-dir>characters/cirilla</output-dir>
    </naming>
</asset-spec>