<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>garfield</entity-name>
        <version>1.0.0</version>
    </meta>
    <!-- Garfield: elegant slim ginger cat, 9 years old, gentleman of the pride.
         Canvas: 20x16. Ginger coat (#D2691E base, #E87722 highlights, #A0522D shadows).
         Anxious but dignified; leader of the cat family. -->
    <layers>
        <!-- z=0: paws — small slim front and rear paw pads -->
        <layer id="paws" type="base" z-order="0" width="20" height="16">
            <pixel-data>
                <!-- front left paw -->
                <rect x="3" y="13" w="2" h="2" color="#D2691E"/>
                <hline x="3" y="14" len="2" color="#C1440E"/>
                <!-- front right paw -->
                <rect x="7" y="13" w="2" h="2" color="#D2691E"/>
                <hline x="7" y="14" len="2" color="#C1440E"/>
                <!-- rear left paw -->
                <rect x="11" y="13" w="2" h="2" color="#D2691E"/>
                <hline x="11" y="14" len="2" color="#C1440E"/>
                <!-- rear right paw -->
                <rect x="15" y="13" w="2" h="2" color="#D2691E"/>
                <hline x="15" y="14" len="2" color="#C1440E"/>
                <!-- paw pad dots -->
                <pixel x="4" y="14" color="#8B2500"/>
                <pixel x="8" y="14" color="#8B2500"/>
                <pixel x="12" y="14" color="#8B2500"/>
                <pixel x="16" y="14" color="#8B2500"/>
            </pixel-data>
        </layer>
        <!-- z=1: legs — slender legs connecting body to paws -->
        <layer id="legs" type="base" z-order="1" width="20" height="16">
            <pixel-data>
                <!-- front left leg -->
                <rect x="3" y="9" w="2" h="4" color="#D2691E"/>
                <!-- front right leg -->
                <rect x="7" y="9" w="2" h="4" color="#D2691E"/>
                <!-- rear left leg -->
                <rect x="11" y="9" w="2" h="4" color="#D2691E"/>
                <!-- rear right leg -->
                <rect x="15" y="9" w="2" h="4" color="#D2691E"/>
                <!-- leg shading -->
                <hline x="3" y="9" len="2" color="#B8601A"/>
                <hline x="7" y="9" len="2" color="#B8601A"/>
                <hline x="11" y="9" len="2" color="#B8601A"/>
                <hline x="15" y="9" len="2" color="#B8601A"/>
            </pixel-data>
        </layer>
        <!-- z=2: body/torso — slim elegant ginger body -->
        <layer id="body" type="base" z-order="2" width="20" height="16">
            <pixel-data>
                <!-- main torso shape: 12px wide, 6px tall, centered -->
                <rect x="3" y="6" w="12" h="5" color="#D2691E"/>
                <!-- highlight stripe on top of back -->
                <hline x="4" y="6" len="10" color="#E87722"/>
                <!-- belly underside slightly lighter -->
                <hline x="4" y="10" len="10" color="#C86010"/>
                <!-- side shadow shaping slim silhouette -->
                <pixel x="3" y="7" color="#B8601A"/>
                <pixel x="3" y="8" color="#B8601A"/>
                <pixel x="14" y="7" color="#B8601A"/>
                <pixel x="14" y="8" color="#B8601A"/>
            </pixel-data>
        </layer>
        <!-- z=3: belly_pattern — cream/white belly patch, gentleman markings -->
        <layer id="belly_pattern" type="overlay" z-order="3" width="20" height="16">
            <pixel-data>
                <!-- pale cream belly centre -->
                <rect x="6" y="8" w="6" h="3" color="#F5CBA0"/>
                <!-- darker ginger stripe highlight along spine -->
                <hline x="5" y="7" len="8" color="#E87722"/>
                <hline x="6" y="6" len="6" color="#CD853F"/>
            </pixel-data>
        </layer>
        <!-- z=4: tail — long elegant curved tail -->
        <layer id="tail" type="base" z-order="4" width="20" height="16">
            <pixel-data>
                <!-- tail base at rear, curving up and right -->
                <pixel x="15" y="9" color="#D2691E"/>
                <pixel x="16" y="8" color="#D2691E"/>
                <pixel x="17" y="7" color="#D2691E"/>
                <pixel x="18" y="6" color="#D2691E"/>
                <pixel x="18" y="5" color="#D2691E"/>
                <pixel x="17" y="4" color="#E87722"/>
                <!-- tail tip -->
                <pixel x="18" y="4" color="#E87722"/>
                <pixel x="19" y="5" color="#A0522D"/>
                <!-- tail underside -->
                <pixel x="16" y="9" color="#C1440E"/>
                <pixel x="17" y="8" color="#C1440E"/>
            </pixel-data>
        </layer>
        <!-- z=5: head — elegant oval ginger head -->
        <layer id="head" type="base" z-order="5" width="20" height="16">
            <pixel-data>
                <!-- head oval, slightly angular for elegance -->
                <rect x="2" y="2" w="8" h="6" color="#D2691E"/>
                <!-- forehead highlight -->
                <hline x="3" y="2" len="6" color="#E87722"/>
                <!-- cheek puff (slight) -->
                <pixel x="2" y="5" color="#E87722"/>
                <pixel x="9" y="5" color="#E87722"/>
                <!-- chin lighter -->
                <hline x="3" y="7" len="5" color="#C86010"/>
                <!-- jaw shadow -->
                <hline x="2" y="6" len="8" color="#B8601A"/>
            </pixel-data>
        </layer>
        <!-- z=6: ears — pointed upright ears, gentleman alert -->
        <layer id="ears" type="base" z-order="6" width="20" height="16">
            <pixel-data>
                <!-- left ear -->
                <pixel x="2" y="1" color="#D2691E"/>
                <pixel x="3" y="0" color="#D2691E"/>
                <pixel x="3" y="1" color="#D2691E"/>
                <!-- left ear inner pink -->
                <pixel x="3" y="1" color="#E87722"/>
                <pixel x="3" y="0" color="#FFB6C1"/>
                <!-- right ear -->
                <pixel x="8" y="1" color="#D2691E"/>
                <pixel x="7" y="0" color="#D2691E"/>
                <pixel x="7" y="1" color="#D2691E"/>
                <!-- right ear inner pink -->
                <pixel x="7" y="1" color="#E87722"/>
                <pixel x="7" y="0" color="#FFB6C1"/>
            </pixel-data>
        </layer>
        <!-- z=7: face_details — green anxious eyes, pink nose, fine whiskers -->
        <layer id="face_details" type="overlay" z-order="7" width="20" height="16">
            <pixel-data>
                <!-- left eye: green, almond shaped, slightly wide (anxious) -->
                <pixel x="4" y="4" color="#228B22"/>
                <pixel x="5" y="3" color="#32CD32"/>
                <pixel x="5" y="4" color="#32CD32"/>
                <pixel x="4" y="3" color="#228B22"/>
                <!-- pupil left -->
                <pixel x="5" y="4" color="#111111"/>
                <!-- right eye -->
                <pixel x="7" y="4" color="#228B22"/>
                <pixel x="8" y="3" color="#32CD32"/>
                <pixel x="8" y="4" color="#32CD32"/>
                <pixel x="7" y="3" color="#228B22"/>
                <!-- pupil right -->
                <pixel x="8" y="4" color="#111111"/>
                <!-- eye shine dots -->
                <pixel x="4" y="3" color="#FFFFFF"/>
                <pixel x="7" y="3" color="#FFFFFF"/>
                <!-- nose — small pink triangle -->
                <pixel x="5" y="5" color="#FF9999"/>
                <pixel x="6" y="5" color="#FF9999"/>
                <pixel x="6" y="6" color="#CC6666"/>
                <!-- mouth thin line -->
                <pixel x="5" y="6" color="#8B4513"/>
                <pixel x="7" y="6" color="#8B4513"/>
                <!-- whiskers left (3px each) -->
                <hline x="0" y="5" len="3" color="#FFFFFF"/>
                <hline x="0" y="6" len="2" color="#DDDDDD"/>
                <!-- whiskers right -->
                <hline x="9" y="5" len="3" color="#FFFFFF"/>
                <hline x="9" y="6" len="2" color="#DDDDDD"/>
            </pixel-data>
        </layer>
    </layers>
    <animations>
        <!-- idle_morning: gentle stretch and yawn, waking up elegantly -->
        <animation name="idle_morning" frames="4" fps="4" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="morning"/>
            <!-- frame 0: sitting still -->
            <frame index="0" layer-offsets=""/>
            <!-- frame 1: head tilts up slightly (yawn prep) -->
            <frame index="1" layer-offsets="head:0,-1; ears:0,-1; face_details:0,-1"/>
            <!-- frame 2: mouth open, eyes squinted (yawn) -->
            <frame index="2" layer-offsets="head:0,-1; ears:0,-2; face_details:0,-1"/>
            <!-- frame 3: head lowers back, settling -->
            <frame index="3" layer-offsets="head:0,0; ears:0,0; face_details:0,0"/>
        </animation>
        <!-- idle_day: alert, looking left and right, upright posture -->
        <animation name="idle_day" frames="4" fps="4" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="day"/>
            <!-- frame 0: facing forward, alert -->
            <frame index="0" layer-offsets=""/>
            <!-- frame 1: head turns left (slight dx) -->
            <frame index="1" layer-offsets="head:-1,0; ears:-1,0; face_details:-1,0"/>
            <!-- frame 2: head back center -->
            <frame index="2" layer-offsets=""/>
            <!-- frame 3: head turns right -->
            <frame index="3" layer-offsets="head:1,0; ears:1,0; face_details:1,0"/>
        </animation>
        <!-- idle_evening: relaxed, half-closed eyes, tail sways slowly -->
        <animation name="idle_evening" frames="4" fps="3" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="evening"/>
            <frame index="0" layer-offsets=""/>
            <!-- frame 1: tail shifts slightly -->
            <frame index="1" layer-offsets="tail:0,1"/>
            <!-- frame 2: head droops very slightly -->
            <frame index="2" layer-offsets="head:0,1; ears:0,1; face_details:0,1; tail:0,1"/>
            <!-- frame 3: still, drooped -->
            <frame index="3" layer-offsets="head:0,1; face_details:0,1"/>
        </animation>
        <!-- idle_night: sleeping, body curled, minimal movement -->
        <animation name="idle_night" frames="4" fps="2" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="night"/>
            <!-- curled up: all layers shift down slightly -->
            <frame index="0" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-2,0"/>
            <frame index="1" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-2,0"/>
            <!-- breathing cycle: body micro-shifts -->
            <frame index="2" layer-offsets="head:0,2; ears:0,2; face_details:0,2; body:0,1; belly_pattern:0,1; tail:-2,0"/>
            <frame index="3" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-2,0"/>
        </animation>
        <!-- walk: standard walking cycle, elegant lifted paws -->
        <animation name="walk" frames="6" fps="8" loop="true" frame-width="20" frame-height="16">
            <!-- frame 0: neutral stance -->
            <frame index="0" layer-offsets=""/>
            <!-- frame 1: front-left + rear-right lift -->
            <frame index="1" layer-offsets="paws:-1,-1; legs:-1,0"/>
            <!-- frame 2: mid-stride, body shifts forward -->
            <frame index="2" layer-offsets="body:-1,0; belly_pattern:-1,0"/>
            <!-- frame 3: front-right + rear-left lift -->
            <frame index="3" layer-offsets="paws:1,-1; legs:1,0"/>
            <!-- frame 4: tail lifts elegantly during walk -->
            <frame index="4" layer-offsets="tail:0,-1; body:1,0; belly_pattern:1,0"/>
            <!-- frame 5: return to neutral -->
            <frame index="5" layer-offsets=""/>
        </animation>
        <!-- groom: unique personality animation — elegant paw licking -->
        <animation name="groom" frames="6" fps="5" loop="false" frame-width="20" frame-height="16">
            <condition type="trigger" value="idle_timeout"/>
            <!-- frame 0: raises front left paw -->
            <frame index="0" layer-offsets="paws:0,-2"/>
            <!-- frame 1: paw near face (licking) -->
            <frame index="1" layer-offsets="paws:0,-4; head:-1,0; face_details:-1,0"/>
            <!-- frame 2: lick stroke -->
            <frame index="2" layer-offsets="paws:0,-4; head:0,0; face_details:0,0"/>
            <!-- frame 3: lick stroke 2 -->
            <frame index="3" layer-offsets="paws:0,-4; head:1,0; face_details:1,0"/>
            <!-- frame 4: paw descends -->
            <frame index="4" layer-offsets="paws:0,-2"/>
            <!-- frame 5: return, satisfied look -->
            <frame index="5" layer-offsets=""/>
        </animation>
    </animations>
    <naming>
        <output-dir>characters/garfield</output-dir>
    </naming>
</asset-spec>