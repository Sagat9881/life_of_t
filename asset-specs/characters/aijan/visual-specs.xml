<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>aijan</entity-name>
        <version>1.0.0</version>
    </meta>
    <!-- Aijan: wildcat-colored tabby, grey-brown with dark brown/black stripes.
         Canvas: 20x16. Loves humans and dogs, hates other cats. Lives in Alexander's room.
         Base: #8B7355 (grey-brown), stripes: #3D2B1F (dark), belly: #C4A882. -->
    <layers>
        <!-- z=0: paws -->
        <layer id="paws" type="base" z-order="0" width="20" height="16">
            <pixel-data>
                <!-- all paws: tawny grey-brown -->
                <rect x="3" y="13" w="2" h="2" color="#8B7355"/>
                <hline x="3" y="14" len="2" color="#6B5335"/>
                <rect x="7" y="13" w="2" h="2" color="#8B7355"/>
                <hline x="7" y="14" len="2" color="#6B5335"/>
                <rect x="11" y="13" w="2" h="2" color="#8B7355"/>
                <hline x="11" y="14" len="2" color="#6B5335"/>
                <rect x="15" y="13" w="2" h="2" color="#8B7355"/>
                <hline x="15" y="14" len="2" color="#6B5335"/>
                <!-- paw pads darker -->
                <pixel x="4" y="14" color="#4A3520"/>
                <pixel x="8" y="14" color="#4A3520"/>
                <pixel x="12" y="14" color="#4A3520"/>
                <pixel x="16" y="14" color="#4A3520"/>
            </pixel-data>
        </layer>
        <!-- z=1: legs -->
        <layer id="legs" type="base" z-order="1" width="20" height="16">
            <pixel-data>
                <rect x="3" y="9" w="2" h="4" color="#8B7355"/>
                <rect x="7" y="9" w="2" h="4" color="#8B7355"/>
                <rect x="11" y="9" w="2" h="4" color="#8B7355"/>
                <rect x="15" y="9" w="2" h="4" color="#8B7355"/>
                <!-- dark stripe bands on each leg -->
                <hline x="3" y="10" len="2" color="#3D2B1F"/>
                <hline x="7" y="10" len="2" color="#3D2B1F"/>
                <hline x="11" y="10" len="2" color="#3D2B1F"/>
                <hline x="15" y="10" len="2" color="#3D2B1F"/>
                <hline x="3" y="12" len="2" color="#3D2B1F"/>
                <hline x="7" y="12" len="2" color="#3D2B1F"/>
                <hline x="11" y="12" len="2" color="#3D2B1F"/>
                <hline x="15" y="12" len="2" color="#3D2B1F"/>
            </pixel-data>
        </layer>
        <!-- z=2: body/torso — grey-brown wildcat body -->
        <layer id="body" type="base" z-order="2" width="20" height="16">
            <pixel-data>
                <rect x="3" y="6" w="12" h="5" color="#8B7355"/>
                <!-- dorsal stripe (tabby M) -->
                <hline x="4" y="6" len="10" color="#3D2B1F"/>
                <!-- side highlight -->
                <hline x="5" y="7" len="8" color="#9E8468"/>
                <!-- underside warm -->
                <hline x="4" y="10" len="10" color="#7A6345"/>
            </pixel-data>
        </layer>
        <!-- z=3: belly_pattern — tabby stripes on flanks, warm buff belly -->
        <layer id="belly_pattern" type="overlay" z-order="3" width="20" height="16">
            <pixel-data>
                <!-- warm buff belly -->
                <rect x="6" y="8" w="6" h="3" color="#C4A882"/>
                <!-- flank stripe marks (tabby) -->
                <pixel x="5" y="7" color="#3D2B1F"/>
                <pixel x="5" y="8" color="#3D2B1F"/>
                <pixel x="5" y="9" color="#3D2B1F"/>
                <pixel x="12" y="7" color="#3D2B1F"/>
                <pixel x="12" y="8" color="#3D2B1F"/>
                <pixel x="12" y="9" color="#3D2B1F"/>
                <!-- belly spots (tabby) -->
                <pixel x="7" y="9" color="#A89070"/>
                <pixel x="10" y="9" color="#A89070"/>
            </pixel-data>
        </layer>
        <!-- z=4: tail — ringed tabby tail (alternating base + stripe) -->
        <layer id="tail" type="base" z-order="4" width="20" height="16">
            <pixel-data>
                <pixel x="15" y="9" color="#8B7355"/>
                <pixel x="16" y="8" color="#3D2B1F"/>
                <pixel x="17" y="7" color="#8B7355"/>
                <pixel x="18" y="6" color="#3D2B1F"/>
                <pixel x="18" y="5" color="#8B7355"/>
                <pixel x="17" y="4" color="#3D2B1F"/>
                <pixel x="18" y="4" color="#8B7355"/>
                <pixel x="19" y="5" color="#3D2B1F"/>
                <!-- tail underside -->
                <pixel x="16" y="9" color="#6B5335"/>
            </pixel-data>
        </layer>
        <!-- z=5: head — wildcat head with tabby M on forehead -->
        <layer id="head" type="base" z-order="5" width="20" height="16">
            <pixel-data>
                <rect x="2" y="2" w="8" h="6" color="#8B7355"/>
                <!-- tabby M mark on forehead -->
                <pixel x="3" y="2" color="#3D2B1F"/>
                <pixel x="4" y="2" color="#3D2B1F"/>
                <pixel x="5" y="3" color="#3D2B1F"/>
                <pixel x="6" y="2" color="#3D2B1F"/>
                <pixel x="7" y="2" color="#3D2B1F"/>
                <!-- cheek stripes -->
                <pixel x="2" y="4" color="#3D2B1F"/>
                <pixel x="2" y="5" color="#3D2B1F"/>
                <pixel x="9" y="4" color="#3D2B1F"/>
                <pixel x="9" y="5" color="#3D2B1F"/>
                <!-- chin buff -->
                <hline x="3" y="7" len="5" color="#C4A882"/>
                <!-- head top highlight -->
                <hline x="3" y="3" len="6" color="#9E8468"/>
            </pixel-data>
        </layer>
        <!-- z=6: ears — pointed wildcat ears with dark tips -->
        <layer id="ears" type="base" z-order="6" width="20" height="16">
            <pixel-data>
                <!-- left ear -->
                <pixel x="2" y="1" color="#8B7355"/>
                <pixel x="3" y="0" color="#3D2B1F"/>
                <pixel x="3" y="1" color="#8B7355"/>
                <pixel x="3" y="1" color="#FFAAAA"/>
                <!-- right ear -->
                <pixel x="8" y="1" color="#8B7355"/>
                <pixel x="7" y="0" color="#3D2B1F"/>
                <pixel x="7" y="1" color="#8B7355"/>
                <pixel x="7" y="1" color="#FFAAAA"/>
            </pixel-data>
        </layer>
        <!-- z=7: face_details — sharp amber eyes, wide nose, threat whiskers -->
        <layer id="face_details" type="overlay" z-order="7" width="20" height="16">
            <pixel-data>
                <!-- left eye: striking amber-green (wild stare) -->
                <pixel x="4" y="4" color="#8B6914"/>
                <pixel x="5" y="3" color="#C8A800"/>
                <pixel x="5" y="4" color="#C8A800"/>
                <pixel x="4" y="3" color="#8B6914"/>
                <pixel x="5" y="4" color="#111111"/>
                <!-- right eye -->
                <pixel x="7" y="4" color="#8B6914"/>
                <pixel x="8" y="3" color="#C8A800"/>
                <pixel x="8" y="4" color="#C8A800"/>
                <pixel x="7" y="3" color="#8B6914"/>
                <pixel x="8" y="4" color="#111111"/>
                <!-- eye shine -->
                <pixel x="4" y="3" color="#FFFFFF"/>
                <pixel x="7" y="3" color="#FFFFFF"/>
                <!-- nose: dark warm brown -->
                <pixel x="5" y="5" color="#CC8866"/>
                <pixel x="6" y="5" color="#CC8866"/>
                <pixel x="6" y="6" color="#996644"/>
                <!-- tabby nose bridge lines -->
                <pixel x="5" y="4" color="#7A6345"/>
                <pixel x="6" y="4" color="#7A6345"/>
                <!-- mouth -->
                <pixel x="5" y="6" color="#6B4432"/>
                <pixel x="7" y="6" color="#6B4432"/>
                <!-- whiskers — long, prominent wildcat style -->
                <hline x="0" y="5" len="3" color="#FFFFFF"/>
                <hline x="0" y="4" len="2" color="#EEEEEE"/>
                <hline x="0" y="6" len="2" color="#DDDDDD"/>
                <hline x="9" y="5" len="3" color="#FFFFFF"/>
                <hline x="9" y="4" len="2" color="#EEEEEE"/>
                <hline x="9" y="6" len="2" color="#DDDDDD"/>
            </pixel-data>
        </layer>
    </layers>
    <animations>
        <!-- idle_morning: stretching with dramatic full-body arch (wild cat way) -->
        <animation name="idle_morning" frames="4" fps="4" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="morning"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="head:0,-1; ears:0,-1; face_details:0,-1; body:0,1; belly_pattern:0,1"/>
            <frame index="2" layer-offsets="head:0,-2; ears:0,-2; face_details:0,-2; body:0,1; belly_pattern:0,1"/>
            <frame index="3" layer-offsets="head:0,-1; ears:0,-1; face_details:0,-1"/>
        </animation>
        <!-- idle_day: alert scanning, territorial posture, slightly puffed -->
        <animation name="idle_day" frames="4" fps="5" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="day"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="head:-2,0; ears:-2,0; face_details:-2,0"/>
            <frame index="2" layer-offsets=""/>
            <frame index="3" layer-offsets="head:2,0; ears:2,0; face_details:2,0"/>
        </animation>
        <!-- idle_evening: relaxed on Alexander's bed, content purring -->
        <animation name="idle_evening" frames="4" fps="3" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="evening"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="tail:0,1"/>
            <frame index="2" layer-offsets="head:0,1; face_details:0,1; body:0,1; belly_pattern:0,1"/>
            <frame index="3" layer-offsets="tail:1,1"/>
        </animation>
        <!-- idle_night: sleeping flat on human -->
        <animation name="idle_night" frames="4" fps="2" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="night"/>
            <frame index="0" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-1,2"/>
            <frame index="1" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-1,2"/>
            <frame index="2" layer-offsets="head:0,2; ears:0,2; face_details:0,2; body:0,1; belly_pattern:0,1; tail:-1,2"/>
            <frame index="3" layer-offsets="head:0,2; ears:0,2; face_details:0,2; tail:-1,2"/>
        </animation>
        <!-- walk: purposeful heavy-pawed wildcat stride -->
        <animation name="walk" frames="6" fps="7" loop="true" frame-width="20" frame-height="16">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="paws:-1,-1; legs:-1,0"/>
            <frame index="2" layer-offsets="body:-1,0; belly_pattern:-1,0"/>
            <frame index="3" layer-offsets="paws:1,-1; legs:1,0"/>
            <frame index="4" layer-offsets="tail:0,-1; body:1,0; belly_pattern:1,0"/>
            <frame index="5" layer-offsets=""/>
        </animation>
        <!-- hiss: unique — arching back, puffing up, baring teeth at other cats -->
        <animation name="hiss" frames="6" fps="8" loop="false" frame-width="20" frame-height="16">
            <condition type="trigger" value="other_cat_nearby"/>
            <!-- frame 0: spots intruder, ears flatten -->
            <frame index="0" layer-offsets="ears:0,1"/>
            <!-- frame 1: back begins to arch -->
            <frame index="1" layer-offsets="body:0,-1; belly_pattern:0,-1; tail:0,-2"/>
            <!-- frame 2: full arch — all layers shift to show puffed profile -->
            <frame index="2" layer-offsets="body:0,-2; belly_pattern:0,-2; tail:1,-3; head:0,-1; face_details:0,-1"/>
            <!-- frame 3: open mouth hiss (face detail shift) -->
            <frame index="3" layer-offsets="body:0,-2; belly_pattern:0,-2; tail:1,-3; head:0,-1; face_details:0,-2; ears:0,-1"/>
            <!-- frame 4: hold posture -->
            <frame index="4" layer-offsets="body:0,-2; belly_pattern:0,-2; tail:1,-3; head:0,-1; face_details:0,-1"/>
            <!-- frame 5: return to normal if threat retreats -->
            <frame index="5" layer-offsets=""/>
        </animation>
    </animations>
    <naming>
        <output-dir>characters/aijan</output-dir>
    </naming>
</asset-spec>