<?xml version="1.0" encoding="UTF-8"?>
<!--
  Aijan — Forest Wildcat Tabby Cat
  Canvas inherited from abstract/entities/cat (128×96).
  Lives in Alexander's room. Loves ALL humans, hates ALL cats.
  Terrified of Garfield (screams when he appears). Pushes hand
  away when done with pets. Bites as warning. Purrs on bed.
  Grey-brown wildcat tabby, amber-green eyes, bold M-mark, ringed tail.
-->
<asset-spec extends="abstract/entities/cat@1.0" version="3.0.0">
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>aijan</entity-name>
        <version>3.0.0</version>
    </meta>

    <color-palette>
        <color name="$fur_base" value="#6B5B4B"/>
        <color name="$fur_light" value="#8B7B6B"/>
        <color name="$fur_shadow" value="#4A4038"/>
        <color name="$fur_dark" value="#3A3028"/>
        <color name="$fur_highlight" value="#A09080"/>
        <color name="$belly_color" value="#C8B89A"/>
        <color name="$eye_color" value="#D4B060"/>
        <color name="$eye_dark" value="#B89840"/>
        <color name="$nose_color" value="#CC8866"/>
        <color name="$paw_pad" value="#2A2018"/>
        <color name="$ear_inner" value="#FFAAAA"/>
        <color name="$pupil" value="#1A1208"/>
        <color name="$eye_shine" value="#FFFFFF"/>
        <color name="$whisker" value="#DDDDDD"/>
        <!-- Aijan-specific tabby colors -->
        <color name="$tabby_stripe" value="#3A3028"/>
        <color name="$tabby_mid" value="#4A4038"/>
        <color name="$muzzle_buff" value="#A89878"/>
        <color name="$eye_bright" value="#E8CC40"/>
        <color name="$deepest_shadow" value="#2A2018"/>
    </color-palette>

    <layer-overrides>
        <!-- Body: lithe wildcat with bold dorsal stripe and flank tabby bars -->
        <layer id="body" replace="true">
            <pixel-data>
                <!-- main body -->
                <rect x="24" y="40" w="64" h="28" color="$fur_base"/>
                <!-- dorsal (spine) stripe — dark, bold -->
                <hline x="28" y="40" len="56" color="$tabby_stripe"/>
                <hline x="32" y="44" len="48" color="$tabby_stripe"/>
                <!-- side highlight band -->
                <hline x="32" y="48" len="48" color="$fur_light"/>
                <!-- vertical flank tabby bars -->
                <rect x="32" y="48" w="4" h="12" color="$tabby_stripe"/>
                <rect x="44" y="48" w="4" h="16" color="$tabby_stripe"/>
                <rect x="56" y="48" w="4" h="16" color="$tabby_stripe"/>
                <rect x="68" y="48" w="4" h="12" color="$tabby_stripe"/>
                <!-- lower flank shadow -->
                <hline x="28" y="64" len="56" color="$tabby_mid"/>
                <!-- shoulder hump -->
                <rect x="24" y="32" w="16" h="12" color="$fur_base"/>
                <hline x="28" y="32" len="8" color="$tabby_stripe"/>
            </pixel-data>
        </layer>

        <!-- Belly: lighter underbelly with tabby spotted pattern -->
        <layer id="belly" replace="true">
            <pixel-data>
                <rect x="36" y="56" w="40" h="12" color="$belly_color"/>
                <hline x="40" y="56" len="32" color="$muzzle_buff"/>
                <hline x="44" y="60" len="24" color="$belly_color"/>
                <hline x="40" y="64" len="32" color="$muzzle_buff"/>
                <!-- belly tabby spots -->
                <pixel x="40" y="60" color="$tabby_mid"/>
                <pixel x="52" y="56" color="$tabby_mid"/>
                <pixel x="60" y="60" color="$tabby_mid"/>
                <pixel x="48" y="64" color="$tabby_stripe"/>
                <pixel x="56" y="64" color="$tabby_stripe"/>
                <!-- belly shadow edge -->
                <hline x="36" y="68" len="40" color="$tabby_mid"/>
                <!-- chest lighter area -->
                <rect x="32" y="44" w="16" h="16" color="$muzzle_buff"/>
                <hline x="36" y="44" len="8" color="$belly_color"/>
            </pixel-data>
        </layer>

        <!-- Tail: long ringed tabby tail with dark tip -->
        <layer id="tail" replace="true">
            <pixel-data>
                <!-- tail base curves up and back -->
                <pixel x="88" y="52" color="$fur_base"/>
                <pixel x="92" y="48" color="$fur_base"/>
                <pixel x="96" y="44" color="$fur_base"/>
                <pixel x="100" y="40" color="$fur_base"/>
                <pixel x="104" y="36" color="$fur_base"/>
                <pixel x="108" y="32" color="$fur_base"/>
                <pixel x="112" y="28" color="$fur_base"/>
                <pixel x="116" y="28" color="$fur_base"/>
                <pixel x="120" y="32" color="$fur_base"/>
                <pixel x="124" y="32" color="$fur_base"/>
                <!-- tabby rings -->
                <pixel x="92" y="48" color="$tabby_stripe"/>
                <pixel x="100" y="40" color="$tabby_stripe"/>
                <pixel x="108" y="32" color="$tabby_stripe"/>
                <pixel x="116" y="28" color="$tabby_stripe"/>
                <pixel x="124" y="32" color="$tabby_stripe"/>
                <!-- dark tail tip (wildcat marking) -->
                <pixel x="120" y="28" color="$deepest_shadow"/>
                <pixel x="124" y="28" color="$deepest_shadow"/>
                <!-- tail underside lighter -->
                <pixel x="92" y="52" color="$fur_light"/>
                <pixel x="96" y="48" color="$fur_light"/>
                <pixel x="100" y="44" color="$fur_light"/>
            </pixel-data>
        </layer>

        <!-- Head: sharp wedge-shaped wildcat head, prominent M forehead -->
        <layer id="head" replace="true">
            <pixel-data>
                <!-- skull -->
                <rect x="4" y="4" w="40" h="28" color="$fur_base"/>
                <!-- crown highlight -->
                <hline x="8" y="4" len="32" color="$fur_light"/>
                <!-- TABBY M MARK on forehead -->
                <pixel x="8" y="8" color="$tabby_stripe"/>
                <pixel x="12" y="4" color="$tabby_stripe"/>
                <pixel x="16" y="8" color="$tabby_stripe"/>
                <pixel x="20" y="4" color="$tabby_stripe"/>
                <pixel x="24" y="8" color="$tabby_stripe"/>
                <pixel x="28" y="4" color="$tabby_stripe"/>
                <pixel x="32" y="8" color="$tabby_stripe"/>
                <!-- cheek tabby stripes -->
                <pixel x="4" y="16" color="$tabby_stripe"/>
                <pixel x="4" y="20" color="$tabby_stripe"/>
                <pixel x="4" y="24" color="$tabby_mid"/>
                <pixel x="40" y="16" color="$tabby_stripe"/>
                <pixel x="40" y="20" color="$tabby_stripe"/>
                <pixel x="40" y="24" color="$tabby_mid"/>
                <!-- muzzle -->
                <rect x="8" y="20" w="28" h="12" color="$muzzle_buff"/>
                <hline x="12" y="20" len="20" color="$fur_light"/>
                <!-- chin -->
                <hline x="12" y="28" len="20" color="$belly_color"/>
            </pixel-data>
        </layer>

        <!-- Ears: large pointed with dark tips (wildcat signature) -->
        <layer id="ears" replace="true">
            <pixel-data>
                <!-- left ear -->
                <rect x="8" y="0" w="12" h="12" color="$fur_base"/>
                <pixel x="12" y="0" color="$fur_light"/>
                <!-- dark ear tips -->
                <pixel x="8" y="0" color="$deepest_shadow"/>
                <pixel x="16" y="0" color="$deepest_shadow"/>
                <!-- ear inner pink -->
                <pixel x="12" y="4" color="$ear_inner"/>
                <pixel x="12" y="8" color="$ear_inner"/>
                <!-- right ear -->
                <rect x="32" y="0" w="12" h="12" color="$fur_base"/>
                <pixel x="36" y="0" color="$fur_light"/>
                <pixel x="32" y="0" color="$deepest_shadow"/>
                <pixel x="40" y="0" color="$deepest_shadow"/>
                <pixel x="36" y="4" color="$ear_inner"/>
                <pixel x="36" y="8" color="$ear_inner"/>
                <!-- ear base connections -->
                <hline x="8" y="12" len="12" color="$tabby_mid"/>
                <hline x="32" y="12" len="12" color="$tabby_mid"/>
            </pixel-data>
        </layer>

        <!-- Face: wild staring amber-green eyes, pink nose, bold whiskers -->
        <layer id="face_details" replace="true">
            <pixel-data>
                <!-- LEFT EYE: large, wild, amber-green -->
                <pixel x="12" y="12" color="$eye_color"/>
                <pixel x="16" y="8" color="$eye_bright"/>
                <pixel x="20" y="8" color="$eye_bright"/>
                <pixel x="24" y="8" color="$eye_color"/>
                <pixel x="12" y="16" color="$eye_color"/>
                <pixel x="16" y="12" color="$eye_bright"/>
                <pixel x="20" y="12" color="$eye_color"/>
                <pixel x="24" y="12" color="$eye_color"/>
                <!-- pupil: vertical slit -->
                <pixel x="20" y="8" color="$pupil"/>
                <pixel x="20" y="12" color="$pupil"/>
                <pixel x="20" y="16" color="$pupil"/>
                <!-- eye shine -->
                <pixel x="16" y="8" color="$eye_shine"/>
                <!-- RIGHT EYE -->
                <pixel x="28" y="12" color="$eye_color"/>
                <pixel x="32" y="8" color="$eye_bright"/>
                <pixel x="36" y="8" color="$eye_bright"/>
                <pixel x="40" y="8" color="$eye_color"/>
                <pixel x="28" y="16" color="$eye_color"/>
                <pixel x="32" y="12" color="$eye_bright"/>
                <pixel x="36" y="12" color="$eye_color"/>
                <pixel x="40" y="12" color="$eye_color"/>
                <pixel x="36" y="8" color="$pupil"/>
                <pixel x="36" y="12" color="$pupil"/>
                <pixel x="36" y="16" color="$pupil"/>
                <pixel x="32" y="8" color="$eye_shine"/>
                <!-- NOSE -->
                <rect x="16" y="20" w="12" h="8" color="$nose_color"/>
                <hline x="16" y="20" len="12" color="#E8A888"/>
                <pixel x="16" y="24" color="#AA6644"/>
                <pixel x="24" y="24" color="#AA6644"/>
                <!-- nose bridge tabby -->
                <pixel x="16" y="16" color="$tabby_mid"/>
                <pixel x="24" y="16" color="$tabby_mid"/>
                <!-- MOUTH -->
                <pixel x="20" y="28" color="$tabby_mid"/>
                <pixel x="24" y="28" color="$tabby_mid"/>
                <!-- WHISKERS: long wildcat-style -->
                <hline x="0" y="16" len="12" color="$whisker"/>
                <hline x="0" y="20" len="16" color="#FFFFFF"/>
                <hline x="0" y="24" len="12" color="$whisker"/>
                <hline x="0" y="28" len="8" color="#CCCCCC"/>
                <hline x="44" y="16" len="12" color="$whisker"/>
                <hline x="44" y="20" len="16" color="#FFFFFF"/>
                <hline x="44" y="24" len="12" color="$whisker"/>
                <hline x="44" y="28" len="8" color="#CCCCCC"/>
            </pixel-data>
        </layer>
    </layer-overrides>

    <!-- Base 5 animations inherited from cat. Aijan-specific extras: -->
    <animations-extra>
        <!-- hiss_warning: Garfield appears or cat too close -->
        <animation name="hiss_warning" frames="12" fps="6" loop="false" frame-width="128" frame-height="96">
            <condition type="trigger" value="cat_detected"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="body:0,-4; belly:0,-4; neck:0,-4; head:0,-4; ears:0,-8; face_details:0,-4; tail:-4,4"/>
            <frame index="2" layer-offsets="body:0,-4; belly:0,-4; neck:0,-8; head:0,-8; ears:0,-12; face_details:0,-4; tail:-8,8"/>
            <frame index="3" layer-offsets="body:0,-4; belly:0,-4; neck:0,-8; head:0,-8; ears:0,-12; face_details:0,4; tail:-8,12"/>
            <frame index="4" layer-offsets="body:0,-4; belly:0,-4; neck:0,-8; head:0,-8; ears:0,-12; face_details:0,4; tail:-8,12; front_legs:0,-4; paws:0,-4"/>
            <frame index="5" layer-offsets="body:0,-4; belly:0,-4; neck:0,-4; head:0,-4; ears:0,-8; face_details:0,4; tail:-8,8"/>
            <frame index="6" layer-offsets="body:4,-4; belly:4,-4; neck:4,-8; head:4,-8; ears:4,-12; face_details:4,4; tail:-4,12"/>
            <frame index="7" layer-offsets="body:-4,-4; belly:-4,-4; neck:-4,-8; head:-4,-8; ears:-4,-12; face_details:-4,4; tail:-12,12"/>
            <frame index="8" layer-offsets="body:4,-4; belly:4,-4; neck:4,-8; head:4,-4; ears:4,-8; face_details:4,4; tail:-8,8"/>
            <frame index="9" layer-offsets="body:0,-4; belly:0,-4; neck:0,-4; head:0,-4; ears:0,-8; face_details:0,0; tail:-4,4"/>
            <frame index="10" layer-offsets="body:0,0; belly:0,0; tail:-4,4"/>
            <frame index="11" layer-offsets=""/>
        </animation>

        <!-- purr_on_bed: Aijan kneading and purring on Alexander's bed -->
        <animation name="purr_on_bed" frames="12" fps="3" loop="true" frame-width="128" frame-height="96">
            <condition type="location" value="alexander_room"/>
            <frame index="0" layer-offsets="body:0,4; belly:0,4; front_legs:0,4; hind_legs:0,4; paws:0,8"/>
            <frame index="1" layer-offsets="body:0,4; belly:0,4; front_legs:-4,4; hind_legs:0,4; paws:-4,4"/>
            <frame index="2" layer-offsets="body:0,4; belly:0,4; front_legs:4,4; hind_legs:0,4; paws:4,4"/>
            <frame index="3" layer-offsets="body:0,4; belly:0,4; front_legs:-4,4; hind_legs:0,4; paws:-4,4; face_details:0,4"/>
            <frame index="4" layer-offsets="body:0,4; belly:0,4; front_legs:4,4; hind_legs:0,4; paws:4,4; face_details:0,4"/>
            <frame index="5" layer-offsets="body:0,4; belly:0,4; front_legs:-4,4; hind_legs:0,4; paws:-4,4"/>
            <frame index="6" layer-offsets="body:0,8; belly:0,8; front_legs:0,8; hind_legs:0,8; paws:0,8; face_details:0,4"/>
            <frame index="7" layer-offsets="body:0,4; belly:0,4; front_legs:0,4; hind_legs:0,4; paws:0,8"/>
            <frame index="8" layer-offsets="body:0,4; belly:0,4; front_legs:-4,4; paws:-4,4; face_details:0,8"/>
            <frame index="9" layer-offsets="body:0,4; belly:0,4; front_legs:4,4; paws:4,4; face_details:0,4"/>
            <frame index="10" layer-offsets="body:0,4; belly:0,4; front_legs:0,4; paws:0,4; face_details:0,0"/>
            <frame index="11" layer-offsets="body:0,4; belly:0,4; front_legs:0,4; hind_legs:0,4; paws:0,8"/>
        </animation>

        <!-- push_hand_away: done with pets, asserting boundary -->
        <animation name="push_hand_away" frames="8" fps="5" loop="false" frame-width="128" frame-height="96">
            <condition type="trigger" value="pet_too_long"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="front_legs:-4,-4; paws:-8,-4"/>
            <frame index="2" layer-offsets="front_legs:-8,-8; paws:-12,-8; head:-4,0; face_details:-4,0"/>
            <frame index="3" layer-offsets="front_legs:-12,-4; paws:-16,-4; head:-4,0; face_details:-4,4"/>
            <frame index="4" layer-offsets="front_legs:-8,-4; paws:-12,-4; head:0,0; face_details:0,0"/>
            <frame index="5" layer-offsets="front_legs:-4,0; paws:-4,0; head:4,0; ears:4,-4"/>
            <frame index="6" layer-offsets="head:4,0; ears:4,-4; face_details:4,0"/>
            <frame index="7" layer-offsets=""/>
        </animation>
    </animations-extra>

    <naming>
        <output-dir>characters/aijan</output-dir>
    </naming>
</asset-spec>