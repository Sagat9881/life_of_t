<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>voland</entity-name>
        <version>1.0.0</version>
    </meta>
    <!-- Voland: French Bulldog, ~11 years old, blind since 2020. Lives in Tanya's parents' cottage.
         Canvas: 20x16 (small stocky dog). French bulldog proportions: wide head, flat face,
         short legs, barrel chest, bat ears. Typical fawn/brindle color.
         Color: #C8A878 (fawn), #8B6914 (brindle marks), #F5DEB3 (lighter patches).
         Blind: cloudy/pale eyes. Moves carefully but knows the layout. -->
    <layers>
        <!-- z=0: paws — wide stumpy bulldog paws -->
        <layer id="paws" type="base" z-order="0" width="20" height="16">
            <pixel-data>
                <!-- front left paw: wide, fawn -->
                <rect x="2" y="13" w="3" h="2" color="#C8A878"/>
                <hline x="2" y="14" len="3" color="#A88858"/>
                <!-- front right paw -->
                <rect x="7" y="13" w="3" h="2" color="#C8A878"/>
                <hline x="7" y="14" len="3" color="#A88858"/>
                <!-- rear left paw: stubby -->
                <rect x="12" y="13" w="3" h="2" color="#C8A878"/>
                <hline x="12" y="14" len="3" color="#A88858"/>
                <!-- rear right paw -->
                <rect x="17" y="13" w="3" h="2" color="#C8A878"/>
                <hline x="17" y="14" len="3" color="#A88858"/>
                <!-- paw pads: dark -->
                <pixel x="3" y="14" color="#664422"/>
                <pixel x="8" y="14" color="#664422"/>
                <pixel x="13" y="14" color="#664422"/>
                <pixel x="18" y="14" color="#664422"/>
            </pixel-data>
        </layer>
        <!-- z=1: legs — very short, stocky bulldog legs -->
        <layer id="legs" type="base" z-order="1" width="20" height="16">
            <pixel-data>
                <!-- front left: very short 2px -->
                <rect x="2" y="10" w="3" h="3" color="#C8A878"/>
                <!-- front right -->
                <rect x="7" y="10" w="3" h="3" color="#C8A878"/>
                <!-- rear left -->
                <rect x="12" y="10" w="3" h="3" color="#C8A878"/>
                <!-- rear right -->
                <rect x="17" y="10" w="3" h="3" color="#C8A878"/>
                <!-- brindle markings on legs -->
                <pixel x="3" y="11" color="#8B6914"/>
                <pixel x="8" y="11" color="#8B6914"/>
                <pixel x="13" y="11" color="#8B6914"/>
                <pixel x="18" y="11" color="#8B6914"/>
            </pixel-data>
        </layer>
        <!-- z=2: body — wide barrel bulldog body, low to ground -->
        <layer id="body" type="base" z-order="2" width="20" height="16">
            <pixel-data>
                <!-- very wide squat body -->
                <rect x="2" y="7" w="14" h="5" color="#C8A878"/>
                <!-- back brindle stripe -->
                <hline x="3" y="7" len="12" color="#8B6914"/>
                <!-- side brindle marks (tiger pattern) -->
                <pixel x="3" y="8" color="#8B6914"/>
                <pixel x="3" y="9" color="#8B6914"/>
                <pixel x="6" y="8" color="#8B6914"/>
                <pixel x="9" y="9" color="#8B6914"/>
                <pixel x="12" y="8" color="#8B6914"/>
                <pixel x="14" y="9" color="#8B6914"/>
                <!-- belly low, wide -->
                <hline x="3" y="11" len="12" color="#B89868"/>
            </pixel-data>
        </layer>
        <!-- z=3: chest_markings — wide white/cream chest bib (French bulldog typical) -->
        <layer id="chest_markings" type="overlay" z-order="3" width="20" height="16">
            <pixel-data>
                <!-- cream chest bib -->
                <rect x="3" y="8" w="6" h="4" color="#F5DEB3"/>
                <!-- bib top edge -->
                <hline x="4" y="8" len="4" color="#FFFFFF"/>
                <!-- wrinkle folds on chest skin -->
                <pixel x="4" y="10" color="#D4B896"/>
                <pixel x="5" y="10" color="#D4B896"/>
                <pixel x="6" y="10" color="#D4B896"/>
            </pixel-data>
        </layer>
        <!-- z=4: tail — vestigial bulldog tail, barely visible, short nub -->
        <layer id="tail" type="base" z-order="4" width="20" height="16">
            <pixel-data>
                <!-- tiny nub tail above rear end -->
                <pixel x="15" y="8" color="#C8A878"/>
                <pixel x="16" y="7" color="#C8A878"/>
                <pixel x="15" y="7" color="#A88858"/>
            </pixel-data>
        </layer>
        <!-- z=5: head — distinctive large flat wide bulldog head with jowls -->
        <layer id="head" type="base" z-order="5" width="20" height="16">
            <pixel-data>
                <!-- very wide head: 10px wide, 8px tall -->
                <rect x="0" y="1" w="11" h="8" color="#C8A878"/>
                <!-- skull slightly darker for roundness -->
                <hline x="1" y="1" len="9" color="#D4B890"/>
                <!-- wrinkled forehead (bulldog) -->
                <hline x="2" y="3" len="7" color="#B89870"/>
                <hline x="2" y="4" len="7" color="#C8A878"/>
                <!-- jowl folds at sides of muzzle -->
                <pixel x="0" y="5" color="#AA8858"/>
                <pixel x="0" y="6" color="#AA8858"/>
                <pixel x="10" y="5" color="#AA8858"/>
                <pixel x="10" y="6" color="#AA8858"/>
                <!-- underbite chin protrudes -->
                <rect x="2" y="8" w="7" h="2" color="#C8A878"/>
            </pixel-data>
        </layer>
        <!-- z=6: ears — large bat ears (French bulldog signature, upright) -->
        <layer id="ears" type="base" z-order="6" width="20" height="16">
            <pixel-data>
                <!-- left bat ear: wide-based, pointed top -->
                <rect x="0" y="0" w="3" h="3" color="#C8A878"/>
                <pixel x="1" y="0" color="#D4B890"/>
                <!-- left ear inner: darker pink -->
                <pixel x="1" y="1" color="#DDAAAA"/>
                <pixel x="1" y="2" color="#DDAAAA"/>
                <!-- right bat ear -->
                <rect x="8" y="0" w="3" h="3" color="#C8A878"/>
                <pixel x="9" y="0" color="#D4B890"/>
                <!-- right ear inner -->
                <pixel x="9" y="1" color="#DDAAAA"/>
                <pixel x="9" y="2" color="#DDAAAA"/>
            </pixel-data>
        </layer>
        <!-- z=7: face_details — CLOUDY/PALE eyes (blind!), wide flat nose, wrinkles -->
        <layer id="face_details" type="overlay" z-order="7" width="20" height="16">
            <pixel-data>
                <!-- left eye: CLOUDY PALE BLUE-WHITE (blind cataract) -->
                <pixel x="2" y="3" color="#AABBCC"/>
                <pixel x="3" y="2" color="#CCDDE0"/>
                <pixel x="4" y="2" color="#CCDDE0"/>
                <pixel x="3" y="3" color="#AABBCC"/>
                <!-- cloudy pupil (not dark, reflecting blindness) -->
                <pixel x="4" y="3" color="#8899AA"/>
                <!-- right eye: same cloudy -->
                <pixel x="6" y="3" color="#AABBCC"/>
                <pixel x="7" y="2" color="#CCDDE0"/>
                <pixel x="8" y="2" color="#CCDDE0"/>
                <pixel x="7" y="3" color="#AABBCC"/>
                <pixel x="8" y="3" color="#8899AA"/>
                <!-- no bright eye shine (blind eyes are milky) -->
                <!-- flat wide nose: bulldog nose, almost at face level -->
                <rect x="3" y="5" w="5" h="2" color="#553322"/>
                <!-- wide nostrils -->
                <pixel x="3" y="6" color="#442211"/>
                <pixel x="4" y="6" color="#442211"/>
                <pixel x="6" y="6" color="#442211"/>
                <pixel x="7" y="6" color="#442211"/>
                <!-- underbite: bottom lip visible -->
                <hline x="2" y="8" len="7" color="#AA8858"/>
                <hline x="3" y="9" len="5" color="#C8A878"/>
                <!-- wrinkle lines on muzzle (bulldog face folds) -->
                <pixel x="2" y="5" color="#AA8858"/>
                <pixel x="2" y="4" color="#AA8858"/>
                <pixel x="9" y="5" color="#AA8858"/>
                <pixel x="9" y="4" color="#AA8858"/>
            </pixel-data>
        </layer>
    </layers>
    <animations>
        <!-- idle_morning: slow careful wake-up, sniffs to orient himself -->
        <animation name="idle_morning" frames="4" fps="3" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="morning"/>
            <frame index="0" layer-offsets=""/>
            <!-- sniff: nose lowers slightly -->
            <frame index="1" layer-offsets="head:0,1; ears:0,1; face_details:0,1"/>
            <!-- smell checking direction -->
            <frame index="2" layer-offsets="head:-1,1; ears:-1,1; face_details:-1,1"/>
            <!-- settle: position confirmed, sits still -->
            <frame index="3" layer-offsets=""/>
        </animation>
        <!-- idle_day: calm standing, nose constantly active, occasional head tilt -->
        <animation name="idle_day" frames="4" fps="3" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="day"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="head:0,1; face_details:0,1"/>
            <frame index="2" layer-offsets="head:1,0; ears:1,0; face_details:1,0"/>
            <frame index="3" layer-offsets=""/>
        </animation>
        <!-- idle_evening: relaxed, listening to familiar voices, tail nub wags -->
        <animation name="idle_evening" frames="4" fps="3" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="evening"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="tail:0,-1"/>
            <frame index="2" layer-offsets="tail:-1,-1; head:0,1; face_details:0,1"/>
            <frame index="3" layer-offsets="tail:1,0"/>
        </animation>
        <!-- idle_night: old dog sleeping soundly, occasional snore twitch -->
        <animation name="idle_night" frames="4" fps="2" loop="true" frame-width="20" frame-height="16">
            <condition type="time_of_day" value="night"/>
            <frame index="0" layer-offsets="head:1,3; ears:1,2; face_details:1,3; legs:0,1; paws:0,1"/>
            <frame index="1" layer-offsets="head:1,3; ears:1,2; face_details:1,3; legs:0,1; paws:0,1"/>
            <frame index="2" layer-offsets="head:1,3; ears:1,2; face_details:1,3; body:0,1; chest_markings:0,1; legs:0,1; paws:0,1"/>
            <frame index="3" layer-offsets="head:1,3; ears:1,2; face_details:1,4; legs:0,1; paws:0,1"/>
        </animation>
        <!-- walk: careful slow shuffle, relies on memory of layout -->
        <animation name="walk" frames="6" fps="5" loop="true" frame-width="20" frame-height="16">
            <frame index="0" layer-offsets=""/>
            <!-- head sweeps low before each step (sniffing path) -->
            <frame index="1" layer-offsets="head:0,1; face_details:0,1; paws:-1,-1; legs:-1,0"/>
            <frame index="2" layer-offsets="body:-1,0; chest_markings:-1,0"/>
            <frame index="3" layer-offsets="head:0,1; face_details:0,1; paws:1,-1; legs:1,0"/>
            <frame index="4" layer-offsets="body:1,0; chest_markings:1,0"/>
            <frame index="5" layer-offsets=""/>
        </animation>
        <!-- sniff: unique — extended nose-led exploration, bumping into things gently -->
        <animation name="sniff" frames="6" fps="5" loop="false" frame-width="20" frame-height="16">
            <condition type="trigger" value="new_smell"/>
            <!-- frame 0: nose drops -->
            <frame index="0" layer-offsets="head:0,1; ears:0,1; face_details:0,2"/>
            <!-- frame 1: sniff left -->
            <frame index="1" layer-offsets="head:-2,2; ears:-2,2; face_details:-2,3"/>
            <!-- frame 2: sniff centre -->
            <frame index="2" layer-offsets="head:0,2; ears:0,2; face_details:0,3"/>
            <!-- frame 3: sniff right -->
            <frame index="3" layer-offsets="head:2,2; ears:2,2; face_details:2,3"/>
            <!-- frame 4: nose bump (found something!) -->
            <frame index="4" layer-offsets="head:3,2; ears:3,2; face_details:3,3; body:1,0"/>
            <!-- frame 5: satisfied, head raises slightly -->
            <frame index="5" layer-offsets="head:0,1; ears:0,1; face_details:0,1"/>
        </animation>
    </animations>
    <naming>
        <output-dir>characters/voland</output-dir>
    </naming>
</asset-spec>