<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>furniture</entity-type>
        <entity-name>computer</entity-name>
        <version>1.0.0</version>
        <location>home_room</location>
        <description>
            Рабочий компьютер Тани — основной объект для действия «Работа».
            Дизайн на Tilda, фриланс. Расположен на столе в home_room.
            Ключевой интерактивный предмет повседневного геймплея.
        </description>
    </meta>

    <layers>
        <!-- Стол (z=0, основа) -->
        <layer id="desk" type="base" z-order="0" width="48" height="48">
            <pixel-data>
                <!-- Столешница -->
                <rect x="4" y="28" w="40" h="3" color="#A07850"/>
                <hline x="4" y="28" len="40" color="#B08860"/>
                <hline x="4" y="30" len="40" color="#906840"/>
                <!-- Ножки стола -->
                <rect x="6" y="31" w="3" h="14" color="#8B6538"/>
                <rect x="39" y="31" w="3" h="14" color="#8B6538"/>
                <!-- Перекладина -->
                <rect x="9" y="38" w="30" h="2" color="#7A5830"/>
                <!-- Тень под столом -->
                <hline x="6" y="45" len="36" color="#D0C0A8"/>
            </pixel-data>
        </layer>

        <!-- Монитор — корпус (z=1, статичный) -->
        <layer id="monitor-frame" type="base" z-order="1" width="48" height="48">
            <pixel-data>
                <!-- Рамка монитора -->
                <rect x="12" y="8" w="24" h="18" color="#3A3A3A"/>
                <rect x="13" y="9" w="22" h="16" color="#2A2A2A"/>
                <!-- Ножка монитора -->
                <rect x="21" y="26" w="6" h="2" color="#3A3A3A"/>
                <!-- Подставка -->
                <rect x="18" y="27" w="12" h="1" color="#4A4A4A"/>
            </pixel-data>
        </layer>

        <!-- Экран — анимируемый слой (z=2) -->
        <layer id="screen-glow" type="animated" z-order="2" width="48" height="48">
            <pixel-data>
                <!-- Базовое свечение экрана -->
                <rect x="14" y="10" w="20" h="14" color="#D0E8F8"/>
                <rect x="15" y="11" w="18" h="12" color="#E0F0FF"/>
            </pixel-data>
        </layer>

        <!-- Курсор на экране (z=3, только при active) -->
        <layer id="cursor" type="animated-overlay" z-order="3" width="48" height="48"
               condition="state:active">
            <pixel-data>
                <pixel x="20" y="16" color="#FF6B9D"/>
            </pixel-data>
        </layer>

        <!-- Клавиатура (z=4, статичная) -->
        <layer id="keyboard" type="base" z-order="4" width="48" height="48">
            <pixel-data>
                <rect x="16" y="29" w="16" h="2" color="#505050"/>
                <rect x="17" y="29" w="14" h="1" color="#606060"/>
                <!-- Точки-клавиши -->
                <pixel x="18" y="29" color="#787878"/>
                <pixel x="20" y="29" color="#787878"/>
                <pixel x="22" y="29" color="#787878"/>
                <pixel x="24" y="29" color="#787878"/>
                <pixel x="26" y="29" color="#787878"/>
                <pixel x="28" y="29" color="#787878"/>
            </pixel-data>
        </layer>

        <!-- Кружка (z=5, статичная) -->
        <layer id="mug" type="base" z-order="5" width="48" height="48">
            <pixel-data>
                <!-- Корпус кружки -->
                <rect x="36" y="24" w="5" h="5" color="#FFB6C1"/>
                <rect x="37" y="25" w="3" h="3" color="#FF9AAF"/>
                <!-- Ручка -->
                <pixel x="41" y="25" color="#FFB6C1"/>
                <pixel x="42" y="26" color="#FFB6C1"/>
                <pixel x="41" y="27" color="#FFB6C1"/>
                <!-- Жидкость внутри -->
                <rect x="37" y="25" w="3" h="1" color="#8B4513"/>
            </pixel-data>
        </layer>

        <!-- Пар от кружки (z=6, анимированный overlay) -->
        <layer id="mug-steam" type="animated-overlay" z-order="6" width="48" height="48">
            <pixel-data>
                <pixel x="38" y="22" color="#E0E0E0"/>
                <pixel x="39" y="23" color="#D0D0D0"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <!-- Idle: мягкое пульсирование экрана + пар от кружки -->
        <animation name="idle" frames="4" fps="2" loop="true"
                   frame-width="48" frame-height="48">
            <description>
                Экран мягко мерцает между двумя оттенками голубого.
                Пар от кружки поднимается двумя пикселями.
            </description>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="screen-glow:0,0; mug-steam:0,-1"/>
            <frame index="2" layer-offsets="mug-steam:0,-2"/>
            <frame index="3" layer-offsets="mug-steam:1,-3"/>
        </animation>

        <!-- Active: Таня работает — экран более активен, курсор двигается -->
        <animation name="active-work" frames="6" fps="4" loop="true"
                   frame-width="48" frame-height="48"
                   condition="state:active">
            <description>
                Экран показывает смену «строк» — горизонтальные полоски
                чередуются, имитируя код/дизайн. Курсор двигается по экрану.
                Пар продолжает подниматься.
            </description>
            <frame index="0" layer-offsets="cursor:0,0; mug-steam:0,-1"/>
            <frame index="1" layer-offsets="cursor:2,0; mug-steam:0,-2"/>
            <frame index="2" layer-offsets="cursor:4,1; mug-steam:1,-3"/>
            <frame index="3" layer-offsets="cursor:2,2; mug-steam:0,0"/>
            <frame index="4" layer-offsets="cursor:0,3; mug-steam:0,-1"/>
            <frame index="5" layer-offsets="cursor:-1,1; mug-steam:0,-2"/>
        </animation>

        <!-- Screen-off: экран выключен (ночь / Таня спит) -->
        <animation name="screen-off" frames="1" fps="1" loop="false"
                   frame-width="48" frame-height="48"
                   condition="state:off">
            <description>
                Экран чёрный. Пар от кружки отсутствует (остыла).
            </description>
            <frame index="0" layer-offsets="screen-glow:0,100"/>
        </animation>
    </animations>

    <states>
        <state name="idle" description="Компьютер включён, Таня не работает — экран светится, пар идёт"/>
        <state name="active" description="Таня работает — активная смена экрана, курсор двигается"/>
        <state name="off" description="Компьютер выключен (ночь) — тёмный экран, нет пара"/>
    </states>

    <interaction>
        <action code="WORK_TILDA" description="Работать на Tilda — переход idle → active"/>
        <action code="BROWSE" description="Сёрфить интернет — аналогично active, но другой паттерн экрана"/>
        <action code="TURN_OFF" description="Выключить — переход active/idle → off"/>
    </interaction>

    <naming>
        <output-dir>furniture/computer</output-dir>
    </naming>
</asset-spec>
