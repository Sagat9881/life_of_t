<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>furniture</entity-type>
        <entity-name>stove</entity-name>
        <version>1.0.0</version>
        <location>kitchen</location>
        <description>
            Плита — основной интерактивный объект кухни.
            Действие «Готовить»: восстановление health,
            снижение hunger питомцев, повышение отношений
            при совместной готовке.
        </description>
    </meta>

    <layers>
        <!-- Корпус плиты (z=0) -->
        <layer id="body" type="base" z-order="0" width="48" height="48">
            <pixel-data>
                <!-- Основной корпус -->
                <rect x="8" y="10" w="32" h="34" color="#F0EDE8"/>
                <!-- Левая грань (тень) -->
                <rect x="8" y="10" w="1" h="34" color="#D8D4D0"/>
                <!-- Нижний край -->
                <hline x="8" y="43" len="32" color="#C8C4C0"/>
                <!-- Ножки -->
                <rect x="10" y="44" w="3" h="3" color="#A0A0A0"/>
                <rect x="35" y="44" w="3" h="3" color="#A0A0A0"/>
            </pixel-data>
        </layer>

        <!-- Варочная панель с конфорками (z=1) -->
        <layer id="cooktop" type="base" z-order="1" width="48" height="48">
            <pixel-data>
                <!-- Поверхность -->
                <rect x="9" y="10" w="30" h="3" color="#E0DCD8"/>
                <!-- Конфорка левая верхняя -->
                <rect x="13" y="11" w="4" h="1" color="#808080"/>
                <pixel x="12" y="11" color="#909090"/>
                <pixel x="17" y="11" color="#909090"/>
                <!-- Конфорка правая верхняя -->
                <rect x="29" y="11" w="4" h="1" color="#808080"/>
                <pixel x="28" y="11" color="#909090"/>
                <pixel x="33" y="11" color="#909090"/>
            </pixel-data>
        </layer>

        <!-- Ручки на фасаде (z=2) -->
        <layer id="knobs" type="base" z-order="2" width="48" height="48">
            <pixel-data>
                <pixel x="14" y="16" color="#C0C0C0"/>
                <pixel x="20" y="16" color="#C0C0C0"/>
                <pixel x="28" y="16" color="#C0C0C0"/>
                <pixel x="34" y="16" color="#C0C0C0"/>
            </pixel-data>
        </layer>

        <!-- Духовка (z=3) -->
        <layer id="oven" type="base" z-order="3" width="48" height="48">
            <pixel-data>
                <!-- Рамка духовки -->
                <rect x="12" y="20" w="24" h="18" color="#D8D4D0"/>
                <!-- Стекло -->
                <rect x="14" y="22" w="20" h="14" color="#2A2A30"/>
                <rect x="15" y="23" w="18" h="12" color="#1A1A20"/>
                <!-- Ручка духовки -->
                <rect x="20" y="20" w="8" h="1" color="#B0B0B0"/>
            </pixel-data>
        </layer>

        <!-- Конфорка горит (z=4, анимируемый overlay) -->
        <layer id="burner-glow" type="animated-overlay" z-order="4" width="48" height="48"
               condition="state:cooking">
            <pixel-data>
                <!-- Левая конфорка горит -->
                <rect x="13" y="11" w="4" h="1" color="#FF6030"/>
                <pixel x="12" y="11" color="#FF8050"/>
                <pixel x="17" y="11" color="#FF8050"/>
            </pixel-data>
        </layer>

        <!-- Пар от кастрюли (z=5, анимируемый overlay) -->
        <layer id="pot-steam" type="animated-overlay" z-order="5" width="48" height="48"
               condition="state:cooking">
            <pixel-data>
                <pixel x="14" y="8" color="#E8E8E8"/>
                <pixel x="15" y="7" color="#E0E0E0"/>
                <pixel x="16" y="8" color="#D8D8D8"/>
            </pixel-data>
        </layer>

        <!-- Духовка светится (z=6, анимируемый overlay) -->
        <layer id="oven-glow" type="animated-overlay" z-order="6" width="48" height="48"
               condition="state:baking">
            <pixel-data>
                <rect x="15" y="23" w="18" h="12" color="#FFE0A0"/>
                <rect x="16" y="24" w="16" h="10" color="#FFD080"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <!-- Idle: плита выключена -->
        <animation name="idle" frames="1" fps="1" loop="false"
                   frame-width="48" frame-height="48">
            <frame index="0" layer-offsets=""/>
        </animation>

        <!-- Cooking: конфорка мерцает + пар поднимается -->
        <animation name="cooking" frames="4" fps="3" loop="true"
                   frame-width="48" frame-height="48"
                   condition="state:cooking">
            <description>
                Конфорка мерцает между двумя оттенками
                оранжевого (#FF6030 / #FF8050).
                Пар поднимается тремя пикселями вверх
                и рассеивается.
            </description>
            <frame index="0" layer-offsets="burner-glow:0,0; pot-steam:0,0"/>
            <frame index="1" layer-offsets="burner-glow:0,0; pot-steam:0,-2"/>
            <frame index="2" layer-offsets="burner-glow:0,0; pot-steam:1,-4"/>
            <frame index="3" layer-offsets="burner-glow:0,0; pot-steam:0,-6"/>
        </animation>

        <!-- Baking: духовка пульсирует тёплым светом -->
        <animation name="baking" frames="2" fps="1" loop="true"
                   frame-width="48" frame-height="48"
                   condition="state:baking">
            <description>
                Стекло духовки пульсирует между
                тёплым жёлтым (#FFE0A0) и насыщенным (#FFD080).
            </description>
            <frame index="0" layer-offsets="oven-glow:0,0"/>
            <frame index="1" layer-offsets="oven-glow:0,0"/>
        </animation>

        <!-- Cooking + Baking одновременно -->
        <animation name="full-cooking" frames="4" fps="3" loop="true"
                   frame-width="48" frame-height="48"
                   condition="state:full-cooking">
            <description>
                Конфорка + пар + духовка все активны.
                Максимальная активность плиты.
            </description>
            <frame index="0" layer-offsets="burner-glow:0,0; pot-steam:0,0; oven-glow:0,0"/>
            <frame index="1" layer-offsets="burner-glow:0,0; pot-steam:0,-2; oven-glow:0,0"/>
            <frame index="2" layer-offsets="burner-glow:0,0; pot-steam:1,-4; oven-glow:0,0"/>
            <frame index="3" layer-offsets="burner-glow:0,0; pot-steam:0,-6; oven-glow:0,0"/>
        </animation>
    </animations>

    <states>
        <state name="idle" description="Плита выключена"/>
        <state name="cooking" description="Готовка на конфорке — огонь + пар"/>
        <state name="baking" description="Выпечка в духовке — свечение стекла"/>
        <state name="full-cooking" description="Конфорка + духовка активны"/>
    </states>

    <interaction>
        <action code="COOK" description="Готовить на плите — переход idle → cooking"/>
        <action code="BAKE" description="Печь в духовке — переход idle → baking"/>
        <action code="COOK_TOGETHER" description="Готовить с Александром — повышение relationship"/>
        <action code="FINISH" description="Завершить — переход * → idle"/>
    </interaction>

    <naming>
        <output-dir>furniture/stove</output-dir>
    </naming>
</asset-spec>
