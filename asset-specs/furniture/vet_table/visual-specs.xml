<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>furniture</entity-type>
        <entity-name>vet_table</entity-name>
        <version>1.0.0</version>
        <location>vet_clinic</location>
        <description>
            Ветеринарный стол осмотра — для квестов save_lada, duke_arrives.
            Визуально — стальной стол с лампой.
            Не является регулярным действием, используется в квестах.
        </description>
    </meta>

    <layers>
        <layer id="table" type="base" z-order="0" width="48" height="36">
            <pixel-data>
                <!-- Столешница -->
                <rect x="4" y="16" w="40" h="4" color="#B0B0B0"/>
                <rect x="4" y="16" w="40" h="1" color="#C0C0C0"/>
                <!-- Ножки -->
                <rect x="8" y="20" w="3" h="16" color="#909090"/>
                <rect x="37" y="20" w="3" h="16" color="#909090"/>
                <!-- Основание -->
                <rect x="4" y="34" w="40" h="2" color="#808080"/>
                <!-- Подушка для питомца -->
                <rect x="10" y="12" w="28" h="6" color="#E8E8F0"/>
                <rect x="10" y="12" w="28" h="1" color="#D8D8E0"/>
            </pixel-data>
        </layer>

        <layer id="lamp" type="base" z-order="1" width="48" height="36">
            <pixel-data>
                <!-- Стойка лампы -->
                <rect x="40" y="2" w="2" h="14" color="#606060"/>
                <!-- Плафон -->
                <rect x="34" y="0" w="12" h="4" color="#808080"/>
                <rect x="36" y="3" w="8" h="2" color="#FFFACD"/>
            </pixel-data>
        </layer>

        <layer id="light_cone" type="animated-overlay" z-order="2" width="48" height="36"
               condition="state:examining">
            <pixel-data>
                <rect x="14" y="6" w="20" h="10" color="#FFFDE880"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <animation name="idle" frames="1" fps="1" loop="false"
                   frame-width="48" frame-height="36">
            <frame index="0" layer-offsets=""/>
        </animation>

        <animation name="examining" frames="2" fps="1" loop="true"
                   frame-width="48" frame-height="36"
                   condition="state:examining">
            <description>Лампа включена, лёгкое мерцание конуса света</description>
            <frame index="0" layer-offsets="light_cone:0,0"/>
            <frame index="1" layer-offsets="light_cone:0,1"/>
        </animation>
    </animations>

    <states>
        <state name="idle" description="Стол пустой, лампа выключена"/>
        <state name="examining" description="Осмотр питомца — лампа включена"/>
    </states>

    <interaction>
        <action code="VET_EXAMINE" description="Начать осмотр (квестовое действие)"/>
    </interaction>

    <naming>
        <output-dir>furniture/vet_table</output-dir>
    </naming>
</asset-spec>