<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>furniture</entity-type>
        <entity-name>phone</entity-name>
        <version>1.0.0</version>
        <location>home_room</location>
        <description>
            Смартфон Тани — используется для действий «Позвонить»,
            «Листать соцсети», получения уведомлений о событиях.
            Лежит на столе/тумбочке. В руке обрабатывается
            анимацией персонажа (tanya/phone-talk).
        </description>
    </meta>

    <layers>
        <!-- Корпус телефона (z=0) -->
        <layer id="body" type="base" z-order="0" width="16" height="20">
            <pixel-data>
                <!-- Корпус -->
                <rect x="4" y="3" w="8" h="14" color="#2A2A2A"/>
                <!-- Скругления углов -->
                <pixel x="4" y="3" color="#3A3A3A"/>
                <pixel x="11" y="3" color="#3A3A3A"/>
                <pixel x="4" y="16" color="#3A3A3A"/>
                <pixel x="11" y="16" color="#3A3A3A"/>
                <!-- Боковая грань (блик) -->
                <vline x="12" y="4" len="12" color="#404040"/>
                <!-- Фронтальная камера -->
                <pixel x="8" y="4" color="#1A1A3A"/>
            </pixel-data>
        </layer>

        <!-- Экран (z=1, анимируемый) -->
        <layer id="screen" type="animated" z-order="1" width="16" height="20">
            <pixel-data>
                <!-- Экран выключен (базовое состояние) -->
                <rect x="5" y="5" w="6" h="10" color="#1A1A1A"/>
            </pixel-data>
        </layer>

        <!-- Notification dot (z=2, overlay по условию) -->
        <layer id="notification-dot" type="overlay" z-order="2" width="16" height="20"
               condition="state:has-notification">
            <pixel-data>
                <pixel x="10" y="3" color="#E74C3C"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <!-- Idle: телефон лежит, экран выключен -->
        <animation name="idle" frames="1" fps="1" loop="false"
                   frame-width="16" frame-height="20">
            <frame index="0" layer-offsets=""/>
        </animation>

        <!-- Incoming: экран мигает розовым + вибрация корпуса -->
        <animation name="incoming" frames="6" fps="8" loop="true"
                   frame-width="16" frame-height="20"
                   condition="state:incoming">
            <description>
                Кадр 0: экран вспыхивает розовым (#FF6B9D), корпус сдвиг +1px X
                Кадр 1: экран яркий (#FFB6C1), корпус сдвиг -1px X
                Кадр 2: экран вспыхивает (#FF6B9D), корпус сдвиг +1px X
                Кадр 3: экран затухает (#FF8AAE), корпус сдвиг -1px X
                Кадр 4: экран тусклый (#3A2030), корпус нейтрально
                Кадр 5: экран выключен, пауза перед циклом
            </description>
            <frame index="0" layer-offsets="body:1,0; screen:1,0"/>
            <frame index="1" layer-offsets="body:-1,0; screen:-1,0"/>
            <frame index="2" layer-offsets="body:1,0; screen:1,0"/>
            <frame index="3" layer-offsets="body:-1,0; screen:-1,0"/>
            <frame index="4" layer-offsets=""/>
            <frame index="5" layer-offsets=""/>
        </animation>

        <!-- Notification: однократная вспышка экрана -->
        <animation name="notification-pulse" frames="4" fps="3" loop="true"
                   frame-width="16" frame-height="20"
                   condition="state:has-notification">
            <description>
                Кадр 0: экран подсвечивается (#FF6B9D)
                Кадр 1: экран ярко (#FFB6C1)
                Кадр 2: экран затухает (#3A2030)
                Кадр 3: экран выключен (пауза)
            </description>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets=""/>
            <frame index="2" layer-offsets=""/>
            <frame index="3" layer-offsets=""/>
        </animation>
    </animations>

    <states>
        <state name="idle" description="Телефон лежит, экран выключен"/>
        <state name="incoming" description="Входящий звонок — экран мигает, корпус вибрирует"/>
        <state name="has-notification" description="Есть непрочитанное уведомление — красная точка + пульс экрана"/>
        <state name="in-hand" description="Телефон в руке Тани — объект скрыт, используется анимация персонажа phone-talk"/>
    </states>

    <interaction>
        <action code="PHONE_CALL" description="Позвонить — переход idle → in-hand (объект скрыт, Таня играет phone-talk)"/>
        <action code="BROWSE_SOCIAL" description="Листать соцсети — переход idle → in-hand"/>
        <action code="ANSWER_CALL" description="Ответить на входящий — переход incoming → in-hand"/>
        <action code="DISMISS" description="Отклонить — переход incoming → idle"/>
    </interaction>

    <naming>
        <output-dir>furniture/phone</output-dir>
    </naming>
</asset-spec>
