<?xml version="1.0" encoding="UTF-8"?>
<asset-spec extends="abstract/materials/metal@1.0" version="2.0.0">
    <meta>
        <entity-type>furniture</entity-type>
        <entity-name>gym_equipment</entity-name>
        <version>2.0.0</version>
        <canvas width="192" height="160" displayScale="1.0"/>
        <location>gym</location>
        <description>
            Беговая дорожка — интерактивный объект для действия "Тренировка".
            Canvas ×4: 48×40 → 192×160.
        </description>
    </meta>

    <color-palette>
        <color name="$frame_main" value="#404040"/>
        <color name="$frame_top" value="#505050"/>
        <color name="$frame_dark" value="#303030"/>
        <color name="$display_bg" value="#1A1A2E"/>
        <color name="$display_panel" value="#0F3460"/>
        <color name="$display_glow" value="#00FF88"/>
        <color name="$belt_main" value="#333333"/>
        <color name="$belt_line" value="#3A3A3A"/>
        <color name="$rail" value="#606060"/>
        <color name="$sweat" value="#87CEEB"/>
    </color-palette>

    <layers>
        <layer id="frame" type="base" z-order="0" width="192" height="160">
            <pixel-data>
                <rect x="16" y="40" w="160" h="96" color="$frame_main"/>
                <rect x="16" y="40" w="160" h="8" color="$frame_top"/>
                <!-- Стойки -->
                <rect x="24" y="8" w="12" h="40" color="$frame_top"/>
                <rect x="156" y="8" w="12" h="40" color="$frame_top"/>
                <!-- Дисплей -->
                <rect x="32" y="8" w="128" h="32" color="$display_bg"/>
                <rect x="40" y="12" w="112" h="24" color="$display_panel"/>
                <!-- Кнопки на панели -->
                <rect x="44" y="32" w="8" h="4" color="#CC3333"/>
                <rect x="56" y="32" w="8" h="4" color="#33CC33"/>
                <rect x="68" y="32" w="8" h="4" color="#3333CC"/>
                <!-- Полотно -->
                <rect x="32" y="56" w="128" h="64" color="$belt_main"/>
                <rect x="32" y="56" w="128" h="4" color="#444444"/>
                <!-- Ножки -->
                <rect x="24" y="136" w="16" h="24" color="$frame_dark"/>
                <rect x="152" y="136" w="16" h="24" color="$frame_dark"/>
                <!-- Поручни -->
                <rect x="16" y="32" w="8" h="56" color="$rail"/>
                <rect x="168" y="32" w="8" h="56" color="$rail"/>
                <!-- Текстура metal grip -->
                <hline x="16" y="40" len="8" color="#707070"/>
                <hline x="16" y="48" len="8" color="#707070"/>
                <hline x="168" y="40" len="8" color="#707070"/>
                <hline x="168" y="48" len="8" color="#707070"/>
            </pixel-data>
        </layer>

        <layer id="display_glow" type="animated" z-order="1" width="192" height="160">
            <pixel-data>
                <!-- Скорость -->
                <rect x="48" y="16" w="32" h="16" color="$display_glow"/>
                <!-- Калории -->
                <rect x="88" y="16" w="24" h="16" color="$display_glow"/>
                <!-- Время -->
                <rect x="120" y="16" w="24" h="16" color="$display_glow"/>
            </pixel-data>
        </layer>

        <layer id="belt_lines" type="animated" z-order="2" width="192" height="160">
            <pixel-data>
                <rect x="32" y="72" w="128" h="2" color="$belt_line"/>
                <rect x="32" y="88" w="128" h="2" color="$belt_line"/>
                <rect x="32" y="104" w="128" h="2" color="$belt_line"/>
            </pixel-data>
        </layer>

        <layer id="sweat_drops" type="animated-overlay" z-order="3" width="192" height="160"
               condition="state:active">
            <pixel-data>
                <rect x="80" y="0" w="4" h="4" color="$sweat"/>
                <rect x="112" y="4" w="4" h="4" color="$sweat"/>
                <rect x="96" y="0" w="4" h="4" color="$sweat"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <animation name="idle" frames="4" fps="1" loop="true"
                   frame-width="192" frame-height="160">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="display_glow:0,0"/>
            <frame index="2" layer-offsets=""/>
            <frame index="3" layer-offsets="display_glow:0,0"/>
        </animation>

        <animation name="active" frames="10" fps="4" loop="true"
                   frame-width="192" frame-height="160"
                   condition="state:active">
            <frame index="0" layer-offsets="belt_lines:0,0; sweat_drops:0,0; display_glow:0,0"/>
            <frame index="1" layer-offsets="belt_lines:0,4; sweat_drops:2,-2; display_glow:0,0"/>
            <frame index="2" layer-offsets="belt_lines:0,8; sweat_drops:-2,-4; display_glow:0,0"/>
            <frame index="3" layer-offsets="belt_lines:0,12; sweat_drops:0,-6; display_glow:0,0"/>
            <frame index="4" layer-offsets="belt_lines:0,16; sweat_drops:2,-8; display_glow:0,0"/>
            <frame index="5" layer-offsets="belt_lines:0,0; sweat_drops:-2,-10; display_glow:0,0"/>
            <frame index="6" layer-offsets="belt_lines:0,4; sweat_drops:0,0; display_glow:0,0"/>
            <frame index="7" layer-offsets="belt_lines:0,8; sweat_drops:2,-2; display_glow:0,0"/>
            <frame index="8" layer-offsets="belt_lines:0,12; sweat_drops:-2,-4; display_glow:0,0"/>
            <frame index="9" layer-offsets="belt_lines:0,16; sweat_drops:0,-6; display_glow:0,0"/>
        </animation>
    </animations>

    <states>
        <state name="idle" description="Дорожка выключена, дисплей в standby"/>
        <state name="active" description="Тренировка — полотно движется, пот летит"/>
    </states>

    <interaction>
        <action code="EXERCISE" description="Начать тренировку — idle → active"/>
        <action code="STOP_EXERCISE" description="Закончить — active → idle"/>
    </interaction>

    <naming>
        <output-dir>furniture/gym_equipment</output-dir>
    </naming>
</asset-spec>