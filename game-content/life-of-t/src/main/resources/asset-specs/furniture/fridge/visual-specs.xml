<?xml version="1.0" encoding="UTF-8"?>
<asset-spec extends="abstract/materials/metal@1.0" version="2.0.0">
    <meta>
        <entity-type>furniture</entity-type>
        <entity-name>fridge</entity-name>
        <version>2.0.0</version>
        <canvas width="128" height="224" displayScale="1.0"/>
        <location>kitchen</location>
        <description>
            Холодильник — интерактивный объект кухни.
            Действие «Перекусить»: быстрое восстановление energy.
            Canvas ×4: 32×56 → 128×224.
        </description>
    </meta>

    <color-palette>
        <color name="$body_main" value="#F0EDE8"/>
        <color name="$body_shadow" value="#D8D4D0"/>
        <color name="$body_highlight" value="#F8F8F4"/>
        <color name="$door_main" value="#E8E4E0"/>
        <color name="$seal" value="#B0ACA8"/>
        <color name="$handle" value="#C0C0C0"/>
        <color name="$handle_highlight" value="#D0D0D0"/>
        <color name="$led_on" value="#40C040"/>
        <color name="$interior_light" value="#FFF8E0"/>
        <color name="$freezer_light" value="#E0F0FF"/>
        <color name="$feet" value="#A0A0A0"/>
    </color-palette>

    <layers>
        <!-- z=0: Корпус -->
        <layer id="body" type="base" z-order="0" width="128" height="224">
            <pixel-data>
                <rect x="16" y="16" w="96" h="192" color="$body_main"/>
                <rect x="16" y="16" w="4" h="192" color="$body_shadow"/>
                <rect x="108" y="16" w="4" h="192" color="$body_highlight"/>
                <hline x="16" y="204" len="96" color="#C8C4C0"/>
                <!-- Ножки -->
                <rect x="24" y="208" w="12" h="12" color="$feet"/>
                <rect x="92" y="208" w="12" h="12" color="$feet"/>
                <!-- Тень у ножек -->
                <rect x="24" y="218" w="12" h="2" color="#888888"/>
                <rect x="92" y="218" w="12" h="2" color="#888888"/>
                <!-- Текстура brushed metal -->
                <hline x="24" y="40" len="80" color="#E8E8E4"/>
                <hline x="24" y="80" len="80" color="#E8E8E4"/>
                <hline x="24" y="120" len="80" color="#E8E8E4"/>
                <hline x="24" y="160" len="80" color="#E8E8E4"/>
            </pixel-data>
        </layer>

        <!-- z=1: Дверца (анимируемая) -->
        <layer id="door" type="animated" z-order="1" width="128" height="224">
            <pixel-data>
                <rect x="20" y="20" w="88" h="88" color="$door_main"/>
                <rect x="20" y="108" w="88" h="4" color="$seal"/>
                <rect x="20" y="112" w="88" h="88" color="$door_main"/>
                <!-- Бренд-лого (абстрактное) -->
                <rect x="52" y="24" w="24" h="4" color="#D0D0D0"/>
            </pixel-data>
        </layer>

        <!-- z=2: Ручка -->
        <layer id="handle" type="base" z-order="2" width="128" height="224">
            <pixel-data>
                <rect x="96" y="56" w="4" h="24" color="$handle"/>
                <rect x="96" y="56" w="4" h="4" color="$handle_highlight"/>
                <rect x="96" y="144" w="4" h="24" color="$handle"/>
                <rect x="96" y="144" w="4" h="4" color="$handle_highlight"/>
            </pixel-data>
        </layer>

        <!-- z=3: Магнитики -->
        <layer id="magnets" type="overlay" z-order="3" width="128" height="224">
            <pixel-data>
                <rect x="40" y="32" w="4" h="4" color="#FF6B9D"/>
                <rect x="56" y="40" w="4" h="4" color="#4ECDC4"/>
                <rect x="72" y="28" w="4" h="4" color="#FFE66D"/>
                <rect x="36" y="48" w="4" h="4" color="#A78BFA"/>
            </pixel-data>
        </layer>

        <!-- z=4: LED -->
        <layer id="led" type="animated-overlay" z-order="4" width="128" height="224">
            <pixel-data>
                <rect x="32" y="120" w="4" h="4" color="$led_on"/>
            </pixel-data>
        </layer>

        <!-- z=5: Внутренности -->
        <layer id="interior" type="overlay" z-order="5" width="128" height="224"
               condition="state:open">
            <pixel-data>
                <!-- Подсветка верхней секции -->
                <rect x="24" y="24" w="80" h="80" color="$interior_light"/>
                <!-- Полки -->
                <rect x="24" y="48" w="80" h="4" color="#D0D0D0"/>
                <rect x="24" y="72" w="80" h="4" color="#D0D0D0"/>
                <!-- Продукты -->
                <rect x="32" y="28" w="12" h="16" color="#FF8080"/>
                <rect x="52" y="28" w="8" h="16" color="#80C0FF"/>
                <rect x="72" y="32" w="16" h="12" color="#FFD070"/>
                <rect x="32" y="52" w="16" h="16" color="#90D890"/>
                <rect x="56" y="56" w="12" h="12" color="#F0C080"/>
                <rect x="32" y="76" w="20" h="16" color="#E0E0E0"/>
                <rect x="64" y="76" w="12" h="12" color="#FFB0B0"/>
                <!-- Морозилка -->
                <rect x="24" y="116" w="80" h="80" color="$freezer_light"/>
                <rect x="24" y="152" w="80" h="4" color="#C0D0E0"/>
                <rect x="32" y="120" w="24" h="28" color="#C8E0F8"/>
                <rect x="64" y="124" w="20" h="20" color="#D0D8F0"/>
                <!-- Иней -->
                <pixel x="28" y="118" color="#FFFFFF"/>
                <pixel x="48" y="120" color="#FFFFFF"/>
                <pixel x="80" y="118" color="#FFFFFF"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <animation name="idle" frames="2" fps="1" loop="true"
                   frame-width="128" frame-height="224">
            <frame index="0" layer-offsets="led:0,0"/>
            <frame index="1" layer-offsets="led:0,0"/>
        </animation>

        <animation name="open" frames="8" fps="6" loop="false"
                   frame-width="128" frame-height="224"
                   condition="state:opening">
            <frame index="0" layer-offsets="door:0,0; handle:0,0; magnets:0,0"/>
            <frame index="1" layer-offsets="door:2,0; handle:2,0; magnets:2,0"/>
            <frame index="2" layer-offsets="door:4,0; handle:4,0; magnets:4,0; interior:0,0"/>
            <frame index="3" layer-offsets="door:6,0; handle:6,0; magnets:6,0; interior:0,0"/>
            <frame index="4" layer-offsets="door:8,0; handle:8,0; magnets:8,0; interior:0,0"/>
            <frame index="5" layer-offsets="door:8,0; handle:8,0; magnets:8,0; interior:0,0"/>
            <frame index="6" layer-offsets="door:8,0; handle:8,0; magnets:8,0; interior:0,0"/>
            <frame index="7" layer-offsets="door:8,0; handle:8,0; magnets:8,0; interior:0,0"/>
        </animation>

        <animation name="close" frames="6" fps="6" loop="false"
                   frame-width="128" frame-height="224"
                   condition="state:closing">
            <frame index="0" layer-offsets="door:8,0; handle:8,0; magnets:8,0; interior:0,0"/>
            <frame index="1" layer-offsets="door:6,0; handle:6,0; magnets:6,0; interior:0,0"/>
            <frame index="2" layer-offsets="door:4,0; handle:4,0; magnets:4,0; interior:0,0"/>
            <frame index="3" layer-offsets="door:2,0; handle:2,0; magnets:2,0"/>
            <frame index="4" layer-offsets="door:0,0; handle:0,0; magnets:0,0"/>
            <frame index="5" layer-offsets=""/>
        </animation>
    </animations>

    <states>
        <state name="idle" description="Холодильник закрыт, LED мерцает"/>
        <state name="opening" description="Дверца открывается"/>
        <state name="open" description="Дверца открыта, видны полки"/>
        <state name="closing" description="Дверца закрывается"/>
    </states>

    <interaction>
        <action code="SNACK" description="Перекусить — idle → opening → open → closing → idle"/>
        <action code="GET_INGREDIENTS" description="Взять ингредиенты для готовки"/>
    </interaction>

    <naming>
        <output-dir>furniture/fridge</output-dir>
    </naming>
</asset-spec>