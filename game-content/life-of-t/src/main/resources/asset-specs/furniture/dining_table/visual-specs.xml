<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>furniture</entity-type>
        <entity-name>dining_table</entity-name>
        <version>1.0.0</version>
        <location>kitchen, parents_cottage</location>
        <description>
            Обеденный стол — место для совместных приёмов пищи.
            Действие "Есть вместе" повышает настроение.
        </description>
    </meta>

    <layers>
        <!-- z=0: ножки стола -->
        <layer id="legs" type="base" z-order="0" width="56" height="32">
            <pixel-data>
                <!-- четыре ножки -->
                <rect x="4" y="22" w="2" h="10" color="#5C3A1E"/>
                <rect x="50" y="22" w="2" h="10" color="#5C3A1E"/>
                <rect x="4" y="26" w="2" h="6" color="#4A2E14"/>
                <rect x="50" y="26" w="2" h="6" color="#4A2E14"/>
                <!-- передние ножки (ближе, видны частично) -->
                <rect x="14" y="24" w="2" h="8" color="#5C3A1E"/>
                <rect x="40" y="24" w="2" h="8" color="#5C3A1E"/>
            </pixel-data>
        </layer>

        <!-- z=1: столешница -->
        <layer id="tabletop" type="base" z-order="1" width="56" height="32">
            <pixel-data>
                <!-- столешница — широкая доска -->
                <rect x="2" y="18" w="52" h="4" color="#B8860B"/>
                <hline x="2" y="18" len="52" color="#CD9B1D"/>
                <hline x="2" y="19" len="52" color="#C8941A"/>
                <!-- кромка -->
                <hline x="2" y="21" len="52" color="#8B6914"/>
                <!-- текстура дерева -->
                <hline x="8" y="19" len="12" color="#AA7A08"/>
                <hline x="30" y="19" len="10" color="#AA7A08"/>
            </pixel-data>
        </layer>

        <!-- z=2: скатерть -->
        <layer id="tablecloth" type="overlay" z-order="2" width="56" height="32">
            <pixel-data>
                <!-- белая скатерть по центру -->
                <rect x="10" y="16" w="36" h="6" color="#FFFAF0"/>
                <hline x="10" y="16" len="36" color="#F5EDE0"/>
                <!-- свисающие края -->
                <rect x="8" y="20" w="2" h="4" color="#F5EDE0"/>
                <rect x="46" y="20" w="2" h="4" color="#F5EDE0"/>
                <!-- вышивка/узор -->
                <hline x="12" y="17" len="32" color="#E8D8C0"/>
            </pixel-data>
        </layer>

        <!-- z=3: тарелки — статичный overlay -->
        <layer id="plates" type="overlay" z-order="3" width="56" height="32">
            <pixel-data>
                <!-- левая тарелка -->
                <rect x="14" y="15" w="8" h="4" color="#F8F8F8"/>
                <rect x="15" y="16" w="6" h="2" color="#EEEEEE"/>
                <hline x="14" y="15" len="8" color="#DDDDDD"/>
                <!-- правая тарелка -->
                <rect x="34" y="15" w="8" h="4" color="#F8F8F8"/>
                <rect x="35" y="16" w="6" h="2" color="#EEEEEE"/>
                <hline x="34" y="15" len="8" color="#DDDDDD"/>
            </pixel-data>
        </layer>

        <!-- z=4: пар от еды — анимируемый overlay -->
        <layer id="steam" type="animated-overlay" z-order="4" width="56" height="32"
               condition="state:food_served">
            <pixel-data>
                <!-- пар — полупрозрачные пиксели -->
                <pixel x="17" y="13" color="#E0E0E0"/>
                <pixel x="18" y="11" color="#D0D0D0"/>
                <pixel x="16" y="10" color="#C0C0C0"/>
                <pixel x="37" y="13" color="#E0E0E0"/>
                <pixel x="38" y="11" color="#D0D0D0"/>
                <pixel x="36" y="10" color="#C0C0C0"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <!-- idle: стол без еды, полностью статичный -->
        <animation name="idle" frames="2" fps="1" loop="true"
                   frame-width="56" frame-height="32">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets=""/>
        </animation>

        <!-- steam-rise: пар поднимается от горячей еды -->
        <animation name="steam-rise" frames="4" fps="3" loop="true"
                   frame-width="56" frame-height="32"
                   condition="state:food_served">
            <frame index="0" layer-offsets="steam:0,0"/>
            <frame index="1" layer-offsets="steam:0,-1"/>
            <frame index="2" layer-offsets="steam:1,-2"/>
            <frame index="3" layer-offsets="steam:0,-3"/>
        </animation>
    </animations>

    <states>
        <state name="empty" description="Пустой стол со скатертью и тарелками"/>
        <state name="food_served" description="На столе еда, поднимается пар"/>
    </states>

    <interaction>
        <action code="EAT_TOGETHER" description="Есть вместе — повышает настроение обоих"/>
        <action code="SET_TABLE" description="Накрыть стол — переход empty → food_served"/>
        <action code="CLEAR_TABLE" description="Убрать со стола — переход food_served → empty"/>
    </interaction>

    <naming>
        <output-dir>furniture/dining_table</output-dir>
    </naming>
</asset-spec>
