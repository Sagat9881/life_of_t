<?xml version="1.0" encoding="UTF-8"?>
<asset-spec extends="abstract/materials/stone@1.0" version="2.0.0">
    <meta>
        <entity-type>furniture</entity-type>
        <entity-name>fireplace</entity-name>
        <version>2.0.0</version>
        <canvas width="160" height="192" displayScale="1.0"/>
        <location>parents_cottage</location>
        <description>
            Печка/камин в parents_cottage. Создаёт уют, рядом любит лежать Воланд.
            Фоновый объект для атмосферы зимних и вечерних сцен.
            Canvas ×4: 40×48 → 160×192.
        </description>
    </meta>

    <color-palette>
        <color name="$brick_main" value="#8B4513"/>
        <color name="$brick_mortar" value="#6B3510"/>
        <color name="$brick_dark" value="#5A3A10"/>
        <color name="$brick_accent" value="#6B4520"/>
        <color name="$firebox_dark" value="#1A0A00"/>
        <color name="$soot" value="#0D0500"/>
        <color name="$grate_dark" value="#333333"/>
        <color name="$grate_light" value="#444444"/>
        <color name="$mantel_main" value="#A0703C"/>
        <color name="$mantel_light" value="#B88050"/>
        <color name="$mantel_dark" value="#8B5E3C"/>
        <color name="$fire_orange" value="#FF6600"/>
        <color name="$fire_yellow" value="#FFAA00"/>
        <color name="$fire_tip" value="#FFDD00"/>
        <color name="$ember_base" value="#CC3300"/>
        <color name="$ember_glow" value="#FF4400"/>
        <color name="$ember_dark" value="#661100"/>
        <color name="$smoke" value="#AAAAAA"/>
    </color-palette>

    <layers>
        <!-- z=0: кирпичная кладка ×4 -->
        <layer id="brickwork" type="base" z-order="0" width="160" height="192">
            <pixel-data>
                <rect x="16" y="40" w="128" h="136" color="$brick_main"/>
                <!-- ряды кирпичей (горизонтальные швы каждые 16px) -->
                <rect x="16" y="56" w="128" h="2" color="$brick_mortar"/>
                <rect x="16" y="72" w="128" h="2" color="$brick_mortar"/>
                <rect x="16" y="88" w="128" h="2" color="$brick_mortar"/>
                <rect x="16" y="104" w="128" h="2" color="$brick_mortar"/>
                <rect x="16" y="120" w="128" h="2" color="$brick_mortar"/>
                <rect x="16" y="136" w="128" h="2" color="$brick_mortar"/>
                <rect x="16" y="152" w="128" h="2" color="$brick_mortar"/>
                <!-- вертикальные швы (смещённые через ряд) -->
                <rect x="48" y="40" w="2" h="16" color="$brick_mortar"/>
                <rect x="80" y="40" w="2" h="16" color="$brick_mortar"/>
                <rect x="112" y="40" w="2" h="16" color="$brick_mortar"/>
                <rect x="64" y="56" w="2" h="16" color="$brick_mortar"/>
                <rect x="96" y="56" w="2" h="16" color="$brick_mortar"/>
                <rect x="48" y="72" w="2" h="16" color="$brick_mortar"/>
                <rect x="80" y="72" w="2" h="16" color="$brick_mortar"/>
                <rect x="112" y="72" w="2" h="16" color="$brick_mortar"/>
                <rect x="64" y="88" w="2" h="16" color="$brick_mortar"/>
                <rect x="96" y="88" w="2" h="16" color="$brick_mortar"/>
                <!-- трещины в кирпичах -->
                <hline x="52" y="48" len="8" color="#7A3A0E"/>
                <hline x="90" y="80" len="6" color="#7A3A0E"/>
                <pixel x="70" y="100" color="#7A3A0E"/>
                <pixel x="71" y="101" color="#7A3A0E"/>
                <!-- фундамент -->
                <rect x="8" y="168" w="144" h="16" color="$brick_dark"/>
                <hline x="8" y="168" len="144" color="$brick_accent"/>
                <hline x="8" y="172" len="144" color="#4A3010"/>
            </pixel-data>
        </layer>

        <!-- z=1: топка (тёмное отверстие) -->
        <layer id="firebox" type="base" z-order="1" width="160" height="192">
            <pixel-data>
                <rect x="40" y="96" w="80" h="72" color="$firebox_dark"/>
                <rect x="48" y="88" w="64" h="8" color="$firebox_dark"/>
                <rect x="56" y="80" w="48" h="8" color="$firebox_dark"/>
                <!-- сажа внутри -->
                <rect x="44" y="100" w="72" h="64" color="$soot"/>
                <!-- обводка арки -->
                <rect x="40" y="96" w="4" h="4" color="#4A2A08"/>
                <rect x="116" y="96" w="4" h="4" color="#4A2A08"/>
                <rect x="48" y="88" w="4" h="4" color="#4A2A08"/>
                <rect x="108" y="88" w="4" h="4" color="#4A2A08"/>
                <rect x="56" y="80" w="4" h="4" color="#4A2A08"/>
                <rect x="100" y="80" w="4" h="4" color="#4A2A08"/>
            </pixel-data>
        </layer>

        <!-- z=2: решётка -->
        <layer id="grate" type="base" z-order="2" width="160" height="192">
            <pixel-data>
                <rect x="48" y="152" w="64" h="4" color="$grate_dark"/>
                <rect x="48" y="144" w="64" h="4" color="$grate_dark"/>
                <rect x="56" y="144" w="4" h="16" color="$grate_light"/>
                <rect x="72" y="144" w="4" h="16" color="$grate_light"/>
                <rect x="88" y="144" w="4" h="16" color="$grate_light"/>
                <rect x="104" y="144" w="4" h="16" color="$grate_light"/>
            </pixel-data>
        </layer>

        <!-- z=3: полка над камином -->
        <layer id="mantel" type="base" z-order="3" width="160" height="192">
            <pixel-data>
                <rect x="8" y="32" w="144" h="12" color="$mantel_main"/>
                <hline x="8" y="32" len="144" color="$mantel_light"/>
                <hline x="8" y="33" len="144" color="$mantel_light"/>
                <hline x="8" y="40" len="144" color="$mantel_dark"/>
                <hline x="8" y="41" len="144" color="$mantel_dark"/>
                <!-- фоторамка на полке -->
                <rect x="24" y="24" w="12" h="10" color="#8B6B4A"/>
                <rect x="26" y="26" w="8" h="6" color="#D0C0A0"/>
                <!-- подсвечник -->
                <rect x="120" y="26" w="4" h="8" color="#C0A030"/>
                <pixel x="121" y="24" color="#FFD700"/>
                <pixel x="122" y="24" color="#FFD700"/>
            </pixel-data>
        </layer>

        <!-- z=4: труба -->
        <layer id="chimney" type="base" z-order="4" width="160" height="192">
            <pixel-data>
                <rect x="64" y="0" w="32" h="40" color="$brick_main"/>
                <hline x="64" y="0" len="32" color="$brick_mortar"/>
                <hline x="64" y="8" len="32" color="$brick_mortar"/>
                <hline x="64" y="16" len="32" color="$brick_mortar"/>
                <hline x="64" y="24" len="32" color="$brick_mortar"/>
                <!-- навершие -->
                <rect x="56" y="0" w="48" h="4" color="$brick_dark"/>
            </pixel-data>
        </layer>

        <!-- z=5: огонь -->
        <layer id="fire" type="animated-overlay" z-order="5" width="160" height="192"
               condition="state:lit">
            <pixel-data>
                <rect x="56" y="120" w="48" h="40" color="$fire_orange"/>
                <rect x="64" y="112" w="32" h="16" color="$fire_yellow"/>
                <rect x="72" y="104" w="16" h="8" color="$fire_tip"/>
                <!-- угли -->
                <rect x="48" y="152" w="64" h="12" color="$ember_base"/>
                <pixel x="56" y="152" color="$ember_glow"/>
                <pixel x="80" y="152" color="$ember_glow"/>
                <pixel x="104" y="152" color="$ember_glow"/>
                <!-- верхушки -->
                <pixel x="76" y="100" color="#FFEE44"/>
                <pixel x="80" y="96" color="#FFCC22"/>
                <pixel x="78" y="98" color="#FFDD33"/>
            </pixel-data>
        </layer>

        <!-- z=6: угли (embers state) -->
        <layer id="embers" type="animated-overlay" z-order="6" width="160" height="192"
               condition="state:embers">
            <pixel-data>
                <rect x="48" y="148" w="64" h="16" color="$ember_dark"/>
                <rect x="56" y="150" w="4" h="4" color="$ember_base"/>
                <rect x="72" y="148" w="4" h="4" color="#AA2200"/>
                <rect x="88" y="150" w="4" h="4" color="$ember_base"/>
                <rect x="104" y="148" w="4" h="4" color="#AA2200"/>
                <rect x="64" y="156" w="4" h="4" color="#882200"/>
                <rect x="96" y="156" w="4" h="4" color="#882200"/>
            </pixel-data>
        </layer>

        <!-- z=7: дым из трубы -->
        <layer id="smoke" type="animated-overlay" z-order="7" width="160" height="192"
               condition="state:lit">
            <pixel-data>
                <rect x="76" y="0" w="4" h="4" color="$smoke"/>
                <rect x="80" y="0" w="4" h="4" color="#999999"/>
                <rect x="72" y="0" w="4" h="4" color="#888888"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <animation name="idle" frames="2" fps="1" loop="true"
                   frame-width="160" frame-height="192">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets=""/>
        </animation>

        <animation name="fire" frames="10" fps="4" loop="true"
                   frame-width="160" frame-height="192"
                   condition="state:lit">
            <frame index="0" layer-offsets="fire:0,0; smoke:0,0"/>
            <frame index="1" layer-offsets="fire:4,-4; smoke:0,-2"/>
            <frame index="2" layer-offsets="fire:-4,-8; smoke:2,-4"/>
            <frame index="3" layer-offsets="fire:0,-4; smoke:-2,-6"/>
            <frame index="4" layer-offsets="fire:4,0; smoke:0,-8"/>
            <frame index="5" layer-offsets="fire:-4,-4; smoke:2,-10"/>
            <frame index="6" layer-offsets="fire:2,-6; smoke:-2,-12"/>
            <frame index="7" layer-offsets="fire:-2,-2; smoke:0,-14"/>
            <frame index="8" layer-offsets="fire:4,-4; smoke:2,-16"/>
            <frame index="9" layer-offsets="fire:0,0; smoke:-2,-18"/>
        </animation>

        <animation name="embers-glow" frames="8" fps="2" loop="true"
                   frame-width="160" frame-height="192"
                   condition="state:embers">
            <frame index="0" layer-offsets="embers:0,0"/>
            <frame index="1" layer-offsets="embers:0,0"/>
            <frame index="2" layer-offsets="embers:2,0"/>
            <frame index="3" layer-offsets="embers:0,0"/>
            <frame index="4" layer-offsets="embers:0,0"/>
            <frame index="5" layer-offsets="embers:-2,0"/>
            <frame index="6" layer-offsets="embers:0,0"/>
            <frame index="7" layer-offsets="embers:2,0"/>
        </animation>
    </animations>

    <states>
        <state name="cold" description="Камин потушен, пусто"/>
        <state name="lit" description="Горит огонь, идёт дым из трубы"/>
        <state name="embers" description="Огонь потух, угли тлеют"/>
    </states>

    <interaction>
        <action code="LIGHT" description="Разжечь камин — переход cold → lit"/>
        <action code="EXTINGUISH" description="Потушить — переход lit → embers → cold"/>
    </interaction>

    <naming>
        <output-dir>furniture/fireplace</output-dir>
    </naming>
</asset-spec>