<?xml version="1.0" encoding="UTF-8"?>
<asset-spec extends="abstract/materials/fabric@1.0" version="2.0.0">
    <meta>
        <entity-type>furniture</entity-type>
        <entity-name>tent</entity-name>
        <version>2.0.0</version>
        <canvas width="192" height="144" displayScale="1.0"/>
        <location>summer_camp</location>
        <description>
            Палатка на summer_camp. Место ночёвки.
            Canvas ×4: 48×36 → 192×144.
        </description>
    </meta>

    <color-palette>
        <color name="$stake" value="#888888"/>
        <color name="$stake_shadow" value="#777777"/>
        <color name="$rope" value="#C8B896"/>
        <color name="$base_edge" value="#446644"/>
        <color name="$floor" value="#556655"/>
        <color name="$canvas_dark" value="#4A7A4A"/>
        <color name="$canvas_mid" value="#5A8A5A"/>
        <color name="$canvas_main" value="#6A9A6A"/>
        <color name="$canvas_light" value="#7AAA7A"/>
        <color name="$canvas_top" value="#8ABA8A"/>
        <color name="$canvas_peak" value="#9ACA9A"/>
        <color name="$canvas_seam" value="#3A6A3A"/>
        <color name="$canvas_highlight" value="#6AAA6A"/>
        <color name="$door_inside" value="#2A1A0A"/>
        <color name="$flag_red" value="#DD4444"/>
        <color name="$flag_shadow" value="#CC3333"/>
        <color name="$pole" value="#888888"/>
    </color-palette>

    <layers>
        <!-- z=0: колышки и растяжки -->
        <layer id="stakes" type="base" z-order="0" width="192" height="144">
            <pixel-data>
                <!-- Левый колышек -->
                <rect x="8" y="120" w="4" h="8" color="$stake"/>
                <rect x="8" y="124" w="4" h="4" color="$stake_shadow"/>
                <!-- Правый колышек -->
                <rect x="180" y="120" w="4" h="8" color="$stake"/>
                <rect x="180" y="124" w="4" h="4" color="$stake_shadow"/>
                <!-- Растяжки левые -->
                <rect x="12" y="116" w="4" h="4" color="$rope"/>
                <rect x="16" y="112" w="4" h="4" color="$rope"/>
                <rect x="20" y="108" w="4" h="4" color="$rope"/>
                <!-- Растяжки правые -->
                <rect x="176" y="116" w="4" h="4" color="$rope"/>
                <rect x="172" y="112" w="4" h="4" color="$rope"/>
                <rect x="168" y="108" w="4" h="4" color="$rope"/>
                <!-- Задние растяжки -->
                <rect x="40" y="128" w="4" h="4" color="$rope"/>
                <rect x="152" y="128" w="4" h="4" color="$rope"/>
            </pixel-data>
        </layer>

        <!-- z=1: каркас -->
        <layer id="frame" type="base" z-order="1" width="192" height="144">
            <pixel-data>
                <rect x="24" y="120" w="144" h="4" color="$base_edge"/>
                <rect x="32" y="112" w="128" h="8" color="$floor"/>
            </pixel-data>
        </layer>

        <!-- z=2: ткань палатки -->
        <layer id="canvas" type="animated" z-order="2" width="192" height="144">
            <pixel-data>
                <!-- Основание -->
                <rect x="24" y="104" w="144" h="16" color="$canvas_dark"/>
                <!-- Средняя часть -->
                <rect x="32" y="88" w="128" h="16" color="$canvas_mid"/>
                <!-- Верхняя часть -->
                <rect x="48" y="72" w="96" h="16" color="$canvas_main"/>
                <!-- Сужение -->
                <rect x="64" y="56" w="64" h="16" color="$canvas_light"/>
                <!-- Конёк -->
                <rect x="80" y="40" w="32" h="16" color="$canvas_top"/>
                <rect x="88" y="32" w="16" h="8" color="$canvas_peak"/>
                <!-- Центральный шов -->
                <rect x="96" y="32" w="2" h="88" color="$canvas_seam"/>
                <!-- Тень левой стороны -->
                <rect x="24" y="104" w="4" h="16" color="$canvas_seam"/>
                <rect x="32" y="88" w="4" h="16" color="$canvas_seam"/>
                <!-- Блик правой стороны -->
                <rect x="164" y="104" w="4" h="16" color="$canvas_highlight"/>
                <!-- Текстура стежков -->
                <hline x="40" y="96" len="112" color="$canvas_seam"/>
                <hline x="56" y="80" len="80" color="$canvas_seam"/>
                <hline x="72" y="64" len="48" color="$canvas_seam"/>
            </pixel-data>
        </layer>

        <!-- z=3: полог входа -->
        <layer id="door-flap" type="animated" z-order="3" width="192" height="144">
            <pixel-data>
                <rect x="64" y="72" w="32" h="48" color="$canvas_mid"/>
                <rect x="68" y="76" w="24" h="40" color="$canvas_dark"/>
                <!-- Прорезь -->
                <rect x="80" y="80" w="2" h="32" color="$door_inside"/>
                <!-- Завязки -->
                <rect x="92" y="72" w="4" h="4" color="$rope"/>
                <rect x="96" y="72" w="4" h="4" color="$rope"/>
            </pixel-data>
        </layer>

        <!-- z=4: флажок -->
        <layer id="flag" type="base" z-order="4" width="192" height="144">
            <pixel-data>
                <rect x="96" y="16" w="2" h="16" color="$pole"/>
                <rect x="100" y="16" w="16" h="12" color="$flag_red"/>
                <rect x="112" y="20" w="4" h="4" color="$flag_shadow"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <animation name="idle" frames="10" fps="2" loop="true"
                   frame-width="192" frame-height="144">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="canvas:0,0; door-flap:-2,0; flag:0,0"/>
            <frame index="2" layer-offsets="canvas:-2,0; door-flap:-4,0; flag:-2,0"/>
            <frame index="3" layer-offsets="canvas:-2,0; door-flap:-2,0; flag:-2,0"/>
            <frame index="4" layer-offsets="canvas:0,0; door-flap:0,0; flag:0,0"/>
            <frame index="5" layer-offsets=""/>
            <frame index="6" layer-offsets="canvas:0,0; door-flap:2,0; flag:2,0"/>
            <frame index="7" layer-offsets="canvas:2,0; door-flap:4,0; flag:2,0"/>
            <frame index="8" layer-offsets="canvas:2,0; door-flap:2,0; flag:2,0"/>
            <frame index="9" layer-offsets="canvas:0,0; door-flap:0,0; flag:0,0"/>
        </animation>

        <animation name="wind" frames="10" fps="4" loop="true"
                   frame-width="192" frame-height="144"
                   condition="weather:windy">
            <frame index="0" layer-offsets="canvas:-4,0; door-flap:-8,0; flag:-4,0"/>
            <frame index="1" layer-offsets="canvas:4,0; door-flap:0,0; flag:4,0"/>
            <frame index="2" layer-offsets="canvas:-4,0; door-flap:8,0; flag:-4,0"/>
            <frame index="3" layer-offsets="canvas:0,0; door-flap:-4,0; flag:0,0"/>
            <frame index="4" layer-offsets="canvas:-4,0; door-flap:-8,0; flag:-4,0"/>
            <frame index="5" layer-offsets="canvas:4,0; door-flap:4,0; flag:4,0"/>
            <frame index="6" layer-offsets="canvas:-2,0; door-flap:0,0; flag:-2,0"/>
            <frame index="7" layer-offsets="canvas:2,0; door-flap:-4,0; flag:2,0"/>
            <frame index="8" layer-offsets="canvas:-4,0; door-flap:8,0; flag:-4,0"/>
            <frame index="9" layer-offsets="canvas:0,0; door-flap:0,0; flag:0,0"/>
        </animation>
    </animations>

    <states>
        <state name="empty" description="Пустая палатка"/>
        <state name="occupied" description="Кто-то внутри — полог закрыт"/>
    </states>

    <interaction>
        <action code="SLEEP" description="Спать в палатке — восстанавливает энергию"/>
        <action code="ENTER" description="Войти в палатку"/>
    </interaction>

    <naming>
        <output-dir>furniture/tent</output-dir>
    </naming>
</asset-spec>