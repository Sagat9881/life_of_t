<?xml version="1.0" encoding="UTF-8"?>
<asset-spec>
    <meta>
        <entity-type>furniture</entity-type>
        <entity-name>pet_bowl</entity-name>
        <version>1.0.0</version>
        <location>home_room, kitchen</location>
        <description>
            Двойная миска для питомцев (Гарфилд + Сэм).
            Действие «Покормить питомцев» — снижение hunger.
            Расположена на полу рядом с зоной кормления.
        </description>
    </meta>

    <layers>
        <!-- Коврик под мисками (z=0) -->
        <layer id="mat" type="base" z-order="0" width="24" height="16">
            <pixel-data>
                <rect x="2" y="10" w="20" h="4" color="#D8A0A0"/>
                <rect x="3" y="11" w="18" h="2" color="#C89090"/>
                <hline x="2" y="13" len="20" color="#B08080"/>
                <!-- Узор на коврике (лапки) -->
                <pixel x="6" y="11" color="#C07878"/>
                <pixel x="12" y="11" color="#C07878"/>
                <pixel x="17" y="11" color="#C07878"/>
            </pixel-data>
        </layer>

        <!-- Миска Гарфилда — большая, левая (z=1) -->
        <layer id="bowl-garfield" type="animated" z-order="1" width="24" height="16">
            <pixel-data>
                <!-- Корпус -->
                <rect x="3" y="6" w="8" h="5" color="#FFB6C1"/>
                <rect x="4" y="7" w="6" h="3" color="#FF9AAF"/>
                <!-- Блик -->
                <pixel x="4" y="7" color="#FFD0D8"/>
                <!-- Верхний край -->
                <hline x="3" y="6" len="8" color="#FF8AA0"/>
                <!-- Дно (тень) -->
                <hline x="4" y="10" len="6" color="#E0A0A8"/>
            </pixel-data>
        </layer>

        <!-- Миска Сэма — маленькая, правая (z=2) -->
        <layer id="bowl-sam" type="animated" z-order="2" width="24" height="16">
            <pixel-data>
                <!-- Корпус -->
                <rect x="13" y="7" w="7" h="4" color="#B5EAD7"/>
                <rect x="14" y="8" w="5" h="2" color="#A0D8C0"/>
                <!-- Блик -->
                <pixel x="14" y="8" color="#C8F0E0"/>
                <!-- Верхний край -->
                <hline x="13" y="7" len="7" color="#90C8B0"/>
                <!-- Дно (тень) -->
                <hline x="14" y="10" len="5" color="#88B8A0"/>
            </pixel-data>
        </layer>

        <!-- Еда в миске Гарфилда — full (z=3, overlay по условию) -->
        <layer id="food-garfield-full" type="overlay" z-order="3" width="24" height="16"
               condition="state:garfield-full OR state:both-full">
            <pixel-data>
                <rect x="4" y="7" w="6" h="2" color="#C89060"/>
                <rect x="5" y="7" w="4" h="1" color="#D8A070"/>
            </pixel-data>
        </layer>

        <!-- Еда в миске Гарфилда — half (z=3, overlay по условию) -->
        <layer id="food-garfield-half" type="overlay" z-order="3" width="24" height="16"
               condition="state:garfield-half">
            <pixel-data>
                <rect x="4" y="8" w="6" h="1" color="#C89060"/>
            </pixel-data>
        </layer>

        <!-- Еда в миске Сэма — full (z=4, overlay по условию) -->
        <layer id="food-sam-full" type="overlay" z-order="4" width="24" height="16"
               condition="state:sam-full OR state:both-full">
            <pixel-data>
                <rect x="14" y="8" w="5" h="1" color="#A08050"/>
                <rect x="15" y="8" w="3" h="1" color="#B09060"/>
            </pixel-data>
        </layer>

        <!-- Еда в миске Сэма — half (z=4, overlay по условию) -->
        <layer id="food-sam-half" type="overlay" z-order="4" width="24" height="16"
               condition="state:sam-half">
            <pixel-data>
                <rect x="15" y="8" w="3" h="1" color="#A08050"/>
            </pixel-data>
        </layer>

        <!-- Брызги при наполнении (z=5, одноразовый overlay) -->
        <layer id="splash" type="animated-overlay" z-order="5" width="24" height="16"
               condition="state:filling">
            <pixel-data>
                <pixel x="5" y="5" color="#D8A070"/>
                <pixel x="9" y="4" color="#D8A070"/>
                <pixel x="15" y="5" color="#A08050"/>
                <pixel x="18" y="6" color="#A08050"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <!-- Idle: миски стоят, статика -->
        <animation name="idle" frames="1" fps="1" loop="false"
                   frame-width="24" frame-height="16">
            <frame index="0" layer-offsets=""/>
        </animation>

        <!-- Eating: миски покачиваются, питомец ест -->
        <animation name="eating-garfield" frames="6" fps="5" loop="true"
                   frame-width="24" frame-height="16"
                   condition="state:garfield-eating">
            <description>
                Миска Гарфилда покачивается влево-вправо,
                имитируя как кот уткнулся мордой и ест.
                Плавное раскачивание с паузами.
            </description>
            <frame index="0" layer-offsets="bowl-garfield:0,0"/>
            <frame index="1" layer-offsets="bowl-garfield:1,0"/>
            <frame index="2" layer-offsets="bowl-garfield:1,0"/>
            <frame index="3" layer-offsets="bowl-garfield:0,0"/>
            <frame index="4" layer-offsets="bowl-garfield:-1,0"/>
            <frame index="5" layer-offsets="bowl-garfield:-1,0"/>
        </animation>

        <animation name="eating-sam" frames="6" fps="6" loop="true"
                   frame-width="24" frame-height="16"
                   condition="state:sam-eating">
            <description>
                Миска Сэма покачивается быстрее (маленькая собака,
                энергичнее ест). Чуть более частая амплитуда.
            </description>
            <frame index="0" layer-offsets="bowl-sam:0,0"/>
            <frame index="1" layer-offsets="bowl-sam:1,0"/>
            <frame index="2" layer-offsets="bowl-sam:0,0"/>
            <frame index="3" layer-offsets="bowl-sam:-1,0"/>
            <frame index="4" layer-offsets="bowl-sam:0,0"/>
            <frame index="5" layer-offsets="bowl-sam:1,0"/>
        </animation>

        <!-- Fill: наполнение с брызгами -->
        <animation name="fill" frames="4" fps="8" loop="false"
                   frame-width="24" frame-height="16"
                   condition="state:filling">
            <description>
                Быстрая одноразовая анимация: еда появляется
                в мисках, маленькие брызги-крошки взлетают вверх.
            </description>
            <frame index="0" layer-offsets="splash:0,0"/>
            <frame index="1" layer-offsets="splash:0,-1"/>
            <frame index="2" layer-offsets="splash:1,-2"/>
            <frame index="3" layer-offsets=""/>
        </animation>
    </animations>

    <states>
        <state name="empty" description="Обе миски пустые"/>
        <state name="garfield-full" description="Миска Гарфилда полная"/>
        <state name="garfield-half" description="Миска Гарфилда наполовину"/>
        <state name="sam-full" description="Миска Сэма полная"/>
        <state name="sam-half" description="Миска Сэма наполовину"/>
        <state name="both-full" description="Обе миски полные"/>
        <state name="garfield-eating" description="Гарфилд ест — миска качается"/>
        <state name="sam-eating" description="Сэм ест — миска качается быстрее"/>
        <state name="filling" description="Наполнение мисок — брызги"/>
    </states>

    <interaction>
        <action code="FEED_PETS" description="Покормить питомцев — переход empty → filling → both-full"/>
        <action code="FEED_GARFIELD" description="Покормить Гарфилда — filling → garfield-full"/>
        <action code="FEED_SAM" description="Покормить Сэма — filling → sam-full"/>
    </interaction>

    <naming>
        <output-dir>furniture/pet_bowl</output-dir>
    </naming>
</asset-spec>
