<?xml version="1.0" encoding="UTF-8"?>
<!--
    Life of T — Abstract Dog Visual Spec v2.0
    Canvas: 128×96 pixels
    View: SIDE PROFILE — head faces LEFT (small x), tail at RIGHT (large x)
    10 layers: paws(z=0) hind_legs(z=1) front_legs(z=2) body(z=3) belly(z=4)
               tail(z=5) neck(z=6) head(z=7) ears(z=8) face_details(z=9)
    5 animations: idle(16) walk(16) sleep(8) play(16) eat(12)

    FIX v2.0.2:
      - color-palette: id= → name=  ($ variable resolution)
      - layer type= attribute RESTORED (parser requires non-blank type)
      - removed z-order=, width=, height= from layer elements (not in schema)
-->
<asset-spec abstract="true" version="2.0">
    <meta>
        <entity-type>abstract</entity-type>
        <entity-name>dog</entity-name>
        <spec-version>2.0</spec-version>
        <canvas width="128" height="96"/>
        <display-scale>1.5</display-scale>
    </meta>

    <color-palette>
        <color name="$fur_base"        value="#C8A060"/>
        <color name="$fur_shadow"      value="#9A7840"/>
        <color name="$fur_highlight"   value="#E0C080"/>
        <color name="$belly_base"      value="#F0E0B8"/>
        <color name="$belly_highlight" value="#FFF8E0"/>
        <color name="$nose_color"      value="#1A1410"/>
        <color name="$eye_color"       value="#5A3818"/>
        <color name="$eye_bright"      value="#7A5028"/>
        <color name="$paw_pad"         value="#7A6050"/>
        <color name="$ear_inner"       value="#D4A878"/>
        <color name="$tongue_color"    value="#E87878"/>
        <color name="$far_layer_tint"  value="#A08050"/>
    </color-palette>

    <layers>

        <!-- z=0  PAWS -->
        <layer id="paws" type="base">
            <pixel-data>
                <!-- FL far paw (behind) -->
                <rect  x="34" y="83" w="12" h="8"  color="$far_layer_tint"/>
                <rect  x="34" y="87" w="12" h="3"  color="$paw_pad"/>
                <hline x="34" y="90" len="12"       color="$fur_shadow"/>
                <!-- FL near paw -->
                <rect  x="46" y="83" w="12" h="8"  color="$fur_base"/>
                <rect  x="48" y="83" w="6"  h="3"  color="$fur_highlight"/>
                <rect  x="46" y="87" w="12" h="3"  color="$paw_pad"/>
                <hline x="46" y="90" len="12"       color="$fur_shadow"/>
                <!-- HL far paw (behind) -->
                <rect  x="72" y="83" w="12" h="8"  color="$far_layer_tint"/>
                <rect  x="72" y="87" w="12" h="3"  color="$paw_pad"/>
                <hline x="72" y="90" len="12"       color="$fur_shadow"/>
                <!-- HL near paw -->
                <rect  x="84" y="83" w="14" h="8"  color="$fur_base"/>
                <rect  x="86" y="83" w="7"  h="3"  color="$fur_highlight"/>
                <rect  x="84" y="87" w="14" h="3"  color="$paw_pad"/>
                <hline x="84" y="90" len="14"       color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- z=1  HIND LEGS -->
        <layer id="hind_legs" type="base">
            <pixel-data>
                <!-- HL far — thigh -->
                <rect  x="70" y="44" w="20" h="24" color="$far_layer_tint"/>
                <rect  x="74" y="44" w="8"  h="24" color="$fur_shadow"/>
                <!-- HL far — stifle spur -->
                <rect  x="86" y="62" w="8"  h="10" color="$fur_shadow"/>
                <!-- HL far — shin -->
                <rect  x="76" y="66" w="12" h="18" color="$far_layer_tint"/>
                <!-- HL far — metatarsus -->
                <rect  x="74" y="80" w="12" h="10" color="$far_layer_tint"/>
                <!-- HL near — thigh -->
                <rect  x="82" y="44" w="20" h="12" color="$fur_base"/>
                <rect  x="84" y="56" w="18" h="12" color="$fur_base"/>
                <rect  x="86" y="44" w="8"  h="24" color="$fur_highlight"/>
                <vline x="82" y="44" len="24"       color="$fur_shadow"/>
                <!-- HL near — stifle spur -->
                <rect  x="98"  y="62" w="8"  h="10" color="$fur_base"/>
                <rect  x="100" y="63" w="4"  h="6"  color="$fur_highlight"/>
                <hline x="98"  y="71" len="8"        color="$fur_shadow"/>
                <!-- HL near — shin -->
                <rect  x="88" y="66" w="12" h="18" color="$fur_base"/>
                <rect  x="90" y="66" w="5"  h="18" color="$fur_highlight"/>
                <vline x="100" y="66" len="18"      color="$fur_shadow"/>
                <!-- HL near — metatarsus -->
                <rect  x="86" y="80" w="12" h="10" color="$fur_base"/>
                <rect  x="88" y="80" w="5"  h="10" color="$fur_highlight"/>
                <vline x="86" y="80" len="10"       color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- z=2  FRONT LEGS -->
        <layer id="front_legs" type="base">
            <pixel-data>
                <!-- FL far — thigh -->
                <rect  x="32" y="58" w="16" h="14" color="$far_layer_tint"/>
                <rect  x="36" y="58" w="6"  h="14" color="$fur_shadow"/>
                <!-- FL far — shin -->
                <rect  x="34" y="70" w="12" h="14" color="$far_layer_tint"/>
                <!-- FL near — thigh -->
                <rect  x="44" y="58" w="16" h="14" color="$fur_base"/>
                <rect  x="48" y="58" w="6"  h="14" color="$fur_highlight"/>
                <vline x="44" y="58" len="14"       color="$fur_shadow"/>
                <!-- elbow -->
                <hline x="44" y="68" len="16"       color="$fur_shadow"/>
                <hline x="46" y="69" len="12"       color="$fur_highlight"/>
                <!-- FL near — shin -->
                <rect  x="46" y="70" w="12" h="14" color="$fur_base"/>
                <rect  x="48" y="70" w="5"  h="14" color="$fur_highlight"/>
                <vline x="46" y="70" len="14"       color="$fur_shadow"/>
                <vline x="58" y="70" len="14"       color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- z=3  BODY -->
        <layer id="body" type="base">
            <pixel-data>
                <!-- main torso -->
                <rect  x="42" y="28" w="70" h="46" color="$fur_base"/>
                <!-- withers -->
                <rect  x="42" y="22" w="38" h="8"  color="$fur_base"/>
                <rect  x="44" y="22" w="32" h="6"  color="$fur_highlight"/>
                <!-- croup -->
                <rect  x="78" y="30" w="34" h="8"  color="$fur_base"/>
                <rect  x="80" y="30" w="28" h="6"  color="$fur_shadow"/>
                <!-- spine dorsal highlight -->
                <hline x="44" y="22" len="66"       color="$fur_highlight"/>
                <hline x="44" y="23" len="62"       color="$fur_highlight"/>
                <!-- chest front wall -->
                <vline x="42" y="28" len="46"       color="$fur_shadow"/>
                <vline x="43" y="28" len="44"       color="$fur_shadow"/>
                <!-- rear rump wall -->
                <vline x="111" y="28" len="46"      color="$fur_shadow"/>
                <vline x="112" y="28" len="44"      color="$fur_shadow"/>
                <!-- underbelly shadow -->
                <hline x="44" y="72" len="66"       color="$fur_shadow"/>
                <hline x="44" y="73" len="66"       color="$fur_shadow"/>
                <!-- ribcage shading -->
                <rect  x="48" y="34" w="6"  h="28" color="$fur_shadow"/>
                <rect  x="96" y="34" w="6"  h="28" color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- z=4  BELLY -->
        <layer id="belly" type="overlay">
            <pixel-data>
                <rect  x="52" y="50" w="46" h="24" color="$belly_base"/>
                <rect  x="62" y="56" w="26" h="14" color="$belly_highlight"/>
                <!-- sternum -->
                <rect  x="44" y="46" w="14" h="22" color="$belly_base"/>
                <rect  x="46" y="48" w="8"  h="18" color="$belly_highlight"/>
                <!-- edge fade -->
                <vline x="52" y="50" len="24"       color="$fur_base"/>
                <vline x="98" y="50" len="24"       color="$fur_base"/>
                <!-- bottom shadow -->
                <hline x="52" y="73" len="46"       color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- z=5  TAIL -->
        <layer id="tail" type="base">
            <pixel-data>
                <!-- ROOT -->
                <rect  x="106" y="34" w="6"  h="5"  color="$fur_base"/>
                <rect  x="107" y="34" w="3"  h="3"  color="$fur_highlight"/>
                <hline x="106" y="38" len="6"        color="$fur_shadow"/>
                <!-- seg 1 -->
                <rect  x="108" y="30" w="5"  h="5"  color="$fur_base"/>
                <rect  x="109" y="30" w="2"  h="3"  color="$fur_highlight"/>
                <hline x="108" y="34" len="5"        color="$fur_shadow"/>
                <!-- seg 2 -->
                <rect  x="110" y="27" w="5"  h="4"  color="$fur_base"/>
                <rect  x="111" y="27" w="2"  h="2"  color="$fur_highlight"/>
                <hline x="110" y="30" len="5"        color="$fur_shadow"/>
                <!-- seg 3 -->
                <rect  x="112" y="24" w="4"  h="4"  color="$fur_base"/>
                <rect  x="113" y="24" w="2"  h="2"  color="$fur_highlight"/>
                <!-- seg 4 -->
                <rect  x="114" y="22" w="4"  h="3"  color="$fur_base"/>
                <rect  x="115" y="22" w="2"  h="2"  color="$fur_highlight"/>
                <!-- seg 5 -->
                <rect  x="116" y="20" w="4"  h="3"  color="$fur_base"/>
                <rect  x="117" y="20" w="2"  h="2"  color="$fur_highlight"/>
                <!-- seg 6 -->
                <rect  x="118" y="19" w="3"  h="3"  color="$fur_base"/>
                <pixel x="119" y="19"                color="$fur_highlight"/>
                <!-- seg 7 -->
                <rect  x="120" y="18" w="3"  h="2"  color="$fur_base"/>
                <pixel x="121" y="18"                color="$fur_highlight"/>
                <!-- seg 8 -->
                <rect  x="122" y="17" w="3"  h="2"  color="$fur_base"/>
                <!-- TIP -->
                <rect  x="124" y="16" w="2"  h="2"  color="$fur_highlight"/>
                <pixel x="126" y="16"                color="$fur_highlight"/>
                <!-- underside shadow -->
                <pixel x="108" y="34"                color="$fur_shadow"/>
                <pixel x="112" y="30"                color="$fur_shadow"/>
                <pixel x="116" y="25"                color="$fur_shadow"/>
                <pixel x="120" y="21"                color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- z=6  NECK -->
        <layer id="neck" type="base">
            <pixel-data>
                <!-- base -->
                <rect  x="44" y="32" w="24" h="12" color="$fur_base"/>
                <rect  x="48" y="32" w="10" h="12" color="$fur_highlight"/>
                <vline x="44" y="32" len="12"       color="$fur_shadow"/>
                <vline x="68" y="32" len="12"       color="$fur_shadow"/>
                <!-- mid -->
                <rect  x="38" y="22" w="22" h="12" color="$fur_base"/>
                <rect  x="42" y="22" w="8"  h="12" color="$fur_highlight"/>
                <vline x="38" y="22" len="12"       color="$fur_shadow"/>
                <vline x="60" y="22" len="12"       color="$fur_shadow"/>
                <!-- throat highlight -->
                <rect  x="44" y="22" w="6"  h="22" color="$belly_base"/>
                <vline x="44" y="22" len="22"       color="$belly_highlight"/>
                <!-- top -->
                <rect  x="30" y="12" w="20" h="12" color="$fur_base"/>
                <rect  x="34" y="12" w="8"  h="12" color="$fur_highlight"/>
                <vline x="30" y="12" len="12"       color="$fur_shadow"/>
                <vline x="50" y="12" len="12"       color="$fur_shadow"/>
                <!-- dewlap -->
                <rect  x="36" y="20" w="6"  h="12" color="$belly_base"/>
            </pixel-data>
        </layer>

        <!-- z=7  HEAD -->
        <layer id="head" type="base">
            <pixel-data>
                <!-- skull -->
                <rect  x="18" y="4"  w="30" h="26" color="$fur_base"/>
                <rect  x="22" y="4"  w="20" h="8"  color="$fur_highlight"/>
                <hline x="20" y="4"  len="24"       color="$fur_highlight"/>
                <!-- skull back -->
                <vline x="48" y="8"  len="18"       color="$fur_shadow"/>
                <vline x="47" y="6"  len="20"       color="$fur_shadow"/>
                <!-- occiput -->
                <rect  x="44" y="4"  w="6"  h="6"  color="$fur_base"/>
                <!-- stop -->
                <rect  x="14" y="18" w="12" h="10" color="$fur_base"/>
                <hline x="16" y="18" len="8"        color="$fur_shadow"/>
                <!-- muzzle -->
                <rect  x="4"  y="20" w="22" h="14" color="$fur_base"/>
                <rect  x="6"  y="20" w="16" h="5"  color="$fur_highlight"/>
                <vline x="4"  y="20" len="14"       color="$fur_highlight"/>
                <rect  x="8"  y="18" w="14" h="4"  color="$fur_base"/>
                <hline x="10" y="18" len="10"       color="$fur_highlight"/>
                <!-- cheek -->
                <rect  x="16" y="24" w="10" h="8"  color="$fur_highlight"/>
                <!-- jaw bottom -->
                <hline x="6"  y="33" len="40"       color="$fur_shadow"/>
                <hline x="8"  y="34" len="36"       color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- z=8  EARS -->
        <layer id="ears" type="base">
            <pixel-data>
                <!-- FAR EAR -->
                <hline x="30" y="8"  len="10"       color="$fur_base"/>
                <hline x="32" y="5"  len="6"        color="$fur_base"/>
                <hline x="33" y="3"  len="4"        color="$fur_base"/>
                <pixel x="35" y="2"                 color="$fur_base"/>
                <rect  x="31" y="5"  w="6"  h="4"  color="$ear_inner"/>
                <hline x="32" y="4"  len="4"        color="$ear_inner"/>
                <vline x="30" y="5"  len="4"        color="$fur_shadow"/>
                <vline x="40" y="5"  len="4"        color="$fur_shadow"/>
                <!-- NEAR EAR -->
                <hline x="22" y="6"  len="12"       color="$fur_base"/>
                <hline x="24" y="3"  len="8"        color="$fur_base"/>
                <hline x="25" y="1"  len="5"        color="$fur_base"/>
                <pixel x="27" y="0"                 color="$fur_base"/>
                <rect  x="23" y="3"  w="8"  h="4"  color="$ear_inner"/>
                <hline x="24" y="2"  len="6"        color="$ear_inner"/>
                <hline x="25" y="1"  len="4"        color="$belly_highlight"/>
                <vline x="22" y="3"  len="4"        color="$fur_shadow"/>
                <vline x="34" y="3"  len="4"        color="$fur_shadow"/>
                <hline x="22" y="7"  len="14"       color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- z=9  FACE DETAILS -->
        <layer id="face_details" type="overlay">
            <pixel-data>
                <!-- BROW -->
                <hline x="20" y="9"  len="8"        color="$fur_shadow"/>
                <hline x="21" y="8"  len="6"        color="$fur_shadow"/>
                <!-- EYE — single, near side, profile -->
                <rect  x="20" y="10" w="10" h="8"  color="#FFFFFF"/>
                <rect  x="22" y="11" w="6"  h="6"  color="$eye_color"/>
                <pixel x="22" y="11"                color="$eye_bright"/>
                <pixel x="23" y="11"                color="$eye_bright"/>
                <rect  x="24" y="12" w="2"  h="4"  color="#0A0A0A"/>
                <pixel x="21" y="11"                color="#FFFFFF"/>
                <hline x="20" y="10" len="10"       color="$fur_shadow"/>
                <hline x="20" y="18" len="10"       color="$fur_shadow"/>
                <!-- NOSE -->
                <rect  x="4"  y="24" w="8"  h="6"  color="$nose_color"/>
                <hline x="5"  y="24" len="4"        color="#383830"/>
                <hline x="5"  y="25" len="3"        color="#303028"/>
                <pixel x="6"  y="25"                color="#000000"/>
                <pixel x="8"  y="27"                color="#000000"/>
                <rect  x="6"  y="20" w="4"  h="5"  color="$fur_shadow"/>
                <!-- MOUTH -->
                <hline x="6"  y="30" len="10"       color="$fur_shadow"/>
                <pixel x="6"  y="29"                color="$fur_shadow"/>
                <pixel x="16" y="29"                color="$fur_shadow"/>
                <hline x="8"  y="31" len="8"        color="$fur_shadow"/>
            </pixel-data>
        </layer>

    </layers>

    <animations>

        <animation name="idle" frames="16" fps="4" loop="true"
                   frame-width="128" frame-height="96">
            <frame index="0"  layer-offsets=""/>
            <frame index="1"  layer-offsets="body:0,-1; belly:0,-1; neck:0,-1; head:0,-1; ears:0,-1; face_details:0,-1"/>
            <frame index="2"  layer-offsets=""/>
            <frame index="3"  layer-offsets="tail:3,-2"/>
            <frame index="4"  layer-offsets="tail:0,-3"/>
            <frame index="5"  layer-offsets="tail:-3,-2"/>
            <frame index="6"  layer-offsets="tail:0,0"/>
            <frame index="7"  layer-offsets="head:2,0; ears:2,0; face_details:2,0"/>
            <frame index="8"  layer-offsets="head:-2,0; ears:-2,0; face_details:-2,0"/>
            <frame index="9"  layer-offsets=""/>
            <frame index="10" layer-offsets="body:0,-1; belly:0,-1; neck:0,-1; head:0,-1; ears:0,-1; face_details:0,-1"/>
            <frame index="11" layer-offsets=""/>
            <frame index="12" layer-offsets="ears:0,-2; face_details:0,0"/>
            <frame index="13" layer-offsets=""/>
            <frame index="14" layer-offsets="tail:3,-2"/>
            <frame index="15" layer-offsets="tail:-3,-2"/>
        </animation>

        <animation name="walk" frames="16" fps="6" loop="true"
                   frame-width="128" frame-height="96">
            <frame index="0"  layer-offsets="front_legs:-3,0; paws:-3,0; hind_legs:3,0; tail:2,-2"/>
            <frame index="1"  layer-offsets="front_legs:-3,0; paws:-3,0; hind_legs:3,-2; body:0,-2; belly:0,-2; neck:0,-2; head:0,-2; ears:0,-2; face_details:0,-2; tail:3,-4"/>
            <frame index="2"  layer-offsets="front_legs:0,-2; paws:0,0; hind_legs:0,0; body:0,-2; belly:0,-2; neck:0,-2; head:0,-2; ears:0,-2; face_details:0,-2; tail:-2,-2"/>
            <frame index="3"  layer-offsets="front_legs:0,-2; paws:0,0; hind_legs:-3,0; body:0,-2; belly:0,-2; neck:0,-2; head:0,-2; ears:0,-2; face_details:0,-2; tail:-3,-4"/>
            <frame index="4"  layer-offsets="front_legs:3,0; paws:3,0; hind_legs:-3,0; tail:-2,-2"/>
            <frame index="5"  layer-offsets="front_legs:3,0; paws:3,0; hind_legs:-3,-2; body:0,-2; belly:0,-2; neck:0,-2; head:0,-2; ears:0,-2; face_details:0,-2; tail:2,-4"/>
            <frame index="6"  layer-offsets="front_legs:0,-2; paws:0,0; hind_legs:0,0; body:0,-2; belly:0,-2; neck:0,-2; head:0,-2; ears:0,-2; face_details:0,-2; tail:2,-2"/>
            <frame index="7"  layer-offsets="front_legs:0,-2; paws:0,0; hind_legs:3,0; body:0,-2; belly:0,-2; neck:0,-2; head:0,-2; ears:0,-2; face_details:0,-2; tail:-2,-2"/>
            <frame index="8"  layer-offsets="front_legs:-3,0; paws:-3,0; hind_legs:3,0; head:0,2; ears:0,2; face_details:0,2; tail:2,-2"/>
            <frame index="9"  layer-offsets="front_legs:0,-2; paws:0,0; body:0,-2; belly:0,-2; neck:0,-2; head:0,-2; ears:0,-2; face_details:0,-2; tail:-2,-2"/>
            <frame index="10" layer-offsets="front_legs:3,0; paws:3,0; hind_legs:-3,0; head:0,2; ears:0,2; face_details:0,2; tail:-2,-2"/>
            <frame index="11" layer-offsets="front_legs:0,-2; paws:0,0; body:0,-2; belly:0,-2; neck:0,-2; head:0,-2; ears:0,-2; face_details:0,-2; tail:2,-2"/>
            <frame index="12" layer-offsets="front_legs:-3,0; paws:-3,0; hind_legs:3,0; tail:0,-2"/>
            <frame index="13" layer-offsets="body:0,-2; belly:0,-2; neck:0,-2; head:0,-2; ears:0,-2; face_details:0,-2; tail:0,-4"/>
            <frame index="14" layer-offsets="front_legs:3,0; paws:3,0; hind_legs:-3,0; tail:0,-2"/>
            <frame index="15" layer-offsets="body:0,-2; belly:0,-2; neck:0,-2; head:0,-2; ears:0,-2; face_details:0,-2; tail:0,-4"/>
        </animation>

        <animation name="sleep" frames="8" fps="2" loop="true"
                   frame-width="128" frame-height="96">
            <frame index="0" layer-offsets="head:4,8; ears:4,10; face_details:4,10; neck:3,6; body:0,6; belly:0,6; front_legs:2,8; paws:4,10; hind_legs:0,6; tail:-8,4"/>
            <frame index="1" layer-offsets="head:4,6; ears:4,8;  face_details:4,8;  neck:3,4; body:0,4; belly:0,4; front_legs:2,8; paws:4,10; hind_legs:0,6; tail:-8,4"/>
            <frame index="2" layer-offsets="head:4,6; ears:4,8;  face_details:4,8;  neck:3,4; body:0,4; belly:0,4; front_legs:2,8; paws:4,10; hind_legs:0,6; tail:-8,4"/>
            <frame index="3" layer-offsets="head:4,8; ears:4,10; face_details:4,10; neck:3,6; body:0,6; belly:0,6; front_legs:2,8; paws:4,10; hind_legs:0,6; tail:-8,4"/>
            <frame index="4" layer-offsets="head:4,10; ears:4,12; face_details:4,12; neck:3,8; body:0,8; belly:0,8; front_legs:2,10; paws:4,12; hind_legs:0,8; tail:-8,6"/>
            <frame index="5" layer-offsets="head:4,10; ears:4,12; face_details:4,12; neck:3,8; body:0,8; belly:0,8; front_legs:2,10; paws:4,12; hind_legs:0,8; tail:-8,6"/>
            <frame index="6" layer-offsets="head:4,8;  ears:4,10; face_details:4,10; neck:3,6; body:0,6; belly:0,6; front_legs:2,6;  paws:6,10; hind_legs:0,6; tail:-8,4"/>
            <frame index="7" layer-offsets="head:4,8;  ears:4,10; face_details:4,10; neck:3,6; body:0,6; belly:0,6; front_legs:2,8;  paws:4,10; hind_legs:0,6; tail:-8,4"/>
        </animation>

        <animation name="play" frames="16" fps="5" loop="true"
