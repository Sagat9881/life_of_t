<?xml version="1.0" encoding="UTF-8"?>
<!--
    Life of T — Abstract Human Visual Spec v2.0
    Style: Punch Club 1/2 — isometric pixel art, ~3/4 front-right view.
    Canvas: 128×192 | displayScale: 1.5
    22 base layers, full pixel-data, $-variable colors.
    Concrete specs override via <color-palette> and <layer-overrides>.
    Anchor points (pixel centers, for animation offsets):
      head_bottom:      x=64, y=54
      neck_top:         x=64, y=52
      neck_bottom:      x=64, y=66
      shoulder_right:   x=98, y=66
      shoulder_left:    x=30, y=66
      elbow_right:      x=103, y=90
      elbow_left:       x=25, y=90
      wrist_right:      x=103, y=114
      wrist_left:       x=25, y=114
      torso_bottom:     x=64, y=104
      hip_right:        x=82, y=112
      hip_left:         x=46, y=112
      knee_right:       x=82, y=144
      knee_left:        x=46, y=144
      ankle_right:      x=82, y=176
      ankle_left:       x=46, y=176
-->
<asset-spec abstract="true" version="2.0">
    <meta>
        <entity-type>entities</entity-type>
        <entity-name>human</entity-name>
        <version>2.0</version>
        <canvas width="128" height="192" displayScale="1.5"/>
        <description>
            Abstract human template v2.0 — Punch Club isometric style.
            22 layers with full pixel-data. 5 base animations.
            All concrete human specs extend this via extends="abstract/entities/human@2.0".
        </description>
    </meta>

    <color-palette>
        <color name="$skin_base"                    value="#E8B888"/>
        <color name="$skin_shadow"                  value="#C89060"/>
        <color name="$skin_highlight"               value="#F8D0A8"/>
        <color name="$skin_dark"                    value="#A87040"/>

        <color name="$hair_base"                    value="#2A1A0A"/>
        <color name="$hair_shadow"                  value="#180E04"/>
        <color name="$hair_highlight"               value="#483820"/>

        <color name="$clothing_primary"             value="#3A5A8A"/>
        <color name="$clothing_primary_shadow"      value="#243A5A"/>
        <color name="$clothing_primary_highlight"   value="#5A7AAA"/>
        <color name="$clothing_primary_dark"        value="#182840"/>

        <color name="$clothing_secondary"           value="#304870"/>
        <color name="$clothing_secondary_shadow"    value="#1C2E4A"/>
        <color name="$clothing_secondary_highlight" value="#4A6090"/>

        <color name="$pants_base"                   value="#2A3040"/>
        <color name="$pants_shadow"                 value="#181E28"/>
        <color name="$pants_highlight"              value="#3A4050"/>
        <color name="$pants_seam"                   value="#161C26"/>

        <color name="$shoe_base"                    value="#1A1208"/>
        <color name="$shoe_shadow"                  value="#0A0804"/>
        <color name="$shoe_highlight"               value="#302010"/>
        <color name="$shoe_sole"                    value="#101010"/>

        <color name="$eye_color"                    value="#2E5080"/>
        <color name="$eye_highlight"                value="#4870A0"/>
        <color name="$eye_white"                    value="#E8E0D0"/>
        <color name="$eye_pupil"                    value="#080808"/>

        <color name="$lip_color"                    value="#B86858"/>
        <color name="$brow_color"                   value="#2A1A0A"/>

        <color name="$outline"                      value="#100808"/>
        <color name="$muscle_shadow"                value="#B87848"/>
        <color name="$muscle_highlight"             value="#F8C890"/>
