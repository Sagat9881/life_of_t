        <!-- LAYER 0: FOOT RIGHT                                          -->
        <!-- Isometric right foot, slight toe-right offset                -->
        <!-- x: 66..98, y: 174..188                                       -->
        <!-- ============================================================ -->
        <layer id="foot_right" type="base" z-order="0" width="128" height="192">
            <pixel-data>
                <!-- sole -->
                <rect x="66" y="183" w="34" h="3"  color="$shoe_sole"/>
                <!-- main body -->
                <rect x="68" y="174" w="30" h="12" color="$shoe_base"/>
                <!-- toe bump -->
                <rect x="94" y="176" w="6"  h="6"  color="$shoe_base"/>
                <!-- highlight band -->
                <hline x="70" y="174" len="26" color="$shoe_highlight"/>
                <!-- side shadow -->
                <vline x="68" y="174" len="12" color="$shoe_shadow"/>
                <!-- ankle crease -->
                <hline x="68" y="177" len="30" color="$shoe_shadow"/>
                <!-- sole edge -->
                <hline x="66" y="185" len="34" color="$outline"/>
                <!-- lace detail -->
