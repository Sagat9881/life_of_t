                <hline x="74" y="21" len="10" color="$brow_color"/>

                <!-- NOSE -->
                <rect x="60" y="36"  w="6"  h="6"  color="$skin_shadow"/>
                <rect x="56" y="40"  w="4"  h="3"  color="$skin_shadow"/>
                <rect x="68" y="40"  w="4"  h="3"  color="$skin_shadow"/>
                <hline x="58" y="42" len="12" color="$skin_dark"/>

                <!-- MOUTH -->
                <hline x="54" y="46" len="20" color="$skin_shadow"/>
                <rect x="56" y="47"  w="16" h="3"  color="$lip_color"/>
                <hline x="58" y="48" len="12" color="$skin_highlight"/>
                <hline x="54" y="50" len="20" color="$skin_highlight"/>

                <!-- CHIN CREASE -->
                <hline x="58" y="52" len="12" color="$skin_shadow"/>

                <!-- CHEEK BLUSH shadow -->
                <rect x="38"  y="36"  w="8"  h="6"  color="$skin_shadow"/>
                <rect x="82"  y="36"  w="8"  h="6"  color="$skin_shadow"/>
            </pixel-data>
        </layer>

        <!-- ============================================================ -->
        <!-- LAYER 17: HAIR BACK                                          -->
        <!-- ============================================================ -->
        <layer id="hair_back" type="overlay" z-order="17" width="128" height="192">
            <pixel-data>
                <!-- back sides -->
                <rect x="32" y="48"  w="10" h="18" color="$hair_shadow"/>
                <rect x="86" y="48"  w="10" h="18" color="$hair_shadow"/>
                <!-- behind ears -->
                <rect x="30" y="58"  w="6"  h="8"  color="$hair_base"/>
                <rect x="92" y="58"  w="6"  h="8"  color="$hair_base"/>
            </pixel-data>
        </layer>

        <!-- ============================================================ -->
        <!-- LAYER 18: HAIR FRONT                                         -->
        <!-- ============================================================ -->
        <layer id="hair_front" type="overlay" z-order="18" width="128" height="192">
            <pixel-data>
                <!-- crown -->
                <rect x="36" y="6"   w="56" h="14" color="$hair_base"/>
                <hline x="40" y="6"  len="48" color="$hair_highlight"/>
                <hline x="44" y="7"  len="36" color="$hair_highlight"/>
                <!-- side left -->
                <rect x="32" y="14"  w="8"  h="20" color="$hair_base"/>
                <rect x="30" y="18"  w="6"  h="16" color="$hair_shadow"/>
                <vline x="32" y="16" len="18" color="$hair_highlight"/>
                <!-- side right -->
                <rect x="88" y="14"  w="8"  h="20" color="$hair_base"/>
                <rect x="92" y="18"  w="6"  h="16" color="$hair_shadow"/>
                <vline x="95" y="16" len="18" color="$hair_highlight"/>
                <!-- fringe dip -->
                <hline x="50" y="14" len="28" color="$hair_shadow"/>
                <hline x="54" y="15" len="20" color="$hair_shadow"/>
            </pixel-data>
        </layer>

        <!-- ============================================================ -->
        <!-- LAYER 19: ACCESSORY (empty base — concrete specs override)   -->
        <!-- follows="neck" for necklaces, follows="head" for headwear    -->
        <!-- ============================================================ -->
        <layer id="accessory" type="overlay" z-order="19" width="128" height="192"/>

        <!-- ============================================================ -->
        <!-- LAYER 20: SHADOW                                             -->
        <!-- ============================================================ -->
        <layer id="shadow" type="effect" z-order="20" width="128" height="192">
            <pixel-data>
                <rect x="22" y="184" w="84" h="4"  color="#00000050"/>
                <rect x="28" y="186" w="72" h="4"  color="#00000038"/>
                <rect x="36" y="188" w="56" h="3"  color="#00000020"/>
            </pixel-data>
        </layer>

        <!-- ============================================================ -->
        <!-- LAYER 21: HIGHLIGHT (rim light — isometric top-left source)  -->
        <!-- ============================================================ -->
        <layer id="highlight" type="effect" z-order="21" width="128" height="192">
            <pixel-data>
                <!-- head left rim -->
                <vline x="38" y="10"  len="44" color="#FFFFFF20"/>
                <!-- torso left rim -->
                <vline x="32" y="64"  len="40" color="#FFFFFF18"/>
                <!-- left arm outer rim -->
                <vline x="18" y="66"  len="60" color="#FFFFFF14"/>
                <!-- left leg outer rim -->
                <vline x="36" y="112" len="64" color="#FFFFFF10"/>
            </pixel-data>
        </layer>

    </layers>

    <animations>
        <!-- ============================================================ -->
        <!-- IDLE — 12 frames, 6 fps, gentle body sway + breathing        -->
        <!-- ============================================================ -->
        <animation name="idle" frames="12" fps="6" loop="true"
                   frame-width="128" frame-height="192">
            <frame index="0"  layer-offsets=""/>
            <frame index="1"  layer-offsets="torso:0,-1; pelvis:0,-1; neck:0,-1; head:0,-1; face:0,-1; hair_back:0,-1; hair_front:0,-1; upper_arm_right:0,-1; upper_arm_left:0,-1; forearm_right:0,-1; forearm_left:0,-1; hand_right:0,-1; hand_left:0,-1; accessory:0,-1"/>
            <frame index="2"  layer-offsets="torso:0,-2; pelvis:0,-2; neck:0,-2; head:0,-2; face:0,-2; hair_back:0,-2; hair_front:0,-2; upper_arm_right:0,-2; upper_arm_left:0,-2; forearm_right:0,-2; forearm_left:0,-2; hand_right:0,-2; hand_left:0,-2; accessory:0,-2"/>
            <frame index="3"  layer-offsets="torso:0,-2; pelvis:0,-2; neck:0,-2; head:0,-2; face:0,-2; hair_back:0,-2; hair_front:0,-2; upper_arm_right:0,-2; upper_arm_left:0,-2; forearm_right:0,-2; forearm_left:0,-2; hand_right:0,-2; hand_left:0,-2; accessory:0,-2"/>
            <frame index="4"  layer-offsets="torso:0,-1; pelvis:0,-1; neck:0,-1; head:0,-1; face:0,-1; hair_back:0,-1; hair_front:0,-1; upper_arm_right:0,-1; upper_arm_left:0,-1; forearm_right:0,-1; forearm_left:0,-1; hand_right:0,-1; hand_left:0,-1; accessory:0,-1"/>
            <frame index="5"  layer-offsets=""/>
            <frame index="6"  layer-offsets="torso:0,1; pelvis:0,1; neck:0,1; head:0,1; face:0,1; hair_back:0,1; hair_front:0,1; upper_arm_right:1,1; upper_arm_left:-1,1; forearm_right:1,0; forearm_left:-1,0; hand_right:1,0; hand_left:-1,0; accessory:0,1"/>
            <frame index="7"  layer-offsets="torso:0,1; pelvis:0,1; neck:0,1; head:0,1; face:0,1; hair_back:0,1; hair_front:0,1; upper_arm_right:1,1; upper_arm_left:-1,1; forearm_right:1,0; forearm_left:-1,0; hand_right:1,0; hand_left:-1,0; accessory:0,1"/>
            <frame index="8"  layer-offsets="torso:0,1; pelvis:0,1; neck:0,1; head:0,1; face:0,1; hair_back:0,1; hair_front:0,1; upper_arm_right:0,1; upper_arm_left:0,1; accessory:0,1"/>
            <frame index="9"  layer-offsets=""/>
            <frame index="10" layer-offsets="neck:0,-1; head:0,-1; face:0,-1; hair_back:0,-1; hair_front:0,-1; accessory:0,-1"/>
            <frame index="11" layer-offsets=""/>
        </animation>

        <!-- ============================================================ -->
        <!-- WALK — 8 frames, 8 fps, isometric gait cycle                 -->
        <!-- Right leg leads on frames 0-3, left leg leads on frames 4-7 -->
        <!-- ============================================================ -->
        <animation name="walk" frames="8" fps="8" loop="true"
                   frame-width="128" frame-height="192">
            <!-- contact: right foot forward -->
            <frame index="0" layer-offsets="foot_right:2,-6; shin_right:2,-4; thigh_right:1,-2; pelvis:0,-1; torso:0,-1; neck:0,-1; head:0,-1; face:0,-1; hair_back:0,-1; hair_front:0,-1; upper_arm_right:-2,2; forearm_right:-3,3; hand_right:-3,3; upper_arm_left:2,-2; forearm_left:3,-3; hand_left:3,-3; accessory:0,-1"/>
            <!-- down: weight shifts right -->
            <frame index="1" layer-offsets="foot_right:1,-3; shin_right:1,-2; thigh_right:0,-1; upper_arm_right:-1,1; forearm_right:-2,2; hand_right:-2,2; upper_arm_left:1,-1; forearm_left:2,-2; hand_left:2,-2"/>
            <!-- passing: body highest, left leg swings through -->
            <frame index="2" layer-offsets="pelvis:0,-2; torso:0,-2; neck:0,-2; head:0,-2; face:0,-2; hair_back:0,-2; hair_front:0,-2; upper_arm_right:0,0; forearm_right:0,0; hand_right:0,0; upper_arm_left:0,0; forearm_left:0,0; hand_left:0,0; foot_left:-2,-2; shin_left:-1,-1; accessory:0,-2"/>
            <!-- up: left foot pushes off -->
            <frame index="3" layer-offsets="foot_left:-2,-4; shin_left:-1,-2; thigh_left:0,-1; pelvis:0,-1; torso:0,-1; neck:0,-1; head:0,-1; face:0,-1; hair_back:0,-1; hair_front:0,-1; upper_arm_right:-1,1; forearm_right:-1,2; hand_right:-1,2; upper_arm_left:1,-1; forearm_left:1,-2; hand_left:1,-2; accessory:0,-1"/>
            <!-- contact: left foot forward -->
            <frame index="4" layer-offsets="foot_left:-2,-6; shin_left:-2,-4; thigh_left:-1,-2; pelvis:0,-1; torso:0,-1; neck:0,-1; head:0,-1; face:0,-1; hair_back:0,-1; hair_front:0,-1; upper_arm_right:2,2; forearm_right:3,3; hand_right:3,3; upper_arm_left:-2,-2; forearm_left:-3,-3; hand_left:-3,-3; accessory:0,-1"/>
            <!-- down: weight shifts left -->
            <frame index="5" layer-offsets="foot_left:-1,-3; shin_left:-1,-2; thigh_left:0,-1; upper_arm_right:1,1; forearm_right:2,2; hand_right:2,2; upper_arm_left:-1,-1; forearm_left:-2,-2; hand_left:-2,-2"/>
            <!-- passing: body highest, right leg swings through -->
            <frame index="6" layer-offsets="pelvis:0,-2; torso:0,-2; neck:0,-2; head:0,-2; face:0,-2; hair_back:0,-2; hair_front:0,-2; upper_arm_right:0,0; forearm_right:0,0; hand_right:0,0; upper_arm_left:0,0; forearm_left:0,0; hand_left:0,0; foot_right:2,-2; shin_right:1,-1; accessory:0,-2"/>
            <!-- up: right foot pushes off -->
            <frame index="7" layer-offsets="foot_right:2,-4; shin_right:1,-2; thigh_right:0,-1; pelvis:0,-1; torso:0,-1; neck:0,-1; head:0,-1; face:0,-1; hair_back:0,-1; hair_front:0,-1; upper_arm_right:1,1; forearm_right:1,2; hand_right:1,2; upper_arm_left:-1,-1; forearm_left:-1,-2; hand_left:-1,-2; accessory:0,-1"/>
        </animation>

        <!-- ============================================================ -->
        <!-- INTERACT_GENERIC — 10 frames, 6 fps                          -->
        <!-- Forward lean + right arm reach toward object                 -->
        <!-- ============================================================ -->
        <animation name="interact_generic" frames="10" fps="6" loop="false"
                   frame-width="128" frame-height="192">
            <!-- anticipation: slight weight back -->
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="torso:0,1; neck:0,1; head:0,1; face:0,1; hair_back:0,1; hair_front:0,1; pelvis:0,1; accessory:0,1"/>
            <!-- reach initiation: lean forward, right arm lifts -->
            <frame index="2" layer-offsets="torso:1,-1; neck:1,-1; head:1,-1; face:1,-1; hair_back:1,-1; hair_front:1,-1; upper_arm_right:3,-4; forearm_right:4,-6; hand_right:5,-8; upper_arm_left:-1,1; forearm_left:-1,2; hand_left:-1,2; accessory:1,-1"/>
            <!-- reach mid: arm extends right-forward -->
            <frame index="3" layer-offsets="torso:2,-2; neck:2,-2; head:2,-2; face:2,-2; hair_back:2,-2; hair_front:2,-2; upper_arm_right:6,-8; forearm_right:8,-12; hand_right:10,-14; upper_arm_left:-2,2; forearm_left:-2,3; hand_left:-2,3; pelvis:1,-1; accessory:2,-2"/>
            <!-- full reach: maximum extension -->
            <frame index="4" layer-offsets="torso:2,-2; neck:2,-2; head:2,-2; face:2,-2; hair_back:2,-2; hair_front:2,-2; upper_arm_right:8,-10; forearm_right:12,-14; hand_right:14,-16; upper_arm_left:-2,2; forearm_left:-2,3; hand_left:-2,3; pelvis:1,-1; accessory:2,-2"/>
            <!-- hold: steady on object -->
            <frame index="5" layer-offsets="torso:2,-2; neck:2,-2; head:2,-2; face:2,-2; hair_back:2,-2; hair_front:2,-2; upper_arm_right:8,-10; forearm_right:12,-14; hand_right:14,-16; upper_arm_left:-2,2; forearm_left:-2,3; hand_left:-2,3; pelvis:1,-1; accessory:2,-2"/>
            <!-- action: slight push/pull on object -->
            <frame index="6" layer-offsets="torso:2,-2; neck:2,-2; head:2,-2; face:2,-2; hair_back:2,-2; hair_front:2,-2; upper_arm_right:8,-9; forearm_right:11,-13; hand_right:13,-15; upper_arm_left:-2,2; forearm_left:-2,3; hand_left:-2,3; pelvis:1,-1; accessory:2,-2"/>
            <!-- retract mid -->
            <frame index="7" layer-offsets="torso:1,-1; neck:1,-1; head:1,-1; face:1,-1; hair_back:1,-1; hair_front:1,-1; upper_arm_right:4,-5; forearm_right:6,-8; hand_right:7,-9; upper_arm_left:-1,1; forearm_left:-1,2; hand_left:-1,2; accessory:1,-1"/>
            <!-- return to neutral -->
            <frame index="8" layer-offsets="torso:0,0; neck:0,0; head:0,0; face:0,0; hair_back:0,0; hair_front:0,0; upper_arm_right:1,-1; forearm_right:2,-2; hand_right:2,-2; upper_arm_left:0,0; forearm_left:0,0; hand_left:0,0; accessory:0,0"/>
            <frame index="9" layer-offsets=""/>
        </animation>

        <!-- ============================================================ -->
        <!-- SLEEP — 16 frames, 4 fps, deep breathing while asleep        -->
        <!-- ============================================================ -->
        <animation name="sleep" frames="16" fps="4" loop="true"
                   frame-width="128" frame-height="192">
            <frame index="0"  layer-offsets=""/>
            <frame index="1"  layer-offsets="torso:0,-1; pelvis:0,-1; neck:0,-1; head:0,-1; face:0,-1; hair_back:0,-1; hair_front:0,-1; upper_arm_right:0,-1; upper_arm_left:0,-1; forearm_right:0,-1; forearm_left:0,-1; hand_right:0,-1; hand_left:0,-1; accessory:0,-1"/>
            <frame index="2"  layer-offsets="torso:0,-2; pelvis:0,-2; neck:0,-2; head:0,-2; face:0,-2; hair_back:0,-2; hair_front:0,-2; upper_arm_right:0,-2; upper_arm_left:0,-2; forearm_right:0,-2; forearm_left:0,-2; hand_right:0,-2; hand_left:0,-2; accessory:0,-2"/>
            <frame index="3"  layer-offsets="torso:0,-2; pelvis:0,-2; neck:0,-2; head:0,-2; face:0,-2; hair_back:0,-2; hair_front:0,-2; upper_arm_right:0,-2; upper_arm_left:0,-2; forearm_right:0,-2; forearm_left:0,-2; hand_right:0,-2; hand_left:0,-2; accessory:0,-2"/>
            <frame index="4"  layer-offsets="torso:0,-2; pelvis:0,-2; neck:0,-2; head:0,-2; face:0,-2; hair_back:0,-2; hair_front:0,-2; upper_arm_right:0,-2; upper_arm_left:0,-2; forearm_right:0,-2; forearm_left:0,-2; hand_right:0,-2; hand_left:0,-2; accessory:0,-2"/>
            <frame index="5"  layer-offsets="torso:0,-1; pelvis:0,-1; neck:0,-1; head:0,-1; face:0,-1; hair_back:0,-1; hair_front:0,-1; upper_arm_right:0,-1; upper_arm_left:0,-1; forearm_right:0,-1; forearm_left:0,-1; hand_right:0,-1; hand_left:0,-1; accessory:0,-1"/>
            <frame index="6"  layer-offsets=""/>
            <frame index="7"  layer-offsets=""/>
            <frame index="8"  layer-offsets="torso:0,1; pelvis:0,1; neck:0,1; head:0,1; face:0,1; hair_back:0,1; hair_front:0,1; upper_arm_right:0,1; upper_arm_left:0,1; forearm_right:0,1; forearm_left:0,1; hand_right:0,1; hand_left:0,1; accessory:0,1"/>
            <frame index="9"  layer-offsets="torso:0,1; pelvis:0,1; neck:0,1; head:0,1; face:0,1; hair_back:0,1; hair_front:0,1; upper_arm_right:0,1; upper_arm_left:0,1; forearm_right:0,1; forearm_left:0,1; hand_right:0,1; hand_left:0,1; accessory:0,1"/>
            <frame index="10" layer-offsets=""/>
            <frame index="11" layer-offsets=""/>
            <frame index="12" layer-offsets="torso:0,-1; pelvis:0,-1; neck:0,-1; head:0,-1; face:0,-1; hair_back:0,-1; hair_front:0,-1; upper_arm_right:0,-1; upper_arm_left:0,-1; forearm_right:0,-1; forearm_left:0,-1; hand_right:0,-1; hand_left:0,-1; accessory:0,-1"/>
            <frame index="13" layer-offsets="torso:0,-2; pelvis:0,-2; neck:0,-2; head:0,-2; face:0,-2; hair_back:0,-2; hair_front:0,-2; upper_arm_right:0,-2; upper_arm_left:0,-2; forearm_right:0,-2; forearm_left:0,-2; hand_right:0,-2; hand_left:0,-2; accessory:0,-2"/>
            <frame index="14" layer-offsets="torso:0,-1; pelvis:0,-1; neck:0,-1; head:0,-1; face:0,-1; hair_back:0,-1; hair_front:0,-1; upper_arm_right:0,-1; upper_arm_left:0,-1; forearm_right:0,-1; forearm_left:0,-1; hand_right:0,-1; hand_left:0,-1; accessory:0,-1"/>
            <frame index="15" layer-offsets=""/>
        </animation>

        <!-- ============================================================ -->
        <!-- WORK — 12 frames, 6 fps, generic desk/task action            -->
        <!-- ============================================================ -->
        <animation name="work" frames="12" fps="6" loop="true"
                   frame-width="128" frame-height="192">
            <frame index="0"  layer-offsets=""/>
            <frame index="1"  layer-offsets="forearm_right:1,-2; hand_right:1,-3"/>
            <frame index="2"  layer-offsets="forearm_right:2,-4; hand_right:2,-5; upper_arm_right:1,-2"/>
            <frame index="3"  layer-offsets="forearm_right:2,-4; hand_right:2,-5; upper_arm_right:1,-2; forearm_left:-1,-2; hand_left:-1,-3"/>
            <frame index="4"  layer-offsets="forearm_right:1,-2; hand_right:1,-3; forearm_left:-2,-4; hand_left:-2,-5; upper_arm_left:-1,-2"/>
            <frame index="5"  layer-offsets="forearm_left:-2,-4; hand_left:-2,-5; upper_arm_left:-1,-2"/>
            <frame index="6"  layer-offsets="forearm_right:1,-2; hand_right:1,-3"/>
            <frame index="7"  layer-offsets="forearm_right:2,-4; hand_right:2,-5; upper_arm_right:1,-2"/>
            <frame index="8"  layer-offsets="forearm_right:1,-2; hand_right:1,-3"/>
            <frame index="9"  layer-offsets=""/>
            <frame index="10" layer-offsets="neck:0,-1; head:0,-1; face:0,-1; hair_back:0,-1; hair_front:0,-1; accessory:0,-1"/>
            <frame index="11" layer-offsets="neck:0,-1; head:0,-1; face:0,-1; hair_back:0,-1; hair_front:0,-1; accessory:0,-1"/>
        </animation>
    </animations>

    <naming>
        <output-dir>abstract/entities/human</output-dir>
    </naming>

</asset-spec>
