<?xml version="1.0" encoding="UTF-8"?>
<!--
  Klop — Russian Blue-type cat, chubby, smoky blue-grey fur.
  Named "Klop" because as kitten he crawled on Tanya's face like a bug.
  Most peaceful creature in the universe — social worker, integrates Lada.
  Canvas inherited from abstract/entities/cat (128×96).
  Overrides: fur palette (blue-grey), face (green eyes, wide pink nose),
  belly (huge pale belly), body shape (extra chubby).
-->
<asset-spec extends="abstract/entities/cat@1.0">
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>klop</entity-name>
        <version>3.0.0</version>
    </meta>

    <color-palette>
        <color name="$fur_base" value="#6B7B8D"/>
        <color name="$fur_light" value="#8899AA"/>
        <color name="$fur_shadow" value="#4A5B6D"/>
        <color name="$fur_dark" value="#3A4A5A"/>
        <color name="$fur_highlight" value="#AABBC8"/>
        <color name="$fur_bright" value="#C8D4DC"/>
        <color name="$undercoat" value="#556677"/>
        <color name="$belly_color" value="#9BABB8"/>
        <color name="$eye_color" value="#44BB44"/>
        <color name="$eye_dark" value="#228B22"/>
        <color name="$nose_color" value="#FFBBDD"/>
        <color name="$paw_pad" value="#CCAACC"/>
        <color name="$ear_inner" value="#CCAACC"/>
        <color name="$pupil" value="#111111"/>
        <color name="$eye_shine" value="#FFFFFF"/>
        <color name="$whisker" value="#FFFFFF"/>
    </color-palette>

    <layer-overrides>
        <!-- Klop is EXTRA chubby — override body to be wider -->
        <layer id="body" replace="true">
            <pixel-data>
                <!-- extremely round wide torso: 72px wide, 32px tall -->
                <rect x="20" y="36" w="72" h="32" color="$fur_base"/>
                <!-- back top silver sheen -->
                <hline x="24" y="36" len="64" color="$fur_bright"/>
                <hline x="28" y="40" len="56" color="$fur_highlight"/>
                <hline x="32" y="44" len="48" color="$fur_light"/>
                <!-- barrel chest sides — round shadow -->
                <rect x="20" y="40" w="4" h="16" color="$fur_shadow"/>
                <rect x="88" y="40" w="4" h="16" color="$fur_shadow"/>
                <!-- lower belly underside -->
                <hline x="24" y="64" len="64" color="$fur_shadow"/>
                <hline x="28" y="68" len="56" color="$undercoat"/>
                <!-- mid-body smoky undercoat band -->
                <hline x="24" y="56" len="64" color="$undercoat"/>
                <!-- fat roll crease at waist -->
                <hline x="28" y="52" len="56" color="#5A6B7A"/>
            </pixel-data>
        </layer>

        <!-- Klop's enormous pale belly -->
        <layer id="belly" replace="true">
            <pixel-data>
                <!-- belly patch: wide pale area -->
                <rect x="32" y="48" w="48" h="20" color="$belly_color"/>
                <!-- belly top highlight -->
                <hline x="36" y="48" len="40" color="$fur_highlight"/>
                <!-- belly center soft highlight -->
                <hline x="40" y="52" len="32" color="$fur_bright"/>
                <!-- belly lower shadow -->
                <hline x="36" y="60" len="40" color="$undercoat"/>
                <hline x="40" y="64" len="32" color="$fur_shadow"/>
                <!-- subtle fur texture rows -->
                <pixel x="36" y="56" color="$fur_light"/>
                <pixel x="44" y="56" color="$fur_light"/>
                <pixel x="52" y="56" color="$fur_light"/>
                <pixel x="60" y="56" color="$fur_light"/>
                <pixel x="68" y="56" color="$fur_light"/>
                <!-- fat belly side rolls -->
                <rect x="32" y="52" w="4" h="8" color="$fur_light"/>
                <rect x="76" y="52" w="4" h="8" color="$fur_light"/>
            </pixel-data>
        </layer>

        <!-- Klop's face: vivid green eyes, wide pink nose, content smile -->
        <layer id="face_details" replace="true">
            <pixel-data>
                <!-- LEFT EYE: vivid green — Russian Blue hallmark -->
                <pixel x="16" y="16" color="$eye_dark"/>
                <pixel x="20" y="12" color="$eye_color"/>
                <pixel x="24" y="12" color="$eye_color"/>
                <pixel x="20" y="16" color="$eye_color"/>
                <pixel x="24" y="16" color="$pupil"/>
                <pixel x="16" y="12" color="$eye_dark"/>
                <pixel x="20" y="12" color="$eye_shine"/>
                <!-- RIGHT EYE -->
                <pixel x="28" y="16" color="$eye_dark"/>
                <pixel x="32" y="12" color="$eye_color"/>
                <pixel x="36" y="12" color="$eye_color"/>
                <pixel x="32" y="16" color="$eye_color"/>
                <pixel x="36" y="16" color="$pupil"/>
                <pixel x="28" y="12" color="$eye_dark"/>
                <pixel x="32" y="12" color="$eye_shine"/>
                <!-- NOSE: pink, wider (chubby cat nose) -->
                <rect x="20" y="24" w="12" h="8" color="$nose_color"/>
                <pixel x="24" y="28" color="#DD99BB"/>
                <pixel x="20" y="28" color="#CC88AA"/>
                <pixel x="28" y="28" color="#CC88AA"/>
                <!-- content smile -->
                <hline x="20" y="32" len="12" color="#557799"/>
                <pixel x="16" y="32" color="$fur_shadow"/>
                <pixel x="32" y="32" color="$fur_shadow"/>
                <!-- WHISKERS: long and relaxed -->
                <hline x="0" y="24" len="16" color="$whisker"/>
                <hline x="0" y="28" len="12" color="#DDDDDD"/>
                <hline x="40" y="24" len="16" color="$whisker"/>
                <hline x="40" y="28" len="12" color="#DDDDDD"/>
                <!-- forehead spot -->
                <pixel x="24" y="8" color="$fur_light"/>
            </pixel-data>
        </layer>
    </layer-overrides>

    <!-- All 5 base animations (idle, walk, sleep, play, eat) inherited from abstract/entities/cat -->
    <!-- Klop-specific extra animations -->
    <animations-extra>
        <!-- social_purr: Klop approaches Lada, slow blink, peaceful presence -->
        <animation name="social_purr" frames="12" fps="3" loop="true" frame-width="128" frame-height="96">
            <condition type="trigger" value="near_lada"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="head:-4,0; ears:-4,0; face_details:-4,0"/>
            <frame index="2" layer-offsets="head:-8,0; ears:-8,0; face_details:-8,0; tail:0,-4"/>
            <frame index="3" layer-offsets="head:-8,0; ears:-8,0; face_details:-8,4; tail:0,-4"/>
            <frame index="4" layer-offsets="head:-8,0; ears:-8,0; face_details:-8,0; tail:0,-4"/>
            <frame index="5" layer-offsets="head:-4,0; ears:-4,0; face_details:-4,0; tail:0,-4"/>
            <frame index="6" layer-offsets="body:0,4; belly:0,4; tail:4,0"/>
            <frame index="7" layer-offsets="body:0,4; belly:0,4; face_details:0,4"/>
            <frame index="8" layer-offsets="body:0,4; belly:0,4"/>
            <frame index="9" layer-offsets="body:4,4; belly:4,4"/>
            <frame index="10" layer-offsets="body:-4,4; belly:-4,4"/>
            <frame index="11" layer-offsets=""/>
        </animation>

        <!-- belly_up: ultimate trust display — rolls onto back -->
        <animation name="belly_up" frames="8" fps="3" loop="true" frame-width="128" frame-height="96">
            <condition type="trigger" value="human_touch"/>
            <frame index="0" layer-offsets="body:0,4; belly:0,4"/>
            <frame index="1" layer-offsets="body:4,8; belly:4,8; front_legs:8,4; hind_legs:-4,4; paws:8,8; tail:-8,4"/>
            <frame index="2" layer-offsets="body:4,8; belly:4,12; front_legs:12,8; hind_legs:-8,4; paws:12,8; tail:-8,4; head:4,4; ears:4,4; face_details:4,4"/>
            <frame index="3" layer-offsets="body:4,8; belly:4,12; front_legs:12,8; hind_legs:-8,4; paws:12,8; tail:-8,4; head:4,4; ears:4,4; face_details:4,8"/>
            <frame index="4" layer-offsets="body:4,8; belly:4,12; front_legs:12,4; hind_legs:-8,4; paws:12,4; tail:-8,4; head:4,4; ears:4,4; face_details:4,4"/>
            <frame index="5" layer-offsets="body:0,8; belly:0,12; front_legs:8,4; hind_legs:-4,4; paws:8,4; tail:-8,4; head:4,4; ears:4,4; face_details:4,4"/>
            <frame index="6" layer-offsets="body:4,4; belly:4,8; front_legs:8,4; hind_legs:-4,4; paws:8,4; tail:-4,4"/>
            <frame index="7" layer-offsets="body:0,4; belly:0,4"/>
        </animation>
    </animations-extra>

    <naming>
        <output-dir>characters/klop</output-dir>
    </naming>
</asset-spec>