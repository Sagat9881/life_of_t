<?xml version="1.0" encoding="UTF-8"?>
<!--
    Life of T — Persi Visual Spec v2.0.0
    Extends: abstract/entities/dog@1.0
    Canvas: 128×96 | displayScale: 1.5
    Breed: Adult Black Shepherd
    Coat: solid black + white chest patch + white paw tips

    OVERRIDES (3 layers only):
      paws         — black base + white tip strip (2px) + dark paw pads
      belly        — white chest patch (front) + black belly (rear)
      face_details — dark brown eyes, black nose, closed mouth, no whiskers

    All coordinates taken verbatim from abstract/entities/dog@1.0:
      paws:  front-right x=14,y=72,w=16,h=14
             front-left  x=38,y=72,w=16,h=14
             hind-right  x=66,y=72,w=18,h=14
             hind-left   x=90,y=72,w=18,h=14
      belly: x=28,y=48,w=64,h=32 (base rect from dog belly)
      face:  eyes x=14..28 y=8..18, nose x=28..44 y=20..30
-->
<asset-spec extends="abstract/entities/dog@1.0" version="2.0.0">
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>persi</entity-name>
        <version>2.0.0</version>
        <display-scale>1.5</display-scale>
    </meta>

    <color-palette>
        <color name="$fur_base"        value="#101010"/>
        <color name="$fur_shadow"      value="#000000"/>
        <color name="$fur_highlight"   value="#282828"/>
        <color name="$chest_base"      value="#E8E8E8"/>
        <color name="$chest_highlight" value="#FFFFFF"/>
        <color name="$nose_color"      value="#101010"/>
        <color name="$nose_highlight"  value="#383838"/>
        <color name="$eye_color"       value="#3A2800"/>
        <color name="$eye_highlight"   value="#6A4810"/>
        <color name="$paw_pad"         value="#303030"/>
        <color name="$paw_tip"         value="#D0D0D0"/>
        <color name="$ear_inner"       value="#1A1A1A"/>
        <color name="$tongue_color"    value="#FF6060"/>
    </color-palette>

    <layer-overrides>

        <!-- ============================================================ -->
        <!-- PAWS override                                                -->
        <!-- Exact geometry from abstract/dog paws layer:                -->
        <!--   front-right: x=14, y=72, w=16, h=14                      -->
        <!--   front-left:  x=38, y=72, w=16, h=14                      -->
        <!--   hind-right:  x=66, y=72, w=18, h=14                      -->
        <!--   hind-left:   x=90, y=72, w=18, h=14                      -->
        <!-- Black base + white tip strip at top (y=72, h=2) + dark pads -->
        <!-- ============================================================ -->
        <layer id="paws" replace="true">
            <pixel-data>
                <!-- FRONT RIGHT PAW — x=14, y=72, w=16, h=14 -->
                <rect x="14" y="72" w="16" h="14" color="$fur_base"/>
                <hline x="14" y="85" len="16"     color="$fur_shadow"/>
                <rect  x="14" y="80" w="16" h="4"  color="$paw_pad"/>
                <!-- white tip strip -->
                <hline x="14" y="72" len="16"     color="$paw_tip"/>
                <hline x="14" y="73" len="16"     color="$paw_tip"/>

                <!-- FRONT LEFT PAW — x=38, y=72, w=16, h=14 -->
                <rect x="38" y="72" w="16" h="14" color="$fur_base"/>
                <hline x="38" y="85" len="16"     color="$fur_shadow"/>
                <rect  x="38" y="80" w="16" h="4"  color="$paw_pad"/>
                <!-- white tip strip -->
                <hline x="38" y="72" len="16"     color="$paw_tip"/>
                <hline x="38" y="73" len="16"     color="$paw_tip"/>

                <!-- HIND RIGHT PAW — x=66, y=72, w=18, h=14 -->
                <rect x="66" y="72" w="18" h="14" color="$fur_base"/>
                <hline x="66" y="85" len="18"     color="$fur_shadow"/>
                <rect  x="66" y="80" w="18" h="4"  color="$paw_pad"/>
                <!-- white tip strip -->
                <hline x="66" y="72" len="18"     color="$paw_tip"/>
                <hline x="66" y="73" len="18"     color="$paw_tip"/>

                <!-- HIND LEFT PAW — x=90, y=72, w=18, h=14 -->
                <rect x="90" y="72" w="18" h="14" color="$fur_base"/>
                <hline x="90" y="85" len="18"     color="$fur_shadow"/>
                <rect  x="90" y="80" w="18" h="4"  color="$paw_pad"/>
                <!-- white tip strip -->
                <hline x="90" y="72" len="18"     color="$paw_tip"/>
                <hline x="90" y="73" len="18"     color="$paw_tip"/>
            </pixel-data>
        </layer>

        <!-- ============================================================ -->
        <!-- BELLY override                                               -->
        <!-- Exact bounding box from abstract/dog belly layer:           -->
        <!--   base rect: x=28, y=48, w=64, h=32                        -->
        <!--   sternum overlay: x=36, y=36, w=40, h=24                  -->
        <!-- White patch: FRONT portion x=28..56 (w=28)                 -->
        <!-- Black belly: REAR portion x=56..92 (w=36)                  -->
        <!-- Transition: 2px fade at x=54..56                            -->
        <!-- ============================================================ -->
        <layer id="belly" replace="true">
            <pixel-data>
                <!-- Full belly base — black -->
                <rect x="28" y="48" w="64" h="32" color="$fur_base"/>
                <rect x="36" y="36" w="40" h="24" color="$fur_base"/>

                <!-- WHITE CHEST PATCH — front portion only -->
                <!-- Main white area -->
                <rect x="28" y="48" w="28" h="28" color="$chest_base"/>
                <!-- Centre highlight -->
                <rect x="34" y="52" w="16" h="20" color="$chest_highlight"/>
                <!-- Upper sternum extension -->
                <rect x="36" y="36" w="16" h="16" color="$chest_base"/>
                <rect x="38" y="38" w="12" h="12" color="$chest_highlight"/>

                <!-- Transition edge — 2px fade strip at x=54..55 -->
                <vline x="54" y="48" len="28"     color="$chest_base"/>
                <vline x="55" y="48" len="28"     color="$fur_highlight"/>

                <!-- Black belly continues from x=56 — already covered by base rect -->
                <!-- Bottom shadow line -->
                <hline x="28" y="79" len="64"     color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- ============================================================ -->
        <!-- FACE DETAILS override                                        -->
        <!-- Side view — single near-side eye, nose at muzzle tip        -->
        <!-- Coordinates from abstract/dog face_details:                 -->
        <!--   eye:   x=14, y=8,  w=14, h=10                            -->
        <!--   nose:  x=28, y=20, w=16, h=10                            -->
        <!--   mouth: hline y=28                                         -->
        <!-- No whiskers. Mouth closed.                                  -->
        <!-- ============================================================ -->
        <layer id="face_details" replace="true">
            <pixel-data>
                <!-- EYE — single, near-side, side view -->
                <!-- white sclera base -->
                <rect x="14" y="8"  w="14" h="10" color="#FFFFFF"/>
                <!-- dark brown iris -->
                <rect x="18" y="10" w="8"  h="6"  color="$eye_color"/>
                <!-- iris highlight -->
                <pixel x="18" y="10"              color="$eye_highlight"/>
                <pixel x="19" y="10"              color="$eye_highlight"/>
                <!-- pupil -->
                <rect x="21" y="11" w="3"  h="4"  color="#000000"/>
                <!-- eye shine -->
                <pixel x="21" y="11"              color="#FFFFFF"/>
                <!-- brow ridge -->
                <hline x="14" y="7"  len="14"     color="$fur_shadow"/>
                <hline x="16" y="6"  len="10"     color="$fur_shadow"/>
                <!-- lower lid -->
                <hline x="14" y="18" len="14"     color="$fur_shadow"/>

                <!-- NOSE — at muzzle tip, black with highlight -->
                <!-- abstract/dog nose: x=28, y=20, w=16, h=10 -->
                <rect x="28" y="20" w="16" h="10" color="$nose_color"/>
                <!-- shine strip -->
                <hline x="29" y="20" len="6"      color="$nose_highlight"/>
                <hline x="29" y="21" len="4"      color="$nose_highlight"/>
                <!-- nostril divider -->
                <vline x="36" y="21" len="7"      color="$fur_shadow"/>
                <!-- nose bridge -->
                <rect x="30" y="16" w="6"  h="5"  color="$fur_shadow"/>

                <!-- MOUTH — closed, single shadow line -->
                <!-- abstract/dog mouth hline y=28 -->
                <hline x="22" y="28" len="28"     color="$fur_shadow"/>
                <!-- jaw fold corners -->
                <pixel x="22" y="29"              color="$fur_shadow"/>
                <pixel x="50" y="29"              color="$fur_shadow"/>
            </pixel-data>
        </layer>

    </layer-overrides>

    <naming>
        <output-dir>characters/persi</output-dir>
    </naming>

</asset-spec>
