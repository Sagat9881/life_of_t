<?xml version="1.0" encoding="UTF-8"?>
<!--
  Persi — Tiny calico kitten, ~3-4 months old.
  Canvas inherited from abstract/entities/cat (128×96).
  Smallest cat in the game. Calico patches: orange + black on white base.
  Huge eyes relative to head size. Always playing or sleeping.
-->
<asset-spec extends="abstract/entities/cat@1.0">
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>persi</entity-name>
        <version>3.0.0</version>
    </meta>

    <color-palette>
        <color name="$fur_base" value="#F0E8D8"/><!-- cream-white base -->
        <color name="$fur_light" value="#FAF5ED"/>
        <color name="$fur_shadow" value="#D8D0C0"/>
        <color name="$fur_dark" value="#C0B8A8"/>
        <color name="$fur_highlight" value="#FFFFFF"/>
        <color name="$belly_color" value="#FAF5ED"/>
        <color name="$eye_color" value="#44AADD"/><!-- kitten blue eyes -->
        <color name="$eye_dark" value="#2277AA"/>
        <color name="$nose_color" value="#FFAAAA"/><!-- pink kitten nose -->
        <color name="$paw_pad" value="#FFBBCC"/>
        <color name="$ear_inner" value="#FFCCCC"/>
        <color name="$pupil" value="#111111"/>
        <color name="$eye_shine" value="#FFFFFF"/>
        <color name="$whisker" value="#EEEEEE"/>
        <!-- Calico-specific colors -->
        <color name="$calico_orange" value="#DD8833"/>
        <color name="$calico_orange_light" value="#EEAA55"/>
        <color name="$calico_black" value="#222222"/>
        <color name="$calico_black_light" value="#333333"/>
    </color-palette>

    <layer-overrides>
        <!-- Calico body with orange and black patches on white base -->
        <layer id="body" replace="true">
            <pixel-data>
                <!-- main body: cream-white base, smaller than adult cats -->
                <rect x="28" y="44" w="56" h="24" color="$fur_base"/>
                <!-- back highlight -->
                <hline x="32" y="44" len="48" color="$fur_light"/>
                <!-- CALICO PATCH: orange on left shoulder/back -->
                <rect x="28" y="44" w="20" h="12" color="$calico_orange"/>
                <hline x="32" y="44" len="12" color="$calico_orange_light"/>
                <!-- CALICO PATCH: black on right hip -->
                <rect x="64" y="48" w="16" h="12" color="$calico_black"/>
                <hline x="68" y="48" len="8" color="$calico_black_light"/>
                <!-- CALICO PATCH: small orange spot on mid-back -->
                <rect x="48" y="48" w="8" h="8" color="$calico_orange"/>
                <!-- belly underside -->
                <hline x="32" y="64" len="48" color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- Kitten's huge eyes and tiny pink nose -->
        <layer id="face_details" replace="true">
            <pixel-data>
                <!-- LEFT EYE: huge relative to face (kitten proportions) -->
                <rect x="12" y="8" w="12" h="12" color="$eye_color"/>
                <rect x="16" y="12" w="4" h="4" color="$pupil"/>
                <pixel x="12" y="8" color="$eye_dark"/>
                <pixel x="16" y="8" color="$eye_shine"/>
                <pixel x="20" y="8" color="$eye_shine"/>
                <!-- RIGHT EYE -->
                <rect x="28" y="8" w="12" h="12" color="$eye_color"/>
                <rect x="32" y="12" w="4" h="4" color="$pupil"/>
                <pixel x="28" y="8" color="$eye_dark"/>
                <pixel x="32" y="8" color="$eye_shine"/>
                <pixel x="36" y="8" color="$eye_shine"/>
                <!-- NOSE: tiny pink -->
                <rect x="20" y="20" w="8" h="4" color="$nose_color"/>
                <pixel x="20" y="24" color="#FF8888"/>
                <pixel x="24" y="24" color="#FF8888"/>
                <!-- tiny mouth -->
                <pixel x="22" y="28" color="#CC9999"/>
                <pixel x="26" y="28" color="#CC9999"/>
                <!-- short kitten whiskers -->
                <hline x="0" y="20" len="12" color="$whisker"/>
                <hline x="40" y="20" len="12" color="$whisker"/>
            </pixel-data>
        </layer>

        <!-- Calico patches on head -->
        <layer id="head" replace="true">
            <pixel-data>
                <!-- head: cream-white base, slightly rounder than adult -->
                <rect x="4" y="0" w="44" h="36" color="$fur_base"/>
                <!-- forehead highlight -->
                <hline x="8" y="0" len="36" color="$fur_highlight"/>
                <!-- CALICO: orange patch on left side of head -->
                <rect x="4" y="4" w="16" h="12" color="$calico_orange"/>
                <hline x="8" y="4" len="8" color="$calico_orange_light"/>
                <!-- CALICO: black patch on right top -->
                <rect x="32" y="0" w="12" h="8" color="$calico_black"/>
                <!-- muzzle: white -->
                <rect x="12" y="24" w="24" h="12" color="$fur_highlight"/>
            </pixel-data>
        </layer>
    </layer-overrides>

    <!-- Base 5 animations inherited. Kitten-specific extras: -->
    <animations-extra>
        <!-- zoomies: kitten random sprint with sudden direction changes -->
        <animation name="zoomies" frames="12" fps="12" loop="true" frame-width="128" frame-height="96">
            <condition type="trigger" value="kitten_energy_burst"/>
            <frame index="0" layer-offsets="body:0,4; belly:0,4; front_legs:0,8; hind_legs:0,8; paws:0,8; head:0,4; neck:0,4; ears:0,4; face_details:0,4; tail:-8,4"/>
            <frame index="1" layer-offsets="body:-4,0; belly:-4,0; front_legs:-4,4; hind_legs:12,-4; paws:-4,4; head:-4,-4; neck:-4,0; ears:-4,-4; face_details:-4,-4; tail:12,-4"/>
            <frame index="2" layer-offsets="body:-8,-8; belly:-8,-8; front_legs:-12,-8; hind_legs:8,-8; paws:-12,-12; head:-8,-12; neck:-8,-8; ears:-8,-12; face_details:-8,-12; tail:12,-12"/>
            <frame index="3" layer-offsets="body:-12,-8; belly:-12,-8; front_legs:-16,-4; hind_legs:12,-8; paws:-16,-8; head:-12,-12; neck:-12,-8; ears:-12,-12; face_details:-12,-12; tail:16,-8"/>
            <frame index="4" layer-offsets="body:-8,-4; belly:-8,-4; front_legs:-8,0; hind_legs:16,-8; paws:-8,0; head:-8,-8; neck:-8,-4; ears:-8,-8; face_details:-8,-8; tail:12,-8"/>
            <frame index="5" layer-offsets="body:-4,4; belly:-4,4; front_legs:-4,4; hind_legs:8,0; paws:-4,4; head:-4,0; neck:-4,0; ears:-4,0; face_details:-4,0; tail:4,0"/>
            <frame index="6" layer-offsets="body:0,4; belly:0,4; front_legs:0,8; hind_legs:0,8; paws:0,8; head:0,4; neck:0,4; ears:0,4; face_details:0,4; tail:-4,4"/>
            <frame index="7" layer-offsets="body:4,0; belly:4,0; front_legs:4,4; hind_legs:-12,-4; paws:4,4; head:4,-4; neck:4,0; ears:4,-4; face_details:4,-4; tail:-12,-4"/>
            <frame index="8" layer-offsets="body:8,-8; belly:8,-8; front_legs:12,-8; hind_legs:-8,-8; paws:12,-12; head:8,-12; neck:8,-8; ears:8,-12; face_details:8,-12; tail:-12,-12"/>
            <frame index="9" layer-offsets="body:12,-8; belly:12,-8; front_legs:16,-4; hind_legs:-12,-8; paws:16,-8; head:12,-12; neck:12,-8; ears:12,-12; face_details:12,-12; tail:-16,-8"/>
            <frame index="10" layer-offsets="body:8,-4; belly:8,-4; front_legs:8,0; hind_legs:-16,-8; paws:8,0; head:8,-8; neck:8,-4; ears:8,-8; face_details:8,-8; tail:-12,-8"/>
            <frame index="11" layer-offsets="body:4,4; belly:4,4; front_legs:4,4; hind_legs:-8,0; paws:4,4; head:4,0; neck:4,0; ears:4,0; face_details:4,0; tail:-4,0"/>
        </animation>
    </animations-extra>

    <naming>
        <output-dir>characters/persi</output-dir>
    </naming>
</asset-spec>