        <!-- ============================================================ -->
        <!-- z=13 HAND LEFT                                               -->
        <!-- forearm_left ends at y=116 → hand top = y=116 flush ✓       -->
        <!-- x=18..30 (w=12), center x=24                                -->
        <!-- accessory watch follows="hand_left" at y=116..122, x=16..26  -->
        <!-- Watch spans x=16..26, y=116..122: 2px left of hand — OK ✓   -->
        <!-- ============================================================ -->
        <layer id="hand_left" replace="true">
            <pixel-data>
                <!-- palm -->
                <rect x="18" y="116" w="12" h="10" color="$skin_base"/>
                <!-- palm highlight -->
                <rect x="21" y="116" w="6"  h="6"  color="$skin_highlight"/>
                <!-- side shadow -->
                <vline x="30" y="116" len="10" color="$skin_shadow"/>
                <vline x="18" y="116" len="10" color="$skin_dark"/>
                <!-- knuckle line -->
                <hline x="19" y="117" len="10" color="$skin_shadow"/>
                <!-- fingers (3 pixel bumps) -->
                <rect x="19" y="116" w="3"  h="3"  color="$skin_highlight"/>
                <rect x="23" y="116" w="3"  h="3"  color="$skin_highlight"/>
                <rect x="27" y="116" w="3"  h="3"  color="$skin_highlight"/>
                <!-- wrist base -->
                <hline x="18" y="125" len="12" color="$skin_shadow"/>
            </pixel-data>
        </layer>

        <!-- ============================================================ -->
        <!-- z=14 NECK                                                    -->
        <!-- head ends at y=54 → neck top = y=52 (2px overlap) ✓         -->
        <!-- neck ends at y=66 → torso top = y=64 (2px overlap) ✓        -->
        <!-- center x=64, collar of polo visible at y=64..70              -->
        <!-- Neck wider for masculine proportions: x=52..76 (w=24) OK ✓  -->
        <!-- Override to ensure correct skin tone and collar meeting       -->
        <!-- ============================================================ -->
        <layer id="neck" replace="true">
            <pixel-data>
                <!-- neck column -->
                <rect x="54" y="52"  w="20" h="14" color="$skin_base"/>
                <!-- highlight -->
                <rect x="59" y="52"  w="6"  h="14" color="$skin_highlight"/>
                <!-- left shadow -->
                <rect x="54" y="52"  w="4"  h="14" color="$skin_shadow"/>
                <!-- right shadow -->
                <rect x="70" y="52"  w="4"  h="14" color="$skin_shadow"/>
                <!-- top highlight -->
                <hline x="56" y="52" len="12" color="$skin_highlight"/>
                <!-- Adam's apple -->
                <rect x="62" y="57"  w="4"  h="4"  color="$skin_shadow"/>
                <rect x="63" y="58"  w="2"  h="2"  color="$skin_dark"/>
                <!-- collar meeting line -->
                <hline x="54" y="64" len="20" color="$clothing_primary_dark"/>
            </pixel-data>
        </layer>

        <!-- ============================================================ -->
        <!-- z=15 HEAD                                                    -->
        <!-- x=38..90 (w=52), y=10..54 (h=44)                            -->
        <!-- neck top = y=52 → 2px overlap ✓                             -->
        <!-- Override for masculine proportions (stronger jaw, wider)     -->
        <!-- ============================================================ -->
        <layer id="head" replace="true">
            <pixel-data>
                <!-- skull main -->
                <rect x="38" y="10"  w="52" h="44" color="$skin_base"/>
                <!-- forehead highlight -->
                <rect x="44" y="10"  w="40" h="8"  color="$skin_highlight"/>
                <!-- left cheek shadow -->
                <rect x="38" y="22"  w="6"  h="28" color="$skin_shadow"/>
                <!-- right cheek shadow -->
                <rect x="84" y="22"  w="6"  h="28" color="$skin_shadow"/>
                <!-- jawline — wider and squarer for male -->
                <rect x="38" y="44"  w="52" h="10" color="$skin_base"/>
                <!-- jaw shadow bottom -->
                <rect x="40" y="50"  w="48" h="4"  color="$skin_shadow"/>
                <!-- neck meet shadow -->
                <rect x="54" y="52"  w="20" h="3"  color="$skin_dark"/>
                <!-- left ear -->
                <rect x="34" y="22"  w="6"  h="16" color="$skin_base"/>
                <rect x="34" y="24"  w="4"  h="12" color="$skin_shadow"/>
                <rect x="35" y="26"  w="2"  h="8"  color="$skin_dark"/>
                <!-- right ear -->
                <rect x="88" y="22"  w="6"  h="16" color="$skin_base"/>
                <rect x="90" y="24"  w="4"  h="12" color="$skin_shadow"/>
                <rect x="91" y="26"  w="2"  h="8"  color="$skin_dark"/>
                <!-- cheekbone highlights -->
                <rect x="40" y="32"  w="5"  h="4"  color="$skin_highlight"/>
                <rect x="83" y="32"  w="5"  h="4"  color="$skin_highlight"/>
                <!-- temple shadows -->
                <rect x="38" y="12"  w="8"  h="8"  color="$skin_shadow"/>
                <rect x="82" y="12"  w="8"  h="8"  color="$skin_shadow"/>
                <!-- jaw line definition -->
                <hline x="38" y="50" len="52" color="$skin_shadow"/>
                <!-- isometric depth right -->
                <vline x="90" y="12" len="42" color="$skin_shadow"/>
                <!-- stubble on jaw -->
                <rect x="42" y="44"  w="44" h="6"  color="$stubble"/>
                <hline x="44" y="44" len="40" color="$skin_shadow"/>
            </pixel-data>
        </layer>

        <!-- ============================================================ -->
        <!-- z=16 FACE — Alexander's features: blue-grey eyes, short hair  -->
        <!-- ============================================================ -->
        <layer id="face" replace="true">
            <pixel-data>
                <!-- LEFT EYE -->
                <rect x="44" y="28"  w="14" h="10" color="$eye_white"/>
                <rect x="46" y="26"  w="10" h="13" color="$eye_color"/>
                <rect x="48" y="28"  w="7"  h="8"  color="$eye_highlight"/>
                <rect x="50" y="30"  w="3"  h="4"  color="$eye_pupil"/>
                <rect x="47" y="26"  w="3"  h="3"  color="$eye_white"/>
                <hline x="44" y="25" len="14" color="$outline"/>
                <hline x="44" y="38" len="14" color="$skin_shadow"/>
                <!-- RIGHT EYE -->
                <rect x="70" y="28"  w="14" h="10" color="$eye_white"/>
                <rect x="72" y="26"  w="10" h="13" color="$eye_color"/>
                <rect x="74" y="28"  w="7"  h="8"  color="$eye_highlight"/>
                <rect x="76" y="30"  w="3"  h="4"  color="$eye_pupil"/>
                <rect x="73" y="26"  w="3"  h="3"  color="$eye_white"/>
                <hline x="70" y="25" len="14" color="$outline"/>
                <hline x="70" y="38" len="14" color="$skin_shadow"/>
                <!-- BROWS — thick, dark -->
                <rect x="43" y="22"  w="16" h="4"  color="$brow_color"/>
                <hline x="45" y="21" len="10" color="$brow_color"/>
                <rect x="69" y="22"  w="16" h="4"  color="$brow_color"/>
                <hline x="71" y="21" len="10" color="$brow_color"/>
                <!-- NOSE — stronger, angular -->
                <rect x="61" y="36"  w="6"  h="6"  color="$skin_shadow"/>
                <rect x="57" y="40"  w="5"  h="3"  color="$skin_shadow"/>
                <rect x="66" y="40"  w="5"  h="3"  color="$skin_shadow"/>
                <hline x="59" y="42" len="10" color="$skin_dark"/>
                <!-- MOUTH — thinner upper, fuller lower -->
                <hline x="55" y="46" len="18" color="$skin_shadow"/>
                <rect x="58" y="47"  w="12" h="3"  color="$lip_color"/>
                <hline x="60" y="48" len="8"  color="$skin_base"/>
                <hline x="55" y="50" len="18" color="$skin_highlight"/>
                <!-- CHIN CREASE -->
                <hline x="60" y="52" len="8"  color="$skin_shadow"/>
                <!-- NASOLABIAL FOLDS -->
                <vline x="56" y="43" len="5"  color="$skin_shadow"/>
                <vline x="72" y="43" len="5"  color="$skin_shadow"/>
            </pixel-data>
        </layer>

        <!-- ============================================================ -->
        <!-- z=17 HAIR BACK — very short, dark brown                      -->
        <!-- ============================================================ -->
        <layer id="hair_back" replace="true">
            <pixel-data>
                <rect x="34" y="18"  w="6"  h="10" color="$hair_shadow"/>
                <rect x="88" y="18"  w="6"  h="10" color="$hair_shadow"/>
                <rect x="34" y="26"  w="4"  h="6"  color="$hair_base"/>
                <rect x="90" y="26"  w="4"  h="6"  color="$hair_base"/>
            </pixel-data>
        </layer>

        <!-- ============================================================ -->
        <!-- z=18 HAIR FRONT — short, neat, dark brown                    -->
        <!-- ============================================================ -->
        <layer id="hair_front" replace="true">
            <pixel-data>
                <!-- crown cap -->
                <rect x="38" y="8"   w="52" h="12" color="$hair_base"/>
                <hline x="42" y="8"  len="44" color="$hair_highlight"/>
                <hline x="46" y="9"  len="32" color="$hair_highlight"/>
                <!-- left side — very close cropped -->
                <rect x="36" y="14"  w="6"  h="8"  color="$hair_base"/>
                <rect x="34" y="18"  w="4"  h="4"  color="$hair_shadow"/>
                <!-- right side -->
                <rect x="86" y="14"  w="6"  h="8"  color="$hair_base"/>
                <rect x="90" y="18"  w="4"  h="4"  color="$hair_shadow"/>
                <!-- hairline front -->
                <hline x="42" y="14" len="44" color="$hair_shadow"/>
                <!-- part line — slight off-centre -->
                <vline x="66" y="8"  len="6"  color="$hair_shadow"/>
            </pixel-data>
        </layer>

        <!-- ============================================================ -->
        <!-- z=19 ACCESSORY — smart watch on left wrist                   -->
        <!-- follows="hand_left": hand_left top = y=116                   -->
        <!-- Watch at x=16..26, y=116..122 — sits on wrist just above     -->
        <!-- hand, 2px left of hand edge (x=18): bracelet wrap effect ✓   -->
        <!-- forearm_left ends at y=116 → watch at y=116: no overlap ✓   -->
        <!-- ============================================================ -->
        <layer id="accessory" replace="true" follows="hand_left">
            <pixel-data>
                <!-- watch strap upper -->
                <rect x="16" y="112" w="10" h="4"  color="$watch_strap"/>
                <!-- watch body / case -->
                <rect x="16" y="116" w="10" h="6"  color="$watch_body"/>
                <!-- screen -->
                <rect x="17" y="117" w="8"  h="4"  color="$watch_screen"/>
                <!-- screen highlight -->
                <rect x="17" y="117" w="3"  h="2"  color="#3A5A9A"/>
                <!-- case highlight edge -->
                <hline x="16" y="116" len="10" color="#383838"/>
                <!-- strap lower -->
                <rect x="16" y="122" w="10" h="3"  color="$watch_strap"/>
            </pixel-data>
        </layer>

        <!-- ============================================================ -->
        <!-- z=20 SHADOW — standard width for 64px torso                  -->
        <!-- ============================================================ -->
        <layer id="shadow" replace="true">
            <pixel-data>
                <rect x="24" y="184" w="80" h="4"  color="#00000050"/>
                <rect x="30" y="186" w="68" h="4"  color="#00000038"/>
                <rect x="38" y="188" w="52" h="3"  color="#00000020"/>
            </pixel-data>
        </layer>

        <!-- ============================================================ -->
        <!-- z=21 HIGHLIGHT — rim light for male silhouette               -->
        <!-- head left rim: x=38                                          -->
        <!-- left arm outer: x=18                                         -->
        <!-- left leg outer: x=36                                         -->
        <!-- ============================================================ -->
        <layer id="highlight" replace="true">
            <pixel-data>
                <vline x="38" y="10"  len="44" color="#FFFFFF20"/>
                <vline x="32" y="64"  len="40" color="#FFFFFF18"/>
                <vline x="18" y="66"  len="60" color="#FFFFFF14"/>
                <vline x="36" y="112" len="64" color="#FFFFFF10"/>
            </pixel-data>
        </layer>

    </layer-overrides>

    <naming>
        <output-dir>characters/alexander</output-dir>
    </naming>

</asset-spec>
