<?xml version="1.0" encoding="UTF-8"?>
<!--
    Life of T — Duke Visual Spec v3.0.0
    Extends: abstract/entities/dog@1.0
    Canvas: 128×96 | displayScale: 1.5
    Breed: Adult East European Shepherd (sable/saddle coat)

    COAT:
      Body:  cream-beige base (#D4C090) + dark saddle stripe hatch y=28..42
      Belly: cream-white (#EDE0C0)
      Mask:  solid black (#101010) — lower head from y=12 downward
      Eye:   amber, positioned ABOVE mask in cream skull zone (y=8..18)
      Paws:  cream-beige, dark pads

    OVERRIDES (4 layers):
      body         — cream base + saddle hatch (y=28..42) + flank shadows
      belly        — light cream underbelly + centre highlight
      head         — cream skull (y=0..16) + black mask (y=12..28)
      face_details — nose + closed mouth fully inside black mask; no whiskers

    All coordinates from abstract/entities/dog@1.0:
      body:  x=12, y=28, w=96, h=44  (x=12..108)
      belly: base x=28,y=48,w=64,h=32 + sternum x=36,y=36,w=40,h=24
      head:  x=6, y=0, w=60, h=28
      face:  eye x=14..28 y=8..18 | nose x=28..44 y=20..30 | mouth hline y=28
-->
<asset-spec extends="abstract/entities/dog@1.0" version="3.0.0">
  <meta>
    <entity-type>characters</entity-type>
    <entity-name>duke</entity-name>
    <version>3.0.0</version>
    <display-scale>1.5</display-scale>
  </meta>

  <color-palette>
    <color name="$fur_base"        value="#D4C090"/>
    <color name="$fur_shadow"      value="#B0A070"/>
    <color name="$fur_highlight"   value="#EAD8A8"/>
    <color name="$belly_base"      value="#EDE0C0"/>
    <color name="$belly_highlight" value="#FAF0D8"/>
    <color name="$mask_color"      value="#101010"/>
    <color name="$mask_shadow"     value="#000000"/>
    <color name="$saddle_dark"     value="#1A1A10"/>
    <color name="$saddle_mid"      value="#303020"/>
    <color name="$nose_color"      value="#101010"/>
    <color name="$nose_highlight"  value="#383838"/>
    <color name="$eye_color"       value="#5A3A10"/>
    <color name="$eye_highlight"   value="#8A6020"/>
    <color name="$paw_pad"         value="#707060"/>
    <color name="$ear_inner"       value="#C0B080"/>
    <color name="$tongue_color"    value="#FF6060"/>
  </color-palette>

  <layer-overrides>

    <!-- ============================================================ -->
    <!-- BODY override                                                -->
    <!-- abstract/dog body: x=12, y=28, w=96, h=44 (x=12..108)      -->
    <!-- Cream-beige base + saddle hatch y=28..42 (14 lines)         -->
    <!-- Flank shadows: x=12..25 and x=95..108                       -->
    <!-- ============================================================ -->
    <layer id="body" replace="true">
      <pixel-data>
        <!-- CREAM BASE — full torso -->
        <rect x="12" y="28" w="96" h="44" color="$fur_base"/>

        <!-- DORSAL HIGHLIGHT — withers zone -->
        <rect x="36" y="28" w="48" h="10" color="$fur_highlight"/>
        <hline x="20" y="28" len="72"      color="$fur_highlight"/>

        <!-- SADDLE HATCH — y=28..42, alternating dark lines -->
        <!-- y=28 --> <hline x="12" y="28" len="96" color="$saddle_dark"/>
        <!-- y=29 --> <hline x="12" y="29" len="96" color="$saddle_mid"/>
        <!-- y=30 --> <hline x="12" y="30" len="96" color="$saddle_dark"/>
        <!-- y=31 --> <hline x="12" y="31" len="96" color="$saddle_mid"/>
        <!-- y=32 --> <hline x="12" y="32" len="96" color="$saddle_dark"/>
        <!-- y=33 --> <hline x="12" y="33" len="96" color="$saddle_mid"/>
        <!-- y=34 --> <hline x="12" y="34" len="96" color="$saddle_dark"/>
        <!-- y=35 --> <hline x="12" y="35" len="96" color="$saddle_mid"/>
        <!-- y=36 --> <hline x="12" y="36" len="96" color="$saddle_dark"/>
        <!-- y=37 --> <hline x="12" y="37" len="96" color="$saddle_mid"/>
        <!-- y=38 --> <hline x="12" y="38" len="96" color="$saddle_dark"/>
        <!-- y=39 --> <hline x="12" y="39" len="96" color="$saddle_mid"/>
        <!-- y=40 --> <hline x="12" y="40" len="96" color="$saddle_dark"/>
        <!-- y=41 --> <hline x="12" y="41" len="96" color="$saddle_mid"/>
        <!-- y=42 saddle bottom edge -->
        <hline x="12" y="42" len="96"      color="$fur_shadow"/>

        <!-- FLANK SHADOWS — left (chest side) -->
        <rect x="12" y="36" w="14" h="36"  color="$fur_shadow"/>
        <!-- FLANK SHADOWS — right (croup side) -->
        <rect x="94" y="36" w="14" h="36"  color="$fur_shadow"/>

        <!-- UNDERLINE SHADOW -->
        <hline x="16" y="70" len="88"      color="$fur_shadow"/>
        <hline x="12" y="71" len="96"      color="$fur_shadow"/>
      </pixel-data>
    </layer>

    <!-- ============================================================ -->
    <!-- BELLY override                                               -->
    <!-- abstract/dog belly: base x=28,y=48,w=64,h=32               -->
    <!--                     sternum x=36,y=36,w=40,h=24            -->
    <!-- Full light cream — no dark markings                          -->
    <!-- ============================================================ -->
    <layer id="belly" replace="true">
      <pixel-data>
        <!-- BELLY BASE — full area -->
        <rect x="28" y="48" w="64" h="32" color="$belly_base"/>
        <!-- STERNUM / CHEST AREA -->
        <rect x="36" y="36" w="40" h="24" color="$belly_base"/>

        <!-- CENTRE HIGHLIGHT — belly -->
        <rect x="44" y="52" w="32" h="20" color="$belly_highlight"/>
        <!-- CENTRE HIGHLIGHT — sternum -->
        <rect x="42" y="38" w="28" h="18" color="$belly_highlight"/>

        <!-- EDGE FADE — blend into body flanks -->
        <vline x="28" y="48" len="32"      color="$fur_base"/>
        <vline x="92" y="48" len="32"      color="$fur_base"/>
        <vline x="36" y="36" len="24"      color="$fur_base"/>
        <vline x="76" y="36" len="24"      color="$fur_base"/>

        <!-- BOTTOM SHADOW -->
        <hline x="28" y="79" len="64"      color="$fur_shadow"/>
      </pixel-data>
    </layer>

    <!-- ============================================================ -->
    <!-- HEAD override                                                -->
    <!-- abstract/dog head: x=6, y=0, w=60, h=28  (x=6..66)         -->
    <!-- Skull (y=0..16): cream-beige                                 -->
    <!-- Transition (y=12..16): 2px fur_shadow strip                  -->
    <!-- Mask (y=12..28): full black from muzzle to mid-skull         -->
    <!-- Eye: ABOVE mask, in cream zone, y=8..18, x=14..28           -->
    <!-- ============================================================ -->
    <layer id="head" replace="true">
      <pixel-data>
        <!-- CREAM SKULL — upper head -->
        <rect x="6"  y="0"  w="60" h="28" color="$fur_base"/>
        <!-- skull top highlight -->
        <rect x="16" y="0"  w="36" h="12" color="$fur_highlight"/>
        <hline x="10" y="1" len="44"       color="$fur_highlight"/>
        <!-- skull back volume -->
        <rect x="60" y="4"  w="6"  h="20" color="$fur_shadow"/>
        <!-- occiput bump -->
        <rect x="58" y="0"  w="8"  h="6"  color="$fur_base"/>
        <hline x="60" y="0" len="4"        color="$fur_highlight"/>

        <!-- SKULL→MASK TRANSITION — y=12..16 -->
        <hline x="6"  y="12" len="58"      color="$fur_shadow"/>
        <hline x="6"  y="13" len="58"      color="$fur_shadow"/>

        <!-- BLACK MASK — covers y=14..28, x=6..64 (full lower head) -->
        <rect x="6"  y="14" w="58" h="14" color="$mask_color"/>
        <!-- mask top feather — 2px blend -->
        <hline x="6"  y="14" len="58"      color="$mask_color"/>
        <hline x="6"  y="15" len="58"      color="$mask_color"/>
        <!-- mask deep shadow at jaw -->
        <hline x="10" y="26" len="52"      color="$mask_shadow"/>
        <hline x="8"  y="27" len="54"      color="$mask_shadow"/>
        <hline x="6"  y="28" len="58"      color="$mask_shadow"/>
        <!-- cheek jowl in mask -->
        <rect x="20" y="18" w="12" h="8"  color="$mask_color"/>

        <!-- AMBER EYE — in cream skull zone, above mask (y=8..18, x=14..28) -->
        <!-- white sclera -->
        <rect x="14" y="8"  w="14" h="10" color="#FFFFFF"/>
        <!-- amber iris -->
        <rect x="18" y="10" w="8"  h="6"  color="$eye_color"/>
        <!-- iris highlight -->
        <pixel x="18" y="10"               color="$eye_highlight"/>
        <pixel x="19" y="10"               color="$eye_highlight"/>
        <!-- pupil -->
        <rect x="21" y="11" w="3"  h="4"  color="#000000"/>
        <!-- eye shine -->
        <pixel x="21" y="11"               color="#FFFFFF"/>
        <!-- brow ridge — cream fur over mask boundary -->
        <hline x="14" y="7"  len="14"      color="$fur_shadow"/>
        <hline x="16" y="6"  len="10"      color="$fur_shadow"/>
        <!-- lower lid — sits at mask edge y=18 -->
        <hline x="14" y="18" len="14"      color="$mask_color"/>

        <!-- muzzle bridge (above nose) in mask -->
        <rect x="6"  y="16" w="22" h="6"  color="$mask_color"/>

        <!-- stop depression -->
        <hline x="26" y="14" len="6"       color="$mask_shadow"/>
      </pixel-data>
    </layer>

    <!-- ============================================================ -->
    <!-- FACE DETAILS override                                        -->
    <!-- Everything inside black mask zone (y=16..28, x=6..30)       -->
    <!-- Nose: x=28..44 y=20..30 from abstract/dog → adapted to mask  -->
    <!-- Nose end of muzzle (leftmost): x=6..14, y=18..24            -->
    <!-- Mouth closed: hline at y=25..26                              -->
    <!-- No whiskers, no white details                                -->
    <!-- ============================================================ -->
    <layer id="face_details" replace="true">
      <pixel-data>
        <!-- NOSE — at muzzle tip, inside black mask -->
        <!-- abstract/dog nose was x=28..44,y=20..30 (frontal);  -->
        <!-- side-view muzzle tip is leftmost: x=6..14, y=18..24 -->
        <rect x="6"  y="18" w="8"  h="6"  color="$nose_color"/>
        <!-- nose shine strip -->
        <hline x="7"  y="18" len="4"       color="$nose_highlight"/>
        <hline x="7"  y="19" len="3"       color="$nose_highlight"/>
        <!-- nostril divider -->
        <vline x="10" y="19" len="4"       color="$mask_shadow"/>
        <!-- nose bridge connects to mask -->
        <rect x="8"  y="14" w="4"  h="5"  color="$mask_shadow"/>

        <!-- CLOSED MOUTH — horizontal line under nose in mask -->
        <hline x="6"  y="25" len="22"      color="$mask_shadow"/>
        <hline x="8"  y="26" len="20"      color="$mask_shadow"/>
        <!-- lip corner folds -->
        <pixel x="6"  y="24"               color="$mask_shadow"/>
        <pixel x="28" y="24"               color="$mask_shadow"/>

        <!-- CHIN SHADOW — underside of jaw in mask -->
        <hline x="8"  y="27" len="18"      color="$mask_shadow"/>
      </pixel-data>
    </layer>

  </layer-overrides>

  <naming>
    <output-dir>characters/duke</output-dir>
  </naming>

</asset-spec>
