<?xml version="1.0" encoding="UTF-8"?>
<!--
  Lada — Black-and-white cat, ~2 years old. Daughter of Asta.
  Rescued twice — first as kitten, then returned after abuse in 2025.
  Klop helped her integrate. Now Klop's chubby friend.
  TWO personality modes: SCARED (default) and CONFIDENT (after Klop quest).
  "Like Batman but darker" — high black-white contrast (tuxedo).
  Canvas inherited from abstract/entities/cat (128×96).
-->
<asset-spec extends="abstract/entities/cat@1.0">
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>lada</entity-name>
        <version>3.0.0</version>
    </meta>

    <color-palette>
        <color name="$fur_base" value="#1A1A1A"/>
        <color name="$fur_light" value="#2E2E2E"/>
        <color name="$fur_shadow" value="#0D0D0D"/>
        <color name="$fur_dark" value="#0D0D0D"/>
        <color name="$fur_highlight" value="#3D3D3D"/>
        <color name="$belly_color" value="#F0F0F0"/>
        <color name="$eye_color" value="#AA6644"/><!-- amber=scared, green=#66AA44=confident -->
        <color name="$eye_dark" value="#883322"/>
        <color name="$nose_color" value="#FFDDDD"/>
        <color name="$paw_pad" value="#FFDDDD"/>
        <color name="$ear_inner" value="#D8D8D8"/>
        <color name="$pupil" value="#111111"/>
        <color name="$eye_shine" value="#FFFFFF"/>
        <color name="$whisker" value="#CCCCCC"/>
        <!-- Lada-specific extra colors -->
        <color name="$white_main" value="#F0F0F0"/>
        <color name="$white_shadow" value="#D8D8D8"/>
        <color name="$white_deep" value="#B8B8B8"/>
        <color name="$transition" value="#888888"/>
    </color-palette>

    <layer-overrides>
        <!-- Tuxedo body: black back with sharp white belly transition -->
        <layer id="body" replace="true">
            <pixel-data>
                <!-- main torso: black -->
                <rect x="28" y="40" w="64" h="28" color="$fur_base"/>
                <!-- back sheen: Batman-dark gloss -->
                <hline x="32" y="40" len="56" color="$fur_light"/>
                <hline x="36" y="44" len="48" color="#222222"/>
                <!-- shoulder highlights -->
                <pixel x="28" y="40" color="$fur_highlight"/>
                <pixel x="32" y="40" color="$fur_highlight"/>
                <!-- tuxedo transition line -->
                <hline x="36" y="64" len="40" color="$transition"/>
                <!-- flank shadows -->
                <rect x="28" y="48" w="4" h="12" color="$fur_shadow"/>
                <rect x="88" y="48" w="4" h="12" color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- White tuxedo chest/belly -->
        <layer id="belly" replace="true">
            <pixel-data>
                <rect x="36" y="48" w="32" h="20" color="$white_main"/>
                <hline x="40" y="48" len="24" color="#FFFFFF"/>
                <hline x="40" y="60" len="24" color="$white_shadow"/>
                <hline x="44" y="64" len="16" color="$white_deep"/>
                <!-- side transitions -->
                <pixel x="36" y="52" color="$white_shadow"/>
                <pixel x="36" y="56" color="$white_deep"/>
                <pixel x="64" y="52" color="$white_shadow"/>
                <pixel x="64" y="56" color="$white_deep"/>
            </pixel-data>
        </layer>

        <!-- White-tipped paws -->
        <layer id="paws" replace="true">
            <pixel-data>
                <!-- front-left: white -->
                <rect x="20" y="76" w="8" h="8" color="$white_main"/>
                <hline x="20" y="76" len="8" color="#FFFFFF"/>
                <hline x="20" y="80" len="8" color="$white_shadow"/>
                <pixel x="20" y="80" color="$paw_pad"/>
                <pixel x="24" y="80" color="$paw_pad"/>
                <!-- front-right -->
                <rect x="40" y="76" w="8" h="8" color="$white_main"/>
                <hline x="40" y="76" len="8" color="#FFFFFF"/>
                <hline x="40" y="80" len="8" color="$white_shadow"/>
                <pixel x="40" y="80" color="$paw_pad"/>
                <pixel x="44" y="80" color="$paw_pad"/>
                <!-- hind-left -->
                <rect x="76" y="76" w="8" h="8" color="$white_main"/>
                <hline x="76" y="76" len="8" color="#FFFFFF"/>
                <hline x="76" y="80" len="8" color="$white_shadow"/>
                <pixel x="76" y="80" color="$paw_pad"/>
                <!-- hind-right -->
                <rect x="96" y="76" w="8" h="8" color="$white_main"/>
                <hline x="96" y="76" len="8" color="#FFFFFF"/>
                <hline x="96" y="80" len="8" color="$white_shadow"/>
                <pixel x="96" y="80" color="$paw_pad"/>
            </pixel-data>
        </layer>

        <!-- Black tail with white tip (Batman highlight) -->
        <layer id="tail" replace="true">
            <pixel-data>
                <pixel x="88" y="44" color="$fur_base"/>
                <pixel x="92" y="40" color="$fur_base"/>
                <pixel x="96" y="36" color="$fur_base"/>
                <pixel x="100" y="32" color="$fur_base"/>
                <pixel x="104" y="28" color="$fur_base"/>
                <pixel x="108" y="28" color="$fur_light"/>
                <!-- white tail tip -->
                <pixel x="112" y="28" color="$white_main"/>
                <pixel x="116" y="28" color="#FFFFFF"/>
                <pixel x="116" y="32" color="$white_shadow"/>
                <pixel x="112" y="24" color="#E0E0E0"/>
                <!-- tail sheen -->
                <pixel x="92" y="44" color="$fur_light"/>
                <pixel x="100" y="36" color="$fur_light"/>
                <!-- tail underside shadow -->
                <pixel x="88" y="40" color="$fur_shadow"/>
                <pixel x="92" y="36" color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- Batman cowl head with white muzzle -->
        <layer id="head" replace="true">
            <pixel-data>
                <!-- head block: black -->
                <rect x="8" y="8" w="40" h="32" color="$fur_base"/>
                <!-- forehead sheen -->
                <hline x="12" y="8" len="32" color="$fur_light"/>
                <hline x="16" y="12" len="24" color="#222222"/>
                <!-- mask sides -->
                <pixel x="8" y="16" color="$fur_shadow"/>
                <pixel x="8" y="20" color="$fur_shadow"/>
                <pixel x="44" y="16" color="$fur_shadow"/>
                <pixel x="44" y="20" color="$fur_shadow"/>
                <!-- white muzzle patch -->
                <rect x="12" y="24" w="28" h="16" color="$white_main"/>
                <hline x="16" y="24" len="20" color="#FFFFFF"/>
                <hline x="16" y="36" len="20" color="$white_shadow"/>
                <!-- black cheeks framing white -->
                <pixel x="12" y="24" color="$fur_base"/>
                <pixel x="12" y="28" color="$fur_base"/>
                <pixel x="12" y="32" color="$transition"/>
                <pixel x="36" y="24" color="$fur_base"/>
                <pixel x="36" y="28" color="$fur_base"/>
                <pixel x="36" y="32" color="$transition"/>
            </pixel-data>
        </layer>

        <!-- Face: scared=amber, confident=green eyes -->
        <layer id="face_details" replace="true">
            <pixel-data>
                <!-- LEFT EYE: wide amber (scared default) -->
                <pixel x="16" y="16" color="$eye_color"/>
                <pixel x="20" y="12" color="#CC8855"/>
                <pixel x="24" y="12" color="#CC8855"/>
                <pixel x="20" y="16" color="#CC8855"/>
                <pixel x="24" y="16" color="$pupil"/>
                <pixel x="16" y="12" color="$eye_dark"/>
                <pixel x="20" y="12" color="$eye_shine"/>
                <!-- RIGHT EYE -->
                <pixel x="28" y="16" color="$eye_color"/>
                <pixel x="32" y="12" color="#CC8855"/>
                <pixel x="36" y="12" color="#CC8855"/>
                <pixel x="32" y="16" color="#CC8855"/>
                <pixel x="36" y="16" color="$pupil"/>
                <pixel x="28" y="12" color="$eye_dark"/>
                <pixel x="32" y="12" color="$eye_shine"/>
                <!-- NOSE: small pink on white muzzle -->
                <rect x="20" y="24" w="8" h="8" color="$nose_color"/>
                <pixel x="20" y="24" color="#FFFFFF"/>
                <pixel x="24" y="28" color="#FF9999"/>
                <pixel x="20" y="28" color="#FF9999"/>
                <!-- MOUTH: tense (scared) -->
                <pixel x="16" y="32" color="$transition"/>
                <pixel x="20" y="32" color="$white_deep"/>
                <pixel x="24" y="32" color="$white_deep"/>
                <pixel x="28" y="32" color="$transition"/>
                <!-- WHISKERS -->
                <hline x="0" y="28" len="16" color="$whisker"/>
                <hline x="0" y="32" len="12" color="#AAAAAA"/>
                <hline x="36" y="28" len="16" color="$whisker"/>
                <hline x="36" y="32" len="12" color="#AAAAAA"/>
            </pixel-data>
        </layer>
    </layer-overrides>

    <!-- Base 5 animations inherited. Lada-specific extras: -->
    <animations-extra>
        <!-- scared_hide: sprint to corner on threat -->
        <animation name="scared_hide" frames="12" fps="12" loop="false" frame-width="128" frame-height="96">
            <condition type="trigger" value="threat_detected"/>
            <frame index="0" layer-offsets="ears:0,4; face_details:0,-4; tail:-4,4"/>
            <frame index="1" layer-offsets="body:12,4; belly:12,4; neck:12,4; head:12,0; ears:12,8; face_details:12,0; front_legs:16,0; hind_legs:8,4; paws:16,4; tail:8,12"/>
            <frame index="2" layer-offsets="body:20,0; belly:20,0; neck:20,0; head:20,0; ears:20,8; face_details:20,0; front_legs:28,-4; hind_legs:16,0; paws:28,0; tail:12,12"/>
            <frame index="3" layer-offsets="body:16,4; belly:16,4; neck:16,4; head:16,4; ears:16,8; face_details:16,4; front_legs:20,0; hind_legs:20,0; paws:20,0; tail:12,12"/>
            <frame index="4" layer-offsets="body:24,0; belly:24,0; neck:24,0; head:24,0; ears:24,8; face_details:24,0; front_legs:32,-4; hind_legs:20,0; paws:32,0; tail:16,12"/>
            <frame index="5" layer-offsets="body:20,4; belly:20,4; neck:20,4; head:20,4; ears:20,8; face_details:20,4; front_legs:24,0; hind_legs:24,0; paws:24,0; tail:16,12"/>
            <frame index="6" layer-offsets="body:28,4; belly:28,4; neck:28,4; head:28,4; ears:28,8; face_details:28,4; front_legs:32,4; hind_legs:28,4; paws:32,4; tail:20,12"/>
            <frame index="7" layer-offsets="body:32,8; belly:32,8; neck:32,8; head:32,8; ears:32,12; face_details:32,8; front_legs:32,8; hind_legs:32,8; paws:32,8; tail:24,16"/>
            <frame index="8" layer-offsets="body:32,12; belly:32,12; neck:32,12; head:32,12; ears:32,16; face_details:32,12; front_legs:32,12; hind_legs:32,12; paws:32,12; tail:20,16"/>
            <frame index="9" layer-offsets="body:36,12; belly:36,12; neck:36,12; head:36,12; ears:36,16; face_details:36,12; front_legs:36,12; hind_legs:36,12; paws:36,12; tail:24,16"/>
            <frame index="10" layer-offsets="body:28,12; belly:28,12; neck:28,12; head:28,12; ears:28,16; face_details:28,12; front_legs:28,12; hind_legs:28,12; paws:28,12; tail:20,16"/>
            <frame index="11" layer-offsets="body:32,12; belly:32,12; neck:32,12; head:32,12; ears:32,16; face_details:32,12; front_legs:32,12; hind_legs:32,12; paws:32,12; tail:28,16"/>
        </animation>

        <!-- trust_approach: Lada approaches Klop — pivotal bonding moment -->
        <animation name="trust_approach" frames="12" fps="5" loop="false" frame-width="128" frame-height="96">
            <condition type="trigger" value="klop_presents_peace_signal"/>
            <frame index="0" layer-offsets="body:20,8; belly:20,8; front_legs:20,8; hind_legs:20,8; paws:20,8; neck:20,8; head:20,4; ears:20,8; face_details:20,4; tail:20,12"/>
            <frame index="1" layer-offsets="body:20,8; belly:20,8; front_legs:16,8; hind_legs:20,8; paws:16,8; neck:12,8; head:12,4; ears:12,8; face_details:12,4; tail:20,12"/>
            <frame index="2" layer-offsets="body:20,8; belly:20,8; front_legs:16,8; hind_legs:20,8; paws:16,8; neck:12,8; head:12,4; ears:12,8; face_details:12,4; tail:16,12"/>
            <frame index="3" layer-offsets="body:20,8; belly:20,8; front_legs:16,8; hind_legs:20,8; paws:16,8; neck:12,8; head:12,4; ears:12,4; face_details:12,4; tail:16,8"/>
            <frame index="4" layer-offsets="body:16,8; belly:16,8; front_legs:12,8; hind_legs:16,8; paws:12,8; neck:8,8; head:8,4; ears:8,4; face_details:8,4; tail:16,8"/>
            <frame index="5" layer-offsets="body:16,8; belly:16,8; front_legs:12,8; hind_legs:16,8; paws:12,8; neck:8,8; head:8,4; ears:8,4; face_details:8,8; tail:12,8"/>
            <frame index="6" layer-offsets="body:16,8; belly:16,8; front_legs:12,8; hind_legs:16,8; paws:12,8; neck:8,8; head:8,4; ears:8,0; face_details:8,4; tail:12,8"/>
            <frame index="7" layer-offsets="body:8,8; belly:8,8; front_legs:4,8; hind_legs:8,8; paws:4,8; neck:4,8; head:4,4; ears:4,4; face_details:4,4; tail:8,8"/>
            <frame index="8" layer-offsets="body:8,8; belly:8,8; front_legs:4,8; hind_legs:8,8; paws:4,8; neck:-4,8; head:-4,4; ears:-4,4; face_details:-4,4; tail:8,8"/>
            <frame index="9" layer-offsets="body:4,8; belly:4,8; front_legs:0,8; hind_legs:4,8; paws:0,8; neck:-8,8; head:-8,4; ears:-8,0; face_details:-8,4; tail:4,8"/>
            <frame index="10" layer-offsets="body:4,8; belly:4,8; front_legs:0,8; hind_legs:4,8; paws:0,8; neck:-8,8; head:-8,4; ears:-8,0; face_details:-8,0; tail:0,8"/>
            <frame index="11" layer-offsets="body:4,8; belly:4,8; front_legs:0,8; hind_legs:4,8; paws:0,8; neck:-4,8; head:-4,4; ears:-4,0; face_details:-4,0; tail:-4,4"/>
        </animation>

        <!-- confident_walk: post-quest — upright, tail high, green eyes -->
        <animation name="confident_walk" frames="12" fps="10" loop="true" frame-width="128" frame-height="96">
            <condition type="state" value="confident_mode"/>
            <frame index="0" layer-offsets="front_legs:-4,0; paws:-4,0; hind_legs:4,0; tail:0,-12"/>
            <frame index="1" layer-offsets="body:-4,-4; belly:-4,-4; neck:-4,-4; head:-4,-4; ears:-4,-8; face_details:-4,-8; front_legs:-8,0; paws:-8,0; tail:-4,-12"/>
            <frame index="2" layer-offsets="body:-4,-4; belly:-4,-4; neck:-4,-4; head:-4,-4; ears:-4,-8; face_details:-4,-8; front_legs:-8,-8; paws:-4,-12; tail:-4,-12"/>
            <frame index="3" layer-offsets="body:-4,-4; belly:-4,-4; neck:-4,-4; head:-4,-4; ears:-4,-8; face_details:-4,-8; front_legs:-4,-8; paws:0,-8; hind_legs:-4,0; tail:-4,-12"/>
            <frame index="4" layer-offsets="front_legs:0,0; paws:0,0; hind_legs:-4,0; tail:0,-12"/>
            <frame index="5" layer-offsets="body:4,-4; belly:4,-4; neck:4,-4; head:4,-4; ears:4,-8; face_details:4,-8; front_legs:4,0; paws:4,0; tail:4,-12"/>
            <frame index="6" layer-offsets="body:4,-4; belly:4,-4; neck:4,-4; head:4,-4; ears:4,-8; face_details:4,-8; front_legs:8,-8; paws:12,-12; tail:4,-12"/>
            <frame index="7" layer-offsets="body:4,-8; belly:4,-8; neck:4,-8; head:4,-8; ears:4,-8; face_details:4,-12; front_legs:4,-8; paws:8,-8; hind_legs:4,0; tail:4,-12"/>
            <frame index="8" layer-offsets="body:0,-8; belly:0,-8; neck:0,-8; head:0,-8; ears:0,-12; face_details:0,-12; tail:0,-16"/>
            <frame index="9" layer-offsets="body:0,-4; belly:0,-4; neck:0,-4; head:0,-4; front_legs:0,0; paws:0,0; tail:0,-12"/>
            <frame index="10" layer-offsets="front_legs:-4,0; paws:-4,0; hind_legs:4,0; tail:0,-12"/>
            <frame index="11" layer-offsets="tail:0,-12; head:0,-4; ears:0,-8; face_details:0,-8"/>
        </animation>
    </animations-extra>

    <naming>
        <output-dir>characters/lada</output-dir>
    </naming>
</asset-spec>