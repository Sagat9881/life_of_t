<?xml version="1.0" encoding="UTF-8"?>
<!--
  Voland — French Bulldog, ~11 years old, blind since 2020
  Canvas inherited from abstract/entities/dog (128×96).
  Lives at Tanya's parents' cottage. Witness to Tanya + Alexander's
  love story since 2015. Blind: cataracts, cloudy milky eyes.
  Moves slowly, bumps into things, but knows his paths by memory.
  Fawn/cream coat, bat ears, screw-tail nub, heavy wrinkles.
-->
<asset-spec extends="abstract/entities/dog@1.0" version="3.0.0">
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>voland</entity-name>
        <version>3.0.0</version>
    </meta>

    <color-palette>
        <color name="$fur_base" value="#D4A574"/>
        <color name="$fur_light" value="#E8C098"/>
        <color name="$fur_shadow" value="#B8956A"/>
        <color name="$fur_dark" value="#A07848"/>
        <color name="$fur_highlight" value="#F0D5B0"/>
        <color name="$belly_color" value="#F0D5B0"/>
        <color name="$eye_color" value="#C0C0D0"/><!-- milky cataract -->
        <color name="$eye_dark" value="#8B9090"/><!-- grey-blue cataract tint -->
        <color name="$nose_color" value="#442211"/>
        <color name="$paw_pad" value="#664422"/>
        <color name="$ear_inner" value="#DDAAAA"/>
        <color name="$pupil" value="#9090A8"/><!-- hazy, NOT dark -->
        <color name="$eye_shine" value="#D8D8E8"/><!-- NO bright shine, milky -->
        <color name="$whisker" value="#CCCCCC"/>
        <!-- Voland-specific -->
        <color name="$wrinkle_deep" value="#8B6440"/>
        <color name="$wrinkle_mid" value="#A07848"/>
        <color name="$nose_detail" value="#553322"/>
        <color name="$sclera_milky" value="#D8D8E8"/>
    </color-palette>

    <layer-overrides>
        <!-- Wide barrel-chested Frenchie body with age wrinkles -->
        <layer id="body" replace="true">
            <pixel-data>
                <!-- very wide barrel body -->
                <rect x="16" y="36" w="80" h="28" color="$fur_base"/>
                <!-- back sheen -->
                <hline x="20" y="36" len="72" color="$fur_light"/>
                <hline x="24" y="40" len="64" color="$fur_light"/>
                <!-- spine groove (visible spinal furrow) -->
                <hline x="44" y="36" len="8" color="$fur_shadow"/>
                <hline x="44" y="40" len="8" color="$fur_shadow"/>
                <!-- rib shadow -->
                <hline x="20" y="56" len="72" color="$wrinkle_mid"/>
                <!-- coat texture -->
                <pixel x="24" y="44" color="$fur_light"/>
                <pixel x="36" y="44" color="$fur_light"/>
                <pixel x="48" y="44" color="$fur_light"/>
                <pixel x="60" y="44" color="$fur_light"/>
                <pixel x="72" y="44" color="$fur_light"/>
                <pixel x="84" y="44" color="$fur_light"/>
                <pixel x="28" y="48" color="$fur_shadow"/>
                <pixel x="40" y="48" color="$fur_shadow"/>
                <pixel x="52" y="48" color="$fur_shadow"/>
                <pixel x="64" y="48" color="$fur_shadow"/>
                <pixel x="76" y="48" color="$fur_shadow"/>
                <!-- rounded rump -->
                <rect x="88" y="32" w="12" h="24" color="$fur_base"/>
                <pixel x="96" y="32" color="$fur_shadow"/>
                <pixel x="96" y="36" color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- Cream/white belly with age-related loose fold -->
        <layer id="belly" replace="true">
            <pixel-data>
                <rect x="32" y="56" w="48" h="12" color="$fur_highlight"/>
                <hline x="36" y="56" len="40" color="$fur_light"/>
                <hline x="40" y="60" len="32" color="$fur_highlight"/>
                <hline x="36" y="64" len="40" color="$fur_light"/>
                <!-- belly loose fold (age) -->
                <hline x="32" y="64" len="48" color="$fur_shadow"/>
                <!-- deep belly shadow -->
                <hline x="28" y="68" len="56" color="$wrinkle_mid"/>
                <!-- cream chest bib -->
                <rect x="28" y="44" w="20" h="16" color="$fur_highlight"/>
                <hline x="32" y="44" len="12" color="#FFFFFF"/>
                <!-- bib wrinkle -->
                <hline x="32" y="52" len="12" color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- Screw-tail nub (vestigial French bulldog tail) -->
        <layer id="tail" replace="true">
            <pixel-data>
                <!-- corkscrew nub: tiny -->
                <pixel x="88" y="44" color="$fur_base"/>
                <pixel x="92" y="40" color="$fur_base"/>
                <pixel x="96" y="36" color="$fur_base"/>
                <pixel x="96" y="32" color="$fur_light"/>
                <!-- screw turn back -->
                <pixel x="92" y="32" color="$fur_base"/>
                <pixel x="88" y="36" color="$fur_shadow"/>
                <pixel x="88" y="40" color="$fur_shadow"/>
                <!-- tail base shadow -->
                <pixel x="84" y="44" color="$wrinkle_mid"/>
                <pixel x="84" y="40" color="$wrinkle_deep"/>
                <!-- nub top highlight -->
                <pixel x="92" y="36" color="$fur_light"/>
            </pixel-data>
        </layer>

        <!-- Massive wide flat bulldog head with deep wrinkles -->
        <layer id="head" replace="true">
            <pixel-data>
                <!-- skull: very wide, squarish -->
                <rect x="0" y="4" w="48" h="32" color="$fur_base"/>
                <!-- skull top highlight -->
                <hline x="4" y="4" len="40" color="$fur_light"/>
                <hline x="8" y="8" len="32" color="$fur_light"/>
                <!-- wrinkled forehead: 3 wrinkle lines -->
                <hline x="8" y="12" len="32" color="$wrinkle_mid"/>
                <hline x="12" y="16" len="24" color="$fur_shadow"/>
                <hline x="8" y="20" len="32" color="$wrinkle_mid"/>
                <!-- compressed flat nose area (brachycephalic) -->
                <rect x="8" y="20" w="32" h="16" color="$fur_base"/>
                <!-- jowl folds -->
                <pixel x="0" y="20" color="$wrinkle_deep"/>
                <pixel x="0" y="24" color="$wrinkle_deep"/>
                <pixel x="0" y="28" color="$wrinkle_mid"/>
                <pixel x="44" y="20" color="$wrinkle_deep"/>
                <pixel x="44" y="24" color="$wrinkle_deep"/>
                <pixel x="44" y="28" color="$wrinkle_mid"/>
                <!-- underbite jaw -->
                <rect x="8" y="32" w="32" h="8" color="$fur_base"/>
                <hline x="12" y="36" len="24" color="$fur_light"/>
                <!-- cheek roundness -->
                <pixel x="4" y="16" color="$fur_shadow"/>
                <pixel x="4" y="20" color="$fur_shadow"/>
                <pixel x="40" y="16" color="$fur_shadow"/>
                <pixel x="40" y="20" color="$fur_shadow"/>
            </pixel-data>
        </layer>

        <!-- Large BAT ears — French bulldog signature -->
        <layer id="ears" replace="true">
            <pixel-data>
                <!-- left bat ear: wide, tall, upright -->
                <rect x="0" y="0" w="16" h="16" color="$fur_base"/>
                <pixel x="4" y="0" color="$fur_light"/>
                <pixel x="8" y="0" color="$fur_light"/>
                <!-- ear inner pink -->
                <pixel x="4" y="4" color="$ear_inner"/>
                <pixel x="8" y="4" color="$ear_inner"/>
                <pixel x="4" y="8" color="$ear_inner"/>
                <pixel x="8" y="8" color="$ear_inner"/>
                <!-- ear edge shadow -->
                <pixel x="0" y="4" color="$fur_shadow"/>
                <pixel x="12" y="4" color="$fur_shadow"/>
                <!-- right bat ear -->
                <rect x="32" y="0" w="16" h="16" color="$fur_base"/>
                <pixel x="36" y="0" color="$fur_light"/>
                <pixel x="40" y="0" color="$fur_light"/>
                <pixel x="36" y="4" color="$ear_inner"/>
                <pixel x="40" y="4" color="$ear_inner"/>
                <pixel x="36" y="8" color="$ear_inner"/>
                <pixel x="40" y="8" color="$ear_inner"/>
                <pixel x="32" y="4" color="$fur_shadow"/>
                <pixel x="44" y="4" color="$fur_shadow"/>
                <!-- ear base attachment -->
                <hline x="0" y="16" len="16" color="$wrinkle_mid"/>
                <hline x="32" y="16" len="16" color="$wrinkle_mid"/>
            </pixel-data>
        </layer>

        <!-- MILKY BLIND EYES, flat wide nose, deep wrinkles -->
        <layer id="face_details" replace="true">
            <pixel-data>
                <!-- LEFT EYE: CLOUDY CATARACT — no sharp pupil, all diffuse -->
                <rect x="8" y="12" w="12" h="12" color="$sclera_milky"/>
                <pixel x="8" y="12" color="$eye_color"/>
                <pixel x="12" y="8" color="$sclera_milky"/>
                <pixel x="16" y="8" color="$sclera_milky"/>
                <pixel x="12" y="12" color="$eye_color"/>
                <pixel x="16" y="12" color="$eye_color"/>
                <pixel x="8" y="16" color="$eye_color"/>
                <pixel x="12" y="16" color="$eye_dark"/>
                <pixel x="16" y="16" color="$pupil"/>
                <pixel x="12" y="12" color="$pupil"/><!-- hazy diffuse pupil -->
                <!-- NO bright eye shine — blind -->
                <!-- eyelid wrinkle (aged, droopy) -->
                <pixel x="8" y="8" color="$wrinkle_mid"/>
                <pixel x="20" y="8" color="$wrinkle_mid"/>
                <!-- RIGHT EYE: same milky cataract -->
                <rect x="28" y="12" w="12" h="12" color="$sclera_milky"/>
                <pixel x="28" y="12" color="$eye_color"/>
                <pixel x="32" y="8" color="$sclera_milky"/>
                <pixel x="36" y="8" color="$sclera_milky"/>
                <pixel x="32" y="12" color="$eye_color"/>
                <pixel x="36" y="12" color="$eye_color"/>
                <pixel x="28" y="16" color="$eye_color"/>
                <pixel x="32" y="16" color="$eye_dark"/>
                <pixel x="36" y="16" color="$pupil"/>
                <pixel x="32" y="12" color="$pupil"/>
                <pixel x="28" y="8" color="$wrinkle_mid"/>
                <pixel x="40" y="8" color="$wrinkle_mid"/>
                <!-- NOSE: wide flat bulldog, dark -->
                <rect x="12" y="24" w="24" h="8" color="$nose_color"/>
                <hline x="16" y="24" len="16" color="$nose_detail"/>
                <!-- wide nostrils -->
                <pixel x="12" y="28" color="#331100"/>
                <pixel x="16" y="28" color="#331100"/>
                <pixel x="24" y="28" color="#331100"/>
                <pixel x="28" y="28" color="#331100"/>
                <!-- nasal fold shadow -->
                <hline x="12" y="20" len="24" color="$wrinkle_deep"/>
                <!-- MOUTH: underbite -->
                <hline x="12" y="32" len="24" color="$wrinkle_mid"/>
                <hline x="16" y="36" len="16" color="$fur_base"/>
                <pixel x="20" y="36" color="$fur_shadow"/>
                <!-- muzzle wrinkles -->
                <pixel x="8" y="24" color="$wrinkle_deep"/>
                <pixel x="8" y="20" color="$wrinkle_mid"/>
                <pixel x="40" y="24" color="$wrinkle_deep"/>
                <pixel x="40" y="20" color="$wrinkle_mid"/>
            </pixel-data>
        </layer>
    </layer-overrides>

    <!-- Base 5 animations inherited from dog. Voland-specific extras: -->
    <animations-extra>
        <!-- walk_blind: unsteady gait, head sweeps low, lateral wobble -->
        <animation name="walk_blind" frames="12" fps="5" loop="true" frame-width="128" frame-height="96">
            <frame index="0" layer-offsets="head:-4,4; ears:-4,4; face_details:-4,8; neck:0,4"/>
            <frame index="1" layer-offsets="head:-4,0; ears:-4,0; face_details:-4,4; front_legs:-4,0; paws:-4,4"/>
            <frame index="2" layer-offsets="head:0,0; front_legs:-4,0; paws:-4,0; body:-4,0; belly:-4,0; neck:4,0"/>
            <frame index="3" layer-offsets="head:0,4; face_details:0,8; front_legs:4,0; paws:0,4; neck:0,4"/>
            <frame index="4" layer-offsets="head:-4,0; face_details:-4,4; front_legs:4,0; paws:4,0; body:4,0; belly:4,0"/>
            <frame index="5" layer-offsets="hind_legs:0,0; paws:0,0; body:0,0; belly:0,0"/>
            <frame index="6" layer-offsets="head:0,8; ears:0,4; face_details:0,12; neck:0,4"/>
            <frame index="7" layer-offsets="head:4,4; ears:4,0; face_details:4,8; front_legs:-4,0; paws:-4,0; neck:0,0"/>
            <frame index="8" layer-offsets="head:0,0; front_legs:-4,0; paws:-4,4; body:-4,0; belly:-4,0; neck:-4,0"/>
            <frame index="9" layer-offsets="head:4,0; body:4,0; belly:4,0; hind_legs:0,0; neck:4,0; face_details:4,0"/>
            <frame index="10" layer-offsets="head:0,4; face_details:0,8; front_legs:4,0; paws:4,0; body:0,0; belly:0,0"/>
            <frame index="11" layer-offsets="head:0,0; face_details:0,4; neck:0,0"/>
        </animation>

        <!-- bump_furniture: walks into object, recoils, redirects by smell -->
        <animation name="bump_furniture" frames="12" fps="5" loop="false" frame-width="128" frame-height="96">
            <condition type="trigger" value="obstacle_contact"/>
            <frame index="0" layer-offsets="head:0,4; face_details:0,8; neck:0,0"/>
            <frame index="1" layer-offsets="head:-4,4; face_details:-8,8; neck:-4,0; front_legs:0,0; paws:0,0"/>
            <frame index="2" layer-offsets="head:-4,4; face_details:-12,8; neck:-4,0; body:-4,0; belly:-4,0"/>
            <frame index="3" layer-offsets="head:4,0; face_details:4,4; neck:4,0; body:0,0"/>
            <frame index="4" layer-offsets="head:0,4; face_details:0,8; neck:0,4"/>
            <frame index="5" layer-offsets="head:-8,4; ears:-8,0; face_details:-8,8; neck:-4,0"/>
            <frame index="6" layer-offsets="head:8,4; ears:8,0; face_details:8,8; neck:4,0"/>
            <frame index="7" layer-offsets="head:0,0; ears:0,-4; face_details:0,0; neck:0,-4"/>
            <frame index="8" layer-offsets="head:0,4; ears:0,4; face_details:0,8; neck:0,4"/>
            <frame index="9" layer-offsets="front_legs:4,0; paws:4,0; body:4,0; belly:4,0; head:4,4; face_details:4,8"/>
            <frame index="10" layer-offsets="front_legs:8,0; paws:8,0; body:8,0; belly:8,0; head:0,4; face_details:0,8; hind_legs:4,0"/>
            <frame index="11" layer-offsets="head:-4,4; face_details:-4,8; neck:-4,0"/>
        </animation>

        <!-- sniff_navigate: nose-led room exploration, primary navigation -->
        <animation name="sniff_navigate" frames="12" fps="4" loop="true" frame-width="128" frame-height="96">
            <condition type="state" value="navigating"/>
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="head:0,8; ears:0,4; face_details:0,12; neck:0,4"/>
            <frame index="2" layer-offsets="head:-8,8; ears:-8,4; face_details:-8,12; neck:-4,4"/>
            <frame index="3" layer-offsets="head:0,8; ears:0,4; face_details:0,12; neck:0,4"/>
            <frame index="4" layer-offsets="head:8,8; ears:8,4; face_details:8,12; neck:4,4"/>
            <frame index="5" layer-offsets="head:0,4; ears:0,0; face_details:0,8; neck:0,0"/>
            <frame index="6" layer-offsets="head:-8,0; ears:-8,-4; face_details:-8,4; neck:-4,0"/>
            <frame index="7" layer-offsets="head:0,0; ears:0,-4; face_details:0,4"/>
            <frame index="8" layer-offsets="head:0,-4; ears:0,-8; face_details:0,-4; neck:0,-4"/>
            <frame index="9" layer-offsets="head:0,-4; ears:0,-8; face_details:0,-4; neck:0,-4"/>
            <frame index="10" layer-offsets="head:-4,0; ears:-4,-4; face_details:-4,0; neck:-4,0"/>
            <frame index="11" layer-offsets="head:-4,4; face_details:-4,8; neck:-4,0; front_legs:-4,0; paws:-4,0"/>
        </animation>

        <!-- memory_path: walks known route flawlessly with confidence -->
        <animation name="memory_path" frames="12" fps="6" loop="true" frame-width="128" frame-height="96">
            <condition type="state" value="on_known_path"/>
            <frame index="0" layer-offsets="front_legs:-4,0; paws:-4,0; hind_legs:4,0"/>
            <frame index="1" layer-offsets="front_legs:-4,0; paws:-4,0; body:-4,0; belly:-4,0"/>
            <frame index="2" layer-offsets="body:-4,0; belly:-4,0; neck:-4,0; head:-4,0; face_details:-4,0"/>
            <frame index="3" layer-offsets="front_legs:4,0; paws:4,0; hind_legs:-4,0"/>
            <frame index="4" layer-offsets="front_legs:4,0; paws:4,0; body:4,0; belly:4,0"/>
            <frame index="5" layer-offsets="body:4,0; belly:4,0; neck:4,0; head:4,0; face_details:4,0; tail:0,-4"/>
            <frame index="6" layer-offsets="front_legs:-4,0; paws:-4,-4; hind_legs:4,0"/>
            <frame index="7" layer-offsets="front_legs:-4,0; paws:-4,-4; body:-4,0; head:-4,0; face_details:-4,0"/>
            <frame index="8" layer-offsets="body:0,-4; belly:0,-4; paws:0,-4; tail:0,-4"/>
            <frame index="9" layer-offsets="front_legs:4,0; paws:4,-4; hind_legs:-4,0"/>
            <frame index="10" layer-offsets="front_legs:4,0; paws:4,-4; body:4,0; tail:4,-4"/>
            <frame index="11" layer-offsets=""/>
        </animation>

        <!-- happy_greet: family comes home, whole-body wag -->
        <animation name="happy_greet" frames="12" fps="5" loop="true" frame-width="128" frame-height="96">
            <condition type="trigger" value="familiar_person_arrives"/>
            <frame index="0" layer-offsets="head:0,-4; ears:0,-8; face_details:0,-4; neck:0,-4"/>
            <frame index="1" layer-offsets="head:0,-4; ears:0,-8; face_details:0,-4; neck:0,-4; hind_legs:4,0; body:4,0; belly:4,0; tail:8,-4"/>
            <frame index="2" layer-offsets="head:0,-4; ears:0,-8; face_details:0,-4; neck:0,-4; hind_legs:-4,0; body:-4,0; belly:-4,0; tail:-8,-4"/>
            <frame index="3" layer-offsets="head:0,-4; ears:0,-8; face_details:0,-4; neck:0,-4; hind_legs:4,0; body:4,0; belly:4,0; tail:8,-4"/>
            <frame index="4" layer-offsets="head:-4,-4; ears:-4,-8; face_details:-4,-4; neck:-4,-4; front_legs:-4,0; paws:-4,0; body:0,0; belly:0,0"/>
            <frame index="5" layer-offsets="head:-8,0; ears:-8,-4; face_details:-8,4; neck:-8,0; front_legs:-4,0; paws:-4,0"/>
            <frame index="6" layer-offsets="head:-8,0; ears:-8,-4; face_details:-8,0; neck:-8,0; body:-4,0; belly:-4,0; hind_legs:-4,0; tail:-4,-8"/>
            <frame index="7" layer-offsets="head:-4,0; ears:-4,-4; face_details:-4,0; neck:-4,0; body:0,0; belly:0,0; hind_legs:4,0; tail:8,-8"/>
            <frame index="8" layer-offsets="head:0,0; ears:0,-4; face_details:0,0; hind_legs:8,0; body:4,0; belly:4,0; tail:12,-4"/>
            <frame index="9" layer-offsets="head:4,0; ears:4,-4; face_details:4,0; neck:4,0; hind_legs:4,0; tail:8,-4"/>
            <frame index="10" layer-offsets="head:0,0; ears:0,-4; face_details:0,0; hind_legs:0,8; paws:0,4; body:0,4; belly:0,8; tail:4,8"/>
            <frame index="11" layer-offsets="head:0,0; ears:0,-4; face_details:0,0; hind_legs:0,8; paws:0,4; body:0,4; belly:0,8; tail:4,8"/>
        </animation>
    </animations-extra>

    <naming>
        <output-dir>characters/voland</output-dir>
    </naming>
</asset-spec>