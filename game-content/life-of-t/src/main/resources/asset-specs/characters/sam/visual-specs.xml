<?xml version="1.0" encoding="UTF-8"?>
<!--
    Life of T — Sam Visual Spec v3.0.0
    Extends: abstract/entities/human@1.0
    Canvas: 128×192 | displayScale: 1.5
    Character: Sam — ~30yo, Tanya's close friend, programmer,
               short blonde pixie cut, blue eyes, glasses,
               graphic tee (band logo), skinny jeans, converse.
               Sarcastic, loyal, geeky.
-->
<asset-spec extends="abstract/entities/human@1.0" version="3.0.0">
    <meta>
        <entity-type>characters</entity-type>
        <entity-name>sam</entity-name>
        <version>3.0.0</version>
        <display-scale>1.5</display-scale>
    </meta>

    <color-palette>
        <color name="$skin_base" value="#F0C8A8"/>
        <color name="$skin_shadow" value="#D8A888"/>
        <color name="$skin_highlight" value="#F8D8C0"/>
        <color name="$hair_base" value="#D8C060"/><!-- blonde -->
        <color name="$hair_shadow" value="#B8A040"/>
        <color name="$hair_highlight" value="#F0D870"/>
        <color name="$clothing_primary" value="#202020"/><!-- black graphic tee -->
        <color name="$clothing_primary_shadow" value="#101010"/>
        <color name="$clothing_primary_highlight" value="#383838"/>
        <color name="$clothing_secondary" value="#202020"/>
        <color name="$clothing_secondary_shadow" value="#101010"/>
        <color name="$clothing_secondary_highlight" value="#383838"/>
        <color name="$pants_base" value="#283040"/><!-- dark skinny jeans -->
        <color name="$pants_shadow" value="#182028"/>
        <color name="$pants_highlight" value="#384050"/>
        <color name="$shoe_base" value="#F0F0F0"/><!-- white converse -->
        <color name="$shoe_shadow" value="#C8C8C8"/>
        <color name="$shoe_highlight" value="#FFFFFF"/>
        <color name="$eye_color" value="#4488CC"/><!-- blue -->
        <color name="$eye_highlight" value="#66AAEE"/>
        <color name="$lip_color" value="#C89080"/>
        <color name="$brow_color" value="#B8A040"/>
        <color name="$glasses_frame" value="#202020"/>
    </color-palette>

    <layer-overrides>
        <layer id="face" replace="true">
            <pixel-data>
                <!-- LEFT EYE -->
                <rect x="42" y="30" w="16" h="10" color="#FFFFFF"/>
                <rect x="44" y="28" w="12" h="13" color="$eye_color"/>
                <rect x="46" y="30" w="9" h="9" color="#5598DD"/>
                <rect x="47" y="31" w="6" h="6" color="$eye_highlight"/>
                <rect x="49" y="32" w="3" h="4" color="#101010"/>
                <rect x="45" y="28" w="3" h="3" color="#FFFFFF"/>
                <hline x="42" y="27" len="16" color="$skin_shadow"/>
                <hline x="42" y="39" len="16" color="$skin_shadow"/>
                <!-- RIGHT EYE -->
                <rect x="70" y="30" w="16" h="10" color="#FFFFFF"/>
                <rect x="72" y="28" w="12" h="13" color="$eye_color"/>
                <rect x="74" y="30" w="9" h="9" color="#5598DD"/>
                <rect x="75" y="31" w="6" h="6" color="$eye_highlight"/>
                <rect x="77" y="32" w="3" h="4" color="#101010"/>
                <rect x="73" y="28" w="3" h="3" color="#FFFFFF"/>
                <hline x="70" y="27" len="16" color="$skin_shadow"/>
                <hline x="70" y="39" len="16" color="$skin_shadow"/>
                <!-- GLASSES — rectangular frames -->
                <rect x="38" y="26" w="24" h="2" color="$glasses_frame"/><!-- L top -->
                <rect x="38" y="40" w="24" h="2" color="$glasses_frame"/><!-- L bottom -->
                <rect x="38" y="26" w="2" h="16" color="$glasses_frame"/><!-- L left -->
                <rect x="60" y="26" w="2" h="16" color="$glasses_frame"/><!-- L right -->
                <rect x="66" y="26" w="24" h="2" color="$glasses_frame"/><!-- R top -->
                <rect x="66" y="40" w="24" h="2" color="$glasses_frame"/><!-- R bottom -->
                <rect x="66" y="26" w="2" h="16" color="$glasses_frame"/><!-- R left -->
                <rect x="88" y="26" w="2" h="16" color="$glasses_frame"/><!-- R right -->
                <hline x="62" y="30" len="4" color="$glasses_frame"/><!-- bridge -->
                <!-- EYEBROWS -->
                <hline x="42" y="24" len="14" color="$brow_color"/>
                <hline x="72" y="24" len="14" color="$brow_color"/>
                <!-- NOSE -->
                <rect x="59" y="38" w="4" h="4" color="$skin_shadow"/>
                <hline x="56" y="44" len="10" color="#D0A080"/>
                <rect x="56" y="45" w="3" h="2" color="#B08060"/>
                <rect x="63" y="45" w="3" h="2" color="#B08060"/>
                <!-- LIPS -->
                <hline x="54" y="48" len="16" color="#A87868"/>
                <rect x="56" y="48" w="12" h="2" color="$lip_color"/>
                <hline x="54" y="50" len="16" color="#D8A898"/>
                <!-- SMIRK — characteristic Sam expression -->
                <rect x="68" y="48" w="4" h="2" color="#B88878"/><!-- raised corner -->
            </pixel-data>
        </layer>

        <layer id="hair_front" replace="true">
            <pixel-data>
                <!-- Short pixie cut — asymmetric, textured -->
                <rect x="36" y="10" w="56" h="10" color="$hair_base"/>
                <hline x="40" y="10" len="48" color="$hair_highlight"/>
                <!-- Longer fringe swept right -->
                <rect x="70" y="14" w="24" h="10" color="$hair_base"/>
                <rect x="74" y="16" w="18" h="6" color="$hair_highlight"/>
                <rect x="80" y="18" w="12" h="4" color="$hair_shadow"/>
                <!-- Short left side -->
                <rect x="32" y="16" w="8" h="6" color="$hair_shadow"/>
                <!-- Textured spikes -->
                <rect x="44" y="8" w="4" h="4" color="$hair_highlight"/>
                <rect x="54" y="9" w="3" h="3" color="$hair_base"/>
                <rect x="62" y="8" w="5" h="4" color="$hair_highlight"/>
            </pixel-data>
        </layer>

        <layer id="hair_back" replace="true">
            <pixel-data>
                <!-- Minimal — pixie cut -->
                <rect x="34" y="14" w="4" h="6" color="$hair_shadow"/>
                <rect x="90" y="14" w="4" h="6" color="$hair_shadow"/>
            </pixel-data>
        </layer>

        <layer id="accessory" follows="head" replace="true">
            <pixel-data>
                <!-- No prominent accessory, just glasses temple arms already in face layer -->
                <!-- Glasses temple arms extending to ears -->
                <hline x="32" y="30" len="6" color="$glasses_frame"/><!-- left arm -->
                <hline x="90" y="30" len="6" color="$glasses_frame"/><!-- right arm -->
            </pixel-data>
        </layer>

        <layer id="torso" replace="true">
            <pixel-data>
                <!-- Black graphic tee -->
                <rect x="26" y="64" w="76" h="40" color="$clothing_primary"/>
                <rect x="48" y="64" w="32" h="40" color="$clothing_primary_highlight"/>
                <rect x="26" y="64" w="10" h="40" color="$clothing_primary_shadow"/>
                <rect x="92" y="64" w="10" h="40" color="$clothing_primary_shadow"/>
                <!-- Band logo graphic (abstract pixel design) -->
                <rect x="50" y="72" w="28" h="20" color="#C02020"/><!-- red square -->
                <rect x="54" y="76" w="20" h="12" color="#202020"/><!-- inner cutout -->
                <rect x="58" y="78" w="4" h="8" color="#C02020"/><!-- letter shape -->
                <rect x="66" y="78" w="4" h="8" color="#C02020"/>
                <!-- Tee hem -->
                <hline x="28" y="103" len="72" color="$clothing_primary_shadow"/>
                <!-- Neckline (crew neck) -->
                <rect x="50" y="62" w="28" h="4" color="$clothing_primary"/>
                <hline x="52" y="62" len="24" color="$clothing_primary_highlight"/>
            </pixel-data>
        </layer>
    </layer-overrides>

    <naming>
        <output-dir>characters/sam</output-dir>
    </naming>
</asset-spec>