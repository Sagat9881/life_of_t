<?xml version="1.0" encoding="UTF-8"?>
<asset-spec extends="abstract/environments/indoor_room@1.0" version="2.0.0">
    <meta>
        <entity-type>locations</entity-type>
        <entity-name>parents_cottage</entity-name>
        <version>2.0.0</version>
        <canvas width="640" height="480" displayScale="1.0"/>
        <description>
            Tanya's parents' cottage at the dacha. Warm, cozy, slightly old-fashioned.
            Home of blind Voland (French Bulldog, ~11 years old). Family photos,
            comfortable old sofa, warm light. Safe and nostalgic atmosphere.
            Canvas ×2: 320×240 → 640×480.
        </description>
    </meta>

    <color-palette>
        <color name="$floor_wood" value="#B89060"/>
        <color name="$floor_line" value="#A88050"/>
        <color name="$floor_joint" value="#986A40"/>
        <color name="$floor_worn" value="#C09868"/>
        <color name="$baseboard" value="#EEE8DC"/>
        <color name="$wall_pine" value="#D4A870"/>
        <color name="$wall_line" value="#C89860"/>
        <color name="$wall_line2" value="#CC9C64"/>
        <color name="$wall_knot" value="#B07840"/>
        <color name="$wall_knot_inner" value="#A06830"/>
        <color name="$corner_board" value="#C09060"/>
        <color name="$crown" value="#E0CCB0"/>
        <color name="$sofa_base" value="#7A6050"/>
        <color name="$sofa_cushion" value="#9A8070"/>
        <color name="$sofa_dark" value="#6A5040"/>
        <color name="$sofa_divider" value="#8A7060"/>
        <color name="$throw" value="#B09880"/>
        <color name="$pillow_color" value="#D4AA8C"/>
        <color name="$window_sky" value="#B0D8F0"/>
        <color name="$window_frame" value="#C09868"/>
        <color name="$garden_green" value="#90C870"/>
        <color name="$flower_pink" value="#FF8090"/>
        <color name="$flower_yellow" value="#FFEE50"/>
        <color name="$curtain_sheer" value="#F8F4EC18"/>
        <color name="$curtain_tie" value="#E8E0D0"/>
        <color name="$voland_fur" value="#C0A06C"/>
        <color name="$voland_dark" value="#B0905C"/>
        <color name="$voland_nose" value="#704030"/>
        <color name="$photo_frame" value="#8A6840"/>
        <color name="$photo_bg" value="#F4ECD8"/>
        <color name="$heater_body" value="#E8E0D0"/>
        <color name="$heater_tile" value="#D0C8B8"/>
        <color name="$heater_blue" value="#4888C8"/>
        <color name="$heater_door" value="#705840"/>
    </color-palette>

    <layer-overrides>
        <layer id="floor" replace="true" type="background" z-order="0" width="640" height="480">
            <pixel-data>
                <rect x="0" y="316" w="640" h="164" color="$floor_wood"/>
                <!-- Wide plank lines -->
                <hline x="0" y="348" len="640" color="$floor_line"/>
                <hline x="0" y="380" len="640" color="#AA8252"/>
                <hline x="0" y="412" len="640" color="$floor_line"/>
                <hline x="0" y="444" len="640" color="#AA8252"/>
                <!-- Vertical plank joints -->
                <rect x="120" y="316" w="4" h="164" color="$floor_joint"/>
                <rect x="280" y="316" w="4" h="164" color="$floor_joint"/>
                <rect x="420" y="316" w="4" h="164" color="$floor_joint"/>
                <rect x="560" y="316" w="4" h="164" color="$floor_joint"/>
                <!-- Worn spots -->
                <rect x="240" y="330" w="60" h="20" color="$floor_worn"/>
                <rect x="400" y="360" w="40" h="16" color="$floor_worn"/>
                <!-- Baseboard -->
                <rect x="0" y="310" w="640" h="10" color="$baseboard"/>
            </pixel-data>
        </layer>

        <layer id="wall" replace="true" type="background" z-order="1" width="640" height="480">
            <pixel-data>
                <rect x="0" y="0" w="640" h="320" color="$wall_pine"/>
                <!-- Horizontal panel lines -->
                <hline x="0" y="28" len="640" color="$wall_line"/>
                <hline x="0" y="56" len="640" color="$wall_line2"/>
                <hline x="0" y="84" len="640" color="$wall_line"/>
                <hline x="0" y="112" len="640" color="$wall_line2"/>
                <hline x="0" y="140" len="640" color="$wall_line"/>
                <hline x="0" y="168" len="640" color="$wall_line2"/>
                <hline x="0" y="196" len="640" color="$wall_line"/>
                <hline x="0" y="224" len="640" color="$wall_line2"/>
                <hline x="0" y="252" len="640" color="$wall_line"/>
                <hline x="0" y="280" len="640" color="$wall_line2"/>
                <!-- Wood knots -->
                <rect x="112" y="68" w="12" h="8" color="$wall_knot"/>
                <rect x="114" y="70" w="8" h="4" color="$wall_knot_inner"/>
                <rect x="400" y="112" w="10" h="8" color="$wall_knot"/>
                <rect x="402" y="114" w="6" h="4" color="$wall_knot_inner"/>
                <rect x="260" y="196" w="12" h="8" color="$wall_knot"/>
                <rect x="262" y="198" w="8" h="4" color="$wall_knot_inner"/>
                <!-- Corner boards -->
                <rect x="0" y="0" w="16" h="320" color="$corner_board"/>
                <rect x="624" y="0" w="16" h="320" color="$corner_board"/>
                <!-- Crown molding -->
                <rect x="0" y="0" w="640" h="16" color="$crown"/>
                <hline x="0" y="14" len="640" color="#C8B0A0"/>
            </pixel-data>
        </layer>
    </layer-overrides>

    <layers>
        <!-- z=2: Sofa -->
        <layer id="sofa" type="foreground" z-order="2" width="640" height="480">
            <pixel-data>
                <!-- Sofa base -->
                <rect x="88" y="296" w="320" h="80" color="$sofa_base"/>
                <!-- Seat cushions -->
                <rect x="92" y="296" w="152" h="44" color="$sofa_cushion"/>
                <rect x="248" y="296" w="156" h="44" color="$sofa_cushion"/>
                <!-- Divider -->
                <rect x="244" y="296" w="8" h="44" color="$sofa_divider"/>
                <!-- Seat highlight -->
                <hline x="94" y="304" len="148" color="#A89080"/>
                <hline x="250" y="304" len="152" color="#A89080"/>
                <!-- Back -->
                <rect x="88" y="236" w="320" h="64" color="$sofa_divider"/>
                <rect x="88" y="240" w="104" h="56" color="$sofa_cushion"/>
                <rect x="196" y="240" w="104" h="56" color="$sofa_cushion"/>
                <rect x="304" y="240" w="100" h="56" color="$sofa_cushion"/>
                <rect x="192" y="236" w="8" h="64" color="$sofa_base"/>
                <rect x="300" y="236" w="8" h="64" color="$sofa_base"/>
                <!-- Arms -->
                <rect x="72" y="236" w="24" h="144" color="$sofa_dark"/>
                <rect x="74" y="238" w="20" h="12" color="$sofa_cushion"/>
                <rect x="400" y="236" w="24" h="144" color="$sofa_dark"/>
                <rect x="402" y="238" w="20" h="12" color="$sofa_cushion"/>
                <!-- Feet -->
                <rect x="88" y="376" w="12" h="16" color="#4A3830"/>
                <rect x="392" y="376" w="12" h="16" color="#4A3830"/>
                <!-- Throw blanket -->
                <rect x="72" y="236" w="28" h="56" color="$throw"/>
                <hline x="74" y="244" len="24" color="#A08870"/>
                <hline x="74" y="252" len="24" color="#A08870"/>
                <hline x="74" y="260" len="24" color="#A08870"/>
                <!-- Throw pillow -->
                <rect x="120" y="264" w="56" h="36" color="#C8A080"/>
                <rect x="124" y="268" w="48" h="28" color="$pillow_color"/>
                <hline x="126" y="276" len="44" color="#BCA080"/>
                <hline x="126" y="286" len="44" color="#BCA080"/>
            </pixel-data>
        </layer>

        <!-- z=3: Window -->
        <layer id="window" type="midground" z-order="3" width="640" height="480">
            <pixel-data>
                <!-- Outside garden -->
                <rect x="468" y="44" w="144" h="136" color="$garden_green"/>
                <rect x="468" y="44" w="144" h="44" color="$window_sky"/>
                <!-- Flowers -->
                <rect x="472" y="120" w="10" h="56" color="#70A050"/>
                <rect x="470" y="112" w="14" h="12" color="$flower_pink"/>
                <rect x="492" y="120" w="10" h="56" color="#70A050"/>
                <rect x="490" y="108" w="14" h="16" color="$flower_yellow"/>
                <rect x="512" y="124" w="10" h="52" color="#70A050"/>
                <rect x="510" y="116" w="14" h="12" color="$flower_pink"/>
                <rect x="532" y="120" w="10" h="56" color="#60A040"/>
                <rect x="560" y="128" w="10" h="48" color="#70A050"/>
                <rect x="558" y="120" w="14" h="12" color="$flower_yellow"/>
                <rect x="584" y="120" w="10" h="56" color="#60A040"/>
                <!-- Fence -->
                <hline x="468" y="172" len="144" color="#B08840"/>
                <!-- Frame -->
                <rect x="464" y="40" w="152" h="6" color="$window_frame"/>
                <rect x="464" y="178" w="152" h="6" color="$window_frame"/>
                <rect x="464" y="40" w="6" h="144" color="$window_frame"/>
                <rect x="610" y="40" w="6" h="144" color="$window_frame"/>
                <!-- Cross -->
                <rect x="464" y="108" w="152" h="4" color="$window_frame"/>
                <rect x="536" y="40" w="4" h="144" color="$window_frame"/>
                <!-- Windowsill -->
                <rect x="460" y="184" w="160" h="12" color="#D4B080"/>
                <!-- Sheer curtain -->
                <rect x="460" y="32" w="160" h="156" color="$curtain_sheer"/>
                <!-- Curtain ties -->
                <rect x="460" y="28" w="20" h="160" color="$curtain_tie"/>
                <rect x="596" y="28" w="20" h="160" color="$curtain_tie"/>
            </pixel-data>
        </layer>

        <!-- z=4: Voland bed -->
        <layer id="voland_bed" type="foreground" z-order="4" width="640" height="480">
            <pixel-data>
                <!-- Dog bed -->
                <rect x="468" y="340" w="160" h="92" color="#9A8870"/>
                <rect x="480" y="352" w="136" h="68" color="#C8B898"/>
                <hline x="482" y="364" len="132" color="#B8A888"/>
                <hline x="482" y="376" len="132" color="#B8A888"/>
                <hline x="482" y="388" len="132" color="#B8A888"/>
                <hline x="468" y="352" len="160" color="#8A7860"/>
                <!-- Bed label -->
                <rect x="576" y="340" w="24" h="12" color="#E8C890"/>
                <!-- Voland curled up -->
                <rect x="496" y="356" w="68" h="40" color="$voland_dark"/>
                <rect x="500" y="352" w="60" h="36" color="$voland_fur"/>
                <!-- Head -->
                <rect x="532" y="348" w="36" h="28" color="$voland_dark"/>
                <rect x="536" y="344" w="28" h="28" color="$voland_fur"/>
                <!-- Bat ears -->
                <rect x="532" y="336" w="10" h="12" color="#A07850"/>
                <rect x="554" y="336" w="10" h="12" color="#A07850"/>
                <!-- Flat nose -->
                <rect x="544" y="358" w="12" h="8" color="$voland_nose"/>
                <!-- Closed eyes (cataracts) -->
                <hline x="538" y="352" len="8" color="#604028"/>
                <hline x="554" y="352" len="8" color="#604028"/>
                <!-- Paws -->
                <rect x="500" y="388" w="20" h="10" color="$voland_dark"/>
                <rect x="528" y="388" w="20" h="10" color="$voland_dark"/>
                <!-- Tennis ball -->
                <rect x="636" y="380" w="20" h="20" color="#C8C840"/>
                <rect x="638" y="382" w="16" h="16" color="#D8D850"/>
                <hline x="638" y="388" len="16" color="#B8B830"/>
            </pixel-data>
        </layer>

        <!-- z=5: Family photos -->
        <layer id="family_photos" type="foreground" z-order="5" width="640" height="480">
            <pixel-data>
                <!-- Photo 1: large family photo -->
                <rect x="164" y="28" w="104" h="80" color="$photo_frame"/>
                <rect x="168" y="32" w="96" h="72" color="$photo_bg"/>
                <rect x="176" y="40" w="20" h="36" color="#D4B890"/>
                <rect x="200" y="36" w="20" h="40" color="#C8A888"/>
                <rect x="224" y="44" w="20" h="28" color="#D4B890"/>
                <!-- Photo 2: young Tanya -->
                <rect x="284" y="36" w="72" h="52" color="#7A6038"/>
                <rect x="288" y="40" w="64" h="44" color="$photo_bg"/>
                <rect x="296" y="48" w="16" h="24" color="#C8B0A0"/>
                <rect x="316" y="44" w="16" h="28" color="#D0B898"/>
                <rect x="332" y="48" w="12" h="24" color="#C8B0A0"/>
                <!-- Photo 3: puppy Voland -->
                <rect x="372" y="28" w="60" h="60" color="#806048"/>
                <rect x="376" y="32" w="52" h="52" color="$photo_bg"/>
                <rect x="384" y="48" w="32" h="24" color="#C0A878"/>
                <rect x="392" y="40" w="20" h="16" color="#C8B080"/>
                <!-- Photo 4: dacha scene -->
                <rect x="164" y="124" w="80" h="56" color="#6A5030"/>
                <rect x="168" y="128" w="72" h="48" color="$photo_bg"/>
                <rect x="172" y="136" w="64" h="16" color="#90B870"/>
                <rect x="180" y="128" w="20" h="16" color="#C8B898"/>
                <!-- Ornate frame highlights -->
                <hline x="164" y="28" len="104" color="#C0A060"/>
                <hline x="164" y="107" len="104" color="#C0A060"/>
                <hline x="284" y="36" len="72" color="#C0A060"/>
                <hline x="284" y="87" len="72" color="#C0A060"/>
            </pixel-data>
        </layer>

        <!-- z=6: Tiled heater (pechka) -->
        <layer id="fireplace" type="foreground" z-order="6" width="640" height="480">
            <pixel-data>
                <!-- Heater body -->
                <rect x="0" y="136" w="60" h="188" color="$heater_body"/>
                <!-- Tile lines -->
                <hline x="0" y="156" len="60" color="$heater_tile"/>
                <hline x="0" y="176" len="60" color="$heater_tile"/>
                <hline x="0" y="196" len="60" color="$heater_tile"/>
                <hline x="0" y="216" len="60" color="$heater_tile"/>
                <hline x="0" y="236" len="60" color="$heater_tile"/>
                <hline x="0" y="256" len="60" color="$heater_tile"/>
                <hline x="0" y="276" len="60" color="$heater_tile"/>
                <hline x="0" y="296" len="60" color="$heater_tile"/>
                <!-- Vertical dividers -->
                <rect x="20" y="136" w="2" h="188" color="$heater_tile"/>
                <rect x="40" y="136" w="2" h="188" color="$heater_tile"/>
                <!-- Blue flower tiles -->
                <rect x="4" y="160" w="14" h="14" color="$heater_blue"/>
                <rect x="6" y="162" w="10" h="10" color="#5898D8"/>
                <pixel x="10" y="166" color="#FFFFFF"/>
                <rect x="24" y="160" w="14" h="14" color="$heater_blue"/>
                <rect x="26" y="162" w="10" h="10" color="#5898D8"/>
                <pixel x="30" y="166" color="#FFFFFF"/>
                <rect x="4" y="200" w="14" h="14" color="$heater_blue"/>
                <rect x="6" y="202" w="10" h="10" color="#5898D8"/>
                <rect x="24" y="200" w="14" h="14" color="$heater_blue"/>
                <rect x="26" y="202" w="10" h="10" color="#5898D8"/>
                <rect x="4" y="240" w="14" h="14" color="$heater_blue"/>
                <rect x="24" y="240" w="14" h="14" color="$heater_blue"/>
                <rect x="4" y="280" w="14" h="14" color="$heater_blue"/>
                <rect x="24" y="280" w="14" h="14" color="$heater_blue"/>
                <!-- Firebox door -->
                <rect x="16" y="224" w="28" h="32" color="$heater_door"/>
                <rect x="18" y="226" w="24" h="28" color="#202020"/>
                <!-- Ember glow -->
                <rect x="20" y="240" w="20" h="10" color="#FF600820"/>
                <!-- Top shelf -->
                <rect x="0" y="132" w="64" h="8" color="#D0C0A8"/>
                <!-- Jam jar on shelf -->
                <rect x="8" y="116" w="20" h="20" color="#C04040"/>
                <rect x="10" y="118" w="16" h="16" color="#D05050"/>
                <rect x="10" y="116" w="16" h="6" color="#804030"/>
            </pixel-data>
        </layer>

        <!-- z=7: Ambient light -->
        <layer id="ambient_light" type="overlay" z-order="7" width="640" height="480">
            <pixel-data>
                <rect x="0" y="0" w="640" h="480" color="#FFE8B008"/>
                <!-- Lamp glow -->
                <rect x="260" y="0" w="200" h="160" color="#FFD88012"/>
                <!-- Heater warmth -->
                <rect x="0" y="120" w="120" h="200" color="#FF800010"/>
                <!-- Window light on floor -->
                <rect x="460" y="316" w="168" h="100" color="#E8F0D010"/>
                <!-- Ember glow -->
                <rect x="0" y="200" w="60" h="120" color="#FF600010"/>
            </pixel-data>
            <conditions>
                <condition id="time_morning">
                    <override layer-ref="ambient_light" tint="#F8F0E8" opacity="0.08"/>
                </condition>
                <condition id="time_day">
                    <override layer-ref="ambient_light" tint="#FFE8B0" opacity="0.06"/>
                </condition>
                <condition id="time_evening">
                    <override layer-ref="ambient_light" tint="#FFB850" opacity="0.20"/>
                </condition>
                <condition id="time_night">
                    <override layer-ref="ambient_light" tint="#FF6820" opacity="0.35"/>
                </condition>
            </conditions>
        </layer>
    </layers>

    <animations>
        <animation name="idle" frames="8" fps="1" loop="true"
                   frame-width="640" frame-height="480">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="ambient_light:0,0"/>
            <frame index="2" layer-offsets=""/>
            <frame index="3" layer-offsets="ambient_light:0,1"/>
            <frame index="4" layer-offsets=""/>
            <frame index="5" layer-offsets="ambient_light:0,0"/>
            <frame index="6" layer-offsets=""/>
            <frame index="7" layer-offsets="ambient_light:0,-1"/>
        </animation>
    </animations>

    <naming><output-dir>locations/parents_cottage</output-dir></naming>
</asset-spec>