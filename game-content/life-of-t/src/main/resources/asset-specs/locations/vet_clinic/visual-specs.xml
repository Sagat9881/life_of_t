<?xml version="1.0" encoding="UTF-8"?>
<asset-spec extends="abstract/environments/indoor_room@1.0" version="2.0.0">
    <meta>
        <entity-type>location</entity-type>
        <entity-name>vet_clinic</entity-name>
        <version>2.0.0</version>
        <canvas width="640" height="480" displayScale="1.0"/>
        <description>
            Ветеринарная клиника — для квестов save_lada, duke_arrives.
            Чистая, стерильная обстановка. Full pixel-data from descriptive v1.
        </description>
    </meta>

    <color-palette>
        <color name="$wall_white" value="#F5F5FF"/>
        <color name="$wall_teal_stripe" value="#00BCD4"/>
        <color name="$floor_tile" value="#E8E8EC"/>
        <color name="$floor_grout" value="#D0D0D8"/>
        <color name="$baseboard" value="#D4D4DC"/>
        <color name="$cabinet" value="#E0E4E8"/>
        <color name="$cabinet_glass" value="#C8E8F0"/>
        <color name="$cabinet_frame" value="#B0B8C0"/>
        <color name="$table_top" value="#E0E0E8"/>
        <color name="$table_leg" value="#C0C0C8"/>
        <color name="$chair_seat" value="#505860"/>
        <color name="$sink" value="#E8ECF0"/>
        <color name="$faucet" value="#C0C8D0"/>
        <color name="$xray_bg" value="#1A2A3A"/>
        <color name="$xray_bone" value="#D0E0F0"/>
        <color name="$poster" value="#F0F8F0"/>
        <color name="$poster_accent" value="#FF9800"/>
        <color name="$carrier" value="#A0B0C0"/>
        <color name="$carrier_door" value="#D0D8E0"/>
        <color name="$first_aid" value="#FF4040"/>
        <color name="$first_aid_cross" value="#FFFFFF"/>
        <color name="$scale_base" value="#C8CCD0"/>
        <color name="$scale_plate" value="#E0E4E8"/>
        <color name="$drip_stand" value="#D0D4D8"/>
        <color name="$drip_bag" value="#E8F0F8"/>
        <color name="$monitor_body" value="#404848"/>
        <color name="$monitor_screen" value="#1A3020"/>
        <color name="$pulse_line" value="#40FF60"/>
        <color name="$light_surgical" value="#F8F8FF"/>
        <color name="$shoe_cover" value="#80C0D0"/>
    </color-palette>

    <layer-overrides>
        <layer id="floor" replace="true" type="background" z-order="0" width="640" height="480">
            <pixel-data>
                <rect x="0" y="300" w="640" h="180" color="$floor_tile"/>
                <!-- Tile grid -->
                <hline x="0" y="330" len="640" color="$floor_grout"/>
                <hline x="0" y="360" len="640" color="$floor_grout"/>
                <hline x="0" y="390" len="640" color="$floor_grout"/>
                <hline x="0" y="420" len="640" color="$floor_grout"/>
                <hline x="0" y="450" len="640" color="$floor_grout"/>
                <rect x="0" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="40" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="80" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="120" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="160" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="200" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="240" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="280" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="320" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="360" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="400" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="440" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="480" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="520" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="560" y="300" w="2" h="180" color="$floor_grout"/>
                <rect x="600" y="300" w="2" h="180" color="$floor_grout"/>
                <!-- Baseboard -->
                <rect x="0" y="296" w="640" h="6" color="$baseboard"/>
                <!-- Floor reflection -->
                <rect x="200" y="340" w="240" h="4" color="#F0F0F820"/>
            </pixel-data>
        </layer>

        <layer id="wall" replace="true" type="background" z-order="1" width="640" height="480">
            <pixel-data>
                <rect x="0" y="0" w="640" h="300" color="$wall_white"/>
                <!-- Teal accent stripe -->
                <rect x="0" y="280" w="640" h="12" color="$wall_teal_stripe"/>
                <!-- Surgical ceiling light -->
                <rect x="260" y="0" w="120" h="8" color="$light_surgical"/>
                <rect x="280" y="8" w="80" h="4" color="#E8E8F0"/>
                <!-- Second light -->
                <rect x="480" y="0" w="80" h="6" color="$light_surgical"/>
            </pixel-data>
        </layer>
    </layer-overrides>

    <layers>
        <!-- z=2: Medicine cabinet -->
        <layer id="cabinet" type="midground" z-order="2" width="640" height="480">
            <pixel-data>
                <!-- Glass cabinet -->
                <rect x="20" y="40" w="140" h="200" color="$cabinet"/>
                <rect x="24" y="44" w="132" h="192" color="$cabinet_glass"/>
                <!-- Frame -->
                <rect x="18" y="38" w="144" h="4" color="$cabinet_frame"/>
                <rect x="18" y="238" w="144" h="4" color="$cabinet_frame"/>
                <rect x="18" y="38" w="4" h="204" color="$cabinet_frame"/>
                <rect x="158" y="38" w="4" h="204" color="$cabinet_frame"/>
                <!-- Shelves -->
                <hline x="24" y="90" len="132" color="$cabinet_frame"/>
                <hline x="24" y="140" len="132" color="$cabinet_frame"/>
                <hline x="24" y="190" len="132" color="$cabinet_frame"/>
                <!-- Bottles/vials on shelves -->
                <rect x="30" y="50" w="10" h="36" color="#FF9800"/>
                <rect x="44" y="54" w="10" h="32" color="#4CAF50"/>
                <rect x="58" y="48" w="8" h="38" color="#2196F3"/>
                <rect x="70" y="52" w="10" h="34" color="#E91E63"/>
                <rect x="84" y="50" w="8" h="36" color="#9C27B0"/>
                <rect x="96" y="56" w="10" h="30" color="#FF5722"/>
                <rect x="110" y="50" w="10" h="36" color="#00BCD4"/>
                <rect x="124" y="54" w="10" h="32" color="#8BC34A"/>
                <rect x="138" y="48" w="8" h="38" color="#FFC107"/>
                <!-- Row 2 -->
                <rect x="30" y="96" w="12" h="40" color="#E0E0E0"/>
                <rect x="46" y="100" w="10" h="36" color="#F5F5F5"/>
                <rect x="60" y="96" w="8" h="40" color="#B0D0E0"/>
                <rect x="72" y="102" w="14" h="34" color="#E8E8E8"/>
                <rect x="90" y="98" w="10" h="38" color="#C8E0F0"/>
                <rect x="104" y="96" w="12" h="40" color="#F0F0F0"/>
                <!-- Row 3 — bandages, cotton -->
                <rect x="30" y="148" w="24" h="16" color="#FFFFFF"/>
                <rect x="58" y="146" w="20" h="20" color="#F8F8F0"/>
                <rect x="82" y="148" w="16" h="16" color="#E0E8F0"/>
                <rect x="102" y="146" w="24" h="20" color="#FFFFFF"/>
                <!-- Handle -->
                <rect x="86" y="236" w="8" h="8" color="#A0A8B0"/>
            </pixel-data>
        </layer>

        <!-- z=3: X-ray + poster -->
        <layer id="wall_items" type="midground" z-order="3" width="640" height="480">
            <pixel-data>
                <!-- X-ray on lightbox -->
                <rect x="200" y="40" w="80" h="100" color="$xray_bg"/>
                <rect x="204" y="44" w="72" h="92" color="#1E3040"/>
                <!-- Cat skeleton -->
                <rect x="220" y="56" w="40" h="20" color="$xray_bone"/>
                <rect x="228" y="52" w="16" h="12" color="$xray_bone"/>
                <rect x="218" y="76" w="4" h="24" color="$xray_bone"/>
                <rect x="226" y="76" w="4" h="24" color="$xray_bone"/>
                <rect x="250" y="76" w="4" h="24" color="$xray_bone"/>
                <rect x="258" y="76" w="4" h="24" color="$xray_bone"/>
                <rect x="260" y="60" w="4" h="16" color="$xray_bone"/>
                <!-- Lightbox glow -->
                <rect x="198" y="38" w="84" h="104" color="#A0D0F010"/>

                <!-- Cat anatomy poster -->
                <rect x="320" y="40" w="100" h="140" color="$poster"/>
                <rect x="324" y="44" w="92" h="132" color="#E8F4E8"/>
                <!-- Cat diagram -->
                <rect x="340" y="60" w="56" h="36" color="#F0C8A0"/>
                <rect x="348" y="56" w="20" h="12" color="#F0C8A0"/>
                <!-- Annotation lines -->
                <hline x="330" y="108" len="80" color="#808080"/>
                <hline x="330" y="120" len="80" color="#808080"/>
                <hline x="330" y="132" len="80" color="#808080"/>
                <hline x="330" y="144" len="60" color="#808080"/>
                <hline x="330" y="156" len="70" color="#808080"/>
                <!-- Title bar -->
                <rect x="324" y="44" w="92" h="12" color="$poster_accent"/>
            </pixel-data>
        </layer>

        <!-- z=4: Exam table -->
        <layer id="exam_table" type="foreground" z-order="4" width="640" height="480">
            <pixel-data>
                <!-- Table top -->
                <rect x="240" y="260" w="200" h="16" color="$table_top"/>
                <rect x="240" y="260" w="200" h="4" color="#D0D0D8"/>
                <!-- Legs -->
                <rect x="248" y="276" w="8" h="48" color="$table_leg"/>
                <rect x="424" y="276" w="8" h="48" color="$table_leg"/>
                <!-- Cross bar -->
                <rect x="248" y="304" w="184" h="4" color="$table_leg"/>
                <!-- Table pad -->
                <rect x="252" y="248" w="120" h="14" color="#E0F0F0"/>
                <rect x="254" y="250" w="116" h="10" color="#D0E8E8"/>
                <!-- Paper roll -->
                <rect x="380" y="248" w="52" h="14" color="#F8F8F0"/>
                <hline x="382" y="254" len="48" color="#E8E8E0"/>
                <!-- Scale next to table -->
                <rect x="460" y="280" w="40" h="6" color="$scale_plate"/>
                <rect x="468" y="286" w="24" h="30" color="$scale_base"/>
                <rect x="472" y="290" w="16" h="8" color="#1A2A2A"/>
                <rect x="476" y="292" w="8" h="4" color="#40FF60"/>
            </pixel-data>
        </layer>

        <!-- z=5: Chair + sink -->
        <layer id="equipment" type="foreground" z-order="5" width="640" height="480">
            <pixel-data>
                <!-- Doctor's stool -->
                <rect x="190" y="300" w="40" h="10" color="$chair_seat"/>
                <rect x="196" y="288" w="28" h="14" color="#585E68"/>
                <rect x="206" y="310" w="8" h="24" color="#606868"/>
                <rect x="196" y="332" w="28" h="4" color="#707878"/>
                <!-- Wheels -->
                <pixel x="198" y="336" color="#505050"/>
                <pixel x="210" y="336" color="#505050"/>
                <pixel x="222" y="336" color="#505050"/>
                <!-- Sink -->
                <rect x="520" y="220" w="80" h="60" color="$sink"/>
                <rect x="524" y="224" w="72" h="52" color="#D8E0E8"/>
                <rect x="528" y="228" w="64" h="44" color="#C8D8E0"/>
                <!-- Faucet -->
                <rect x="554" y="208" w="12" h="16" color="$faucet"/>
                <rect x="550" y="204" w="20" h="6" color="#B0B8C0"/>
                <!-- Soap dispenser -->
                <rect x="526" y="204" w="14" h="20" color="#E0E8F0"/>
                <rect x="530" y="198" w="6" h="8" color="#00BCD4"/>
                <!-- Sink legs -->
                <rect x="524" y="280" w="4" h="24" color="$faucet"/>
                <rect x="592" y="280" w="4" h="24" color="$faucet"/>
            </pixel-data>
        </layer>

        <!-- z=6: Foreground items -->
        <layer id="foreground" type="foreground" z-order="6" width="640" height="480">
            <pixel-data>
                <!-- Cat carrier -->
                <rect x="40" y="310" w="72" h="48" color="$carrier"/>
                <rect x="44" y="314" w="64" h="40" color="#B0C0D0"/>
                <rect x="44" y="314" w="8" h="40" color="$carrier_door"/>
                <!-- Carrier ventilation -->
                <hline x="48" y="320" len="4" color="#808890"/>
                <hline x="48" y="328" len="4" color="#808890"/>
                <hline x="48" y="336" len="4" color="#808890"/>
                <hline x="48" y="344" len="4" color="#808890"/>
                <!-- Carrier handle -->
                <rect x="64" y="306" w="20" h="6" color="#909AA0"/>

                <!-- First aid box on wall -->
                <rect x="560" y="80" w="48" h="40" color="$first_aid"/>
                <rect x="564" y="84" w="40" h="32" color="#E83838"/>
                <rect x="580" y="88" w="8" h="24" color="$first_aid_cross"/>
                <rect x="572" y="96" w="24" h="8" color="$first_aid_cross"/>

                <!-- Shoe covers container -->
                <rect x="580" y="360" w="40" h="36" color="#E0E4E8"/>
                <rect x="584" y="356" w="32" h="8" color="#D0D4D8"/>
                <!-- Shoe covers inside -->
                <rect x="586" y="364" w="10" h="8" color="$shoe_cover"/>
                <rect x="598" y="362" w="10" h="10" color="$shoe_cover"/>

                <!-- IV drip stand -->
                <rect x="450" y="180" w="4" h="120" color="$drip_stand"/>
                <rect x="440" y="176" w="24" h="4" color="$drip_stand"/>
                <!-- Drip bag -->
                <rect x="446" y="160" w="16" h="20" color="$drip_bag"/>
                <rect x="448" y="162" w="12" h="16" color="#D0E8F8"/>
                <!-- Tube -->
                <rect x="452" y="180" w="2" h="40" color="#C0D0E0"/>

                <!-- Heart monitor -->
                <rect x="140" y="200" w="52" h="40" color="$monitor_body"/>
                <rect x="144" y="204" w="44" h="32" color="$monitor_screen"/>
                <!-- Pulse line -->
                <hline x="148" y="218" len="8" color="$pulse_line"/>
                <pixel x="156" y="216" color="$pulse_line"/>
                <pixel x="158" y="210" color="$pulse_line"/>
                <pixel x="160" y="214" color="$pulse_line"/>
                <hline x="162" y="218" len="6" color="$pulse_line"/>
                <pixel x="168" y="216" color="$pulse_line"/>
                <pixel x="170" y="208" color="$pulse_line"/>
                <pixel x="172" y="212" color="$pulse_line"/>
                <hline x="174" y="218" len="10" color="$pulse_line"/>
                <!-- Monitor stand -->
                <rect x="160" y="240" w="12" h="24" color="#505858"/>
                <rect x="152" y="262" w="28" h="4" color="#606868"/>
            </pixel-data>
        </layer>

        <!-- z=7: Ambient light -->
        <layer id="ambient_light" type="overlay" z-order="7" width="640" height="480">
            <pixel-data>
                <!-- Surgical light cone -->
                <rect x="240" y="0" w="160" h="280" color="#F8F8FF08"/>
                <rect x="260" y="40" w="120" h="220" color="#FFFFFF06"/>
                <!-- Monitor glow -->
                <rect x="130" y="196" w="72" h="50" color="#40FF6008"/>
                <!-- General sterile white -->
                <rect x="0" y="0" w="640" h="480" color="#F0F0FF04"/>
            </pixel-data>
            <conditions>
                <condition id="time_day">
                    <description>Стандартный приём — яркий свет</description>
                    <override layer-ref="ambient_light" tint="#F8F8FF" opacity="0.06"/>
                </condition>
                <condition id="time_night">
                    <description>Экстренный ночной визит — приглушённый</description>
                    <override layer-ref="ambient_light" tint="#1A2030" opacity="0.30"/>
                </condition>
                <condition id="surgery_mode">
                    <description>Операция — яркий хирургический свет над столом</description>
                    <override layer-ref="ambient_light" tint="#FFFFFF" opacity="0.12"/>
                </condition>
            </conditions>
        </layer>

        <!-- z=8: Monitor pulse animation layer -->
        <layer id="pulse_anim" type="animated-overlay" z-order="8" width="640" height="480">
            <pixel-data>
                <hline x="148" y="218" len="36" color="$pulse_line"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <animation name="idle" frames="12" fps="2" loop="true"
                   frame-width="640" frame-height="480">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="pulse_anim:2,0"/>
            <frame index="2" layer-offsets="pulse_anim:4,0"/>
            <frame index="3" layer-offsets="pulse_anim:6,0"/>
            <frame index="4" layer-offsets="pulse_anim:8,0"/>
            <frame index="5" layer-offsets="pulse_anim:10,0"/>
            <frame index="6" layer-offsets="pulse_anim:12,0"/>
            <frame index="7" layer-offsets="pulse_anim:14,0"/>
            <frame index="8" layer-offsets="pulse_anim:16,0"/>
            <frame index="9" layer-offsets="pulse_anim:18,0"/>
            <frame index="10" layer-offsets="pulse_anim:20,0"/>
            <frame index="11" layer-offsets=""/>
        </animation>
    </animations>

    <naming><output-dir>locations/vet_clinic</output-dir></naming>
</asset-spec>