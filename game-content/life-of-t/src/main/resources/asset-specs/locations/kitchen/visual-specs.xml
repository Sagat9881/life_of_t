<?xml version="1.0" encoding="UTF-8"?>
<asset-spec extends="abstract/environments/indoor_room@1.0" version="2.0.0">
    <meta>
        <entity-type>location</entity-type>
        <entity-name>kitchen</entity-name>
        <version>2.0.0</version>
        <canvas width="640" height="480" displayScale="1.0"/>
        <description>
            Shared kitchen. Light, airy, homey.
            Canvas ×2: 320×240 → 640×480.
        </description>
    </meta>

    <color-palette>
        <color name="$floor_tile" value="#F0EDE0"/>
        <color name="$floor_grout" value="#D8D4C0"/>
        <color name="$floor_border" value="#E0D8C8"/>
        <color name="$wall_upper" value="#FBF8F0"/>
        <color name="$backsplash" value="#EFF2DC"/>
        <color name="$backsplash_grout" value="#DDE0C8"/>
        <color name="$counter" value="#D0C8B0"/>
        <color name="$counter_edge" value="#C0B8A0"/>
        <color name="$counter_base" value="#B8B0A0"/>
        <color name="$cabinet" value="#D0C8A8"/>
        <color name="$cabinet_inner" value="#C8C0A0"/>
        <color name="$cabinet_edge" value="#B0A888"/>
        <color name="$cabinet_handle" value="#C0B890"/>
        <color name="$fridge_body" value="#E8E8E8"/>
        <color name="$fridge_line" value="#C8C8C8"/>
        <color name="$fridge_handle" value="#C0C0B8"/>
        <color name="$table_top" value="#C8A878"/>
        <color name="$table_edge" value="#B89868"/>
        <color name="$window_sky" value="#C8E4F8"/>
        <color name="$window_frame" value="#C0C0B0"/>
    </color-palette>

    <layer-overrides>
        <layer id="floor" replace="true" type="background" z-order="0" width="640" height="480">
            <pixel-data>
                <rect x="0" y="320" w="640" h="160" color="$floor_tile"/>
                <hline x="0" y="360" len="640" color="$floor_grout"/>
                <hline x="0" y="400" len="640" color="$floor_grout"/>
                <hline x="0" y="440" len="640" color="$floor_grout"/>
                <rect x="80"  y="320" w="2" h="160" color="$floor_grout"/>
                <rect x="160" y="320" w="2" h="160" color="$floor_grout"/>
                <rect x="240" y="320" w="2" h="160" color="$floor_grout"/>
                <rect x="320" y="320" w="2" h="160" color="$floor_grout"/>
                <rect x="400" y="320" w="2" h="160" color="$floor_grout"/>
                <rect x="480" y="320" w="2" h="160" color="$floor_grout"/>
                <rect x="560" y="320" w="2" h="160" color="$floor_grout"/>
                <rect x="0" y="314" w="640" h="10" color="$floor_border"/>
                <!-- Tile shadow details -->
                <rect x="82" y="362" w="76" h="36" color="#ECE9DC"/>
                <rect x="322" y="402" w="76" h="36" color="#ECE9DC"/>
            </pixel-data>
        </layer>

        <layer id="wall" replace="true" type="background" z-order="1" width="640" height="480">
            <pixel-data>
                <rect x="0" y="0" w="640" h="324" color="$wall_upper"/>
                <!-- Backsplash -->
                <rect x="0" y="192" w="640" h="128" color="$backsplash"/>
                <hline x="0" y="204" len="640" color="$backsplash_grout"/>
                <hline x="0" y="220" len="640" color="$backsplash_grout"/>
                <hline x="0" y="236" len="640" color="$backsplash_grout"/>
                <hline x="0" y="252" len="640" color="$backsplash_grout"/>
                <hline x="0" y="268" len="640" color="$backsplash_grout"/>
                <hline x="0" y="284" len="640" color="$backsplash_grout"/>
                <hline x="0" y="300" len="640" color="$backsplash_grout"/>
                <hline x="0" y="316" len="640" color="$backsplash_grout"/>
                <!-- Vertical grout -->
                <rect x="32"  y="192" w="2" h="132" color="$backsplash_grout"/>
                <rect x="64"  y="192" w="2" h="132" color="$backsplash_grout"/>
                <rect x="96"  y="192" w="2" h="132" color="$backsplash_grout"/>
                <rect x="128" y="192" w="2" h="132" color="$backsplash_grout"/>
                <rect x="160" y="192" w="2" h="132" color="$backsplash_grout"/>
                <rect x="192" y="192" w="2" h="132" color="$backsplash_grout"/>
                <rect x="224" y="192" w="2" h="132" color="$backsplash_grout"/>
                <rect x="256" y="192" w="2" h="132" color="$backsplash_grout"/>
                <rect x="288" y="192" w="2" h="132" color="$backsplash_grout"/>
                <rect x="320" y="192" w="2" h="132" color="$backsplash_grout"/>
                <rect x="352" y="192" w="2" h="132" color="$backsplash_grout"/>
                <rect x="384" y="192" w="2" h="132" color="$backsplash_grout"/>
                <rect x="416" y="192" w="2" h="132" color="$backsplash_grout"/>
                <rect x="448" y="192" w="2" h="132" color="$backsplash_grout"/>
            </pixel-data>
        </layer>
    </layer-overrides>

    <layers>
        <!-- z=2: Counter -->
        <layer id="counter" type="foreground" z-order="2" width="640" height="480">
            <pixel-data>
                <rect x="0" y="260" w="460" h="64" color="$counter"/>
                <rect x="0" y="260" w="460" h="6" color="$counter_edge"/>
                <rect x="0" y="324" w="460" h="16" color="$counter_base"/>
                <!-- Sink -->
                <rect x="136" y="270" w="100" h="44" color="#9A9890"/>
                <rect x="140" y="274" w="92" h="36" color="#8A8880"/>
                <rect x="176" y="296" w="20" h="12" color="#707068"/>
                <!-- Faucet -->
                <rect x="180" y="256" w="8" h="20" color="#B0B0A8"/>
                <rect x="172" y="254" w="24" h="6" color="#C0C0B8"/>
                <!-- Stove area -->
                <rect x="8" y="264" w="120" h="56" color="#D8D0C0"/>
                <rect x="28" y="276" w="32" h="20" color="#484040"/>
                <rect x="72" y="276" w="32" h="20" color="#484040"/>
                <rect x="28" y="304" w="32" h="12" color="#484040"/>
                <rect x="72" y="304" w="32" h="12" color="#484040"/>
                <!-- Knobs -->
                <rect x="20" y="262" w="10" h="10" color="#606060"/>
                <rect x="52" y="262" w="10" h="10" color="#606060"/>
                <rect x="80" y="262" w="10" h="10" color="#606060"/>
                <rect x="110" y="262" w="10" h="10" color="#606060"/>
                <!-- Kettle -->
                <rect x="24" y="256" w="40" h="24" color="#707080"/>
                <rect x="26" y="258" w="36" h="20" color="#808090"/>
                <rect x="64" y="264" w="10" h="6" color="#505060"/>
                <!-- Cutting board -->
                <rect x="256" y="266" w="72" h="36" color="#C8A870"/>
                <hline x="258" y="276" len="68" color="#B89860"/>
                <hline x="258" y="286" len="68" color="#B89860"/>
                <!-- Knife -->
                <rect x="270" y="268" w="4" h="32" color="#A0A0A8"/>
                <rect x="268" y="268" w="8" h="6" color="#808080"/>
                <!-- Glass -->
                <rect x="356" y="260" w="16" h="24" color="#B8D8E880"/>
                <rect x="358" y="262" w="12" h="20" color="#C8E4F080"/>
                <!-- Spice rack -->
                <rect x="384" y="236" w="72" h="28" color="#D0C0A0"/>
                <rect x="388" y="240" w="12" h="20" color="#E8A050"/>
                <rect x="404" y="242" w="12" h="18" color="#50A850"/>
                <rect x="420" y="240" w="12" h="20" color="#D06050"/>
                <rect x="436" y="242" w="12" h="18" color="#C8C050"/>
            </pixel-data>
        </layer>

        <!-- z=3: Table -->
        <layer id="table" type="foreground" z-order="3" width="640" height="480">
            <pixel-data>
                <rect x="336" y="300" w="296" h="96" color="$table_top"/>
                <rect x="336" y="300" w="296" h="6" color="$table_edge"/>
                <rect x="336" y="396" w="296" h="8" color="#B09060"/>
                <!-- Legs -->
                <rect x="340" y="400" w="10" h="32" color="#A08860"/>
                <rect x="618" y="400" w="10" h="32" color="#A08860"/>
                <!-- Plates -->
                <rect x="350" y="310" w="56" h="36" color="#D4B0A0"/>
                <rect x="356" y="316" w="16" h="20" color="#E8C090"/>
                <rect x="520" y="310" w="56" h="36" color="#B8C8A0"/>
                <rect x="540" y="316" w="16" h="20" color="#E8C090"/>
                <!-- Chairs -->
                <rect x="310" y="370" w="72" h="32" color="#B09878"/>
                <rect x="314" y="374" w="64" h="24" color="#C0A888"/>
                <rect x="316" y="324" w="60" h="48" color="#A08860"/>
                <rect x="588" y="370" w="72" h="32" color="#B09878"/>
                <rect x="592" y="374" w="64" h="24" color="#C0A888"/>
                <rect x="594" y="324" w="60" h="48" color="#A08860"/>
            </pixel-data>
        </layer>

        <!-- z=4: Fridge -->
        <layer id="fridge" type="foreground" z-order="4" width="640" height="480">
            <pixel-data>
                <rect x="476" y="60" w="152" h="264" color="$fridge_body"/>
                <hline x="476" y="160" len="152" color="$fridge_line"/>
                <!-- Handles -->
                <rect x="478" y="96" w="6" h="48" color="$fridge_handle"/>
                <rect x="478" y="184" w="6" h="72" color="$fridge_handle"/>
                <!-- Top edge -->
                <rect x="476" y="56" w="152" h="8" color="#D0D0D0"/>
                <!-- Magnets -->
                <rect x="516" y="72" w="14" h="14" color="#E04040"/>
                <rect x="518" y="74" w="10" h="10" color="#F06060"/>
                <rect x="540" y="68" w="20" h="20" color="#4080C0"/>
                <rect x="542" y="72" w="8" h="8" color="#E8E8FF"/>
                <rect x="572" y="72" w="16" h="16" color="#F0C040"/>
                <rect x="576" y="76" w="8" h="8" color="#FFE060"/>
                <!-- Shopping list -->
                <rect x="504" y="96" w="44" h="36" color="#FFF0A0"/>
                <hline x="508" y="106" len="36" color="#E8D880"/>
                <hline x="508" y="114" len="28" color="#E8D880"/>
                <hline x="508" y="122" len="32" color="#E8D880"/>
                <!-- Heart magnet -->
                <pixel x="564" y="102" color="#FF6080"/>
                <rect x="560" y="104" w="12" h="8" color="#FF6080"/>
                <rect x="562" y="112" w="8" h="6" color="#FF6080"/>
                <pixel x="564" y="118" color="#FF6080"/>
                <!-- Bottom -->
                <rect x="476" y="320" w="152" h="8" color="#D8D8D8"/>
            </pixel-data>
        </layer>

        <!-- z=5: Cabinets -->
        <layer id="cabinets" type="foreground" z-order="5" width="640" height="480">
            <pixel-data>
                <!-- Left cabinets -->
                <rect x="0" y="40" w="132" h="152" color="$cabinet"/>
                <rect x="4" y="44" w="60" h="144" color="$cabinet_inner"/>
                <rect x="68" y="44" w="60" h="144" color="$cabinet_inner"/>
                <rect x="4" y="44" w="60" h="4" color="$cabinet_edge"/>
                <rect x="4" y="44" w="4" h="144" color="$cabinet_edge"/>
                <rect x="60" y="44" w="4" h="144" color="$cabinet_edge"/>
                <rect x="68" y="44" w="60" h="4" color="$cabinet_edge"/>
                <rect x="68" y="44" w="4" h="144" color="$cabinet_edge"/>
                <rect x="124" y="44" w="4" h="144" color="$cabinet_edge"/>
                <rect x="30" y="108" w="4" h="16" color="$cabinet_handle"/>
                <rect x="94" y="108" w="4" h="16" color="$cabinet_handle"/>
                <!-- Right cabinets -->
                <rect x="240" y="40" w="144" h="152" color="$cabinet"/>
                <rect x="244" y="44" w="68" h="144" color="$cabinet_inner"/>
                <rect x="316" y="44" w="64" h="144" color="$cabinet_inner"/>
                <rect x="244" y="44" w="68" h="4" color="$cabinet_edge"/>
                <rect x="244" y="44" w="4" h="144" color="$cabinet_edge"/>
                <rect x="308" y="44" w="4" h="144" color="$cabinet_edge"/>
                <rect x="316" y="44" w="64" h="4" color="$cabinet_edge"/>
                <rect x="316" y="44" w="4" h="144" color="$cabinet_edge"/>
                <rect x="376" y="44" w="4" h="144" color="$cabinet_edge"/>
                <rect x="276" y="108" w="4" h="16" color="$cabinet_handle"/>
                <rect x="344" y="108" w="4" h="16" color="$cabinet_handle"/>
                <!-- Bottom edges -->
                <rect x="0" y="188" w="132" h="6" color="$counter_base"/>
                <rect x="240" y="188" w="144" h="6" color="$counter_base"/>
            </pixel-data>
        </layer>

        <!-- z=6: Window -->
        <layer id="window" type="midground" z-order="6" width="640" height="480">
            <pixel-data>
                <rect x="136" y="44" w="100" h="144" color="$window_sky"/>
                <!-- Greenery outside -->
                <rect x="136" y="152" w="100" h="20" color="#90B870"/>
                <rect x="136" y="140" w="32" h="32" color="#A8A8A8"/>
                <rect x="180" y="132" w="28" h="40" color="#B0B0B0"/>
                <!-- Clouds -->
                <rect x="144" y="56" w="28" h="12" color="#FFFFFF"/>
                <rect x="140" y="62" w="36" h="8" color="#F0F8FF"/>
                <rect x="184" y="68" w="20" h="8" color="#F0F8FF"/>
                <!-- Frame -->
                <rect x="132" y="40" w="108" h="6" color="$window_frame"/>
                <rect x="132" y="186" w="108" h="6" color="$window_frame"/>
                <rect x="132" y="40" w="6" h="152" color="$window_frame"/>
                <rect x="234" y="40" w="6" h="152" color="$window_frame"/>
                <rect x="132" y="110" w="108" h="4" color="$window_frame"/>
                <rect x="184" y="40" w="4" h="152" color="$window_frame"/>
                <!-- Windowsill -->
                <rect x="128" y="192" w="116" h="16" color="#D8D0B8"/>
                <!-- Plants -->
                <rect x="136" y="180" w="20" h="20" color="#8A6040"/>
                <rect x="138" y="168" w="16" h="16" color="#60A850"/>
                <rect x="140" y="160" w="6" h="12" color="#48C048"/>
                <rect x="148" y="156" w="6" h="16" color="#50B850"/>
                <rect x="164" y="180" w="20" h="16" color="#7A5838"/>
                <rect x="166" y="168" w="16" h="16" color="#60A050"/>
                <rect x="168" y="160" w="12" h="12" color="#78C060"/>
                <rect x="192" y="180" w="20" h="20" color="#8A6040"/>
                <rect x="196" y="156" w="12" h="28" color="#58A848"/>
                <rect x="192" y="164" w="8" h="8" color="#48C040"/>
                <rect x="204" y="160" w="8" h="12" color="#50B840"/>
            </pixel-data>
        </layer>

        <!-- z=7: Decorations + cat bowls -->
        <layer id="decorations" type="foreground" z-order="7" width="640" height="480">
            <pixel-data>
                <!-- Cat bowls -->
                <rect x="8" y="384" w="40" h="20" color="#E89090"/>
                <rect x="10" y="386" w="36" h="16" color="#ECA0A0"/>
                <pixel x="18" y="392" color="#C06060"/>
                <pixel x="24" y="390" color="#C06060"/>
                <pixel x="30" y="392" color="#C06060"/>
                <pixel x="36" y="390" color="#C06060"/>
                <rect x="56" y="384" w="40" h="20" color="#90B8E8"/>
                <rect x="58" y="386" w="36" h="16" color="#A0C8F0"/>
                <hline x="62" y="392" len="28" color="#C0E0FF80"/>
                <!-- Jars on counter -->
                <rect x="284" y="232" w="24" h="32" color="#E0A830"/>
                <rect x="286" y="234" w="20" h="28" color="#F0C050"/>
                <rect x="286" y="232" w="20" h="8" color="#A08020"/>
                <rect x="314" y="228" w="20" h="36" color="#E8E0C0"/>
                <rect x="316" y="230" w="16" h="32" color="#F4ECCC"/>
                <rect x="316" y="228" w="16" h="8" color="#C0B898"/>
                <rect x="340" y="232" w="24" h="32" color="#80A040"/>
                <rect x="342" y="234" w="20" h="28" color="#90B050"/>
                <rect x="342" y="232" w="20" h="8" color="#506030"/>
                <!-- Shelf rack -->
                <hline x="0" y="28" len="120" color="#A09070"/>
                <rect x="20" y="28" w="4" h="16" color="#A09070"/>
                <rect x="48" y="28" w="4" h="12" color="#A09070"/>
                <rect x="76" y="28" w="4" h="16" color="#A09070"/>
                <!-- Clock -->
                <rect x="12" y="40" w="32" h="20" color="#707080"/>
                <rect x="14" y="42" w="28" h="16" color="#808090"/>
                <!-- Ladle -->
                <rect x="52" y="36" w="6" h="16" color="#9090A0"/>
                <rect x="50" y="50" w="10" h="8" color="#A0A0B0"/>
                <!-- Recipe note -->
                <rect x="8" y="168" w="44" h="32" color="#FFF8E8"/>
                <hline x="12" y="176" len="36" color="#C0A870"/>
                <hline x="12" y="182" len="28" color="#C0A870"/>
                <hline x="12" y="188" len="32" color="#C0A870"/>
                <hline x="12" y="194" len="24" color="#C0A870"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <animation name="idle" frames="4" fps="1" loop="true"
                   frame-width="640" frame-height="480">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets=""/>
            <frame index="2" layer-offsets=""/>
            <frame index="3" layer-offsets=""/>
        </animation>
    </animations>

    <naming><output-dir>locations/kitchen</output-dir></naming>
</asset-spec>