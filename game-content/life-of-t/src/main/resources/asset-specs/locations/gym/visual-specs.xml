<?xml version="1.0" encoding="UTF-8"?>
<asset-spec extends="abstract/environments/indoor_room@1.0" version="2.0.0">
    <meta>
        <entity-type>location</entity-type>
        <entity-name>gym</entity-name>
        <version>2.0.0</version>
        <canvas width="640" height="480" displayScale="1.0"/>
        <description>
            Спортзал — небольшой фитнес-клуб.
            Full pixel-data rewrite from descriptive v1.
        </description>
    </meta>

    <color-palette>
        <color name="$wall_main" value="#E8E8E8"/>
        <color name="$wall_stripe" value="#FF6B6B"/>
        <color name="$floor_rubber" value="#404048"/>
        <color name="$floor_line" value="#484850"/>
        <color name="$mirror" value="#D8E8F0"/>
        <color name="$mirror_frame" value="#808080"/>
        <color name="$mirror_shine" value="#F0F8FF"/>
        <color name="$metal_dark" value="#505050"/>
        <color name="$metal_mid" value="#707070"/>
        <color name="$metal_light" value="#909090"/>
        <color name="$padding" value="#303030"/>
        <color name="$padding_top" value="#383838"/>
        <color name="$treadmill_belt" value="#2A2A2A"/>
        <color name="$treadmill_frame" value="#606060"/>
        <color name="$treadmill_screen" value="#4ECDC4"/>
        <color name="$dumbbell" value="#555555"/>
        <color name="$weight_red" value="#E04040"/>
        <color name="$weight_blue" value="#4060C0"/>
        <color name="$poster_bg" value="#FF6B6B"/>
        <color name="$poster_text" value="#FFFFFF"/>
        <color name="$water_bottle" value="#80C0E0"/>
        <color name="$towel" value="#F0F0F0"/>
        <color name="$bag" value="#8060A0"/>
        <color name="$fan_body" value="#C0C0C0"/>
        <color name="$fan_blade" value="#A0A0A0"/>
        <color name="$vent" value="#B0B0B0"/>
    </color-palette>

    <layer-overrides>
        <layer id="floor" replace="true" type="background" z-order="0" width="640" height="480">
            <pixel-data>
                <rect x="0" y="320" w="640" h="160" color="$floor_rubber"/>
                <!-- Rubber mat lines -->
                <hline x="0" y="340" len="640" color="$floor_line"/>
                <hline x="0" y="360" len="640" color="$floor_line"/>
                <hline x="0" y="380" len="640" color="$floor_line"/>
                <hline x="0" y="400" len="640" color="$floor_line"/>
                <hline x="0" y="420" len="640" color="$floor_line"/>
                <hline x="0" y="440" len="640" color="$floor_line"/>
                <hline x="0" y="460" len="640" color="$floor_line"/>
                <!-- Safety zone markings -->
                <rect x="200" y="320" w="4" h="160" color="#FFFF6030"/>
                <rect x="440" y="320" w="4" h="160" color="#FFFF6030"/>
            </pixel-data>
        </layer>

        <layer id="wall" replace="true" type="background" z-order="1" width="640" height="480">
            <pixel-data>
                <rect x="0" y="0" w="640" h="324" color="$wall_main"/>
                <!-- Red accent stripe -->
                <rect x="0" y="300" w="640" h="8" color="$wall_stripe"/>
                <rect x="0" y="312" w="640" h="12" color="#D0D0D0"/>
                <!-- Ventilation grille -->
                <rect x="520" y="20" w="80" h="24" color="$vent"/>
                <hline x="524" y="24" len="72" color="#A0A0A0"/>
                <hline x="524" y="28" len="72" color="#A0A0A0"/>
                <hline x="524" y="32" len="72" color="#A0A0A0"/>
                <hline x="524" y="36" len="72" color="#A0A0A0"/>
                <!-- Ceiling light bars -->
                <rect x="100" y="0" w="120" h="8" color="#F8F8FF"/>
                <rect x="300" y="0" w="120" h="8" color="#F8F8FF"/>
                <rect x="500" y="0" w="100" h="8" color="#F8F8FF"/>
            </pixel-data>
        </layer>
    </layer-overrides>

    <layers>
        <!-- z=2: Mirror -->
        <layer id="mirror" type="base" z-order="2" width="640" height="480">
            <pixel-data>
                <rect x="40" y="40" w="200" h="260" color="$mirror"/>
                <!-- Frame -->
                <rect x="36" y="36" w="208" h="4" color="$mirror_frame"/>
                <rect x="36" y="300" w="208" h="4" color="$mirror_frame"/>
                <rect x="36" y="36" w="4" h="268" color="$mirror_frame"/>
                <rect x="240" y="36" w="4" h="268" color="$mirror_frame"/>
                <!-- Shine streaks -->
                <rect x="60" y="60" w="4" h="40" color="$mirror_shine"/>
                <rect x="68" y="50" w="4" h="30" color="$mirror_shine"/>
                <!-- Faint reflection of room -->
                <rect x="100" y="200" w="60" h="80" color="#D0E0E8"/>
                <rect x="180" y="180" w="40" h="60" color="#D4E4EC"/>
            </pixel-data>
        </layer>

        <!-- z=3: Treadmill -->
        <layer id="treadmill" type="base" z-order="3" width="640" height="480">
            <pixel-data>
                <!-- Frame -->
                <rect x="280" y="200" w="120" h="140" color="$treadmill_frame"/>
                <!-- Belt -->
                <rect x="288" y="280" w="104" h="50" color="$treadmill_belt"/>
                <hline x="290" y="290" len="100" color="#343434"/>
                <hline x="290" y="300" len="100" color="#343434"/>
                <hline x="290" y="310" len="100" color="#343434"/>
                <!-- Uprights -->
                <rect x="284" y="200" w="8" h="80" color="$metal_mid"/>
                <rect x="388" y="200" w="8" h="80" color="$metal_mid"/>
                <!-- Console -->
                <rect x="300" y="200" w="80" h="24" color="$metal_dark"/>
                <rect x="308" y="204" w="64" h="16" color="$treadmill_screen"/>
                <!-- Screen content -->
                <rect x="312" y="208" w="20" h="4" color="#2A8A80"/>
                <rect x="340" y="208" w="28" h="4" color="#2A8A80"/>
                <rect x="312" y="214" w="56" h="2" color="#3A9A90"/>
                <!-- Handles -->
                <rect x="282" y="240" w="12" h="4" color="$metal_light"/>
                <rect x="386" y="240" w="12" h="4" color="$metal_light"/>
                <!-- Base -->
                <rect x="280" y="330" w="120" h="12" color="$metal_dark"/>
                <!-- Shadow -->
                <rect x="284" y="340" w="116" h="4" color="#303038"/>
            </pixel-data>
        </layer>

        <!-- z=4: Dumbbell rack + bench -->
        <layer id="equipment" type="base" z-order="4" width="640" height="480">
            <pixel-data>
                <!-- Dumbbell rack -->
                <rect x="440" y="180" w="80" h="140" color="$metal_mid"/>
                <rect x="444" y="184" w="72" h="4" color="$metal_dark"/>
                <!-- Shelf 1 -->
                <rect x="444" y="220" w="72" h="4" color="$metal_dark"/>
                <!-- Shelf 2 -->
                <rect x="444" y="260" w="72" h="4" color="$metal_dark"/>
                <!-- Shelf 3 -->
                <rect x="444" y="300" w="72" h="4" color="$metal_dark"/>
                <!-- Dumbbells row 1 (light) -->
                <rect x="450" y="192" w="12" h="24" color="$dumbbell"/>
                <rect x="466" y="192" w="12" h="24" color="$dumbbell"/>
                <rect x="482" y="192" w="12" h="24" color="$dumbbell"/>
                <rect x="498" y="192" w="12" h="24" color="$dumbbell"/>
                <!-- Dumbbells row 2 (medium, red) -->
                <rect x="450" y="228" w="14" h="28" color="$weight_red"/>
                <rect x="468" y="228" w="14" h="28" color="$weight_red"/>
                <rect x="486" y="228" w="14" h="28" color="$weight_red"/>
                <rect x="504" y="228" w="14" h="28" color="$weight_red"/>
                <!-- Dumbbells row 3 (heavy, blue) -->
                <rect x="450" y="268" w="16" h="28" color="$weight_blue"/>
                <rect x="470" y="268" w="16" h="28" color="$weight_blue"/>
                <rect x="490" y="268" w="16" h="28" color="$weight_blue"/>
                <!-- Bench press -->
                <rect x="540" y="260" w="80" h="12" color="$padding"/>
                <rect x="540" y="260" w="80" h="4" color="$padding_top"/>
                <rect x="548" y="272" w="8" h="60" color="$metal_mid"/>
                <rect x="604" y="272" w="8" h="60" color="$metal_mid"/>
                <!-- Barbell rack -->
                <rect x="544" y="220" w="4" h="40" color="$metal_mid"/>
                <rect x="612" y="220" w="4" h="40" color="$metal_mid"/>
                <!-- Barbell -->
                <rect x="540" y="216" w="80" h="4" color="$metal_dark"/>
                <rect x="532" y="212" w="12" h="12" color="$weight_red"/>
                <rect x="616" y="212" w="12" h="12" color="$weight_red"/>
            </pixel-data>
        </layer>

        <!-- z=5: Poster + decorations -->
        <layer id="decorations" type="foreground" z-order="5" width="640" height="480">
            <pixel-data>
                <!-- Motivational poster -->
                <rect x="280" y="60" w="100" h="60" color="$poster_bg"/>
                <rect x="284" y="64" w="92" h="52" color="#E05050"/>
                <rect x="296" y="72" w="68" h="8" color="$poster_text"/>
                <rect x="300" y="88" w="60" h="8" color="$poster_text"/>
                <rect x="308" y="104" w="44" h="4" color="$poster_text"/>
                <!-- Water bottle -->
                <rect x="430" y="330" w="10" h="24" color="$water_bottle"/>
                <rect x="432" y="326" w="6" h="6" color="#60A0C0"/>
                <rect x="432" y="332" w="6" h="4" color="#A0E0FF"/>
                <!-- Towel on hook -->
                <rect x="260" y="310" w="6" h="4" color="$metal_mid"/>
                <rect x="254" y="314" w="18" h="30" color="$towel"/>
                <hline x="256" y="324" len="14" color="#E0E0E0"/>
                <!-- Tanya's bag -->
                <rect x="40" y="340" w="40" h="32" color="$bag"/>
                <rect x="42" y="338" w="36" h="4" color="#7050A0"/>
                <rect x="54" y="330" w="12" h="10" color="#9070B0"/>
                <!-- Fan on ceiling -->
                <rect x="160" y="8" w="16" h="16" color="$fan_body"/>
                <rect x="148" y="14" w="40" h="4" color="$fan_blade"/>
                <rect x="164" y="4" w="8" h="24" color="$fan_blade"/>
            </pixel-data>
        </layer>

        <!-- z=6: Fan animation overlay -->
        <layer id="fan_spin" type="animated-overlay" z-order="6" width="640" height="480">
            <pixel-data>
                <rect x="148" y="14" w="40" h="4" color="$fan_blade"/>
                <rect x="164" y="4" w="8" h="24" color="$fan_blade"/>
            </pixel-data>
        </layer>
    </layers>

    <animations>
        <animation name="idle" frames="8" fps="2" loop="true"
                   frame-width="640" frame-height="480">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="fan_spin:2,0"/>
            <frame index="2" layer-offsets="fan_spin:0,2"/>
            <frame index="3" layer-offsets="fan_spin:-2,0"/>
            <frame index="4" layer-offsets="fan_spin:0,-2"/>
            <frame index="5" layer-offsets="fan_spin:2,0"/>
            <frame index="6" layer-offsets="fan_spin:0,2"/>
            <frame index="7" layer-offsets="fan_spin:-2,0"/>
        </animation>
    </animations>

    <time-of-day-variations>
        <variation time="morning"><lighting>Fresh morning light</lighting></variation>
        <variation time="day"><lighting>Full bright fluorescent</lighting></variation>
        <variation time="evening"><lighting>Dimmed, tired light</lighting></variation>
    </time-of-day-variations>

    <naming><output-dir>locations/gym</output-dir></naming>
</asset-spec>