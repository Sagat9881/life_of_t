<?xml version="1.0" encoding="UTF-8"?>
<event id="event_aijan_hiss" type="TRIGGERED">
    <meta>
        <title-ru>Айджан шипит</title-ru>
        <description-ru>Айджан натолкнулась на другую кошку — мир рушится, она это докажет.</description-ru>
        <probability>0.8</probability>
        <cooldown-hours>2</cooldown-hours>
    </meta>
    <conditions>
        <condition type="location" value="alexander_room"/>
        <condition type="trigger" value="cat_enters_room"/>
    </conditions>
    <dialogue>
        <line speaker="aijan" lang="ru">ШШШШ!!!! (шерсть дыбом, хвост трубой, максимальная драматичность)</line>
        <line speaker="narrator" lang="ru">Другая кошка замирает. Айджан делает один шаг вперёд — просто чтобы обозначить позицию. Самая сильная. Всегда.</line>
        <line speaker="tanya" lang="ru">Айджан! Никто не претендует на твою территорию! Успокойся!</line>
        <line speaker="aijan" lang="ru">Ш... (недовольно, но успокаивается)</line>
    </dialogue>
    <options>
        <option id="ok" label-ru="Понятно, всё под контролем">
            <effects>
                <stat-change stat="anxiety" value="+3"/>
            </effects>
        </option>
    </options>
</event>
