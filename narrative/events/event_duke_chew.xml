<?xml version="1.0" encoding="UTF-8"?>
<event id="event_duke_chew" type="RANDOM">
    <meta>
        <title-ru>Дюк грызёт что-то</title-ru>
        <description-ru>Дюк нашёл что-то и грызёт это с большим энтузиазмом. Это не его вещь.</description-ru>
        <probability>0.55</probability>
        <cooldown-hours>3</cooldown-hours>
    </meta>
    <conditions>
        <condition type="time_of_day" value="day"/>
    </conditions>
    <dialogue>
        <line speaker="narrator" lang="ru">Подозрительная тишина. Потом звук: хрум-хрум-хрум. Дюк лежит в углу и грызёт что-то явно не своё — судя по цвету, это был тапочек.</line>
        <line speaker="tanya" lang="ru">Дюк! Это мой тапочек! Отдай! ОТДАЙ! Перси, скажи ему!</line>
        <line speaker="persi" lang="ru">...(смотрит в другую сторону)</line>
        <line speaker="tanya" lang="ru">Предательница.</line>
    </dialogue>
    <options>
        <option id="rescue_slipper" label-ru="Отобрать тапочек">
            <effects>
                <stat-change stat="happiness" value="+3"/>
            </effects>
        </option>
        <option id="let_go" label-ru="Тапочек уже не спасти">
            <effects>
                <stat-change stat="happiness" value="+5"/>
                <stat-change stat="energy" value="+2"/>
            </effects>
        </option>
    </options>
</event>
