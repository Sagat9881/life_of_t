<?xml version="1.0" encoding="UTF-8"?>
<event id="event_klop_belly" type="RANDOM">
    <meta>
        <title-ru>Клоп подставляет живот</title-ru>
        <description-ru>Клоп демонстративно переворачивается пузом вверх перед Таней. Погладь его — это обязательно.</description-ru>
        <probability>0.5</probability>
        <cooldown-hours>6</cooldown-hours>
    </meta>
    <conditions>
        <condition type="time_of_day" value="day"/>
        <condition type="location" value="living_room"/>
    </conditions>
    <dialogue>
        <line speaker="klop" lang="ru">Пурр-р-р... (переворачивается с видом существа, которое полностью контролирует ситуацию)</line>
        <line speaker="tanya" lang="ru">Клоп. Ты делаешь это каждый раз когда я прохожу мимо. (наклоняется и жмякает его живот) Ты идеальный.</line>
        <line speaker="klop" lang="ru">Пурр-р-р-р-р... (интенсивнее)</line>
    </dialogue>
    <options>
        <option id="belly_rub" label-ru="Хорошенько почесать живот">
            <effects>
                <stat-change stat="happiness" value="+10"/>
                <stat-change stat="anxiety" value="-5"/>
            </effects>
        </option>
        <option id="quick_pat" label-ru="Быстро потрепать и пойти дальше">
            <effects>
                <stat-change stat="happiness" value="+4"/>
            </effects>
        </option>
    </options>
</event>
