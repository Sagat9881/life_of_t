<?xml version="1.0" encoding="UTF-8"?>
<event id="event_alexander_code" type="RANDOM">
    <meta>
        <title-ru>Александр кодит и забыл поесть</title-ru>
        <description-ru>Александр кодит глубоко ночью и забыл поужинать. Таня его замечает.</description-ru>
        <probability>0.45</probability>
        <cooldown-hours>16</cooldown-hours>
    </meta>
    <conditions>
        <condition type="time_of_day" value="night"/>
        <condition type="location" value="alexander_room"/>
    </conditions>
    <dialogue>
        <line speaker="narrator" lang="ru">Половина первого. В рабочей комнате Александра горит свет. Айджан спит у него на коленях. На столе — пустая кружка и никакой еды.</line>
        <line speaker="tanya" lang="ru">Саш. Ты ел?</line>
        <line speaker="alexander" lang="ru">(не поднимает взгляд) Сейчас доделаю и...</line>
        <line speaker="tanya" lang="ru">Ел или нет?</line>
        <line speaker="alexander" lang="ru">(пауза) Не помню.</line>
        <line speaker="tanya" lang="ru">Иди есть. Я разогрею. Айджан, слезь с него — это я тоже тебе говорю.</line>
    </dialogue>
    <options>
        <option id="warm_up" label-ru="Разогреть еду для Саши">
            <effects>
                <stat-change stat="happiness" value="+8"/>
                <relationship-change target="alexander" value="+3"/>
            </effects>
        </option>
        <option id="leave_him" label-ru="Пусть сам разберётся">
            <effects>
                <stat-change stat="happiness" value="+2"/>
            </effects>
        </option>
    </options>
</event>
