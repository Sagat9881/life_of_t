<?xml version="1.0" encoding="UTF-8"?>
<event id="event_alexander_snore" type="RANDOM">
    <meta>
        <title-ru>Александр храпит</title-ru>
        <description-ru>Александр храпит. Это смешно и немного раздражает одновременно.</description-ru>
        <probability>0.3</probability>
        <cooldown-hours>24</cooldown-hours>
    </meta>
    <conditions>
        <condition type="time_of_day" value="night"/>
        <condition type="location" value="home_room"/>
    </conditions>
    <effects>
        <stat-change stat="happiness" value="+5"/>
        <stat-change stat="energy" value="-3"/>
        <dialogue speaker="narrator">
            <line-ru>Тихо. Спокойно. Потом: хр-р-р. Пауза. Хр-р-р-р. Александр спит богатырским сном программиста после трудного дня.</line-ru>
        </dialogue>
        <dialogue speaker="tanya">
            <line-ru>(шёпотом) Саша. Тихо. (пауза) Саша. (толкает) Саша!</line-ru>
        </dialogue>
        <dialogue speaker="alexander">
            <line-ru>(сквозь сон) Мм... да... коммит...(переворачивается, замолкает)</line-ru>
        </dialogue>
        <dialogue speaker="tanya">
            <line-ru>(тихо смеётся) Я тебя всё равно люблю.</line-ru>
        </dialogue>
    </effects>
</event>