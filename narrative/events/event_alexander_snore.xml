<?xml version="1.0" encoding="UTF-8"?>
<event id="event_alexander_snore" type="RANDOM">
    <meta>
        <title-ru>Александр храпит</title-ru>
        <description-ru>Александр храпит. Это смешно и немного раздражает одновременно.</description-ru>
        <probability>0.3</probability>
        <cooldown-hours>24</cooldown-hours>
    </meta>
    <conditions>
        <condition type="time_of_day" value="night"/>
        <condition type="location" value="home_room"/>
    </conditions>
    <dialogue>
        <line speaker="narrator" lang="ru">Тихо. Спокойно. Потом: хр-р-р. Пауза. Хр-р-р-р. Александр спит богатырским сном программиста после трудного дня.</line>
        <line speaker="tanya" lang="ru">(шёпотом) Саша. Тихо. (пауза) Саша. (толкает) Саша!</line>
        <line speaker="alexander" lang="ru">(сквозь сон) Мм... да... коммит...(переворачивается, замолкает)</line>
        <line speaker="tanya" lang="ru">(тихо смеётся) Я тебя всё равно люблю.</line>
    </dialogue>
    <options>
        <option id="laugh_it_off" label-ru="Посмеяться и засыпать">
            <effects>
                <stat-change stat="happiness" value="+5"/>
                <stat-change stat="energy" value="-3"/>
            </effects>
        </option>
        <option id="poke_again" label-ru="Ещё раз потолкать его">
            <effects>
                <stat-change stat="happiness" value="+3"/>
                <stat-change stat="energy" value="-5"/>
            </effects>
        </option>
    </options>
</event>
