<?xml version="1.0" encoding="UTF-8"?>
<asset-spec version="1.0.0">

    <meta>
        <entity-type>characters</entity-type>
        <entity-name>husband</entity-name>
        <version>1.0.0</version>
    </meta>

    <layers>
        <layer id="base" type="base" z-order="0">Base body silhouette — tall build, casual posture</layer>
        <layer id="outfit" type="outfit" z-order="1">Default outfit — polo shirt and jeans</layer>
        <layer id="accessory" type="accessory" z-order="2">Glasses, watch</layer>
    </layers>

    <color-palette>
        <primary>
            <color hex="#F5E6D3" name="warm-beige"/>
            <color hex="#4A5859" name="dark-gray"/>
            <color hex="#6B4423" name="dark-brown"/>
        </primary>
        <secondary>
            <color hex="#FFF9E9" name="cream"/>
            <color hex="#A8B2B7" name="silver"/>
        </secondary>
    </color-palette>

    <animations>
        <animation name="idle" frames="24" fps="12" loop="true"
                   frame-width="128" frame-height="128"/>
        <animation name="walk" frames="16" fps="12" loop="true"
                   frame-width="128" frame-height="128"/>
        <animation name="sit_relax" frames="12" fps="8" loop="true"
                   frame-width="128" frame-height="128"/>
    </animations>

    <naming>
        <output-dir>assets/characters/husband</output-dir>
    </naming>

    <constraints>
        <max-file-size-kb>500</max-file-size-kb>
        <max-sprite-sheet-width>2048</max-sprite-sheet-width>
        <max-sprite-sheet-height>2048</max-sprite-sheet-height>
        <compression-quality>85</compression-quality>
        <bit-depth>32</bit-depth>
    </constraints>

</asset-spec>
