<?xml version="1.0" encoding="UTF-8"?>
<!--
  Visual specification for the bed – home room furniture.

  Naming conventions:
    - Directory (outputDir):  snake_case  → furniture/bed
    - Prompt files:           kebab-case  → visual-specs.xml
    - Output PNG:             snake_case  → bed_static.png

  Atlas format: horizontal-strip, 1 frame (static furniture).
  No anti-aliasing. No GIF. Max 50 frames (this asset uses 1).
-->
<asset id="bed">

    <naming>
        <outputDir>furniture/bed</outputDir>
        <fileName>bed_static</fileName>
    </naming>

    <layers>
        <layer id="frame" type="BASE" zOrder="0">
            <description>
                Wooden bed frame, side/top-down 2.5D pixel-art view, 48×32 px.
                Frame colour: #8B5E3C (medium brown).
                Headboard: 48×8px rectangle at top.
                Footboard: 48×4px at bottom.
                Side rails: 4px wide running the length.
                No anti-aliasing. Block shading: 1px darker edge #6A4428.
            </description>
        </layer>
        <layer id="mattress" type="FILL" zOrder="1">
            <description>
                Mattress on top of frame: 40×20px centred horizontally.
                Colour: #E8E0D0 (off-white). Button indents: 4×4px blocks
                of slightly darker #D0C8B8, placed in 2×2 grid.
                No anti-aliasing.
            </description>
        </layer>
        <layer id="pillow" type="DETAIL" zOrder="2">
            <description>
                Single pillow near the headboard: 20×8px rectangle.
                Colour: #F8F0E8. Outline: 1px #C8C0B0.
                No anti-aliasing.
            </description>
        </layer>
        <layer id="blanket" type="DETAIL" zOrder="3">
            <description>
                Folded blanket at foot of bed: 40×6px strip.
                Colour: #6080C0 (blue). Stripe detail: every 4px a 1px
                lighter #8090D0 horizontal line.
                No anti-aliasing.
            </description>
        </layer>
    </layers>

    <animations>
        <animation id="bed_static" frames="1" frameRate="1">
            <layerIds>
                <layerId>frame</layerId>
                <layerId>mattress</layerId>
                <layerId>pillow</layerId>
                <layerId>blanket</layerId>
            </layerIds>
        </animation>
    </animations>

    <canvasSize width="48" height="32"/>

</asset>
