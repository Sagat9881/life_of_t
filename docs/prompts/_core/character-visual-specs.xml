<?xml version="1.0" encoding="UTF-8"?>
<character-visual-specifications>
    <meta>
        <name>Character Visual Specifications Template</name>
        <version>2.0.0</version>
        <purpose>Универсальный шаблон для спецификации визуала персонажей</purpose>
        <last-updated>2026-03-08</last-updated>
    </meta>

    <visual-style>
        <overall-style>Pixel Art HD - высокодетализированная пиксельная графика</overall-style>
        <inspiration>Punch Club, Stardew Valley - современный pixel art с выразительными персонажами</inspiration>
        <technical-approach>Процедурная генерация через PixelRect/PixelLine/PixelDot из XML-спецификаций</technical-approach>

        <key-traits>
            <trait>Выразительные позы и силуэты</trait>
            <trait>Читаемые эмоции через позу тела и голову</trait>
            <trait>Чёткие пиксельные границы без anti-aliasing</trait>
            <trait>Ограниченная палитра 16-32 цвета</trait>
            <trait>Стилизованные пропорции (semi-chibi для pixel art холста)</trait>
        </key-traits>
    </visual-style>

    <canvas-specifications>
        <base-resolution>128×192 пикселей (высокодетализированный холст)</base-resolution>
        <display-scale>2.0 (итоговый CSS-размер: 256×384px)</display-scale>
        <proportions-guide>
            <segment name="head">24×28px (~15% высоты)</segment>
            <segment name="neck">8×12px</segment>
            <segment name="torso">32×48px</segment>
            <segment name="pelvis">24×20px</segment>
            <segment name="legs-total">~80px (~42% высоты)</segment>
        </proportions-guide>
        <rationale>Холст 128×192 даёт в 4 раза больше площади чем 32×48 для детализации суставов и плавных анимаций</rationale>
    </canvas-specifications>

    <lighting-and-shading>
        <light-source>Верхний левый угол (консистентно для всех ассетов)</light-source>
        <shading-technique>Дизеринг вместо градиентов</shading-technique>
        <shadow-color>Затемнение базового цвета на 20-30%, не чёрный</shadow-color>
    </lighting-and-shading>

    <layer-structure>
        <description>Сегментированная анатомия для анимаций</description>
        <layers z-order="bottom-to-top">
            <layer id="slippers" name="Тапочки" z="1" />
            <layer id="foot_left" name="Стопа левая" z="2" />
            <layer id="foot_right" name="Стопа правая" z="3" />
            <layer id="shin_left" name="Голень левая" z="4" />
            <layer id="shin_right" name="Голень правая" z="5" />
            <layer id="knee_left" name="Колено левое" z="6" />
            <layer id="knee_right" name="Колено правое" z="7" />
            <layer id="thigh_left" name="Бедро левое" z="8" />
            <layer id="thigh_right" name="Бедро правое" z="9" />
            <layer id="pelvis" name="Таз" z="10" />
            <layer id="torso" name="Торс" z="11" />
            <layer id="necklace" name="Ожерелье" z="12" />
            <layer id="upper_arm_left" name="Плечо левое" z="13" />
            <layer id="upper_arm_right" name="Плечо правое" z="14" />
            <layer id="forearm_left" name="Предплечье левое" z="15" />
            <layer id="forearm_right" name="Предплечье правое" z="16" />
            <layer id="hand_left" name="Кисть левая" z="17" />
            <layer id="hand_right" name="Кисть правая" z="18" />
            <layer id="neck" name="Шея" z="19" />
            <layer id="head" name="Голова" z="20" />
            <layer id="hair_back" name="Волосы (задний план)" z="21" />
            <layer id="hair_front" name="Волосы (передний план)" z="22" />
        </layers>
    </layer-structure>

    <animation-requirements>
        <frames min="12" recommended="16-18" max="30" />
        <fps default="4" range="3-8" />
        <format>Horizontal strip sprite atlas</format>
        <atlas-max-width>2048px</atlas-max-width>
        <note>16 кадров × 128px = 2048px (лимит)</note>
    </animation-requirements>

    <color-palette>
        <description>Тёплая приглушённая палитра</description>
        <primary-colors>
            <color hex="#F5D5B8" name="Кожа (тёплый бежевый)" />
            <color hex="#8B1A1A" name="Волосы (burgundy)" />
            <color hex="#6B8E23" name="Глаза (зелёный с оливковым)" />
        </primary-colors>
        <clothing-colors>
            <color hex="#FFB6C1" name="Розовый (пастельный)" />
            <color hex="#F5E6D3" name="Бежевый (светлый)" />
            <color hex="#B5EAD7" name="Мятный" />
            <color hex="#A8B2B7" name="Серый (нейтральный)" />
        </clothing-colors>
        <shading-rules>
            <rule>Использовать дизеринг для мягких переходов</rule>
            <rule>Тени = базовый цвет с понижением яркости на 20-30%</rule>
            <rule>Не использовать чистый чёрный (#000000) для теней</rule>
        </shading-rules>
    </color-palette>

    <physical-proportions>
        <style>Semi-chibi (стилизованные для pixel art)</style>
        <head-to-body-ratio>1:5 (голова составляет ~20% от роста, вместо реалистичных 1:7.5)</head-to-body-ratio>
        <features>
            <feature>Большая выразительная голова</feature>
            <feature>Средней длины ноги (~40% роста)</feature>
            <feature>Компактный торс</feature>
            <feature>Читаемые руки с видимыми кистями</feature>
        </features>
    </physical-proportions>

    <xml-spec-example>
        <description>Пример структуры visual-specs.xml для персонажа</description>
        <template><![CDATA[
<?xml version="1.0" encoding="UTF-8"?>
<asset-specification entity-type="character" entity-name="tanya">
    <canvas width="128" height="192"/>
    <layers>
        <layer id="head" z-order="20">
            <pixel-data>
                <!-- PixelRect/PixelDot coordinates -->
            </pixel-data>
        </layer>
        <!-- ... остальные 21 слой -->
    </layers>
    <animations>
        <animation name="idle" frames="16" fps="4" loop="true" frame-width="128" frame-height="192">
            <frame index="0" layer-offsets=""/>
            <frame index="1" layer-offsets="torso:0,-1; head:0,-1"/>
            <!-- ... все 16 кадров -->
        </animation>
        <animation name="walk" frames="16" fps="6" loop="true" frame-width="128" frame-height="192">
            <!-- ... -->
        </animation>
    </animations>
</asset-specification>
        ]]></template>
    </xml-spec-example>

</character-visual-specifications>