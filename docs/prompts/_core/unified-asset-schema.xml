<?xml version="1.0" encoding="UTF-8"?>
<!--
  UNIFIED ASSET SPECIFICATION SCHEMA
  ==================================
  Reference schema for all entity visual-specs.xml files.
  Version: 1.0.0

  This file documents the unified XML structure used by the
  LayeredAssetGenerator v2 to generate game assets.

  Entity spec files live at:
    docs/prompts/{entity-type}/{entity-name}/visual-specs.xml

  Supported entity types: characters, locations, pets
-->
<asset-spec version="1.0.0">

    <!-- REQUIRED: Entity metadata -->
    <meta>
        <entity-type>characters|locations|pets</entity-type>
        <entity-name>snake_case_name</entity-name>
        <version>1.0.0</version>
    </meta>

    <!-- REQUIRED: Layer definitions (at least one layer) -->
    <layers>
        <!--
          Each layer represents a visual plane in the asset.
          Attributes:
            id       - unique identifier (e.g. "background", "base", "outfit")
            type     - layer type: background, midground, foreground, base, outfit, overlay, accessory
            z-order  - rendering order (lower = behind, default = position in list)
        -->
        <layer id="background" type="background" z-order="0">Background environment</layer>
        <layer id="midground" type="midground" z-order="1">Middle ground objects</layer>
        <layer id="foreground" type="foreground" z-order="2">Foreground details and overlays</layer>
    </layers>

    <!-- OPTIONAL: Color palette -->
    <color-palette>
        <primary>
            <color hex="#F5E6D3" name="warm-beige"/>
            <color hex="#FFB6C1" name="light-pink"/>
            <color hex="#B5EAD7" name="mint-green"/>
            <color hex="#FFF4B8" name="pastel-yellow"/>
            <color hex="#E0BBE4" name="lavender"/>
        </primary>
        <secondary>
            <color hex="#6B4423" name="dark-brown"/>
            <color hex="#4A5859" name="dark-gray"/>
            <color hex="#FFF9E9" name="cream"/>
            <color hex="#A8B2B7" name="silver"/>
        </secondary>
    </color-palette>

    <!-- OPTIONAL: Animation specifications -->
    <animations>
        <!--
          Each animation defines a sprite-sheet animation.
          Attributes:
            name         - animation identifier (e.g. "idle", "walk")
            frames       - total frame count (1..50, NEVER exceed 50)
            fps          - playback speed in frames per second
            loop         - whether animation loops (true/false)
            frame-width  - pixel width of each frame
            frame-height - pixel height of each frame
        -->
        <animation name="idle" frames="24" fps="12" loop="true"
                   frame-width="128" frame-height="128"/>
    </animations>

    <!-- OPTIONAL: Time-of-day variations (primarily for locations) -->
    <time-of-day-variations>
        <variation time="morning">
            <lighting>Soft golden light from the east</lighting>
            <mood>Peaceful, awakening</mood>
        </variation>
        <variation time="day">
            <lighting>Bright overhead light</lighting>
            <mood>Active, vibrant</mood>
        </variation>
        <variation time="evening">
            <lighting>Warm orange sunset tones</lighting>
            <mood>Relaxing, winding down</mood>
        </variation>
        <variation time="night">
            <lighting>Cool blue moonlight with warm indoor glow</lighting>
            <mood>Quiet, intimate</mood>
        </variation>
    </time-of-day-variations>

    <!-- OPTIONAL: Naming conventions -->
    <naming>
        <output-dir>assets/{entity-type}/{entity-name}</output-dir>
    </naming>

    <!-- OPTIONAL: Technical constraints -->
    <constraints>
        <max-file-size-kb>500</max-file-size-kb>
        <max-sprite-sheet-width>2048</max-sprite-sheet-width>
        <max-sprite-sheet-height>2048</max-sprite-sheet-height>
        <compression-quality>85</compression-quality>
        <bit-depth>32</bit-depth>
    </constraints>

</asset-spec>
