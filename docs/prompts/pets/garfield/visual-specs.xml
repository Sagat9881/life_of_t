<?xml version="1.0" encoding="UTF-8"?>
<asset-spec version="1.0.0">
    <meta>
        <entity-type>pets</entity-type>
        <entity-name>garfield</entity-name>
        <version>1.0.0</version>
    </meta>
    <layers>
        <layer id="base" type="base" z-order="0">Cat body — orange tabby, plump</layer>
        <layer id="markings" type="overlay" z-order="1">Tabby stripe markings</layer>
        <layer id="accessories" type="accessory" z-order="2">Collar with tag</layer>
    </layers>
    <color-palette>
        <primary>
            <color hex="#FF8C00" name="Orange"/>
            <color hex="#FFD700" name="Gold"/>
            <color hex="#F5E6D3" name="Warm Beige"/>
        </primary>
        <secondary>
            <color hex="#8B4513" name="Saddle Brown"/>
            <color hex="#2F4F4F" name="Dark Slate"/>
        </secondary>
    </color-palette>
    <animations>
        <animation name="idle" frames="20" fps="6" loop="true" frame-width="64" frame-height="64"/>
        <animation name="walk" frames="24" fps="10" loop="true" frame-width="64" frame-height="64"/>
        <animation name="sleep" frames="20" fps="4" loop="true" frame-width="64" frame-height="64"/>
        <animation name="eat" frames="22" fps="8" loop="false" frame-width="64" frame-height="64"/>
        <animation name="play" frames="24" fps="12" loop="true" frame-width="64" frame-height="64"/>
    </animations>
    <naming>
        <output-dir>assets/pets/garfield</output-dir>
    </naming>
    <constraints>
        <max-file-size-kb>500</max-file-size-kb>
        <max-sprite-sheet-width>2048</max-sprite-sheet-width>
        <max-sprite-sheet-height>2048</max-sprite-sheet-height>
        <compression-quality>85</compression-quality>
        <bit-depth>32</bit-depth>
    </constraints>
</asset-spec>
