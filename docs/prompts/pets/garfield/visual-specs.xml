<?xml version="1.0" encoding="UTF-8"?>
<!--
  visual-specs.xml — Garfield (pet cat)
  Life of T game asset specification

  Generated against unified-asset-schema.xml v2.0
-->
<asset id="garfield" category="pet">

  <description>Garfield: an overweight, cynical orange tabby cat. Obsessed with
  lasagne and naps. Unexpectedly expressive face. Moves slowly unless food
  is involved.</description>

  <layers>
    <layer name="body"    type="base"    paletteRef="fur"     zIndex="0" optional="false"/>
    <layer name="stripes" type="overlay" paletteRef="stripes" zIndex="1" optional="false"/>
    <layer name="face"    type="overlay" paletteRef="face"    zIndex="2" optional="false"/>
    <layer name="shadow"  type="shadow"                       zIndex="-1" optional="true"/>
  </layers>

  <animations>
    <animation state="idle"  frameCount="3" fps="4"  loop="true">
      <frames>0 1 2</frames>
    </animation>
    <animation state="sleep" frameCount="2" fps="2"  loop="true">
      <frames>3 4</frames>
    </animation>
    <animation state="eat"   frameCount="4" fps="10" loop="false">
      <frames>5 6 7 8</frames>
    </animation>
  </animations>

  <palettes>
    <palette name="fur">
      <color>#E08030</color>
      <color>#C86820</color>
    </palette>
    <palette name="stripes">
      <color>#8B4010</color>
    </palette>
    <palette name="face">
      <color>#FFDFC4</color>
    </palette>
  </palettes>

  <variations>
    <variation timeOfDay="morning" colorShift="#FFF4CC" opacity="0.08"/>
    <variation timeOfDay="evening" colorShift="#FF8800" opacity="0.18"/>
    <variation timeOfDay="night"   colorShift="#001133" opacity="0.38"/>
  </variations>

  <naming
    prefix="garfield"
    layerPattern="%s_layer_%02d.png"
    atlasPattern="%s_atlas.webp"
    configPattern="%s_atlas.json"
  />

  <constraints
    widthPx="48"
    heightPx="48"
    maxFrames="16"
    allowTransparency="true"
    outputFormats="png,webp"
  />

</asset>
