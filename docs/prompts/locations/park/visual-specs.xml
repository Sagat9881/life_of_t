<?xml version="1.0" encoding="UTF-8"?>
<asset-spec version="1.0.0">
    <meta>
        <entity-type>locations</entity-type>
        <entity-name>park</entity-name>
        <version>1.0.0</version>
    </meta>
    <layers>
        <layer id="background" type="background" z-order="0">Sky, distant trees, city skyline</layer>
        <layer id="midground" type="midground" z-order="1">Pond, benches, walking path, flower beds</layer>
        <layer id="foreground" type="foreground" z-order="2">Close tree branches, bush, fence railing</layer>
    </layers>
    <color-palette>
        <primary>
            <color hex="#B5EAD7" name="Mint Green"/>
            <color hex="#FFF4B8" name="Soft Yellow"/>
            <color hex="#87CEEB" name="Sky Blue"/>
        </primary>
        <secondary>
            <color hex="#228B22" name="Forest Green"/>
            <color hex="#6B4423" name="Deep Brown"/>
        </secondary>
    </color-palette>
    <animations>
        <animation name="duck_swim" frames="24" fps="8" loop="true" frame-width="48" frame-height="48"/>
        <animation name="tree_sway" frames="20" fps="3" loop="true" frame-width="64" frame-height="96"/>
        <animation name="fountain" frames="25" fps="10" loop="true" frame-width="64" frame-height="64"/>
    </animations>
    <time-of-day-variations>
        <variation time="morning">
            <lighting>Soft dawn light, dew glistening</lighting>
            <mood>Fresh, calm morning</mood>
        </variation>
        <variation time="day">
            <lighting>Bright sunlight, dappled shadows under trees</lighting>
            <mood>Lively, active</mood>
        </variation>
        <variation time="evening">
            <lighting>Golden hour, long warm shadows</lighting>
            <mood>Romantic, peaceful</mood>
        </variation>
    </time-of-day-variations>
    <naming>
        <output-dir>assets/locations/park</output-dir>
    </naming>
    <constraints>
        <max-file-size-kb>500</max-file-size-kb>
        <max-sprite-sheet-width>2048</max-sprite-sheet-width>
        <max-sprite-sheet-height>2048</max-sprite-sheet-height>
        <compression-quality>85</compression-quality>
        <bit-depth>32</bit-depth>
    </constraints>
</asset-spec>
