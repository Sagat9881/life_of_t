<?xml version="1.0" encoding="UTF-8"?>
<!--
  Visual specification for the home-room background.

  Naming conventions:
    - Directory (outputDir):  snake_case  → locations/home_room
    - Prompt files:           kebab-case  → visual-specs.xml
    - Output PNG:             snake_case  → home_room_bg.png

  Atlas format: horizontal-strip, 1 frame (static background).
  No anti-aliasing. No GIF. Max 50 frames (this asset uses 1).
-->
<asset id="home_room_bg">

    <naming>
        <outputDir>locations/home_room</outputDir>
        <fileName>home_room_bg</fileName>
    </naming>

    <layers>
        <layer id="wall_back" type="BACKGROUND" zOrder="0">
            <description>
                Dark blue-grey wall, pixel-art style, 16x16 tile repeat.
                Colour: #2E3B4E. No gradients. No anti-aliasing.
            </description>
        </layer>
        <layer id="skirting" type="DETAIL" zOrder="1">
            <description>
                Wooden skirting board at bottom 10% of image.
                Colour: #5C3D1E. Pixel-art blocks, no curves.
            </description>
        </layer>
        <layer id="window" type="DETAIL" zOrder="2">
            <description>
                Single pixel-art window on the back wall, top-centre.
                Frame colour: #8B5E3C. Glass: #6ABFDF with horizontal
                light-ray lines (4px apart, 30% opacity). No blur.
            </description>
        </layer>
        <layer id="floor" type="FOREGROUND" zOrder="3">
            <description>
                Wooden floor, bottom 30% of image.
                Colour: #4A3728, planks defined by 1px lighter lines
                every 16 pixels horizontally. No gradients.
            </description>
        </layer>
    </layers>

    <animations>
        <animation id="static" frames="1" frameRate="1">
            <layerIds>
                <layerId>wall_back</layerId>
                <layerId>skirting</layerId>
                <layerId>window</layerId>
                <layerId>floor</layerId>
            </layerIds>
        </animation>
    </animations>

    <canvasSize width="320" height="192"/>

</asset>
