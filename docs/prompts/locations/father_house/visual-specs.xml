<?xml version="1.0" encoding="UTF-8"?>
<asset-spec version="1.0.0">
    <meta>
        <entity-type>locations</entity-type>
        <entity-name>father_house</entity-name>
        <version>1.0.0</version>
    </meta>
    <layers>
        <layer id="background" type="background" z-order="0">Old apartment wall, window with curtains, family photos</layer>
        <layer id="midground" type="midground" z-order="1">Vintage furniture: armchair, TV stand, dining table</layer>
        <layer id="foreground" type="foreground" z-order="2">Coat rack edge, indoor plant, doorframe</layer>
    </layers>
    <color-palette>
        <primary>
            <color hex="#F5E6D3" name="Warm Beige"/>
            <color hex="#DEB887" name="Burlywood"/>
            <color hex="#FFF4B8" name="Soft Yellow"/>
        </primary>
        <secondary>
            <color hex="#8B4513" name="Saddle Brown"/>
            <color hex="#A8B2B7" name="Muted Gray"/>
        </secondary>
    </color-palette>
    <time-of-day-variations>
        <variation time="day">
            <lighting>Warm light through old curtains</lighting>
            <mood>Nostalgic comfort</mood>
        </variation>
        <variation time="evening">
            <lighting>Warm lamp, TV glow</lighting>
            <mood>Family warmth</mood>
        </variation>
    </time-of-day-variations>
    <naming>
        <output-dir>assets/locations/father_house</output-dir>
    </naming>
    <constraints>
        <max-file-size-kb>500</max-file-size-kb>
        <max-sprite-sheet-width>2048</max-sprite-sheet-width>
        <max-sprite-sheet-height>2048</max-sprite-sheet-height>
        <compression-quality>85</compression-quality>
        <bit-depth>32</bit-depth>
    </constraints>
</asset-spec>
