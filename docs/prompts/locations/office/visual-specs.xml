<?xml version="1.0" encoding="UTF-8"?>
<asset-spec version="1.0.0">
    <meta>
        <entity-type>locations</entity-type>
        <entity-name>office</entity-name>
        <version>1.0.0</version>
    </meta>
    <layers>
        <layer id="background" type="background" z-order="0">Office wall with windows, cityscape view</layer>
        <layer id="midground" type="midground" z-order="1">Open-plan office: desks, monitors, office chairs</layer>
        <layer id="foreground" type="foreground" z-order="2">Water cooler edge, plant, doorframe</layer>
    </layers>
    <color-palette>
        <primary>
            <color hex="#F5E6D3" name="Warm Beige"/>
            <color hex="#A8B2B7" name="Muted Gray"/>
            <color hex="#FFF9E9" name="Cream White"/>
        </primary>
        <secondary>
            <color hex="#4A5859" name="Charcoal"/>
            <color hex="#6B4423" name="Deep Brown"/>
        </secondary>
    </color-palette>
    <time-of-day-variations>
        <variation time="morning">
            <lighting>Fluorescent + morning sun from windows</lighting>
            <mood>Start of workday</mood>
        </variation>
        <variation time="evening">
            <lighting>Artificial fluorescent, dark windows</lighting>
            <mood>Late work, overtime</mood>
        </variation>
    </time-of-day-variations>
    <naming>
        <output-dir>assets/locations/office</output-dir>
    </naming>
    <constraints>
        <max-file-size-kb>500</max-file-size-kb>
        <max-sprite-sheet-width>2048</max-sprite-sheet-width>
        <max-sprite-sheet-height>2048</max-sprite-sheet-height>
        <compression-quality>85</compression-quality>
        <bit-depth>32</bit-depth>
    </constraints>
</asset-spec>
