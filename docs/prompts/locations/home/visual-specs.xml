<?xml version="1.0" encoding="UTF-8"?>
<asset-spec version="1.0.0">
    <meta>
        <entity-type>locations</entity-type>
        <entity-name>home</entity-name>
        <version>1.0.0</version>
    </meta>
    <layers>
        <layer id="background" type="background" z-order="0">Far wall with large window overlooking city</layer>
        <layer id="midground" type="midground" z-order="1">Main room: desk, chair, sofa, coffee table</layer>
        <layer id="foreground" type="foreground" z-order="2">Door frame edge, bookshelf edge, curtain</layer>
    </layers>
    <color-palette>
        <primary>
            <color hex="#FFF9E9" name="Cream"/>
            <color hex="#FFB6C1" name="Rose Pink"/>
            <color hex="#B5EAD7" name="Mint Green"/>
        </primary>
        <secondary>
            <color hex="#A8B2B7" name="Muted Gray"/>
            <color hex="#6B4423" name="Deep Brown"/>
        </secondary>
    </color-palette>
    <animations>
        <animation name="desk_computer" frames="22" fps="8" loop="true" frame-width="64" frame-height="64"/>
        <animation name="wall_clock" frames="24" fps="1" loop="true" frame-width="32" frame-height="32"/>
        <animation name="plant_sway" frames="20" fps="4" loop="true" frame-width="48" frame-height="48"/>
        <animation name="window_light_cycle" frames="25" fps="2" loop="true" frame-width="128" frame-height="128"/>
        <animation name="pet_bowls" frames="20" fps="4" loop="false" frame-width="48" frame-height="32"/>
    </animations>
    <time-of-day-variations>
        <variation time="morning">
            <lighting>Soft diffused golden light from window</lighting>
            <mood>Calm awakening</mood>
        </variation>
        <variation time="day">
            <lighting>Bright daylight, clear shadows</lighting>
            <mood>Activity, work</mood>
        </variation>
        <variation time="evening">
            <lighting>Warm artificial light + pink sunset from window</lighting>
            <mood>Relaxation, coziness</mood>
        </variation>
        <variation time="night">
            <lighting>Dim lamp light, blue shadows</lighting>
            <mood>Quiet intimacy, rest</mood>
        </variation>
    </time-of-day-variations>
    <naming>
        <output-dir>assets/locations/home</output-dir>
    </naming>
    <constraints>
        <max-file-size-kb>500</max-file-size-kb>
        <max-sprite-sheet-width>2048</max-sprite-sheet-width>
        <max-sprite-sheet-height>2048</max-sprite-sheet-height>
        <compression-quality>85</compression-quality>
        <bit-depth>32</bit-depth>
    </constraints>
</asset-spec>
